<script type="module">
  const $ = (s,p=document)=>p.querySelector(s);
  const TURNSTILE_ENABLED = <%- safeJson(tsEnabled) %>;

  const passInput = $('#passwordInput');
  const passToggle = $('#passToggle');
  passToggle?.addEventListener('click', () => {
    const next = passInput?.type === 'password' ? 'text' : 'password';
    if (passInput) passInput.type = next;
    passToggle.innerHTML = next === 'password'
  ? '👁'
  : `
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M3 3L21 21" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
      <path d="M10.58 10.58A2 2 0 0 0 13.42 13.42" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
      <path d="M9.88 5.09A9.6 9.6 0 0 1 12 4.85C17.5 4.85 21 12 21 12A16.3 16.3 0 0 1 18.7 15.08" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M6.61 6.61C4.33 8.16 3 12 3 12S6.5 19.15 12 19.15A9.7 9.7 0 0 0 15.39 18.54" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  `;
  });

  // ======= LOGIN SUBMIT =======
  const form = $('#loginForm');
  const submit = $('#btnLogin');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submit.disabled = true;

    const fd = new FormData(form);
    const next = fd.get('next') || '/';

    try {
      const res = await fetch('/login', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: new URLSearchParams(fd),
      });
      const data = await res.json().catch(()=> ({}));

      if (!res.ok || !data?.ok) {
        window.showMsg?.({ variant:'error', icon:'⚠️', title:'เข้าสู่ระบบไม่สำเร็จ', text: data?.message || 'ตรวจสอบชื่อผู้ใช้/รหัสผ่าน' });
        submit.disabled = false;
        return;
      }

      window.showMsg?.({ variant:'success', icon:'✅', title:'สำเร็จ!', text:'ล็อกอินสำเร็จ' });
      setTimeout(()=> location.assign(data.redirect || next || '/'), 500);
    } catch (err) {
      window.showMsg?.({ variant:'error', icon:'⚠️', title:'เครือข่ายมีปัญหา', text:'โปรดลองใหม่อีกครั้ง' });
      submit.disabled = false;
    }
  });

  // ======= ลืมรหัสผ่าน =======
  const forgotModal = $('#forgotModal');
  let forgotClosingTimer = null;

  const openForgot  = () => {
    if (!forgotModal) return;
    clearTimeout(forgotClosingTimer);
    forgotModal.classList.remove('is-closing');
    forgotModal.hidden = false;
    document.body.classList.add('blurred');
    setTimeout(()=>$('#forgotEmail')?.focus(), 120);
  };

  const closeForgot = () => {
    if (!forgotModal || forgotModal.hidden) return;
    forgotModal.classList.add('is-closing');
    clearTimeout(forgotClosingTimer);
    forgotClosingTimer = setTimeout(() => {
      forgotModal.hidden = true;
      forgotModal.classList.remove('is-closing');
      document.body.classList.remove('blurred');
    }, 230);
  };

  $('#linkForgot')?.addEventListener('click', e => { e.preventDefault(); openForgot(); });
  $('#forgotCancel')?.addEventListener('click', closeForgot);
  $('#forgotX')?.addEventListener('click', closeForgot);
  forgotModal?.querySelector('.rtx-forgot-backdrop')?.addEventListener('click', closeForgot);
  window.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeForgot(); });

  $('#forgotSubmit')?.addEventListener('click', async () => {
    const btn = $('#forgotSubmit');
    const email = ($('#forgotEmail')?.value || '').trim().toLowerCase();
    if (!email) {
      window.showMsg?.({ variant:'warn', icon:'⚠️', title:'กรอกอีเมล', text:'โปรดกรอกอีเมลที่ใช้สมัคร' });
      return;
    }

    btn.disabled = true;
    try {
      const r = await fetch('/password/forgot', {
        method:'POST',
        headers:{ 'Content-Type':'application/json' },
        body: JSON.stringify({ email })
      });
      const j = await r.json().catch(()=> ({}));

      if (j.ok) {
        closeForgot();
        window.showMsg?.({
          variant:'success',
          icon:'✅',
          title:'ส่งเรียบร้อย',
          text:'ส่งลิงก์รีเซ็ตรหัสผ่านเข้าอีเมลของคุณแล้ว โปรดตรวจสอบกล่องจดหมาย'
        });
        return;
      }

      if (j.code === 'not_found') {
        window.showMsg?.({ variant:'error', icon:'✖', title:'ไม่พบอีเมลนี้', text:'ยังไม่มีอีเมลนี้ในระบบ' });
      } else if (j.code === 'need_verify') {
        closeForgot();
        window.showMsg?.({
          variant:'info',
          icon:'✉️',
          title:'ต้องยืนยันอีเมลก่อน',
          text:'ได้ส่งลิงก์ยืนยันอีเมลไปให้แล้ว โปรดยืนยันให้เสร็จ จากนั้นกด “ลืมรหัสผ่าน?” อีกครั้ง'
        });
      } else {
        window.showMsg?.({ variant:'error', icon:'✖', title:'ส่งไม่สำเร็จ', text: j.error || 'โปรดลองใหม่อีกครั้ง' });
      }
    } catch (e) {
      window.showMsg?.({ variant:'error', icon:'✖', title:'เครือข่ายมีปัญหา', text:'โปรดลองใหม่อีกครั้ง' });
    } finally {
      btn.disabled = false;
    }
  });

  // ======= TURNSTILE + THEME SYNC =======
  (function () {
    if (!TURNSTILE_ENABLED) return;

    function tsCurrentTheme() {
      const t = document.documentElement.getAttribute('data-theme') || document.body.getAttribute('data-theme');
      return t === 'light' ? 'light' : 'dark';
    }

    function tsRender() {
      const container = document.getElementById('cf-turnstile');
      if (!container || !window.turnstile) return;

      const sitekey = container.dataset.sitekey;
      if (!sitekey) return;

      container.innerHTML = '';
      window.turnstile.render(container, {
        sitekey,
        theme: tsCurrentTheme(),
        language: 'th'
      });
    }

    function tsInit() {
      if (window.turnstile) {
        tsRender();
      } else {
        window.addEventListener('turnstile-ready', () => tsRender(), { once: true });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', tsInit, { once: true });
    } else {
      tsInit();
    }

    window.addEventListener('themechange', () => {
      if (!window.turnstile) return;
      tsRender();
    });
  })();
</script>
