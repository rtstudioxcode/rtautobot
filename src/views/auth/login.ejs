  body.blurred{overflow:hidden;}

  @keyframes rtxForgotBackdropIn{from{opacity:0}to{opacity:1}}
  @keyframes rtxForgotBackdropOut{from{opacity:1}to{opacity:0}}
  @keyframes rtxForgotCardIn{
    from{opacity:0;transform:translateY(22px) scale(.965);filter:blur(10px)}
    to{opacity:1;transform:translateY(0) scale(1);filter:blur(0)}
  }
  @keyframes rtxForgotCardOut{
    from{opacity:1;transform:translateY(0) scale(1);filter:blur(0)}
    to{opacity:0;transform:translateY(12px) scale(.975);filter:blur(8px)}
  }
  @keyframes rtxForgotSheen{
    0%,42%{transform:translateX(-58%) rotate(7deg)}
    72%,100%{transform:translateX(62%) rotate(7deg)}
  }
  @keyframes rtxForgotBadgeFloat{
    0%,100%{transform:translateY(0)}
    50%{transform:translateY(-5px)}
  }
  @keyframes rtxForgotBtnShine{
    0%,48%{left:-60%}
    72%,100%{left:125%}
  }

  @media (max-width:700px){
    .rtx-forgot-card{border-radius:28px;padding:24px 18px;}
    .rtx-forgot-head{grid-template-columns:1fr;padding-right:48px;gap:14px;}
    .rtx-forgot-badge{width:60px;height:60px;border-radius:20px;}
    .rtx-forgot-badge span{font-size:26px;}
    .rtx-forgot-actions{flex-direction:column-reverse;}
    .rtx-btn{width:100%;}
  }
  @media (max-width:420px){
    .rtx-forgot{padding:12px;}
    .rtx-forgot-card{width:min(100%,calc(100vw - 24px));border-radius:24px;}
    .rtx-forgot-x{right:14px;top:14px;width:42px;height:42px;}
    .rtx-forgot-note{grid-template-columns:38px minmax(0,1fr);padding:11px 12px;}
  }}

  .rtx-rise{animation:rtxRise .58s cubic-bezier(.2,.8,.2,1) both;}
  .rtx-delay{animation-delay:.08s;}
  @keyframes rtxRise{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}

  @media (max-width:1100px){
    .rtx-shell{grid-template-columns:1fr;max-width:760px;}
    .rtx-hero{min-height:auto;}
    .rtx-card{max-width:760px;}
  }
  @media (max-width:700px){
    .rtx-login{padding:14px;place-items:start center;min-height:calc(100vh - 70px);}
    .rtx-shell{gap:16px;}
    .rtx-hero,.rtx-card{border-radius:24px;padding:22px;}
    .rtx-hero h1{font-size:clamp(36px,12vw,54px);}
    .rtx-lead{font-size:15px;line-height:1.75;}
    .rtx-feature-row{grid-template-columns:1fr;margin-top:24px;}
    .rtx-feature{min-height:96px;}
    .rtx-card-head h2{font-size:28px;}
    .rtx-links{flex-direction:column;align-items:flex-start;}
    .rtx-turnstile{justify-content:flex-start;}
    .rtx-forgot-actions{flex-direction:column-reverse;}
    .rtx-btn{width:100%;}
  }
  @media (max-width:420px){
    .rtx-hero,.rtx-card{padding:18px;border-radius:22px;}
    .rtx-inputbox{grid-template-columns:48px minmax(0,1fr) auto;}
    .rtx-input-icon{width:48px;}
    .rtx-pass{width:40px;height:40px;margin-right:6px;}
  }
  @media (prefers-reduced-motion:reduce){
    .rtx-orb,.rtx-rise,.rtx-forgot-card{animation:none!important;}
    .rtx-feature,.rtx-inputbox,.rtx-pass,.rtx-submit{transition:none!important;}
  }
  @media (max-width: 520px){
    .rtx-turnstile{
      min-height:64px;
      padding:8px;
      border-radius:16px;
    }

    .rtx-turnstile .cf-turnstile{
      transform:scale(.86);
