<% const title = "เข้าสู่ระบบ"; %>
<% const tsEnabled = (typeof turnstileEnabled !== "undefined") ? !!turnstileEnabled : !!turnstileSiteKey; %>

<section class="rtx-login" aria-label="เข้าสู่ระบบ RTAUTOBOT">
  <div class="rtx-bg" aria-hidden="true">
    <span class="rtx-orb rtx-orb-1"></span>
    <span class="rtx-orb rtx-orb-2"></span>
    <span class="rtx-orb rtx-orb-3"></span>
    <span class="rtx-grid"></span>
  </div>

  <div class="rtx-shell">
    <section class="rtx-hero rtx-rise">
      <div class="rtx-pill"><span>✦</span> RTAUTOBOT LOGIN ACCESS</div>

      <h1>เข้าสู่ระบบจัดการ Bonustime Automation</h1>
      <p class="rtx-lead">
        ระบบจัดการบอท LINE และแพ็กเกจ Bonustime สำหรับดูแลลูกค้า ติดตามออเดอร์ เติมเครดิต และใช้งานบริการอัตโนมัติในที่เดียว
      </p>

      <div class="rtx-feature-row" aria-label="จุดเด่นระบบ">
        <article class="rtx-feature">
          <span class="rtx-feature-icon">⚡</span>
          <strong>ทำงานรวดเร็ว</strong>
          <small>อยู่ที่ไหนก็ใช้งานได้</small>
        </article>
        <article class="rtx-feature">
          <span class="rtx-feature-icon">🛡️</span>
          <strong>ปลอดภัย</strong>
          <small>ความปลอดภัยระดับสูงสุด</small>
        </article>
        <article class="rtx-feature">
          <span class="rtx-feature-icon">📊</span>
          <strong>ครบในที่เดียว</strong>
          <small>เติมเครดิตออโต้ สั่งซื้อ Bonustime ติดตามสถานะ และจัดการข้อมูลบัญชี</small>
        </article>
      </div>

      <div class="rtx-meta">
        <span>All Right Reserved</span>
        <i></i>
        <span>© 2026</span>
        <i></i>
        <span>RTAUTOBOT</span>
      </div>
    </section>

    <section class="rtx-card rtx-rise rtx-delay" aria-label="แบบฟอร์มเข้าสู่ระบบ">
      <div class="rtx-card-glow" aria-hidden="true"></div>

      <header class="rtx-card-head">
        <div class="rtx-lock">🔐</div>
        <div>
          <h2>เข้าสู่ระบบ</h2>
          <p>ระบบพร้อมให้บริการ 24 ชั่วโมง</p>
        </div>
      </header>

      <% if (typeof error === 'string' && error) { %>
        <div class="rtx-alert"><%= error %></div>
      <% } %>

      <form id="loginForm" class="rtx-form" action="/login" method="post" novalidate>
        <input type="hidden" name="next" value="<%= next %>">

        <label class="rtx-field">
          <span class="rtx-label">ชื่อผู้ใช้หรืออีเมล</span>
          <div class="rtx-inputbox">
            <span class="rtx-input-icon">👤</span>
            <input name="username" required autocomplete="username" placeholder="กรอกชื่อผู้ใช้หรืออีเมล">
          </div>
        </label>

        <label class="rtx-field">
          <span class="rtx-label">รหัสผ่าน</span>
          <div class="rtx-inputbox">
            <span class="rtx-input-icon">••</span>
            <input id="passwordInput" type="password" name="password" required autocomplete="current-password" placeholder="กรอกรหัสผ่าน">
            <button type="button" class="rtx-pass" id="passToggle" aria-label="แสดงหรือซ่อนรหัสผ่าน">👁</button>
          </div>
        </label>

        <% if (tsEnabled) { %>
          <div class="rtx-turnstile">
            <div id="cf-turnstile" class="cf-turnstile" data-sitekey="<%= turnstileSiteKey %>"></div>
          </div>
        <% } %>

        <button class="rtx-submit" type="submit" id="btnLogin">
          <span>เข้าสู่ระบบ</span>
          <b>→</b>
        </button>

        <div class="rtx-links">
          <span>ยังไม่มีบัญชี? <a href="/register">สมัครสมาชิก</a></span>
          <button id="linkForgot" type="button">ลืมรหัสผ่าน?</button>
        </div>
      </form>
    </section>
  </div>
</section>

<!-- Modal แจ้งเตือนภายในหน้า -->
<dialog id="notifyDialog" class="rtx-dialog">
  <div class="rtx-dialog-card">
    <div class="rtx-dialog-icon" id="mdlIcon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="30" height="30">
        <path fill="white" d="M9 16.2l-3.5-3.5L4 14.2 9 19l12-12-1.5-1.5z"/>
      </svg>
    </div>
    <h3 id="mdlTitle">สำเร็จ!</h3>
    <p id="mdlText">กำลังเข้าสู่ระบบ...</p>
    <button class="rtx-mini-primary" id="mdlClose">ตกลง</button>
  </div>
</dialog>

<!-- Forgot Password Modal -->
<div id="forgotModal" class="rtx-forgot rtx-forgot-enterprise" hidden>
  <div class="rtx-forgot-backdrop" aria-hidden="true"></div>

  <div class="rtx-forgot-card" role="dialog" aria-modal="true" aria-labelledby="fgTitle" aria-describedby="fgDesc">
    <span class="rtx-forgot-border" aria-hidden="true"></span>
    <span class="rtx-forgot-orb rtx-forgot-orb-a" aria-hidden="true"></span>
    <span class="rtx-forgot-orb rtx-forgot-orb-b" aria-hidden="true"></span>

    <button class="rtx-forgot-x" id="forgotX" type="button" aria-label="ปิด">×</button>

    <div class="rtx-forgot-head">
      <div class="rtx-forgot-badge" aria-hidden="true">
        <span>🔐</span>
      </div>
      <div class="rtx-forgot-titlebox">
        <div class="rtx-pill small rtx-forgot-kicker"><span>✦</span> Password Recovery</div>
        <h3 id="fgTitle">รีเซ็ตรหัสผ่าน</h3>
        <p id="fgDesc">กรอกอีเมลที่ใช้สมัคร ระบบจะส่งลิงก์สำหรับตั้งรหัสผ่านใหม่ให้คุณอย่างปลอดภัย</p>
      </div>
    </div>

    <div class="rtx-forgot-notes" aria-label="ขั้นตอนการรีเซ็ตรหัสผ่าน">
      <div class="rtx-forgot-note">
        <b>01</b>
        <span>ตรวจสอบอีเมลที่ผูกกับบัญชี</span>
      </div>
      <div class="rtx-forgot-note">
        <b>02</b>
        <span>ส่งลิงก์รีเซ็ตรหัสผ่านแบบใช้ครั้งเดียว</span>
      </div>
      <div class="rtx-forgot-note">
        <b>03</b>
        <span>ตั้งรหัสผ่านใหม่แล้วกลับมาเข้าสู่ระบบ</span>
      </div>
    </div>

    <label class="rtx-field forgot-field">
      <span class="rtx-label">อีเมลที่ผูกกับบัญชี</span>
      <div class="rtx-inputbox rtx-forgot-inputbox">
        <span class="rtx-input-icon">✉️</span>
        <input id="forgotEmail" type="email" autocomplete="email" placeholder="you@example.com">
      </div>
    </label>

    <div class="rtx-forgot-actions">
      <button class="rtx-btn ghost" id="forgotCancel" type="button">ยกเลิก</button>
      <button class="rtx-btn primary rtx-forgot-submit" id="forgotSubmit" type="button">
        <span>ส่งลิงก์รีเซ็ต</span>
        <b aria-hidden="true">→</b>
      </button>
    </div>
  </div>
</div>

<style>
  .rtx-login{
    --rtx-page:var(--page, var(--bg, #07080c));
    --rtx-card:color-mix(in srgb,var(--card,#17181f) 92%, transparent);
    --rtx-card-solid:color-mix(in srgb,var(--card,#17181f) 96%, var(--page,#07080c));
    --rtx-soft:color-mix(in srgb,var(--card,#1d1f27) 80%, #fff 4%);
    --rtx-text:var(--text,#eef6ff);
    --rtx-muted:var(--muted,#08b84f);
    --rtx-border:var(--border,rgba(255,255,255,.12));
    --rtx-accent:var(--accent,#08b84f);
    --rtx-accent2:#05b84f;
    --rtx-danger:#ff5f73;
    --rtx-shadow:rgba(0,0,0,.48);
    position:relative;
    min-height:calc(100vh - 84px);
    display:grid;
    place-items:center;
    padding:clamp(22px,4vw,54px);
    overflow:hidden;
    isolation:isolate;
    color:var(--rtx-text);
  }

  :root[data-theme="light"] .rtx-login,
  body[data-theme="light"] .rtx-login,
  html.light .rtx-login{
    --rtx-page:#f5f7fb;
    --rtx-card:rgba(255,255,255,.76);
    --rtx-card-solid:#ffffff;
    --rtx-soft:rgba(255,255,255,.72);
    --rtx-text:#151822;
    --rtx-muted:#606879;
    --rtx-border:rgba(17,24,39,.12);
    --rtx-shadow:rgba(20,30,55,.15);
  }

  .rtx-bg{position:absolute;inset:0;z-index:-3;background:
    radial-gradient(circle at 15% 28%,color-mix(in srgb,var(--rtx-accent) 34%,transparent),transparent 31%),
    radial-gradient(circle at 92% 78%,rgba(61,137,255,.22),transparent 34%),
    linear-gradient(135deg,color-mix(in srgb,var(--rtx-page) 92%,#000),var(--rtx-page));}
  .rtx-grid{position:absolute;inset:-1px;background-image:linear-gradient(color-mix(in srgb,var(--rtx-border) 42%,transparent) 1px,transparent 1px),linear-gradient(90deg,color-mix(in srgb,var(--rtx-border) 42%,transparent) 1px,transparent 1px);background-size:54px 54px;mask-image:radial-gradient(circle at 50% 50%,#000 0 45%,transparent 72%);opacity:.36;}
  .rtx-orb{position:absolute;border-radius:50%;filter:blur(34px);opacity:.58;animation:rtxFloat 9s ease-in-out infinite alternate;}
  .rtx-orb-1{width:270px;height:270px;background:color-mix(in srgb,var(--rtx-accent) 44%,transparent);left:7%;top:22%;}
  .rtx-orb-2{width:340px;height:340px;background:rgba(54,134,255,.20);right:7%;bottom:8%;animation-delay:-2.5s;}
  .rtx-orb-3{width:210px;height:210px;background:rgba(147,94,255,.16);left:50%;bottom:2%;animation-delay:-5s;}
  @keyframes rtxFloat{from{transform:translate3d(0,0,0) scale(1)}to{transform:translate3d(18px,-22px,0) scale(1.08)}}

  .rtx-shell{width:min(1220px,100%);display:grid;grid-template-columns:minmax(0,1.08fr) minmax(390px,.72fr);gap:28px;align-items:center;}
  .rtx-hero,.rtx-card{position:relative;border:1px solid var(--rtx-border);background:linear-gradient(180deg,rgba(255,255,255,.07),rgba(255,255,255,.022)),var(--rtx-card);box-shadow:0 30px 90px var(--rtx-shadow),inset 0 1px 0 rgba(255,255,255,.08);backdrop-filter:blur(18px);overflow:hidden;}
  .rtx-hero{border-radius:34px;padding:clamp(34px,4.8vw,62px);min-height:500px;display:flex;flex-direction:column;justify-content:center;}
  .rtx-hero::before{content:"";position:absolute;inset:0;background:linear-gradient(116deg,transparent 0 50%,rgba(255,255,255,.085) 50% 61%,transparent 61%);transform:translateX(-18%);pointer-events:none;}
  .rtx-hero > *{position:relative;z-index:1;}

  .rtx-pill{width:max-content;max-width:100%;display:inline-flex;align-items:center;gap:8px;padding:9px 15px;border-radius:999px;border:1px solid color-mix(in srgb,var(--rtx-accent) 55%,transparent);background:color-mix(in srgb,var(--rtx-accent) 13%,transparent);color:color-mix(in srgb,var(--rtx-accent) 82%,var(--rtx-text));font-size:12px;font-weight:950;letter-spacing:.08em;text-transform:uppercase;box-shadow:inset 0 1px 0 rgba(255,255,255,.12);}
  .rtx-pill.small{font-size:11px;padding:8px 13px;}
  .rtx-hero h1{max-width:780px;margin:28px 0 18px;font-size:clamp(44px,5.2vw,70px);line-height:1.02;letter-spacing:-.064em;}
  .rtx-lead{max-width:740px;margin:0;color:var(--rtx-muted);font-size:clamp(16px,1.42vw,20px);line-height:1.82;font-weight:780;}
  .rtx-feature-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;margin-top:44px;}
  .rtx-feature{min-height:134px;border:1px solid var(--rtx-border);border-radius:24px;background:color-mix(in srgb,var(--rtx-soft) 68%,transparent);padding:16px;display:flex;flex-direction:column;justify-content:center;transition:transform .24s ease,border-color .24s ease,box-shadow .24s ease;}
  .rtx-feature:hover{transform:translateY(-4px);border-color:color-mix(in srgb,var(--rtx-accent) 58%,transparent);box-shadow:0 18px 42px color-mix(in srgb,var(--rtx-accent) 15%,transparent);}
  .rtx-feature-icon{width:44px;height:44px;border-radius:16px;display:grid;place-items:center;background:linear-gradient(135deg,#21b95c,#05b84f);box-shadow:0 14px 34px color-mix(in srgb,var(--rtx-accent) 22%,transparent);margin-bottom:12px;}
  .rtx-feature strong{font-size:15px;}
  .rtx-feature small{margin-top:6px;color:var(--rtx-muted);line-height:1.5;font-weight:720;}
  .rtx-meta{margin-top:auto;padding-top:36px;display:flex;align-items:center;flex-wrap:wrap;gap:10px;color:color-mix(in srgb,var(--rtx-accent) 76%,var(--rtx-muted));font-size:12px;font-weight:900;}
  .rtx-meta i{width:5px;height:5px;border-radius:50%;background:var(--rtx-accent);opacity:.76;}

  .rtx-card{justify-self:center;width:100%;max-width:500px;border-radius:30px;padding:32px;}
  .rtx-card::before{content:"";position:absolute;inset:0 0 auto;height:1px;background:linear-gradient(90deg,transparent,var(--rtx-accent),transparent);opacity:.5;}
  .rtx-card-glow{position:absolute;right:-28%;bottom:-34%;width:300px;height:300px;background:radial-gradient(circle,color-mix(in srgb,var(--rtx-accent) 25%,transparent),transparent 66%);filter:blur(22px);pointer-events:none;}
  .rtx-card-head{position:relative;display:flex;align-items:center;gap:16px;margin-bottom:24px;}
  .rtx-lock{width:56px;height:56px;flex:0 0 56px;border-radius:19px;display:grid;place-items:center;background:linear-gradient(135deg,#08b84f,#05b84f);box-shadow:0 18px 42px color-mix(in srgb,var(--rtx-accent) 25%,transparent);}
  .rtx-card-head h2{margin:0 0 7px;font-size:32px;line-height:1;letter-spacing:-.045em;}
  .rtx-card-head p{margin:0;color:var(--rtx-muted);font-weight:850;}

  .rtx-alert{margin:0 0 18px;padding:12px 14px;border-radius:16px;border:1px solid rgba(255,95,115,.34);background:rgba(255,95,115,.12);color:#ffb6bf;font-weight:850;}
  .rtx-form{position:relative;display:grid;gap:16px;}
  .rtx-field{display:grid;gap:8px;}
  .rtx-label{font-size:13px;font-weight:950;color:color-mix(in srgb,var(--rtx-muted) 92%,var(--rtx-text));}
  .rtx-inputbox{position:relative;width:100%;min-height:58px;border:1px solid var(--rtx-border);border-radius:18px;background:color-mix(in srgb,var(--rtx-page) 72%,#0d111a);display:grid;grid-template-columns:54px minmax(0,1fr) auto;align-items:center;overflow:hidden;box-shadow:inset 0 1px 0 rgba(255,255,255,.055);transition:border-color .18s ease,box-shadow .18s ease,transform .18s ease;}
  .rtx-inputbox:focus-within{border-color:color-mix(in srgb,var(--rtx-accent) 70%,transparent);box-shadow:0 0 0 4px color-mix(in srgb,var(--rtx-accent) 15%,transparent),inset 0 1px 0 rgba(255,255,255,.08);transform:translateY(-1px);}
  .rtx-input-icon{width:54px;height:58px;display:grid;place-items:center;background:rgba(0,0,0,.18);color:var(--rtx-accent);font-weight:950;line-height:1;}
  .rtx-inputbox input{width:100%;min-width:0;height:58px;border:0;outline:0;background:transparent;color:var(--rtx-text);font:inherit;font-weight:850;padding:0 14px;}
  .rtx-inputbox input::placeholder{color:color-mix(in srgb,var(--rtx-muted) 52%,transparent);}
  .rtx-pass{
    width:44px;
    height:44px;
    margin-right:6px;
    margin-left:4px;
    border:1px solid var(--rtx-border);
    border-radius:15px;
    background:color-mix(in srgb,var(--rtx-soft) 54%,transparent);
    color:var(--rtx-text);
    cursor:pointer;
    display:grid;
    place-items:center;
    transition:
      transform .18s ease,
      border-color .18s ease,
      background .18s ease;
  }

  .rtx-pass:hover{
    transform:translateY(-1px);
    border-color:color-mix(in srgb,var(--rtx-accent) 60%,transparent);
    background:color-mix(in srgb,var(--rtx-accent) 12%,var(--rtx-soft));
  }

  .rtx-turnstile{
    min-height:72px;
    padding:10px;
    border-radius:18px;
    border:1px dashed color-mix(in srgb,var(--rtx-border) 82%,transparent);
    background:color-mix(in srgb,var(--rtx-soft) 42%,transparent);
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
  }

  /* Cloudflare Turnstile */
  .rtx-turnstile .cf-turnstile,
  .rtx-turnstile iframe{
    max-width:100% !important;
  }
  .rtx-submit{height:60px;border:0;border-radius:18px;background:linear-gradient(135deg,#08b84f,#08b84f 55%,#05b84f);color:#17130a;font-size:16px;font-weight:950;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:12px;box-shadow:0 20px 48px color-mix(in srgb,var(--rtx-accent) 30%,transparent);transition:transform .2s ease,filter .2s ease,box-shadow .2s ease;}
  .rtx-submit:hover{transform:translateY(-2px);filter:saturate(1.05);box-shadow:0 26px 58px color-mix(in srgb,var(--rtx-accent) 36%,transparent);}
  .rtx-submit[disabled]{opacity:.66;pointer-events:none;filter:grayscale(.18);}
  .rtx-submit b{font-size:22px;}
  .rtx-links{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;color:var(--rtx-muted);font-size:14px;font-weight:850;}
  .rtx-links a,.rtx-links button{color:color-mix(in srgb,var(--rtx-accent) 84%,var(--rtx-text));font:inherit;font-weight:950;text-decoration:none;background:none;border:0;padding:0;cursor:pointer;}
  .rtx-links a:hover,.rtx-links button:hover{text-decoration:underline;}

  .rtx-dialog{border:0;padding:0;background:transparent;color:var(--rtx-text);}
  .rtx-dialog::backdrop{background:rgba(0,0,0,.64);backdrop-filter:blur(12px);}
  .rtx-dialog-card{width:min(92vw,400px);padding:28px;border-radius:28px;text-align:center;border:1px solid var(--rtx-border);background:var(--rtx-card-solid);box-shadow:0 30px 90px var(--rtx-shadow);}
  .rtx-dialog-icon{width:62px;height:62px;margin:0 auto 14px;border-radius:20px;background:linear-gradient(135deg,#29df82,#0fab68);display:grid;place-items:center;}
  .rtx-dialog-card h3{font-size:24px;margin:0 0 7px;}
  .rtx-dialog-card p{margin:0 0 18px;color:var(--rtx-muted);font-weight:800;}
  .rtx-mini-primary{border:0;border-radius:15px;padding:12px 20px;background:linear-gradient(135deg,#08b84f,#05b84f);color:#17130a;font-weight:950;cursor:pointer;}

  .rtx-forgot[hidden]{display:none!important;}
  .rtx-forgot{
    position:fixed;
    inset:0;
    z-index:9999;
    display:grid;
    place-items:center;
    padding:clamp(16px,3vw,28px);
    color:var(--rtx-text);
    isolation:isolate;
  }

  .rtx-forgot-backdrop{
    position:absolute;
    inset:0;
    background:
      radial-gradient(circle at 18% 22%, color-mix(in srgb,var(--rtx-accent) 20%, transparent), transparent 34%),
      radial-gradient(circle at 82% 80%, rgba(139,92,246,.22), transparent 36%),
      rgba(0,0,0,.74);
    backdrop-filter:blur(18px) saturate(1.08);
    animation:rtxForgotBackdropIn .32s ease both;
  }

  .rtx-forgot-card{
    --fg-green:#08b84f;
    --fg-green2:#05b84f;
    --fg-deep:#090a0f;
    position:relative;
    width:min(94vw,560px);
    border:1px solid color-mix(in srgb,var(--rtx-accent) 34%,var(--rtx-border));
    border-radius:34px;
    padding:clamp(24px,3vw,34px);
    background:
      linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,255,255,.025)),
      radial-gradient(circle at 88% 12%, color-mix(in srgb,var(--rtx-accent) 15%, transparent), transparent 32%),
      linear-gradient(145deg,color-mix(in srgb,var(--rtx-card-solid) 94%,#050507),#090a0f);
    box-shadow:
      0 42px 120px rgba(0,0,0,.62),
      0 0 0 1px rgba(255,255,255,.035) inset,
      0 0 80px color-mix(in srgb,var(--rtx-accent) 12%,transparent);
    overflow:hidden;
    transform-origin:center;
    animation:rtxForgotCardIn .46s cubic-bezier(.18,.9,.18,1) both;
  }

  .rtx-forgot.is-closing .rtx-forgot-backdrop{animation:rtxForgotBackdropOut .22s ease both;}
  .rtx-forgot.is-closing .rtx-forgot-card{animation:rtxForgotCardOut .22s ease both;}

  .rtx-forgot-border{
    position:absolute;
    inset:0 0 auto;
    height:3px;
    background:linear-gradient(90deg,transparent,#08b84f,#05b84f,#8b5cf6,transparent);
    opacity:.95;
