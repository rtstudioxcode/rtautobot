      width:300px;
      max-width:300px;
      height:56px;
      display:flex;
      justify-content:center;
    }

    .rtx-turnstile iframe{
      width:300px !important;
      max-width:300px !important;
    }
  }

  @media (max-width: 390px){
    .rtx-turnstile .cf-turnstile{
      transform:scale(.78);
    }
  }

