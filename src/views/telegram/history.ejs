<% const PAGE_TITLE = "Telegram — ประวัติการใช้งาน"; %>
<%
  const safeHistory = Array.isArray(history) ? history : [];
  const totalJobs = safeHistory.length;
  const finishedJobs = safeHistory.filter(j => j.status === 'finished').length;
  const runningJobs = safeHistory.filter(j => ['running','pending'].includes(j.status)).length;
  const failedJobs = safeHistory.filter(j => ['failed','error'].includes(j.status)).length;
  const totalInvited = safeHistory.reduce((n,j)=> n + Number(j.invited || 0), 0);
  function stLabel(st){
    return st === 'finished' ? 'สำเร็จ' :
      st === 'running' || st === 'pending' ? 'กำลังทำงาน' :
      st === 'stopped' ? 'ยกเลิกแล้ว' :
      st === 'failed' || st === 'error' ? 'ล้มเหลว' : (st || '-');
  }
  function stClass(st){
    return st === 'finished' ? 'done' :
      st === 'running' || st === 'pending' ? 'run' :
      st === 'stopped' ? 'stop' :
      st === 'failed' || st === 'error' ? 'fail' : 'wait';
  }
%>

<section class="page telegram-page tg-history-enterprise" style="padding:0; width:100%;">
  <div class="tgh-hero">
    <div class="tgh-hero-content">
      <div class="tgh-kicker"><span>✦</span> Telegram History</div>
      <h1><%= PAGE_TITLE %></h1>
      <p>ตรวจงานย้อนหลัง ดูสถานะ เช็คจำนวนที่เชิญ และเปิดบันทึกการทำงานได้แบบอ่านง่ายในหน้าเดียว</p>
    </div>
    <div class="tgh-stats" aria-label="history summary">
      <div class="tgh-stat"><strong><%= totalJobs.toLocaleString('th-TH') %></strong><span>งานทั้งหมด</span></div>
      <div class="tgh-stat"><strong><%= finishedJobs.toLocaleString('th-TH') %></strong><span>สำเร็จ</span></div>
      <div class="tgh-stat"><strong><%= totalInvited.toLocaleString('th-TH') %></strong><span>เชิญสำเร็จ</span></div>
      <div class="tgh-stat"><strong><%= failedJobs.toLocaleString('th-TH') %></strong><span>ล้มเหลว</span></div>
    </div>
  </div>

  <div class="tabs tgh-tabs">
    <button type="button" class="tab" data-tab="accounts"><span>👤</span> ตั้งค่าบัญชี</button>
    <button type="button" class="tab" data-tab="pull"><span>🚀</span> ใช้งานบอท</button>
    <button type="button" class="tab active" data-tab="history"><span>📜</span> ประวัติการทำงาน</button>
  </div>

  <section id="tab-history" class="tabpane show">
    <section class="tgh-panel">
      <div class="tgh-toolbar">
        <div>
          <h2>รายการงานล่าสุด</h2>
          <p>คลิกการ์ดเพื่อย่อ/ขยายรายละเอียด กด “ดูบันทึก” เพื่อดูรายงานแบบละเอียด</p>
        </div>
        <div class="tgh-count"><%= totalJobs.toLocaleString('th-TH') %> รายการ</div>
      </div>

      <div class="card-container tgh-list">
        <% if (safeHistory.length > 0) { %>
          <% safeHistory.forEach((job, idx) => { 
              const limit = Number(job.limit || 0);
              const invited = Number(job.invited || 0);
              const pct = limit > 0 ? Math.min(100, Math.round((invited / limit) * 100)) : 0;
              const c = stClass(job.status);
              const canStop = ['running','pending'].includes(String(job.status || '').toLowerCase());
          %>
            <article class="tgh-item card-item" style="--delay:<%= idx %>;">
              <div class="card-header tgh-item-head" onclick="toggleCard('<%= job._id %>')">
                <div class="tgh-idblock">
                  <span class="tgh-order"><%= job.orderId || ('#' + String(job._id).slice(-8)) %></span>
                  <span class="tgh-date"><%= new Date(job.createdAt).toLocaleString('th-TH') %></span>
                </div>
                <span class="tgh-pill <%= c %>"><i></i><%= stLabel(job.status) %></span>
              </div>

              <div class="card-content tgh-body" id="card-<%= job._id %>">
                <div class="tgh-grid">
                  <div class="tgh-info"><span>กลุ่มต้นทาง</span><strong><%= job.srcGroup || '-' %></strong></div>
                  <div class="tgh-info"><span>กลุ่มปลายทาง</span><strong><%= job.destGroup || '-' %></strong></div>
                  <div class="tgh-info"><span>จำนวนที่เชิญ</span><strong><%= invited.toLocaleString('th-TH') %>/<%= limit.toLocaleString('th-TH') %> คน</strong></div>
                </div>
                <div class="tgh-progress" aria-label="progress">
                  <div style="width:<%= pct %>%"></div>
                </div>
                <div class="tgh-actions">
                  <% if (canStop) { %>
                    <button type="button" class="tgh-stop-btn" data-stop-job="<%= job._id %>" onclick="event.stopPropagation(); stopTelegramHistoryJob('<%= job._id %>', this)" aria-label="ยกเลิกการทำงาน">
                      <span class="tgh-stop-ico">⛔</span> ยกเลิก
                    </button>
                  <% } %>
                  <button type="button" class="tgh-log-btn" onclick="event.stopPropagation(); openLogModalById('<%= job._id %>')" aria-label="ดูรายละเอียด">
                    <img src="/static/assets/emoji/detail.png" alt="" class="detail-icon"> ดูบันทึก
                  </button>
                </div>
              </div>
            </article>
          <% }) %>
        <% } else { %>
          <div class="tgh-empty">
            <div class="tgh-empty-ico">📭</div>
            <h3>ยังไม่มีประวัติการดึงสมาชิก</h3>
            <p>เมื่อเริ่มงาน Telegram แล้ว รายการทั้งหมดจะมาแสดงตรงนี้</p>
          </div>
        <% } %>
      </div>
    </section>

    <!-- Modal ถูกสร้างด้วย JavaScript เป็น native <dialog> เพื่อให้ลอยกลาง viewport จริงเสมอ -->
  </section>
</section>

<script>
document.addEventListener('click', (e) => {
  const btn = e.target.closest('.tab');
  if (!btn) return;
  const tab = btn.dataset.tab;
  if (tab === 'accounts' || tab === 'pull') {
    window.location.href = '/telegram';
    return;
  }
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.tabpane').forEach(p => p.classList.remove('show'));
  document.getElementById('tab-' + tab)?.classList.add('show');
});

function escapeHtml(value) {
  return String(value ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}

function ensureTelegramLogDialog() {
  let dialog = document.getElementById('tgLogDialog');
  if (dialog) return dialog;

  dialog = document.createElement('dialog');
  dialog.id = 'tgLogDialog';
  dialog.className = 'tglog-dialog';
  dialog.innerHTML = `
    <div class="tglog-shell" role="document">
      <div class="tglog-topbar" aria-hidden="true"></div>
      <header class="tglog-head">
        <div class="tglog-title-wrap">
          <div class="tglog-kicker"><span>✦</span> Activity stream</div>
          <h3>บันทึกการทำงาน</h3>
          <p>ตรวจรายละเอียดการเชิญสมาชิกแบบเรียลไทม์ อ่านง่าย และแยกสถานะชัดเจน</p>
        </div>
        <button type="button" class="tglog-close" aria-label="ปิด Modal">×</button>
      </header>
      <div class="tglog-summary" id="tgLogSummary">
        <div><strong>0</strong><span>รายการทั้งหมด</span></div>
        <div><strong>0</strong><span>สำเร็จ</span></div>
        <div><strong>0</strong><span>ไม่สำเร็จ</span></div>
      </div>
      <main id="tgModalContent" class="tglog-list" aria-live="polite"></main>
    </div>
  `;

  document.body.appendChild(dialog);

  dialog.querySelector('.tglog-close')?.addEventListener('click', closeLogModal);

  // กดพื้นที่ว่างนอกกล่องเพื่อปิด
  dialog.addEventListener('click', (e) => {
    const shell = dialog.querySelector('.tglog-shell');
    if (shell && !shell.contains(e.target)) closeLogModal();
  });

  dialog.addEventListener('cancel', (e) => {
    e.preventDefault();
    closeLogModal();
  });

  return dialog;
}

function classifyTelegramWorkLog(text) {
  const s = String(text || '').trim();
  if (!s) return null;

  // ไม่นับ log ระบบ/หัวท้ายงาน เพราะไม่ใช่รายการที่พยายามเชิญหรือดึงสมาชิกจริง
  if (/^(เริ่มงาน|กำลังโหลด|คืนเครดิต)/i.test(s)) return null;
  if (/จบงาน|ดึงสมาชิกสำเร็จ|ยกเลิกงาน|งานนี้ถูกยกเลิก|บัญชีทั้งหมดติด|รายชื่อในรายการถูกใช้งานจนครบ/i.test(s)) return null;

  // สำเร็จ: ต้องเป็น log เชิญที่สำเร็จจริงเท่านั้น ห้ามนับคำว่า “ไม่สำเร็จ”
  if (/✅/.test(s) && /เชิญ/i.test(s) && /สำเร็จ/i.test(s) && !/ไม่สำเร็จ/i.test(s)) return 'success';

  // ไม่สำเร็จ: log ระดับ target/member ที่พยายามทำแล้ว fail หรือข้ามเพราะ resolve/import ไม่ได้
  if (/❌/.test(s) && /(เชิญ|ข้าม|หา user|resolve|import|ไม่สำเร็จ)/i.test(s)) return 'failed';
  if (/^(ข้าม|skip)/i.test(s) && /(หา user|resolve|import|ไม่ได้|ไม่เจอ)/i.test(s)) return 'failed';
  if (/เชิญ/i.test(s) && /ไม่สำเร็จ/i.test(s)) return 'failed';

  return null;
}

function calcTelegramWorkStats(logs = [], fallbackStats = null) {
  if (fallbackStats && Number.isFinite(Number(fallbackStats.total))) {
    return {
      total: Number(fallbackStats.total || 0),
      success: Number(fallbackStats.success || 0),
      failed: Number(fallbackStats.failed || 0),
    };
  }

  let success = 0;
  let failed = 0;
  for (const item of (Array.isArray(logs) ? logs : [])) {
    const type = classifyTelegramWorkLog(item?.text || item);
    if (type === 'success') success++;
    if (type === 'failed') failed++;
  }
  return { total: success + failed, success, failed };
}

function setLogSummary(logs = [], fallbackStats = null) {
  const box = document.getElementById('tgLogSummary');
  if (!box) return;
  const { total, success, failed } = calcTelegramWorkStats(logs, fallbackStats);
  box.innerHTML = `
    <div><strong>${total.toLocaleString('th-TH')}</strong><span>รายการทั้งหมด</span></div>
    <div><strong>${success.toLocaleString('th-TH')}</strong><span>สำเร็จ</span></div>
    <div><strong>${failed.toLocaleString('th-TH')}</strong><span>ไม่สำเร็จ</span></div>
  `;
}

function showLogModal() {
  const dialog = ensureTelegramLogDialog();
  document.documentElement.classList.add('tglog-open');
  document.body.classList.add('tglog-open');

  if (!dialog.open) {
    if (typeof dialog.showModal === 'function') {
      dialog.showModal();
    } else {
      dialog.setAttribute('open', '');
    }
  }

  requestAnimationFrame(() => {
    const list = document.getElementById('tgModalContent');
    if (list) list.scrollTop = 0;
    dialog.querySelector('.tglog-close')?.focus({ preventScroll:true });
  });

  return dialog;
}

async function openLogModalById(jobId) {
  showLogModal();
  const body = document.getElementById('tgModalContent');
  setLogSummary([]);
  if (body) {
    body.innerHTML = `
      <div class="tglog-state tglog-loading">
        <span class="tglog-spinner"></span>
        <strong>กำลังโหลดบันทึก...</strong>
        <small>กำลังดึงข้อมูลล่าสุดจากระบบ</small>
      </div>
    `;
  }

  try {
    const res = await fetch(`/telegram/history/${encodeURIComponent(jobId)}`, {
      headers: { 'Accept': 'application/json' },
      cache: 'no-store',
    });
    const data = await res.json();
    if (!data.ok) {
      if (body) body.innerHTML = `<div class="tglog-state"><strong>${escapeHtml(data.error || 'โหลดบันทึกไม่สำเร็จ')}</strong></div>`;
      return;
    }
    openLogModal(Array.isArray(data.logs) ? data.logs : [], data.stats || null);
  } catch (err) {
    if (body) body.innerHTML = `<div class="tglog-state"><strong>โหลดบันทึกไม่สำเร็จ</strong><small>${escapeHtml(err?.message || '')}</small></div>`;
  }
}

function logTone(text) {
  const t = String(text || '');
  if (/❌|ไม่สำเร็จ|error|fail|USER_|FLOOD|PEER|resolve|IMPORT/i.test(t)) return 'bad';
  if (/✅/.test(t) && /สำเร็จ|success/i.test(t) && !/ไม่สำเร็จ/i.test(t)) return 'ok';
  if (/เริ่ม|start|pending|กำลัง/i.test(t)) return 'run';
  return 'info';
}

function openLogModal(logs = [], stats = null) {
  showLogModal();
  const body = document.getElementById('tgModalContent');
  if (!body) return;

  setLogSummary(logs, stats);

  if (!logs || logs.length === 0) {
    body.innerHTML = `
      <div class="tglog-state">
        <span class="tglog-empty-ico">📭</span>
        <strong>ไม่มีบันทึก</strong>
        <small>งานนี้ยังไม่มีรายละเอียด log ให้แสดง</small>
      </div>
    `;
    return;
  }

  body.innerHTML = logs.map((l, i) => {
    const time = l.time ? new Date(l.time).toLocaleString('th-TH') : '-';
    const text = String(l.text || '');
    const tone = logTone(text);
    const icon = tone === 'ok' ? '✓' : tone === 'bad' ? '×' : tone === 'run' ? '↻' : '•';
    return `
      <article class="tglog-row ${tone}" style="--i:${i}">
        <div class="tglog-dot">${icon}</div>
        <div class="tglog-content">
          <time>${escapeHtml(time)}</time>
          <p>${escapeHtml(text)}</p>
        </div>
      </article>
    `;
  }).join('');
}

function closeLogModal() {
  const dialog = document.getElementById('tgLogDialog');
  if (dialog?.open) dialog.close();
  else dialog?.removeAttribute('open');
  document.documentElement.classList.remove('tglog-open');
  document.body.classList.remove('tglog-open');
}

document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') closeLogModal();
});


async function stopTelegramHistoryJob(jobId, btn) {
  const id = String(jobId || '').trim();
  if (!id) return;

  const ok = await (window.UIConfirm ? window.UIConfirm({
    tone: 'danger',
    icon: '⛔',
    kicker: 'Telegram job control',
    title: 'ยืนยันยกเลิกงานนี้?',
    message: 'ระบบจะยกเลิการทำงานของรายการนี้',
    confirmText: 'ยืนยันยกเลิก',
    cancelText: 'ไม่ยกเลิก'
  }) : Promise.resolve(confirm('ยืนยันยกเลิกงานนี้ใช่ไหม? ระบบจะยกเลิการทำงานของรายการนี้')));
  if (!ok) return;

  const original = btn?.innerHTML;
  if (btn) {
    btn.disabled = true;
    btn.classList.add('is-loading');
    btn.innerHTML = '<span class="tgh-stop-spinner"></span> กำลังยกเลิก...';
  }

  try {
    const res = await fetch(`/telegram/history/${encodeURIComponent(id)}/stop`, {
      method: 'POST',
      headers: {
        'Accept': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      credentials: 'same-origin',
      cache: 'no-store',
    });

    const data = await res.json().catch(() => ({}));
    if (!res.ok || !data.ok) {
      throw new Error(data.error || 'ยกเลิกงานไม่สำเร็จ');
    }

    const item = btn?.closest('.tgh-item');
    const pill = item?.querySelector('.tgh-pill');
    if (pill) {
      pill.className = 'tgh-pill stop';
      pill.innerHTML = '<i></i>ยกเลิกแล้ว';
    }

    const body = item?.querySelector('.tgh-body');
    const log = data.refund > 0
      ? `ยกเลิกงานนี้แล้ว • คืน ${Number(data.refund || 0).toLocaleString('th-TH')} เครดิต`
      : 'ยกเลิกงานนี้แล้ว';
    if (body && !body.querySelector('.tgh-stop-note')) {
      body.insertAdjacentHTML('afterbegin', `<div class="tgh-stop-note">${escapeHtml(log)}</div>`);
    }

    btn?.remove();
  } catch (err) {
    if (btn) {
      btn.disabled = false;
      btn.classList.remove('is-loading');
      btn.innerHTML = original || '<span class="tgh-stop-ico">⛔</span> ยกเลิก';
    }
    alert(err?.message || 'ยกเลิกงานไม่สำเร็จ');
  }
}


function toggleCard(jobId) {
  const cardContent = document.getElementById('card-' + jobId);
  if (!cardContent) return;
  const item = cardContent.closest('.tgh-item');
  const closed = cardContent.style.display === 'none';
  cardContent.style.display = closed ? 'block' : 'none';
  item?.classList.toggle('is-collapsed', !closed);
}
</script>

