)}.tgh-tabs{grid-template-columns:1fr;gap:7px;border-radius:20px}.tgh-tabs .tab{min-height:46px!important;font-size:13px!important}.tgh-toolbar{align-items:flex-start;flex-direction:column}.tgh-item-head{align-items:flex-start;flex-direction:column}.tgh-pill{align-self:flex-start}.tgh-log-row{grid-template-columns:1fr}.tgh-modal-card{border-radius:24px!important;padding:18px!important}}@media(prefers-reduced-motion:reduce){.tg-history-enterprise *,.tg-history-enterprise *::before,.tg-history-enterprise *::after{animation:none!important;transition:none!important;scroll-behavior:auto!important}}

/* =========================================================
   Native Dialog Modal: ลอยกลาง viewport จริงเสมอ
   - ใช้ top-layer ของ browser ผ่าน showModal()
   - ไม่โดน parent transform/overflow/filter จับตำแหน่งผิด
   - คลิกพื้นที่ว่างนอก modal เพื่อปิดได้
========================================================= */
html.tglog-open,
body.tglog-open{
  overflow:hidden!important;
}

#tgLogDialog.tglog-dialog{
  --tglog-page:var(--page,#070708);
  --tglog-card:var(--card,#17171b);
  --tglog-text:var(--text,#fff6e8);
  --tglog-muted:var(--muted,#b9ad96);
  --tglog-border:color-mix(in srgb,var(--border,#313036) 76%,transparent);
  --tglog-accent:var(--accent,#e8bc53);
  --tglog-accent2:#ffe28a;
  position:fixed!important;
  inset:0!important;
  width:100dvw!important;
  max-width:none!important;
  height:100dvh!important;
  max-height:none!important;
  margin:0!important;
  padding:clamp(14px,2.4vw,28px)!important;
  border:0!important;
  background:transparent!important;
  color:var(--tglog-text)!important;
  overflow:hidden!important;
  box-sizing:border-box!important;
}

#tgLogDialog.tglog-dialog::backdrop{
  background:
    radial-gradient(680px 360px at 48% 48%, color-mix(in srgb,var(--tglog-accent) 14%,transparent), transparent 68%),
    rgba(0,0,0,.72)!important;
  backdrop-filter:blur(14px) saturate(1.12)!important;
  -webkit-backdrop-filter:blur(14px) saturate(1.12)!important;
}

#tgLogDialog .tglog-shell{
  position:fixed!important;
  top:50%!important;
  left:50%!important;
  transform:translate(-50%,-50%)!important;
  width:min(760px, calc(100dvw - 32px))!important;
  max-height:calc(100dvh - 42px)!important;
  display:flex!important;
  flex-direction:column!important;
  overflow:hidden!important;
  border-radius:30px!important;
  border:1px solid color-mix(in srgb,var(--tglog-border) 88%,transparent)!important;
  background:
    linear-gradient(180deg,rgba(255,255,255,.055),rgba(255,255,255,.018)),
    radial-gradient(620px 260px at 0% 0%, color-mix(in srgb,var(--tglog-accent) 18%,transparent), transparent 72%),
    color-mix(in srgb,var(--tglog-card) 94%,var(--tglog-page))!important;
  box-shadow:
    0 38px 120px rgba(0,0,0,.62),
    0 0 0 1px rgba(255,255,255,.035) inset,
    inset 0 1px 0 rgba(255,255,255,.08)!important;
  animation:tglogPop .24s cubic-bezier(.2,.9,.2,1) both;
}

#tgLogDialog .tglog-topbar{
  height:4px;
  background:linear-gradient(90deg,transparent,var(--tglog-accent2),var(--tglog-accent),transparent);
  opacity:.9;
  flex:0 0 auto;
}

#tgLogDialog .tglog-head{
  flex:0 0 auto;
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:16px;
  padding:22px 22px 16px;
  border-bottom:1px solid var(--tglog-border);
}

#tgLogDialog .tglog-title-wrap{min-width:0;}
#tgLogDialog .tglog-kicker{
  width:max-content;
  max-width:100%;
  display:inline-flex;
  align-items:center;
  gap:7px;
  margin-bottom:9px;
  padding:7px 10px;
  border-radius:999px;
  border:1px solid color-mix(in srgb,var(--tglog-accent) 44%,var(--tglog-border));
  background:color-mix(in srgb,var(--tglog-accent) 12%,transparent);
  color:var(--tglog-accent2);
  font-size:11px;
  font-weight:950;
  letter-spacing:.10em;
  text-transform:uppercase;
}
#tgLogDialog h3{
  margin:0;
  color:var(--tglog-text);
  font-size:clamp(22px,2.4vw,32px);
  line-height:1.05;
  letter-spacing:-.04em;
}
#tgLogDialog .tglog-head p{
  margin:8px 0 0;
  color:var(--tglog-muted);
  font-size:13px;
  line-height:1.55;
  font-weight:650;
}

#tgLogDialog .tglog-close{
  width:44px;
  height:44px;
  flex:0 0 44px;
  border-radius:16px;
  border:1px solid var(--tglog-border);
  background:linear-gradient(180deg,rgba(255,255,255,.055),rgba(255,255,255,.018));
  color:var(--tglog-text);
  font-size:26px;
  font-weight:900;
  line-height:1;
  cursor:pointer;
  display:grid;
  place-items:center;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.06);
  transition:transform .18s ease,border-color .18s ease,background .18s ease;
}
#tgLogDialog .tglog-close:hover{
  transform:translateY(-1px) rotate(4deg);
  border-color:color-mix(in srgb,var(--tglog-accent) 55%,var(--tglog-border));
  background:color-mix(in srgb,var(--tglog-accent) 13%,var(--tglog-card));
}

#tgLogDialog .tglog-summary{
  flex:0 0 auto;
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:10px;
  padding:14px 22px;
  border-bottom:1px solid var(--tglog-border);
}
#tgLogDialog .tglog-summary > div{
  min-width:0;
  padding:12px;
  border-radius:18px;
  border:1px solid var(--tglog-border);
  background:color-mix(in srgb,var(--tglog-card) 75%,transparent);
}
#tgLogDialog .tglog-summary strong{
  display:block;
  color:var(--tglog-accent2);
  font-size:20px;
  line-height:1;
  font-weight:950;
}
#tgLogDialog .tglog-summary span{
  display:block;
  margin-top:6px;
  color:var(--tglog-muted);
  font-size:11px;
  font-weight:850;
}

#tgLogDialog .tglog-list{
  flex:1 1 auto;
  min-height:220px;
  max-height:calc(100dvh - 270px);
  overflow:auto;
  padding:18px 22px 22px;
  display:grid;
  gap:10px;
  scrollbar-width:thin;
  scrollbar-color:color-mix(in srgb,var(--tglog-accent) 58%,transparent) transparent;
}
#tgLogDialog .tglog-list::-webkit-scrollbar{width:8px;}
#tgLogDialog .tglog-list::-webkit-scrollbar-thumb{
  border-radius:999px;
  background:color-mix(in srgb,var(--tglog-accent) 54%,transparent);
}

#tgLogDialog .tglog-row{
  position:relative;
  display:grid;
  grid-template-columns:38px minmax(0,1fr);
  gap:12px;
  padding:13px;
  border-radius:18px;
  border:1px solid var(--tglog-border);
  background:linear-gradient(180deg,rgba(255,255,255,.036),rgba(255,255,255,.014)),color-mix(in srgb,var(--tglog-card) 78%,transparent);
  box-shadow:inset 0 1px 0 rgba(255,255,255,.04);
  animation:tglogRowIn .28s ease both;
  animation-delay:calc(min(var(--i),18) * 18ms);
}
#tgLogDialog .tglog-row::before{
  content:"";
  position:absolute;
  left:31px;
  top:52px;
  bottom:-12px;
  width:1px;
  background:linear-gradient(180deg,color-mix(in srgb,var(--tglog-accent) 46%,transparent),transparent);
  opacity:.55;
}
#tgLogDialog .tglog-row:last-child::before{display:none;}
#tgLogDialog .tglog-dot{
  width:34px;
  height:34px;
  border-radius:14px;
  display:grid;
  place-items:center;
  color:#17130a;
  font-weight:950;
  background:linear-gradient(135deg,#ffe28a,#d39a2a);
  box-shadow:0 10px 26px color-mix(in srgb,var(--tglog-accent) 25%,transparent);
}
#tgLogDialog .tglog-row.ok .tglog-dot{background:linear-gradient(135deg,#53ee9b,#12b866);color:#062214;}
#tgLogDialog .tglog-row.bad .tglog-dot{background:linear-gradient(135deg,#ff8492,#dd3349);color:#fff;}
#tgLogDialog .tglog-row.run .tglog-dot{background:linear-gradient(135deg,#7db7ff,#486cff);color:#fff;}
#tgLogDialog .tglog-content{min-width:0;}
#tgLogDialog .tglog-content time{
  display:block;
  color:var(--tglog-accent2);
  font-size:12px;
  font-weight:900;
  margin-bottom:4px;
}
#tgLogDialog .tglog-content p{
  margin:0;
  color:var(--tglog-text);
  font-size:13.5px;
  line-height:1.58;
  overflow-wrap:anywhere;
}

#tgLogDialog .tglog-state{
  min-height:260px;
  display:grid;
  place-items:center;
  align-content:center;
  gap:8px;
  text-align:center;
  color:var(--tglog-muted);
  border:1px dashed color-mix(in srgb,var(--tglog-accent) 34%,var(--tglog-border));
  border-radius:22px;
  background:color-mix(in srgb,var(--tglog-card) 58%,transparent);
}
#tgLogDialog .tglog-state strong{color:var(--tglog-text);font-size:18px;}
#tgLogDialog .tglog-state small{color:var(--tglog-muted);font-weight:650;}
#tgLogDialog .tglog-empty-ico{font-size:42px;}
#tgLogDialog .tglog-spinner{
  width:34px;
  height:34px;
  border-radius:999px;
  border:3px solid color-mix(in srgb,var(--tglog-accent) 24%,transparent);
  border-top-color:var(--tglog-accent2);
  animation:tglogSpin .85s linear infinite;
}

@keyframes tglogPop{
  from{opacity:0;transform:translate(-50%,-47%) scale(.965);filter:blur(8px);}
  to{opacity:1;transform:translate(-50%,-50%) scale(1);filter:blur(0);}
}
@keyframes tglogRowIn{
  from{opacity:0;transform:translateY(10px) scale(.992);}
  to{opacity:1;transform:translateY(0) scale(1);}
}
@keyframes tglogSpin{to{transform:rotate(360deg);}}

@media(max-width:680px){
  #tgLogDialog.tglog-dialog{padding:10px!important;}
  #tgLogDialog .tglog-shell{
    width:calc(100dvw - 20px)!important;
    max-height:calc(100dvh - 20px)!important;
    border-radius:24px!important;
  }
  #tgLogDialog .tglog-head{padding:18px 16px 13px;}
  #tgLogDialog .tglog-summary{grid-template-columns:1fr;gap:8px;padding:12px 16px;}
  #tgLogDialog .tglog-list{padding:14px 16px 18px;max-height:calc(100dvh - 330px);}
  #tgLogDialog .tglog-row{grid-template-columns:32px minmax(0,1fr);gap:10px;padding:11px;}
  #tgLogDialog .tglog-dot{width:30px;height:30px;border-radius:12px;}
  #tgLogDialog .tglog-row::before{left:26px;top:48px;}
}

@media(prefers-reduced-motion:reduce){
