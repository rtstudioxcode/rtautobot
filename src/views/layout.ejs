<script>
(() => {
  const body = document.body;
  const sidebar = document.getElementById('sb');
  const backdrop = document.querySelector('.sb-backdrop');
  const mobileQuery = window.matchMedia('(max-width: 900px)');

  const openMenu = () => {
    body.classList.add('sb-mobile-open');
    body.classList.add('sb-open');
    sidebar?.setAttribute('aria-hidden', 'false');
  };

  const closeMenu = () => {
    body.classList.remove('sb-mobile-open');
    body.classList.remove('sb-open');
    sidebar?.setAttribute('aria-hidden', 'true');
  };

  const toggleMenu = () => {
    if (!mobileQuery.matches) return;
    body.classList.contains('sb-mobile-open') || body.classList.contains('sb-open') ? closeMenu() : openMenu();
  };

  const isMenuButton = (el) => !!el?.closest?.('[data-sb-toggle="1"], .js-sb-toggle, .rt-mobile-menu, #sbToggle');

  // จับแบบ capture เพื่อกัน script เก่าที่ซ้ำกันมาปิดเมนูทันที
  document.addEventListener('click', (e) => {
    const trigger = isMenuButton(e.target);
    if (!trigger) return;
    if (!mobileQuery.matches) return;
    e.preventDefault();
    e.stopPropagation();
    e.stopImmediatePropagation();
    toggleMenu();
  }, true);

  backdrop?.addEventListener('click', (e) => {
    e.preventDefault();
    closeMenu();
  });

  sidebar?.addEventListener('click', (e) => {
    const link = e.target.closest('a.sb-item');
    if (link && mobileQuery.matches) closeMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  mobileQuery.addEventListener?.('change', (e) => {
    if (!e.matches) closeMenu();
  });
})();
</script>



<script id="rt-final-sidebar-mobile-fix-js">
(() => {
  const body = document.body;
  const sidebar = document.getElementById('sb');
  const backdrop = document.getElementById('sbBackdrop');

  const isMobile = () => window.matchMedia('(max-width: 900px)').matches;
  const openMenu = () => {
    if (!isMobile()) return;
    body.classList.add('sb-mobile-open');
    sidebar?.setAttribute('aria-hidden', 'false');
  };
  const closeMenu = () => {
    body.classList.remove('sb-mobile-open');
    sidebar?.setAttribute('aria-hidden', 'true');
  };
  const toggleMenu = (e) => {
    e?.preventDefault?.();
    e?.stopPropagation?.();
    body.classList.contains('sb-mobile-open') ? closeMenu() : openMenu();
  };

  // Prevent old duplicated handlers from winning on mobile.
  document.querySelectorAll('[data-sb-toggle="1"], .js-sb-toggle, #sbToggle').forEach((btn) => {
    btn.addEventListener('click', toggleMenu, true);
  });

  backdrop?.addEventListener('click', (e) => {
    if (isMobile()) {
      e.preventDefault();
      closeMenu();
    }
  }, true);

  sidebar?.addEventListener('click', (e) => {
    const link = e.target.closest?.('a.sb-item');
    if (link && isMobile()) closeMenu();
  }, true);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  window.addEventListener('resize', () => {
    if (!isMobile()) closeMenu();
  }, { passive: true });

  closeMenu();
})();
</script>


