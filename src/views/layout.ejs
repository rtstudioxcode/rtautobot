          if (e.target.closest('[data-uic-confirm]')) closeUIConfirm(true);
        });

        document.addEventListener('keydown', (e)=>{
          if (!overlay.classList.contains('show')) return;
          if (e.key === 'Escape') closeUIConfirm(false);
          if (e.key === 'Enter') closeUIConfirm(true);
        });

        return overlay;
      }

      function closeUIConfirm(value){
        const overlay = document.getElementById('rtsmmUIConfirm');
        if (!overlay || !overlay.classList.contains('show')) return;

        overlay.classList.remove('show');
        document.body.classList.remove('uic-open');

        const resolver = activeResolve;
        activeResolve = null;

        window.setTimeout(()=>{
          overlay.setAttribute('aria-hidden', 'true');
          if (resolver) resolver(!!value);
        }, 150);
      }

      function openUIConfirm(options = {}){
        const overlay = ensureUIConfirm();

        if (activeResolve) closeUIConfirm(false);

        const title = options.title || 'ยืนยันการทำรายการ';
        const message = options.message || options.text || 'กรุณายืนยันก่อนดำเนินการต่อ';
        const confirmText = options.confirmText || 'ยืนยัน';
        const cancelText = options.cancelText || 'ยกเลิก';
        const tone = options.tone || options.variant || 'danger';
        const icon = options.icon || (tone === 'danger' ? '⛔' : tone === 'success' ? '✅' : '⚠');
        const kicker = options.kicker || (tone === 'danger' ? 'Critical action' : 'Confirm action');

        overlay.querySelector('#uicTitle').textContent = title;
        overlay.querySelector('#uicMessage').textContent = message;
        overlay.querySelector('#uicIcon').textContent = icon;
        overlay.querySelector('#uicKicker').textContent = kicker;

        const confirmBtn = overlay.querySelector('[data-uic-confirm]');
        const cancelBtn = overlay.querySelector('[data-uic-cancel]:not(.uic-close)');
        confirmBtn.textContent = confirmText;
        cancelBtn.textContent = cancelText;
        confirmBtn.className = 'uic-btn confirm ' + (tone === 'danger' ? 'danger' : tone === 'success' ? 'success' : '');

        overlay.removeAttribute('aria-hidden');
        document.body.classList.add('uic-open');

        requestAnimationFrame(()=>{
          overlay.classList.add('show');
          confirmBtn.focus({ preventScroll:true });
        });

        return new Promise(resolve => {
          activeResolve = resolve;
        });
      }

      window.UIConfirm = Object.assign(openUIConfirm, {
        __enterprise: true,
        open: openUIConfirm,
        close: closeUIConfirm,
      });

      window.uiConfirm = openUIConfirm;
    })();
  </script>



<script id="rt-global-custom-select-script">
(function(){
  const SELECTOR = 'select:not([multiple]):not([data-native-select="true"]):not(.rt-native-select-hidden)';
  let openWidget = null;

  function optionText(option){ return (option?.textContent || option?.label || '').trim(); }
  function getSelectedOption(select){ return select.options[select.selectedIndex] || select.options[0] || null; }
  function close(widget){
    if (!widget) return;
    widget.classList.remove('is-open');
    const btn = widget.querySelector('.rt-select__button');
    if (btn) btn.setAttribute('aria-expanded','false');
    if (openWidget === widget) openWidget = null;
  }
  function closeAll(except){
    document.querySelectorAll('.rt-select.is-open').forEach(w => { if (w !== except) close(w); });
  }
  function sync(select){
    const widget = select.__rtSelectWidget;
    if (!widget) return;
    const selected = getSelectedOption(select);
    const value = widget.querySelector('.rt-select__value');
    if (value) value.textContent = selected ? optionText(selected) : 'เลือกข้อมูล';
    widget.classList.toggle('is-disabled', select.disabled);
    const menu = widget.querySelector('.rt-select__menu');
    if (!menu) return;
    menu.innerHTML = '';
    Array.from(select.options).forEach((opt, index) => {
      const item = document.createElement('button');
      item.type = 'button';
      item.className = 'rt-select__option';
      item.setAttribute('role','option');
      item.dataset.index = String(index);
      item.innerHTML = `<span>${optionText(opt) || '&nbsp;'}</span><span class="rt-select__check">✓</span>`;
      if (opt.disabled) { item.classList.add('is-disabled'); item.disabled = true; }
      if (index === select.selectedIndex) { item.classList.add('is-selected'); item.setAttribute('aria-selected','true'); }
      item.addEventListener('click', () => {
        if (opt.disabled) return;
        select.selectedIndex = index;
        select.dispatchEvent(new Event('input', { bubbles:true }));
        select.dispatchEvent(new Event('change', { bubbles:true }));
        sync(select);
        close(widget);
      });
      menu.appendChild(item);
    });
  }
  function enhance(select){
    if (!select || select.__rtSelectWidget || select.multiple || select.dataset.nativeSelect === 'true') return;
    if (select.closest('.rt-select')) return;
    const widget = document.createElement('div');
    widget.className = 'rt-select';
    widget.setAttribute('data-rt-select','');
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'rt-select__button';
    btn.setAttribute('aria-haspopup','listbox');
    btn.setAttribute('aria-expanded','false');
    btn.innerHTML = '<span class="rt-select__value"></span><span class="rt-select__chevron" aria-hidden="true">⌄</span>';
    const menu = document.createElement('div');
    menu.className = 'rt-select__menu';
    menu.setAttribute('role','listbox');
    select.parentNode.insertBefore(widget, select.nextSibling);
    widget.appendChild(btn);
    widget.appendChild(menu);
    select.classList.add('rt-native-select-hidden');
    select.__rtSelectWidget = widget;
    widget.__rtNativeSelect = select;
    btn.addEventListener('click', (ev) => {
      ev.preventDefault();
      if (select.disabled) return;
      const willOpen = !widget.classList.contains('is-open');
      closeAll(widget);
      widget.classList.toggle('is-open', willOpen);
      btn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
      openWidget = willOpen ? widget : null;
      if (willOpen) {
        const selectedItem = menu.querySelector('.is-selected');
        if (selectedItem) selectedItem.scrollIntoView({ block:'nearest' });
      }
    });
    select.addEventListener('change', () => sync(select));
    select.addEventListener('rt-select:refresh', () => sync(select));
    new MutationObserver(() => sync(select)).observe(select, { childList:true, subtree:true, attributes:true, attributeFilter:['disabled','label','value','selected'] });
    sync(select);
  }
  function enhanceAll(root=document){ root.querySelectorAll(SELECTOR).forEach(enhance); }
  document.addEventListener('click', (ev) => { if (openWidget && !ev.target.closest('.rt-select')) close(openWidget); });
  document.addEventListener('keydown', (ev) => { if (ev.key === 'Escape') closeAll(); });
  document.addEventListener('DOMContentLoaded', () => enhanceAll());
  new MutationObserver((mutations) => {
    for (const m of mutations) {
      m.addedNodes.forEach(node => {
        if (node.nodeType !== 1) return;
        if (node.matches && node.matches(SELECTOR)) enhance(node);
        if (node.querySelectorAll) enhanceAll(node);
      });
    }
  }).observe(document.documentElement, { childList:true, subtree:true });
  window.RTCustomSelect = { enhanceAll, refresh(select){ if (select) sync(select); else document.querySelectorAll('select.rt-native-select-hidden').forEach(sync); } };
})();
</script>

