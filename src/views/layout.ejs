  /* ==========================================================
     MOBILE SIDEBAR LAYER FIX — ให้เมนูอยู่เหนือ blur overlay จริง
     แก้ปัญหาเมนูเบลอ / คลิกไม่ได้ / overlay ทับเมนูใน Responsive
     ========================================================== */
  .sb-backdrop{
    position:fixed;
    inset:0;
    z-index:980;
    opacity:0;
    visibility:hidden;
    pointer-events:none;
    background:rgba(0,0,0,.58);
    -webkit-backdrop-filter:blur(14px) saturate(120%);
    backdrop-filter:blur(14px) saturate(120%);
    transition:opacity .24s ease, visibility .24s ease;
  }

  @media (min-width:901px){
    .sb-backdrop{display:none!important;}
  }

  @media (max-width:900px){
    /* ปิด pseudo overlay เดิม เพราะบาง browser เอาไปทับ sidebar แล้วเมนูคลิกไม่ได้ */
    body.sb-open::before{
      content:none!important;
      display:none!important;
      opacity:0!important;
      visibility:hidden!important;
      pointer-events:none!important;
      -webkit-backdrop-filter:none!important;
      backdrop-filter:none!important;
    }

    body.sb-open .sb-backdrop{
      opacity:1;
      visibility:visible;
      pointer-events:auto;
    }

    .sidebar{
      z-index:1005!important;
      filter:none!important;
      -webkit-filter:none!important;
      opacity:1!important;
      pointer-events:auto!important;
      transform:translateX(-106%);
      box-shadow:28px 0 70px rgba(0,0,0,.56), 1px 0 0 rgba(255,255,255,.08) inset;
    }

    .sidebar.open{
      transform:translateX(0)!important;
      opacity:1!important;
      visibility:visible!important;
      pointer-events:auto!important;
    }

    .sidebar,
    .sidebar *,
    .sb-item,
    .sb-name,
    .sb-group,
    .sb-brand{
      -webkit-filter:none!important;
      filter:none!important;
      text-shadow:none;
    }

    .sb-item,
    .sb-item *{
      pointer-events:auto!important;
    }

    .sb-name{
      display:inline!important;
      opacity:1!important;
      visibility:visible!important;
      max-width:none!important;
      color:var(--text)!important;
      font-weight:650!important;
    }

    .sb-group{
      display:block!important;
      opacity:1!important;
      visibility:visible!important;
      color:var(--muted)!important;
      font-weight:350!important;
    }

    .app-main,
    body.sb-open .app-main,
    body.sb-open .m-topbar,
    body.sb-open .m-subnav{
      filter:none!important;
      -webkit-filter:none!important;
    }
  }



