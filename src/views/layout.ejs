
<!doctype html>
<html lang="th">
<%
  const _bodyClass = (typeof bodyClass !== 'undefined'
    ? bodyClass
    : (locals.bodyClass || ''));

  // --------- TITLE & META DEFAULTS (กัน error + SEO) ----------
  const pageTitle = (
    typeof title !== 'undefined' && title
      ? title
      : 'RTAUTOBOT | ระบบ Bonustime อัตโนมัติ'
  );

  const pageDescription = (
    typeof metaDescription !== 'undefined' && metaDescription
      ? metaDescription
      : 'RTAUTOBOT ศูนย์สั่งซื้อและจัดการ Bonustime สำหรับสล็อต บาคาร่า และหวย พร้อมเครดิตในบัญชีเดียว'
  );

  const pageKeywords = (
    typeof metaKeywords !== 'undefined' && metaKeywords
      ? metaKeywords
      : 'RTAUTOBOT, Bonustime, ระบบโบนัสไทม์, บอทโบนัสไทม์, สล็อต, บาคาร่า, หวย'
  );

  const ogImage = (
    typeof metaOgImage !== 'undefined' && metaOgImage
      ? metaOgImage
      : 'https://rtautobot.com/static/og/og-default.png'
  );

  const ogType = (
    typeof metaOgType !== 'undefined' && metaOgType
      ? metaOgType
      : 'website'
  );

  const robotsMeta = (
    typeof metaRobots !== 'undefined' && metaRobots
      ? metaRobots
      : 'index,follow'
  );

  const currentPath = (typeof locals !== 'undefined' && locals.currentPath)
    ? locals.currentPath
    : ((typeof req !== 'undefined' && req.originalUrl) ? req.originalUrl : '/');

  // Canonical ไม่ควรติด query/hash เช่น ?tab=history เพื่อกัน duplicate URL ใน Google
  const canonicalPath = String(currentPath || '/').split('?')[0].split('#')[0] || '/';
  const fullUrl = 'https://rtautobot.com' + canonicalPath;

  const p = String(currentPath || '');
  const socialActive =
    p.startsWith('/bonustime') || !!showMyOrdersNav;
%>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Primary Title -->
  <title><%= pageTitle %></title>

  <!-- Canonical & language -->
  <meta http-equiv="content-language" content="th" />
  <link rel="canonical" href="<%= fullUrl %>" />
  <link rel="alternate" hreflang="th-TH" href="<%= fullUrl %>" />
  <link rel="alternate" hreflang="x-default" href="<%= fullUrl %>" />

  <!-- Basic SEO -->
  <meta name="description" content="<%= pageDescription %>">
  <meta name="keywords" content="<%= pageKeywords %>">
  <meta name="robots" content="<%= robotsMeta %>">

  <!-- Open Graph (Facebook / LINE / etc.) -->
  <meta property="og:locale" content="th_TH">
  <meta property="og:site_name" content="RTAUTOBOT">
  <meta property="og:type" content="<%= ogType %>">
  <meta property="og:title" content="<%= pageTitle %>">
  <meta property="og:description" content="<%= pageDescription %>">
  <meta property="og:url" content="<%= fullUrl %>">
  <meta property="og:image" content="<%= ogImage %>">
  <meta property="og:image:alt" content="RTAUTOBOT Bonustime Automation">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= pageTitle %>">
  <meta name="twitter:description" content="<%= pageDescription %>">
  <meta name="twitter:image" content="<%= ogImage %>">

  <!-- Font preload -->
  <link rel="preload" href="/static/fonts/prompt/prompt-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/static/fonts/prompt/prompt-500.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/static/fonts/prompt/prompt-700.woff2" as="font" type="font/woff2" crossorigin>

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="48x48" href="/static/logo/favicon-48.png">
  <link rel="icon" type="image/png" sizes="96x96" href="/static/logo/favicon-96.png">

  <!-- Apple / iOS Home Screen -->
  <link rel="apple-touch-icon" sizes="180x180" href="/static/logo/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-title" content="RTAUTOBOT">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

  <!-- Android / PWA -->
  <link rel="icon" type="image/png" sizes="192x192" href="/static/logo/icon-192.png">
  <link rel="icon" type="image/png" sizes="512x512" href="/static/logo/icon-512.png">
  <link rel="manifest" href="/manifest.webmanifest">

  <!-- Browser theme color -->
  <meta name="theme-color" content="#050505">
  <meta name="msapplication-TileColor" content="#050505">

  <!-- <img src="/static/assets/payment/qrcode.png" /> -->
  <link rel="preload" href="/static/fonts/prompt/prompt-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/static/fonts/prompt/prompt-500.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/static/fonts/prompt/prompt-700.woff2" as="font" type="font/woff2" crossorigin>

  <!-- Structured Data: Website (JSON-LD) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "RTAUTOBOT",
    "url": "https://rtautobot.com",
    "inLanguage": "th-TH",
    "description": "<%- pageDescription.replace(/"/g, '\\"') %>",
    "publisher": {
      "@type": "Organization",
      "name": "RTAUTOBOT",
      "logo": {
        "@type": "ImageObject",
        "url": "https://rtautobot.com/static/logo/logo-rtautobot.png"
      }
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://rtautobot.com/search?q={search_term}",
      "query-input": "required name=search_term"
    }
  }
  </script>

  <!-- Optional: Page-level Breadcrumb (ถ้าหน้าไหนส่ง breadcrumbJsonLd มา) -->
  <% if (typeof breadcrumbJsonLd !== 'undefined' && breadcrumbJsonLd) { %>
    <script type="application/ld+json">
    <%- breadcrumbJsonLd %>
    </script>
  <% } %>

  <!-- Optional: Page-level Service/Product structured data -->
  <% if (typeof structuredDataJsonLd !== 'undefined' && structuredDataJsonLd) { %>
    <script type="application/ld+json">
    <%- structuredDataJsonLd %>
    </script>
  <% } %>

  <!-- Cloudflare Turnstile (global) -->
  <script>
    window.onTurnstileLoad = function () {
      window.dispatchEvent(new Event('turnstile-ready'));
    };
  </script>
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit&onload=onTurnstileLoad" async defer></script>

  <!-- THEME MANAGER: แหล่งความจริงเดียว -->
  <script>
  (function () {
    const html = document.documentElement;

    function applyTheme(name) {
      const t = (name === 'dark') ? 'dark' : 'light';
      html.setAttribute('data-theme', t);
      html.classList.toggle('light', t === 'light');
      html.classList.toggle('dark',  t === 'dark');
      try { html.style.colorScheme = (t === 'dark') ? 'dark' : 'light'; } catch(e){}

      if (document.body) {
        document.body.removeAttribute('data-theme');
        document.body.classList.remove('dark','light');
      } else {
        document.addEventListener('DOMContentLoaded', () => {
          document.body.removeAttribute('data-theme');
          document.body.classList.remove('dark','light');
        }, {once:true});
      }
      localStorage.setItem('theme', t);
      window.dispatchEvent(new CustomEvent('themechange', { detail:{ theme:t } }));
    }

    let t = localStorage.getItem('theme');

    // ค่าเริ่มต้นของเว็บ = Dark Mode เสมอ
    // แต่ถ้าผู้ใช้เคยเลือกธีมไว้แล้ว ให้เคารพค่าที่บันทึกใน localStorage
    if (!t) t = 'dark';

    applyTheme(t);

    window.setTheme   = (name) => applyTheme(name);
    window.toggleTheme= () => {
      const cur  = html.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
      const next = cur === 'dark' ? 'light' : 'dark';
      applyTheme(next);
      return next;
    };
  })();
  </script>

  <!-- CSS หลัก -->
  <link rel="stylesheet" href="/static/css/styles.css?v=46">

  <!-- ช่องให้หน้าอื่น inject meta เพิ่ม (เช่น noindex, custom og ฯลฯ) -->
  <%- typeof extraHead !== 'undefined' ? extraHead : '' %>


  <style id="rtsmm-sidebar-enterprise-style-fix">
    /* ==========================================================
      RTSMM Sidebar Enterprise Skin Override
      - คงโครงสร้างเดิม แต่แก้เฉพาะงานตกแต่ง/สถานะ responsive
      - รองรับ light/dark ผ่านตัวแปรจาก layout
    ========================================================== */
    :root{
      --sbx-page: var(--page, #08090d);
      --sbx-card: var(--card, #15161b);
      --sbx-text: var(--text, #fff6e6);
      --sbx-muted: var(--muted, #d9cda9);
      --sbx-border: var(--border, rgba(255,255,255,.10));
      --sbx-accent: var(--accent, #f4c95d);
      --sbx-gold: #f6cf69;
      --sbx-blue: #38a7ff;
      --sbx-shadow: 0 22px 60px rgba(0,0,0,.42);
    }

    html[data-theme="light"]{
      --sbx-page: var(--page, #f6f8fc);
      --sbx-card: var(--card, #ffffff);
      --sbx-text: var(--text, #171923);
      --sbx-muted: var(--muted, #6b6474);
      --sbx-border: var(--border, rgba(13,18,32,.12));
      --sbx-shadow: 0 22px 54px rgba(23,28,45,.14);
    }

    .sidebar{
      background:
        radial-gradient(420px 280px at 8% 0%, color-mix(in srgb, var(--sbx-accent) 16%, transparent), transparent 58%),
        linear-gradient(180deg, color-mix(in srgb, var(--sbx-card) 94%, #111318), color-mix(in srgb, var(--sbx-page) 96%, #050507));
      border-right: 1px solid color-mix(in srgb, var(--sbx-border) 88%, transparent);
      box-shadow: var(--sbx-shadow);
      color: var(--sbx-text);
      backdrop-filter: blur(20px) saturate(130%);
      -webkit-backdrop-filter: blur(20px) saturate(130%);
      font-weight: 560;
      transition: width .28s cubic-bezier(.2,.8,.2,1), transform .28s cubic-bezier(.2,.8,.2,1), box-shadow .28s ease, background .28s ease;
    }

    .sb-head{
      padding: 12px 10px;
      gap: 10px;
      border-bottom: 1px solid color-mix(in srgb, var(--sbx-border) 72%, transparent);
      background: linear-gradient(180deg, color-mix(in srgb, var(--sbx-accent) 9%, transparent), transparent);
    }

    .sb-brand{
      min-height: 54px;
      padding: 8px 12px;
      border-radius: 18px;
      background:
        linear-gradient(135deg, color-mix(in srgb, var(--sbx-card) 92%, transparent), color-mix(in srgb, var(--sbx-accent) 9%, transparent)),
        color-mix(in srgb, var(--sbx-card) 96%, transparent);
      border: 1px solid color-mix(in srgb, var(--sbx-border) 90%, transparent);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.06), 0 14px 32px rgba(0,0,0,.20);
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform .22s ease, border-color .22s ease, box-shadow .22s ease, background .22s ease;
    }

    .sb-brand:hover{
      transform: translateY(-1px);
      border-color: color-mix(in srgb, var(--sbx-accent) 45%, var(--sbx-border));
      box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 18px 38px rgba(0,0,0,.26), 0 0 0 4px color-mix(in srgb, var(--sbx-accent) 7%, transparent);
    }

    .sb-brand .brand-icon{
      width: 30px;
      height: 30px;
      object-fit: contain;
      flex: 0 0 auto;
      filter: drop-shadow(0 0 10px color-mix(in srgb, var(--sbx-accent) 30%, transparent));
    }

    .sb-brand .brand-wordmark{
      width: auto;
      max-width: 146px;
      height: 40px;
      object-fit: contain;
      flex: 0 1 auto;
      opacity: 1;
      transform: translateX(0);
      transition: opacity .22s ease, transform .22s ease, max-width .22s ease;
      filter: drop-shadow(0 8px 18px rgba(0,0,0,.24));
    }

    .sb-pin{
      width: 44px;
      height: 44px;
      border-radius: 16px;
      border: 1px solid color-mix(in srgb, var(--sbx-border) 90%, transparent);
      background:
        radial-gradient(circle at 35% 25%, color-mix(in srgb, var(--sbx-blue) 20%, transparent), transparent 42%),
        color-mix(in srgb, var(--sbx-card) 90%, transparent);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 12px 28px rgba(0,0,0,.20);
      transition: transform .2s ease, border-color .2s ease, background .2s ease;
    }

    .sb-pin:hover{
      transform: translateY(-1px) scale(1.02);
      border-color: color-mix(in srgb, var(--sbx-accent) 48%, var(--sbx-border));
      background: color-mix(in srgb, var(--sbx-accent) 11%, var(--sbx-card));
    }

    .sb-list{
      padding: 16px 10px 22px;
      scrollbar-width: thin;
      scrollbar-color: color-mix(in srgb, var(--sbx-accent) 48%, transparent) transparent;
    }

    .sb-group{
      margin: 16px 6px 8px;
      color: color-mix(in srgb, var(--sbx-accent) 78%, var(--sbx-muted));
      font-size: 12px;
      line-height: 1.2;
      letter-spacing: .03em;
      font-weight: 350;
      opacity: .92;
      text-shadow: 0 1px 0 rgba(0,0,0,.16);
      transition: opacity .22s ease, transform .22s ease;
    }

    .sb-item{
      position: relative;
      min-height: 44px;
      border-radius: 16px;
      color: var(--sbx-text) !important;
      font-weight: 610;
      letter-spacing: -.01em;
      border: 1px solid transparent;
      background: transparent;
      overflow: hidden;
      transition: transform .2s ease, background .2s ease, border-color .2s ease, box-shadow .2s ease, color .2s ease;
    }

    .sb-item::before{
      content:"";
      position:absolute;
      inset:0;
      background: linear-gradient(90deg, color-mix(in srgb, var(--sbx-accent) 18%, transparent), transparent 70%);
      opacity:0;
      transition: opacity .2s ease;
      pointer-events:none;
    }

    .sb-item:hover{
      transform: translateX(2px);
      background: color-mix(in srgb, var(--sbx-card) 78%, transparent);
      border-color: color-mix(in srgb, var(--sbx-border) 84%, transparent);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.05), 0 12px 24px rgba(0,0,0,.16);
    }

    .sb-item:hover::before{ opacity:1; }

    .sb-item.active{
      color: color-mix(in srgb, var(--sbx-text) 95%, #fff) !important;
      background:
        linear-gradient(90deg, color-mix(in srgb, var(--sbx-accent) 22%, transparent), color-mix(in srgb, var(--sbx-card) 74%, transparent));
      border-color: color-mix(in srgb, var(--sbx-accent) 62%, var(--sbx-border));
      box-shadow: inset 3px 0 0 color-mix(in srgb, var(--sbx-accent) 95%, #fff), 0 14px 30px rgba(0,0,0,.22), 0 0 0 4px color-mix(in srgb, var(--sbx-accent) 6%, transparent);
    }

    .sb-item .ico{
      width: 20px;
      height: 20px;
      object-fit: contain;
      flex: 0 0 auto;
      filter: drop-shadow(0 8px 12px rgba(0,0,0,.26));
      transition: transform .2s ease, filter .2s ease;
    }

    .sb-item:hover .ico,
    .sb-item.active .ico{
      transform: translateY(-1px) scale(1.06);
      filter: drop-shadow(0 0 10px color-mix(in srgb, var(--sbx-accent) 28%, transparent));
    }

    .sb-item .txt{
      min-width: 0;
      white-space: nowrap;
      font-weight: 310;
      transition: opacity .18s ease, transform .18s ease;
    }

    @media (min-width: 901px){
      .sidebar:not(.open):not(.pinned):not(:hover) .sb-brand{
        padding-left: 8px;
        padding-right: 8px;
      }
      .sidebar:not(.open):not(.pinned):not(:hover) .sb-brand .brand-wordmark{
        max-width: 0;
        opacity: 0;
        transform: translateX(-6px);
        pointer-events: none;
      }
      .sidebar:not(.open):not(.pinned):not(:hover) .sb-group{
        opacity: 0;
        height: 0;
        margin: 8px 0 0;
        overflow: hidden;
        transform: translateX(-4px);
      }
      .sidebar:not(.open):not(.pinned):not(:hover) .sb-item{
        justify-content: center;
      }
      .sidebar:not(.open):not(.pinned):not(:hover) .sb-item .txt{
        opacity: 0;
        width: 0;
        transform: translateX(-6px);
        overflow: hidden;
      }
    }

    @media (max-width: 900px){
      body.sb-open{ overflow: hidden; }
      body.sb-open::before{
        content:"";
        position: fixed;
        inset: 0;
        z-index: 89;
        background: rgba(0,0,0,.58);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        animation: sbxFade .22s ease both;
      }

      .sidebar{
        position: fixed;
        z-index: 90;
        top: 0;
        left: 0;
        width: min(286px, calc(100vw - 36px));
        max-width: min(286px, calc(100vw - 36px));
        height: 100dvh;
        transform: translateX(-108%);
        visibility: hidden;
        pointer-events: none;
        border-right: 1px solid color-mix(in srgb, var(--sbx-accent) 24%, var(--sbx-border));
        box-shadow: 28px 0 70px rgba(0,0,0,.48);
      }

      .sidebar.open{
        transform: translateX(0);
        visibility: visible;
        pointer-events: auto;
      }

      .sidebar.pinned:not(.open){
        transform: translateX(-108%);
        visibility: hidden;
        pointer-events: none;
      }

      .sidebar.open .sb-head{
        padding: 12px 10px;
      }

      .sidebar.open .sb-brand{
        min-height: 54px;
        justify-content: flex-start;
        padding: 8px 12px;
      }

      .sidebar.open .sb-brand .brand-wordmark{
        max-width: 148px;
        height: 40px;
        opacity: 1;
        transform: none;
      }

      .sidebar.open .sb-group{
        display: block;
        opacity: .96;
        height: auto;
        margin: 16px 6px 8px;
        transform: none;
      }

      .sidebar.open .sb-item{
        justify-content: flex-start;
      }

      .sidebar.open .sb-item .txt{
        display: inline;
        width: auto;
        opacity: 1;
        transform: none;
        overflow: visible;
      }
    }

    @keyframes sbxFade{from{opacity:0}to{opacity:1}}
  

    /* =========================================================
       ENTERPRISE MENU POLISH — style-only upgrade + mobile fix
       - Keeps original structure/layout intent
       - Makes responsive sidebar readable, closable, and non-stuck
       ========================================================= */
    :root{
      --rt-menu-glow: color-mix(in srgb, var(--sbx-accent) 28%, transparent);
      --rt-menu-ink: color-mix(in srgb, var(--text) 94%, #fff 6%);
      --rt-menu-muted: color-mix(in srgb, var(--muted) 82%, var(--text) 18%);
    }

    .sb-head{
      padding: 10px 10px;
      background:
        radial-gradient(circle at 12% 0%, color-mix(in srgb, var(--sbx-accent) 16%, transparent), transparent 42%),
        linear-gradient(180deg, color-mix(in srgb, var(--card) 94%, transparent), color-mix(in srgb, var(--page) 88%, transparent));
    }

    .sb-brand{
      min-height: 58px;
      padding: 7px 13px;
      border-radius: 19px;
      background:
        linear-gradient(135deg, color-mix(in srgb, var(--card) 94%, transparent), color-mix(in srgb, var(--accent) 10%, var(--page))),
        color-mix(in srgb, var(--page) 88%, transparent);
      border-color: color-mix(in srgb, var(--accent) 21%, var(--border));
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.075),
        inset 0 -20px 34px rgba(0,0,0,.10),
        0 16px 38px rgba(0,0,0,.24);
    }
    .sb-brand .brand-wordmark{
      width: auto;
      max-width: 168px;
      height: 43px;
      object-fit: contain;
      filter: drop-shadow(0 8px 16px rgba(0,0,0,.32));
    }
    .sb-pin{
      background:
        radial-gradient(circle at 50% 22%, color-mix(in srgb, var(--blue) 26%, transparent), transparent 44%),
        linear-gradient(180deg, color-mix(in srgb, var(--card) 96%, transparent), color-mix(in srgb, var(--page) 92%, transparent));
      border-color: color-mix(in srgb, var(--accent) 25%, var(--border));
      box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 10px 26px rgba(0,0,0,.22);
    }
    .sb-pin:hover{ box-shadow: inset 0 1px 0 rgba(255,255,255,.1), 0 0 0 4px color-mix(in srgb, var(--accent) 10%, transparent), 0 14px 30px rgba(0,0,0,.28); }

    .sb-group{
      color: color-mix(in srgb, var(--accent) 74%, var(--text));
      letter-spacing: .02em;
      font-weight: 350;
      opacity: .96;
      text-shadow: 0 0 18px color-mix(in srgb, var(--accent) 14%, transparent);
    }
    .sb-link{
      font-weight: 620;
      color: var(--rt-menu-ink);
      border-color: transparent;
      background: transparent;
      position: relative;
      overflow: hidden;
    }
    .sb-link::before{
      content:"";
      position:absolute;
      inset: 7px auto 7px 7px;
      width: 3px;
      border-radius: 999px;
      background: linear-gradient(180deg, var(--accent), color-mix(in srgb, var(--accent) 35%, transparent));
      opacity: 0;
      transform: scaleY(.45);
      transition: opacity .18s ease, transform .18s ease;
    }
    .sb-link:hover,
    .sb-link.active{
      background:
        radial-gradient(circle at 18% 50%, color-mix(in srgb, var(--accent) 20%, transparent), transparent 48%),
        linear-gradient(135deg, color-mix(in srgb, var(--accent) 13%, var(--card)), color-mix(in srgb, var(--card) 96%, transparent));
      border-color: color-mix(in srgb, var(--accent) 42%, var(--border));
      box-shadow: inset 0 1px 0 rgba(255,255,255,.07), 0 10px 26px rgba(0,0,0,.18);
      color: color-mix(in srgb, var(--text) 96%, var(--accent));
    }
    .sb-link:hover::before,
    .sb-link.active::before{ opacity:1; transform:scaleY(1); }
    .sb-link .ico{
      filter: drop-shadow(0 8px 12px rgba(0,0,0,.22));
      transition: transform .2s ease, filter .2s ease;
    }
    .sb-link:hover .ico{ transform: translateY(-1px) scale(1.04); filter: drop-shadow(0 0 12px color-mix(in srgb, var(--blue) 34%, transparent)); }

    /* Top navigation: high-end glass treatment without changing markup */
    .topbar{
      background:
        radial-gradient(circle at 8% 0%, color-mix(in srgb, var(--accent) 12%, transparent), transparent 42%),
