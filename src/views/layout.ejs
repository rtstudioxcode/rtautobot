  <style id="rtsmm-global-uiconfirm-enterprise">
    /* =========================================================
       RTSMM Global UIConfirm — Enterprise High-end
       ใช้แทน window.confirm แบบ native dialog
    ========================================================= */
    :root{
      --uic-page: var(--page, #07080c);
      --uic-card: var(--card, #18191f);
      --uic-text: var(--text, #fff6e6);
      --uic-muted: var(--muted, #d9cda9);
      --uic-border: var(--border, rgba(255,255,255,.12));
      --uic-accent: var(--accent, #f4c95d);
      --uic-danger: #ff5d64;
      --uic-success: #35d38a;
      --uic-shadow: rgba(0,0,0,.58);

      --rt-page: var(--page, #07080b);
      --rt-card: var(--card, #17181d);
      --rt-card-2: color-mix(in srgb, var(--card, #17181d) 72%, #0a0b10);
      --rt-soft: color-mix(in srgb, var(--card, #17181d) 84%, #ffffff 4%);
      --rt-text: var(--text, #fff4df);
      --rt-muted: var(--muted, #d9c895);
      --rt-border: var(--border, rgba(255,255,255,.12));
      --rt-accent: var(--accent, #f8d66b);
      --rt-accent-2: #d59a25;
      --rt-green: #33e889;
      --rt-blue: #4eb7ff;
      --rt-red: #ff6b7e;
      --rt-shadow: rgba(0,0,0,.48);
      --rt-radius-xl: 34px;
      --rt-radius-lg: 26px;
      --rt-radius-md: 18px;
    }

    html[data-theme="light"]{
      --uic-page: var(--page, #f6f8fc);
      --uic-card: var(--card, #ffffff);
      --uic-text: var(--text, #171923);
      --uic-muted: var(--muted, #6b6474);
      --uic-border: var(--border, rgba(13,18,32,.12));
      --uic-shadow: rgba(23,28,45,.22);
    }

    .uic-overlay{
      position:fixed;
      inset:0;
      z-index:2147483646;
      display:grid;
      place-items:center;
      padding:22px;
      background:
        radial-gradient(680px 360px at 25% 15%, color-mix(in srgb,var(--uic-accent) 20%, transparent), transparent 68%),
        radial-gradient(620px 320px at 78% 88%, rgba(65,116,255,.16), transparent 70%),
        rgba(0,0,0,.68);
      backdrop-filter:blur(18px) saturate(125%);
      -webkit-backdrop-filter:blur(18px) saturate(125%);
      opacity:0;
      pointer-events:none;
      transition:opacity .22s ease;
    }

    html[data-theme="light"] .uic-overlay{
      background:
        radial-gradient(680px 360px at 25% 15%, color-mix(in srgb,var(--uic-accent) 20%, transparent), transparent 68%),
        radial-gradient(620px 320px at 78% 88%, rgba(65,116,255,.12), transparent 70%),
        rgba(245,247,252,.66);
    }

    .uic-overlay.show{
      opacity:1;
      pointer-events:auto;
    }

    .uic-card{
      position:relative;
      width:min(520px, calc(100vw - 32px));
      overflow:hidden;
      border-radius:30px;
      border:1px solid color-mix(in srgb,var(--uic-accent) 34%,var(--uic-border));
      color:var(--uic-text);
      background:
        linear-gradient(135deg, color-mix(in srgb,var(--uic-card) 96%,#fff 3%), color-mix(in srgb,var(--uic-page) 88%,#000 12%)),
        var(--uic-card);
      box-shadow:
        0 34px 100px var(--uic-shadow),
        inset 0 1px 0 rgba(255,255,255,.10);
      transform:translateY(18px) scale(.965);
      opacity:0;
      transition:transform .28s cubic-bezier(.2,.9,.2,1), opacity .22s ease;
      isolation:isolate;
    }

    .uic-overlay.show .uic-card{
      transform:translateY(0) scale(1);
      opacity:1;
    }

    .uic-card::before{
      content:"";
      position:absolute;
      inset:0 0 auto 0;
      height:4px;
      background:linear-gradient(90deg,var(--uic-accent),#ffe7a3,rgba(122,94,255,.9),var(--uic-accent));
      background-size:220% 100%;
      animation:uicGoldFlow 4.8s ease-in-out infinite;
      z-index:2;
    }

    .uic-card::after{
      content:"";
      position:absolute;
      width:320px;
      height:320px;
      right:-160px;
      top:-170px;
      border-radius:999px;
      background:color-mix(in srgb,var(--uic-accent) 18%, transparent);
      filter:blur(26px);
      pointer-events:none;
      z-index:-1;
    }

    .uic-body{
      padding:30px;
      display:grid;
      gap:18px;
    }

    .uic-head{
      display:flex;
      gap:16px;
      align-items:flex-start;
    }

    .uic-icon{
      width:58px;
      height:58px;
      border-radius:20px;
      display:grid;
      place-items:center;
      flex:0 0 auto;
      color:#1b1408;
      background:linear-gradient(135deg,#fff0a8,var(--uic-accent),#b87f22);
      box-shadow:0 18px 42px color-mix(in srgb,var(--uic-accent) 26%, transparent), inset 0 1px 0 rgba(255,255,255,.55);
      font-size:26px;
      animation:uicIconFloat 2.7s ease-in-out infinite;
    }

    .uic-copy{min-width:0}
    .uic-kicker{
      display:inline-flex;
      align-items:center;
      gap:7px;
      margin-bottom:8px;
      padding:6px 10px;
      border-radius:999px;
      border:1px solid color-mix(in srgb,var(--uic-accent) 42%,var(--uic-border));
      color:var(--uic-accent);
      background:color-mix(in srgb,var(--uic-accent) 10%, transparent);
      font-size:11px;
      font-weight:950;
      letter-spacing:.08em;
      text-transform:uppercase;
    }

    .uic-title{
      margin:0;
      font-size:clamp(22px,3vw,30px);
      line-height:1.14;
      letter-spacing:-.04em;
      color:var(--uic-text);
      font-weight:950;
    }

    .uic-message{
      margin:10px 0 0;
      color:var(--uic-muted);
      font-weight:700;
      line-height:1.75;
      font-size:14px;
      white-space:pre-wrap;
    }

    .uic-actions{
      display:flex;
      justify-content:flex-end;
      gap:10px;
      flex-wrap:wrap;
      padding-top:6px;
    }

    .uic-btn{
      min-height:46px;
      border:0;
      border-radius:16px;
      padding:0 20px;
      font:inherit;
      font-weight:950;
      cursor:pointer;
      transition:transform .18s ease, box-shadow .18s ease, filter .18s ease, opacity .18s ease;
    }

    .uic-btn:hover{transform:translateY(-1px)}
    .uic-btn:active{transform:translateY(0) scale(.99)}
    .uic-btn.cancel{
      color:var(--uic-text);
      background:linear-gradient(180deg,color-mix(in srgb,var(--uic-card) 86%,#fff 4%),color-mix(in srgb,var(--uic-page) 86%,#000 8%));
      border:1px solid color-mix(in srgb,var(--uic-border) 88%,transparent);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.06),0 12px 28px rgba(0,0,0,.18);
    }

    .uic-btn.confirm{
      color:#171005;
      background:linear-gradient(135deg,#ffe593,var(--uic-accent),#bf8526);
      box-shadow:0 18px 42px color-mix(in srgb,var(--uic-accent) 28%,transparent), inset 0 1px 0 rgba(255,255,255,.52);
    }

    .uic-btn.danger{
      color:#fff;
      background:linear-gradient(135deg,#ff8d8d,var(--uic-danger),#a71925);
      box-shadow:0 18px 42px rgba(255,74,84,.25), inset 0 1px 0 rgba(255,255,255,.32);
    }

    .uic-btn.success{
      color:#06170f;
      background:linear-gradient(135deg,#8dffc5,var(--uic-success),#13975b);
      box-shadow:0 18px 42px rgba(53,211,138,.22), inset 0 1px 0 rgba(255,255,255,.34);
    }

    .uic-close{
      position:absolute;
      top:16px;
      right:16px;
      width:42px;
      height:42px;
      border-radius:15px;
      border:1px solid color-mix(in srgb,var(--uic-border) 80%,transparent);
      background:rgba(255,255,255,.055);
      color:var(--uic-text);
      display:grid;
      place-items:center;
      cursor:pointer;
      font-size:22px;
      font-weight:950;
      transition:transform .18s ease, background .18s ease, border-color .18s ease;
    }

    .uic-close:hover{
      transform:translateY(-1px) rotate(4deg);
      background:color-mix(in srgb,var(--uic-danger) 14%,transparent);
      border-color:color-mix(in srgb,var(--uic-danger) 36%,var(--uic-border));
    }

    body.uic-open{overflow:hidden!important}

    @keyframes uicGoldFlow{
      0%,100%{background-position:0% 50%}
      50%{background-position:100% 50%}
    }

    @keyframes uicIconFloat{
      0%,100%{transform:translateY(0)}
      50%{transform:translateY(-3px)}
    }

    @media (max-width:560px){
      .uic-overlay{padding:14px}
      .uic-body{padding:26px 20px 20px}
      .uic-head{display:grid;gap:14px;text-align:center;justify-items:center}
      .uic-actions{display:grid;grid-template-columns:1fr;gap:9px}
      .uic-btn{width:100%}
    }

    @media (prefers-reduced-motion: reduce){
      .uic-card,.uic-overlay,.uic-btn,.uic-close{transition:none!important}
      .uic-card::before,.uic-icon{animation:none!important}
    }

    .rt-footer{border-top:1px solid var(--rt-border);padding:20px 0;color:var(--rt-muted);text-align: center;font-size:14px;font-weight:400}.rt-footer .rt-wrap{display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap}
  </style>



  <style id="rt-sidebar-center-compact-final-patch">
  /* =========================================================
     FINAL SIDEBAR ALIGNMENT PATCH
