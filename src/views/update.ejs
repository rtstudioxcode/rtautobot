<% const PAGE_TITLE = title || "อัปเดตบริการ"; %>

<section class="upd-enterprise" aria-label="<%= PAGE_TITLE %>">
  <div class="upd-bg" aria-hidden="true">
    <span class="orb orb-a"></span>
    <span class="orb orb-b"></span>
    <span class="orb orb-c"></span>
  </div>

  <section class="upd-hero">
    <div class="hero-copy">
      <div class="hero-kicker"><span>✦</span> Services Update</div>
      <h1><%= PAGE_TITLE %></h1>
      <p>ติดตามความเปลี่ยนแปลงของบริการแบบวันต่อวัน เห็นสถานะเปิด–ปิด รายการใหม่ และการอัปเดตสำคัญ</p>
    </div>

    <div class="hero-actions">
      <button id="btnRefresh" class="upd-btn upd-btn-primary" type="button">
        <span class="btn-ico">↻</span>
        <span>รีเฟรชข้อมูล</span>
      </button>
    </div>
  </section>

  <section class="upd-metrics" aria-label="สรุปสถานะอัปเดต">
    <article class="metric-card">
      <span class="metric-ico">🛰️</span>
      <div>
        <strong id="metricTotal">0</strong>
        <small>รายการอัปเดตล่าสุด</small>
      </div>
    </article>
    <article class="metric-card">
      <span class="metric-ico">✅</span>
      <div>
        <strong id="metricOpen">0</strong>
        <small>เปิดใช้งาน</small>
      </div>
    </article>
    <article class="metric-card">
      <span class="metric-ico">⛔</span>
      <div>
        <strong id="metricClose">0</strong>
        <small>ปิด/นำออก</small>
      </div>
    </article>
    <article class="metric-card">
      <span class="metric-ico">🆕</span>
      <div>
        <strong id="metricNew">0</strong>
        <small>บริการใหม่</small>
      </div>
    </article>
  </section>

  <section class="upd-card" id="updatesCard">
    <div class="upd-card-head">
      <div>
        <div class="head-kicker">Latest service changes</div>
        <h3 class="title">รายการอัปเดต (วันล่าสุด)</h3>
      </div>
      <div class="head-right">
        <span class="live-dot"></span>
        <span id="foot" class="muted">กำลังโหลด…</span>
      </div>
    </div>

    <!-- Desktop table -->
    <div class="upd-desktop">
      <div class="table-wrap">
        <table class="upd-table zebra">
          <thead>
            <tr>
              <th style="width:100px">ID</th>
              <th>ชื่อบริการ / หมวดหมู่</th>
              <th style="width:330px">สิ่งที่ได้รับการอัปเดต</th>
              <th style="width:180px">วันที่</th>
            </tr>
          </thead>
          <tbody id="updTbody"><!-- filled by JS --></tbody>
        </table>
      </div>
    </div>

    <!-- Mobile cards -->
    <div class="upd-mobile" id="upCards"><!-- filled by JS --></div>
  </section>
</section>

