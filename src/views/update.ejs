========================================================= */
.upd-enterprise{
  --ue-page:var(--page,#080b12);
  --ue-card:var(--card,#111827);
  --ue-text:var(--text,#f8fafc);
  --ue-muted:var(--muted,#94a3b8);
  --ue-border:var(--border,rgba(255,255,255,.10));
  --ue-accent:var(--accent,#08b84f);
  --ue-accent-2:#08b84f;
  --ue-soft:color-mix(in srgb,var(--ue-card) 82%,transparent);
  --ue-soft-2:color-mix(in srgb,var(--ue-card) 66%,transparent);
  --ue-shadow:rgba(0,0,0,.30);
  --ue-success:#22c55e;
  --ue-danger:#ef4444;
  --ue-info:#60a5fa;
  --ue-warning:#00b84a;
  position:relative;
  isolation:isolate;
  color:var(--ue-text);
  display:grid;
  gap:18px;
  animation:ueFadeUp .5s ease both;
}
html[data-theme="light"] .upd-enterprise,
html.light .upd-enterprise,
body.light .upd-enterprise{
  --ue-page:var(--page,#f6f7fb);
  --ue-card:var(--card,#ffffff);
  --ue-text:var(--text,#111827);
  --ue-muted:var(--muted,#64748b);
  --ue-border:var(--border,#e5e7eb);
  --ue-soft:rgba(255,255,255,.78);
  --ue-soft-2:rgba(255,255,255,.92);
  --ue-shadow:rgba(15,23,42,.10);
}
.upd-bg{position:absolute;inset:-30px;z-index:-1;overflow:hidden;pointer-events:none;border-radius:34px;}
.upd-bg .orb{position:absolute;border-radius:999px;filter:blur(6px);opacity:.42;animation:ueFloat 8s ease-in-out infinite;}
.upd-bg .orb-a{width:270px;height:270px;right:4%;top:-70px;background:radial-gradient(circle,var(--ue-accent),transparent 68%);}
.upd-bg .orb-b{width:210px;height:210px;left:-70px;top:190px;background:radial-gradient(circle,#60a5fa,transparent 70%);animation-delay:-2.2s;}
.upd-bg .orb-c{width:160px;height:160px;right:18%;bottom:-80px;background:radial-gradient(circle,#22c55e,transparent 70%);animation-delay:-4s;}

.upd-hero{
  position:relative;
  overflow:hidden;
  border:1px solid var(--ue-border);
  border-radius:30px;
  padding:28px;
  background:
    linear-gradient(135deg,color-mix(in srgb,var(--ue-accent) 13%,transparent),transparent 36%),
    linear-gradient(180deg,rgba(255,255,255,.055),rgba(255,255,255,.018)),
    color-mix(in srgb,var(--ue-card) 90%,transparent);
  box-shadow:0 22px 55px var(--ue-shadow),inset 0 1px 0 rgba(255,255,255,.08);
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:22px;
  backdrop-filter:blur(16px);
}
.upd-hero::after{content:"";position:absolute;inset:0;background:linear-gradient(110deg,transparent 0 40%,rgba(255,255,255,.08),transparent 62%);transform:translateX(-120%);animation:ueShine 6s ease-in-out infinite;pointer-events:none;}
.hero-copy{max-width:820px;position:relative;z-index:1;}
.hero-kicker,.head-kicker{display:inline-flex;align-items:center;gap:8px;color:var(--ue-accent-2);font-size:12px;font-weight:900;letter-spacing:.14em;text-transform:uppercase;margin-bottom:8px;}
.upd-hero h1{margin:0;font-size:clamp(26px,4vw,46px);line-height:1.05;font-weight:950;letter-spacing:-.04em;}
.upd-hero p{margin:12px 0 0;color:var(--ue-muted);font-size:15px;line-height:1.75;max-width:760px;}
.hero-actions{position:relative;z-index:1;display:flex;gap:10px;flex-wrap:wrap;}
.upd-btn{height:46px;border:1px solid var(--ue-border);border-radius:16px;padding:0 18px;display:inline-flex;align-items:center;justify-content:center;gap:9px;cursor:pointer;font-weight:900;transition:.2s ease;background:var(--ue-soft);color:var(--ue-text);}
.upd-btn-primary{border:0;color:#17130a;background:linear-gradient(135deg,#08b84f,#08b84f 55%,#05b84f);box-shadow:0 14px 30px color-mix(in srgb,var(--ue-accent) 24%,transparent),inset 0 1px 0 rgba(255,255,255,.48);}
.upd-btn:hover{transform:translateY(-2px);filter:saturate(1.05);}
.upd-btn:disabled{opacity:.65;cursor:wait;transform:none;}
.upd-btn:disabled .btn-ico{animation:ueSpin 1s linear infinite;}

.upd-metrics{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px;}
.metric-card{border:1px solid var(--ue-border);border-radius:22px;padding:16px;background:linear-gradient(180deg,rgba(255,255,255,.045),rgba(255,255,255,.014)),var(--ue-soft);box-shadow:0 16px 36px var(--ue-shadow),inset 0 1px 0 rgba(255,255,255,.06);display:flex;align-items:center;gap:14px;min-width:0;transition:.2s ease;}
.metric-card:hover{transform:translateY(-2px);}
.metric-ico{width:44px;height:44px;border-radius:16px;display:grid;place-items:center;background:color-mix(in srgb,var(--ue-accent) 18%,transparent);border:1px solid color-mix(in srgb,var(--ue-accent) 28%,transparent);font-size:22px;box-shadow:inset 0 1px 0 rgba(255,255,255,.06);}
.metric-card strong{display:block;font-size:24px;line-height:1;font-weight:950;letter-spacing:-.03em;}
.metric-card small{display:block;margin-top:5px;color:var(--ue-muted);font-size:12px;font-weight:800;}

.upd-card{border:1px solid var(--ue-border);border-radius:28px;background:linear-gradient(180deg,rgba(255,255,255,.05),rgba(255,255,255,.018)),color-mix(in srgb,var(--ue-card) 90%,transparent);box-shadow:0 22px 55px var(--ue-shadow),inset 0 1px 0 rgba(255,255,255,.06);overflow:hidden;}
.upd-card-head{padding:20px 22px;border-bottom:1px solid var(--ue-border);display:flex;align-items:center;justify-content:space-between;gap:16px;background:linear-gradient(135deg,color-mix(in srgb,var(--ue-accent) 9%,transparent),transparent 52%);}
.upd-card-head h3{margin:0;font-size:20px;font-weight:950;letter-spacing:-.02em;}
.head-right{display:inline-flex;align-items:center;gap:9px;padding:9px 12px;border-radius:999px;background:var(--ue-soft);border:1px solid var(--ue-border);font-size:12px;font-weight:800;white-space:nowrap;}
.live-dot{width:8px;height:8px;border-radius:50%;background:var(--ue-success);box-shadow:0 0 0 6px color-mix(in srgb,var(--ue-success) 18%,transparent);animation:uePulse 1.8s ease-in-out infinite;}
.muted{color:var(--ue-muted)!important;}

.table-wrap{max-height:calc(100vh - 290px);min-height:360px;overflow:auto;}
.upd-table{width:100%;border-collapse:separate;border-spacing:0;font-size:14px;}
.upd-table thead th{text-align:left;font-weight:900;font-size:12px;letter-spacing:.06em;text-transform:uppercase;color:var(--ue-muted);padding:14px 16px;position:sticky;top:0;background:color-mix(in srgb,var(--ue-card) 94%,transparent);border-bottom:1px solid var(--ue-border);z-index:2;backdrop-filter:blur(10px);}
.upd-table td{padding:15px 16px;border-bottom:1px solid color-mix(in srgb,var(--ue-border) 78%,transparent);vertical-align:top;transition:.16s ease;background:color-mix(in srgb,var(--ue-card) 78%,transparent);}
.upd-table.zebra tbody tr:nth-child(even) td{background:color-mix(in srgb,var(--ue-card) 88%,rgba(255,255,255,.04));}
.upd-table.zebra tbody tr:hover td{background:color-mix(in srgb,var(--ue-accent) 8%,var(--ue-card));}
.upd-table.zebra tbody tr:hover td:first-child{box-shadow:inset 3px 0 0 var(--ue-accent);}
.id-mono{font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-weight:900;color:color-mix(in srgb,var(--ue-text) 82%,var(--ue-muted));}
.dot{width:8px;height:8px;border-radius:50%;display:inline-block;background:var(--ue-accent);margin-right:8px;box-shadow:0 0 14px color-mix(in srgb,var(--ue-accent) 48%,transparent);}
.svc-ico{width:26px;height:26px;object-fit:contain;border-radius:9px;background:rgba(255,255,255,.06);padding:3px;border:1px solid var(--ue-border);}
.name-badge{font-size:10px;font-weight:950;letter-spacing:.08em;text-transform:uppercase;color:#17130a;background:linear-gradient(135deg,#08b84f,#08b84f);border-radius:999px;padding:4px 7px;margin-left:.5rem;white-space:nowrap;}
.chip{display:inline-flex;align-items:center;gap:.35rem;padding:5px 9px;font-size:11px;border-radius:999px;background:color-mix(in srgb,var(--ue-info) 16%,transparent);border:1px solid color-mix(in srgb,var(--ue-info) 35%,transparent);color:color-mix(in srgb,var(--ue-info) 80%,var(--ue-text));font-weight:900;}
