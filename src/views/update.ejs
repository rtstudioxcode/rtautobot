.pill.neutral{background:color-mix(in srgb,#94a3b8 16%,transparent);color:var(--ue-text);border-color:color-mix(in srgb,#94a3b8 28%,transparent);}

.upd-mobile{display:none;}
.u-card{border:1px solid var(--ue-border);border-radius:22px;background:linear-gradient(180deg,rgba(255,255,255,.045),rgba(255,255,255,.014)),var(--ue-soft);overflow:hidden;cursor:pointer;transition:.18s ease;box-shadow:0 12px 28px var(--ue-shadow);}
.u-card:hover{transform:translateY(-2px);}
.u-head{display:grid;grid-template-columns:1fr auto;gap:8px;padding:15px;border-bottom:1px dashed var(--ue-border);}
.u-id{font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-weight:950;color:var(--ue-accent-2);}
.u-name{font-weight:900;line-height:1.35;display:flex;align-items:center;gap:6px;flex-wrap:wrap;}
.u-meta{color:var(--ue-muted);font-size:12px;margin-top:5px;font-weight:700;}
.u-body{display:none;padding:14px 15px;}
.u-card.open .u-body{display:block;animation:ueFadeUp .22s ease both;}
.u-row{display:grid;grid-template-columns:110px 1fr;gap:10px;padding:9px 0;border-bottom:1px dotted var(--ue-border);}
.u-row:last-child{border-bottom:0;}
.u-label{color:var(--ue-muted);font-weight:900;font-size:12px;}

.table-wrap::-webkit-scrollbar,.upd-mobile::-webkit-scrollbar{width:8px;height:8px;}
.table-wrap::-webkit-scrollbar-thumb,.upd-mobile::-webkit-scrollbar-thumb{border-radius:999px;background:color-mix(in srgb,var(--ue-accent) 45%,transparent);}
.table-wrap::-webkit-scrollbar-track,.upd-mobile::-webkit-scrollbar-track{background:transparent;}

@media (max-width:1050px){.upd-metrics{grid-template-columns:repeat(2,minmax(0,1fr));}.upd-hero{align-items:flex-start;flex-direction:column;}.hero-actions{width:100%;}.upd-btn{width:100%;}}
@media (max-width:900px){.upd-desktop{display:none;}.upd-mobile{display:grid;gap:12px;padding:14px;}.table-wrap{min-height:0;}.upd-card-head{align-items:flex-start;flex-direction:column;}.head-right{width:100%;justify-content:center;}}
@media (max-width:560px){.upd-enterprise{gap:14px;}.upd-hero{padding:22px;border-radius:24px;}.upd-metrics{grid-template-columns:1fr;}.metric-card{padding:14px;border-radius:20px;}.upd-card{border-radius:24px;}.upd-card-head{padding:18px;}.u-row{grid-template-columns:1fr;gap:4px;}.name-badge{margin-left:0;}}
@media (prefers-reduced-motion:reduce){.upd-enterprise *,.upd-enterprise *::before,.upd-enterprise *::after{animation:none!important;transition:none!important;scroll-behavior:auto!important;}}
@keyframes ueFadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:none;}}
@keyframes ueFloat{0%,100%{transform:translateY(0) scale(1);}50%{transform:translateY(-18px) scale(1.04);}}
@keyframes ueShine{0%,55%{transform:translateX(-120%);}72%,100%{transform:translateX(120%);}}
@keyframes uePulse{0%,100%{opacity:.7;transform:scale(.9);}50%{opacity:1;transform:scale(1.05);}}
@keyframes ueSpin{to{transform:rotate(360deg);}}
</style>

