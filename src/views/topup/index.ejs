  }

  #qrModal.tp-qr-modal .tp-expire-line{
    padding-top:6px !important;
  }
}

@media (max-width: 980px){
  .tp-hero-content{ flex-direction:column; align-items:stretch; }
  .tp-layout{ grid-template-columns:1fr; }
  .tp-side-card{ position:relative; top:auto; }
  .tp-wallet-rail{ grid-template-columns:repeat(2,minmax(0,1fr)); }
  .tp-checkout-grid{ grid-template-columns:1fr; }
}
@media (max-width: 640px){
  .topup-enterprise{ padding-top:8px; }
  .tp-hero{ border-radius:24px; padding:22px; }
  .tp-hero-metrics{ grid-template-columns:1fr; }
  .tabs.tp-main-tabs{ gap:8px; padding:6px; border-radius:20px; }
  .tabs .tab{ padding:13px 10px; border-radius:15px; font-size:14px; }
  .tp-wallet-rail{ grid-template-columns:1fr; }
  .tp-payment-header{ flex-direction:column; align-items:stretch; }
  .tp-expire-badge{ width:100%; }
  .tp-quick-grid{ grid-template-columns:repeat(3,minmax(0,1fr)); }
  .d-desktop{ display:none!important; }
  .d-mobile{ display:block!important; }
  .tp-side-card,.tp-main-card,.tp-history-card{ border-radius:22px; padding:14px; }
