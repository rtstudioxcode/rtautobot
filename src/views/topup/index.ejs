    inset 0 1px 0 rgba(255,255,255,.50),
    inset 0 -10px 18px rgba(58,37,7,.18);
  animation:tnBadgeFloat 2.8s ease-in-out infinite;
}
.tp-enterprise-notice .notice-badge-core{
  position:relative;
  z-index:2;
  color:#1b1408;
  font-size:28px;
  line-height:1;
  text-shadow:0 1px 0 rgba(255,255,255,.42);
}
.tp-enterprise-notice .notice-badge-ring{
  position:absolute;
  inset:-7px;
  border-radius:26px;
  border:1px solid color-mix(in srgb, var(--tn-gold-2) 42%, transparent);
  opacity:.7;
  animation:tnPulse 2.2s ease-in-out infinite;
}
.tp-enterprise-notice .notice-kicker{
  display:inline-flex;
  align-items:center;
  gap:8px;
  margin-bottom:4px;
  color:var(--tn-gold-2);
  font-size:11px;
  font-weight:900;
  letter-spacing:.14em;
  text-transform:uppercase;
}
.tp-enterprise-notice .notice-kicker::before{
  content:"";
  width:7px;
  height:7px;
  border-radius:999px;
  background:var(--tn-gold);
  box-shadow:0 0 18px var(--tn-gold);
}
.tp-enterprise-notice .toast-title{
  margin:0;
  font-size:clamp(22px, 4.6vw, 30px);
  line-height:1.16;
  letter-spacing:-.035em;
}
.tp-enterprise-notice .toast-headtxt .muted{
  margin-top:6px;
  color:var(--tn-muted)!important;
  font-size:13px!important;
  line-height:1.55;
}
.tp-enterprise-notice .toast-body{
  padding:20px 24px 8px;
}
.tp-enterprise-notice .notice-list{
  display:grid;
  gap:10px;
  margin:0;
  padding:0;
  list-style:none;
}
.tp-enterprise-notice .notice-list li{
  display:grid;
  grid-template-columns:42px 1fr;
  align-items:start;
  gap:12px;
  padding:12px 13px;
  border-radius:18px;
  border:1px solid color-mix(in srgb, var(--tn-border) 78%, transparent);
  background:linear-gradient(135deg, rgba(255,255,255,.055), rgba(255,255,255,.018));
  color:color-mix(in srgb, var(--tn-text) 82%, var(--tn-muted));
  line-height:1.55;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.045);
  opacity:0;
  transform:translateY(10px);
  animation:tnItemIn .42s cubic-bezier(.16,1,.3,1) forwards;
}
.tp-enterprise-notice .notice-list li:nth-child(1){ animation-delay:.08s; }
.tp-enterprise-notice .notice-list li:nth-child(2){ animation-delay:.13s; }
.tp-enterprise-notice .notice-list li:nth-child(3){ animation-delay:.18s; }
.tp-enterprise-notice .notice-list li:nth-child(4){ animation-delay:.23s; }
.tp-enterprise-notice .notice-list li:nth-child(5){ animation-delay:.28s; }
.tp-enterprise-notice .notice-dot{
  display:grid;
  place-items:center;
  width:34px;
  height:34px;
  border-radius:13px;
  color:#17130a;
  font-size:11px;
  font-weight:950;
  background:linear-gradient(135deg, #ffe493, #d59b25);
  box-shadow:0 8px 18px color-mix(in srgb, var(--tn-gold) 18%, transparent), inset 0 1px 0 rgba(255,255,255,.42);
}
.tp-enterprise-notice .notice-check-row{
  position:relative;
  display:grid;
  grid-template-columns:48px 1fr;
  align-items:center;
  gap:12px;
  margin-top:16px;
  padding:13px;
  border-radius:20px;
  cursor:pointer;
  user-select:none;
  border:1px solid color-mix(in srgb, var(--tn-border) 82%, transparent);
  background:color-mix(in srgb, var(--tn-page) 42%, transparent);
  transition:transform .2s ease, border-color .2s ease, background .2s ease;
}
.tp-enterprise-notice .notice-check-row:hover{
  transform:translateY(-1px);
  border-color:color-mix(in srgb, var(--tn-gold) 40%, var(--tn-border));
  background:color-mix(in srgb, var(--tn-gold) 7%, transparent);
}
.tp-enterprise-notice .notice-check-row input{
  position:absolute;
  opacity:0;
  pointer-events:none;
}
.tp-enterprise-notice .notice-check-ui{
  width:46px;
  height:28px;
  border-radius:999px;
  border:1px solid rgba(255,255,255,.14);
  background:linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,.035));
  box-shadow:inset 0 2px 8px rgba(0,0,0,.38);
  position:relative;
  transition:.24s ease;
}
.tp-enterprise-notice .notice-check-ui::before{
  content:"";
  position:absolute;
  top:4px;
  left:4px;
  width:20px;
  height:20px;
  border-radius:50%;
  background:#f5f5f2;
  box-shadow:0 5px 14px rgba(0,0,0,.38), inset 0 1px 0 rgba(255,255,255,.75);
  transition:transform .24s cubic-bezier(.2,.8,.2,1), background .24s ease;
}
.tp-enterprise-notice .notice-check-row input:checked + .notice-check-ui{
  background:linear-gradient(135deg, #36d56d, #20a955);
  box-shadow:0 0 22px rgba(54,213,109,.26), inset 0 1px 0 rgba(255,255,255,.18);
}
.tp-enterprise-notice .notice-check-row input:checked + .notice-check-ui::before{
  transform:translateX(18px);
}
.tp-enterprise-notice .notice-check-copy b{
  display:block;
  color:var(--tn-text);
  font-size:14px;
}
.tp-enterprise-notice .notice-check-copy small{
  display:block;
  color:var(--tn-muted);
  margin-top:2px;
  font-size:12px;
}
.tp-enterprise-notice .toast-actions{
  display:flex;
  justify-content:flex-end;
  padding:16px 24px 24px;
}
.tp-enterprise-notice .notice-accept-btn{
  position:relative;
  overflow:hidden;
  min-height:48px;
  border:0!important;
  border-radius:999px;
  padding:0 20px;
  cursor:pointer;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:10px;
  color:#17130a!important;
  font-weight:950;
  background:linear-gradient(135deg,#fff0a7 0%, #e8bc53 54%, #b98222 100%)!important;
  box-shadow:
    0 16px 34px color-mix(in srgb, var(--tn-gold) 24%, transparent),
    inset 0 1px 0 rgba(255,255,255,.62)!important;
  transition:transform .2s ease, filter .2s ease, box-shadow .2s ease;
}
.tp-enterprise-notice .notice-accept-btn:hover{
  transform:translateY(-2px);
  filter:saturate(1.08) brightness(1.03);
  box-shadow:0 20px 42px color-mix(in srgb, var(--tn-gold) 30%, transparent), inset 0 1px 0 rgba(255,255,255,.70)!important;
}
.tp-enterprise-notice .notice-accept-btn i{
  font-style:normal;
  font-size:18px;
  transition:transform .2s ease;
}
.tp-enterprise-notice .notice-accept-btn:hover i{ transform:translateX(3px); }
@keyframes tnBackdropIn{ from{opacity:0} to{opacity:1} }
@keyframes tnBackdropOut{ to{opacity:0} }
@keyframes tnCardIn{ from{opacity:0; transform:translateY(18px) scale(.94); filter:blur(10px)} to{opacity:1; transform:none; filter:none} }
@keyframes tnCardOut{ to{opacity:0; transform:translateY(10px) scale(.965); filter:blur(8px)} }
@keyframes tnItemIn{ to{opacity:1; transform:none} }
@keyframes tnBadgeFloat{ 0%,100%{transform:translateY(0) rotate(0deg)} 50%{transform:translateY(-4px) rotate(-2deg)} }
@keyframes tnPulse{ 0%,100%{transform:scale(.96); opacity:.38} 50%{transform:scale(1.06); opacity:.86} }
@keyframes tnGlowFloat{ 0%,100%{transform:translate3d(0,0,0) scale(1)} 50%{transform:translate3d(0,12px,0) scale(1.06)} }
@media (max-width:560px){
  .tp-enterprise-notice{ width:min(100%, calc(100vw - 20px)); }
  .tp-enterprise-notice .toast-card{ border-radius:28px; }
  .tp-enterprise-notice .toast-headbar{ padding:20px 18px 17px; align-items:flex-start; }
  .tp-enterprise-notice .toast-badge{ width:54px; height:54px; flex-basis:54px; border-radius:20px; }
  .tp-enterprise-notice .toast-body{ padding:16px 16px 6px; }
  .tp-enterprise-notice .notice-list li{ grid-template-columns:38px 1fr; padding:10px; gap:10px; }
  .tp-enterprise-notice .toast-actions{ padding:14px 16px 18px; }
  .tp-enterprise-notice .notice-accept-btn{ width:100%; }
}
@media (prefers-reduced-motion: reduce){
  .tp-enterprise-notice,
  .tp-enterprise-notice *,
  .tp-enterprise-notice::backdrop{ animation:none!important; transition:none!important; }
}


/* =========================================================
   TOPUP QR MODAL — ENTERPRISE COMPACT RESPONSIVE THEME
   ดำ/ทอง + รองรับ light/dark จาก layout.ejs
   ลดขนาด QR และกล่องให้พอดี viewport ไม่ต้องมี scrollbar
========================================================= */
:root{
  --tp-modal-page: var(--page, #08090d);
  --tp-modal-card: var(--card, #15161b);
  --tp-modal-text: var(--text, #fff6df);
  --tp-modal-muted: var(--muted, #c7b98a);
  --tp-modal-border: var(--border, rgba(255,255,255,.10));
  --tp-modal-accent: var(--accent, #f4c95d);
  --tp-modal-gold: #f4c95d;
  --tp-modal-gold2: #b9892f;
  --tp-modal-blue: #263660;
  --tp-modal-shadow: rgba(0,0,0,.58);
}

html[data-theme="light"]{
  --tp-modal-page: var(--page, #f7f3e8);
  --tp-modal-card: var(--card, #fffaf0);
  --tp-modal-text: var(--text, #17130a);
  --tp-modal-muted: var(--muted, #6f6042);
  --tp-modal-border: var(--border, rgba(23,19,10,.12));
  --tp-modal-shadow: rgba(58,42,12,.20);
}

.topup-enterprise .tp-qr-modal,
#qrModal.tp-qr-modal{
  position:fixed !important;
  inset:0 !important;
  z-index:99990 !important;
  display:grid !important;
  place-items:center !important;
  padding:clamp(10px, 2.2vw, 24px) !important;
  isolation:isolate !important;
}

#qrModal.hidden{
  display:none !important;
}

#qrModal.tp-qr-modal .overlay{
  position:fixed !important;
  inset:0 !important;
  z-index:0 !important;
  background:
    radial-gradient(circle at 18% 14%, color-mix(in srgb, var(--tp-modal-accent) 20%, transparent), transparent 28%),
    radial-gradient(circle at 88% 78%, color-mix(in srgb, var(--tp-modal-blue) 28%, transparent), transparent 34%),
    color-mix(in srgb, var(--tp-modal-page) 72%, rgba(0,0,0,.70)) !important;
  -webkit-backdrop-filter: blur(18px) saturate(132%) !important;
  backdrop-filter: blur(18px) saturate(132%) !important;
}

#qrModal.tp-qr-modal .dialog{
  position:relative !important;
  top:auto !important;
  left:auto !important;
  transform:none !important;
  z-index:1 !important;
  width:min(440px, calc(100vw - 24px)) !important;
  max-height:calc(100dvh - 24px) !important;
  overflow:visible !important;
  border-radius:30px !important;
  padding:0 !important;
  color:var(--tp-modal-text) !important;
  background:
    linear-gradient(145deg,
      color-mix(in srgb, var(--tp-modal-card) 96%, #ffffff 4%),
      color-mix(in srgb, var(--tp-modal-card) 90%, #000000 10%) 55%,
      color-mix(in srgb, var(--tp-modal-blue) 20%, var(--tp-modal-card))) padding-box,
    linear-gradient(135deg,
      color-mix(in srgb, var(--tp-modal-accent) 72%, transparent),
      color-mix(in srgb, var(--tp-modal-border) 62%, transparent) 48%,
      color-mix(in srgb, var(--tp-modal-blue) 52%, transparent)) border-box !important;
  border:1px solid transparent !important;
  box-shadow:
    0 28px 90px var(--tp-modal-shadow),
    0 0 0 1px rgba(255,255,255,.035),
    inset 0 1px 0 rgba(255,255,255,.12) !important;
  -webkit-backdrop-filter: blur(22px) saturate(140%) !important;
  backdrop-filter: blur(22px) saturate(140%) !important;
  animation:tpEnterpriseModalIn .24s cubic-bezier(.2,.8,.2,1) both !important;
}

#qrModal.tp-qr-modal .dialog::before{
  content:"";
  position:absolute;
  inset:0;
  pointer-events:none;
  border-radius:inherit;
  background:
    radial-gradient(circle at 20% 0%, color-mix(in srgb, var(--tp-modal-accent) 20%, transparent), transparent 35%),
    linear-gradient(115deg, rgba(255,255,255,.10), transparent 30%, rgba(255,255,255,.035) 70%, transparent);
}

#qrModal.tp-qr-modal .dialog::after{
  content:"";
  position:absolute;
  left:28px;
  right:28px;
  top:0;
  height:1px;
  background:linear-gradient(90deg, transparent, color-mix(in srgb, var(--tp-modal-accent) 88%, transparent), transparent);
  pointer-events:none;
}

#qrModal.tp-qr-modal .close{
  position:absolute !important;
  top:14px !important;
  right:14px !important;
  z-index:4 !important;
  width:40px !important;
  height:40px !important;
  border-radius:16px !important;
  border:1px solid color-mix(in srgb, var(--tp-modal-border) 80%, transparent) !important;
  color:var(--tp-modal-text) !important;
  background:color-mix(in srgb, var(--tp-modal-card) 82%, transparent) !important;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.10), 0 12px 26px rgba(0,0,0,.18) !important;
  cursor:pointer !important;
  transition:transform .18s ease, background .18s ease, border-color .18s ease !important;
}

#qrModal.tp-qr-modal .close:hover{
  transform:translateY(-1px) scale(1.03) !important;
  background:color-mix(in srgb, var(--tp-modal-accent) 14%, var(--tp-modal-card)) !important;
  border-color:color-mix(in srgb, var(--tp-modal-accent) 46%, var(--tp-modal-border)) !important;
}

#qrModal.tp-qr-modal .tp-modal-head{
  position:relative !important;
  z-index:2 !important;
  padding:26px 22px 10px !important;
  text-align:center !important;
}

#qrModal.tp-qr-modal .tp-modal-head > span{
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
  min-height:32px !important;
  padding:7px 13px !important;
  border-radius:999px !important;
  color:#17130a !important;
  background:linear-gradient(135deg, #ffe58f, var(--tp-modal-accent) 56%, var(--tp-modal-gold2)) !important;
  box-shadow:0 12px 28px color-mix(in srgb, var(--tp-modal-accent) 24%, transparent), inset 0 1px 0 rgba(255,255,255,.56) !important;
  font-size:12px !important;
  font-weight:900 !important;
}

#qrModal.tp-qr-modal .tp-modal-head h3{
  margin:12px 0 0 !important;
  font-size:clamp(24px, 3.1vw, 31px) !important;
  letter-spacing:-.04em !important;
  line-height:1.12 !important;
  color:var(--tp-modal-text) !important;
  text-wrap:balance !important;
}

#qrModal.tp-qr-modal .body{
  position:relative !important;
  z-index:2 !important;
  padding:0 22px 16px !important;
  gap:12px !important;
  display:grid !important;
  justify-items:center !important;
}

#qrModal.tp-qr-modal .tp-qr-ring{
  padding:8px !important;
  border-radius:28px !important;
  background:
    conic-gradient(from 180deg,
      color-mix(in srgb, var(--tp-modal-accent) 18%, transparent),
      color-mix(in srgb, var(--tp-modal-accent) 92%, transparent),
      color-mix(in srgb, var(--tp-modal-blue) 44%, transparent),
      color-mix(in srgb, var(--tp-modal-accent) 18%, transparent)) !important;
  box-shadow:0 16px 36px rgba(0,0,0,.24), 0 0 30px color-mix(in srgb, var(--tp-modal-accent) 13%, transparent) !important;
}

#qrModal.tp-qr-modal .tp-qr-ring::before{
  inset:2px !important;
  border-radius:26px !important;
  background:linear-gradient(180deg,
    color-mix(in srgb, var(--tp-modal-card) 96%, #000),
    color-mix(in srgb, var(--tp-modal-card) 88%, #000)) !important;
}

#qrModal.tp-qr-modal .qr-img{
  width:min(270px, 63vw) !important;
  max-width:270px !important;
  aspect-ratio:1 / 1 !important;
  border-radius:22px !important;
  padding:9px !important;
  box-shadow:0 16px 38px rgba(0,0,0,.32), inset 0 0 0 1px rgba(0,0,0,.06) !important;
}

#qrModal.tp-qr-modal .qr-meta{
  width:100% !important;
  border:1px solid color-mix(in srgb, var(--tp-modal-border) 82%, transparent) !important;
  border-radius:22px !important;
  padding:12px !important;
  background:
    linear-gradient(180deg,
      color-mix(in srgb, var(--tp-modal-card) 78%, rgba(255,255,255,.08)),
      color-mix(in srgb, var(--tp-modal-card) 90%, transparent)) !important;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.08) !important;
  text-align:left !important;
}

#qrModal.tp-qr-modal .tp-pay-amount{
  display:flex !important;
  align-items:center !important;
  justify-content:space-between !important;
  gap:12px !important;
  padding:11px 13px !important;
  border-radius:17px !important;
  background:color-mix(in srgb, var(--tp-modal-accent) 10%, transparent) !important;
  border:1px solid color-mix(in srgb, var(--tp-modal-accent) 18%, var(--tp-modal-border)) !important;
}

#qrModal.tp-qr-modal .tp-pay-amount b{
  color:color-mix(in srgb, var(--tp-modal-accent) 88%, var(--tp-modal-text)) !important;
  font-size:17px !important;
}

#qrModal.tp-qr-modal .tp-warning-line{
  padding:10px 13px !important;
  border-radius:17px !important;
  margin-top:10px !important;
  color:color-mix(in srgb, var(--tp-modal-accent) 70%, var(--tp-modal-text)) !important;
  background:color-mix(in srgb, var(--tp-modal-accent) 9%, transparent) !important;
  border:1px solid color-mix(in srgb, var(--tp-modal-accent) 15%, var(--tp-modal-border)) !important;
  line-height:1.5 !important;
}

#qrModal.tp-qr-modal .tp-expire-line{
  color:var(--tp-modal-muted) !important;
  padding:8px 2px 0 !important;
  text-align:center !important;
  font-size:13px !important;
}

#qrModal.tp-qr-modal .tp-modal-kv{
  align-items:center !important;
  padding:9px 2px !important;
}

#qrModal.tp-qr-modal .footer{
  position:relative !important;
  z-index:2 !important;
  padding:0 22px 20px !important;
  display:flex !important;
  justify-content:center !important;
}

#qrModal.tp-qr-modal #qrStatus{
  position:relative !important;
  z-index:2 !important;
  padding:0 22px 20px !important;
}

#qrModal.tp-qr-modal .btn,
#qrModal.tp-qr-modal .pill{
  min-height:44px !important;
  border-radius:16px !important;
}

@keyframes tpEnterpriseModalIn{
  from{ opacity:0; transform:translateY(14px) scale(.968); filter:blur(4px); }
  to{ opacity:1; transform:translateY(0) scale(1); filter:blur(0); }
}

@media (max-width: 640px){
  #qrModal.tp-qr-modal{
    padding:10px !important;
  }

  #qrModal.tp-qr-modal .dialog{
    width:min(420px, calc(100vw - 20px)) !important;
    max-height:calc(100dvh - 20px) !important;
    border-radius:26px !important;
  }

  #qrModal.tp-qr-modal .tp-modal-head{
    padding:22px 16px 8px !important;
  }

  #qrModal.tp-qr-modal .tp-modal-head h3{
    font-size:clamp(22px, 7vw, 28px) !important;
  }

  #qrModal.tp-qr-modal .body{
    padding:0 16px 14px !important;
    gap:10px !important;
  }

  #qrModal.tp-qr-modal .qr-img{
    width:min(238px, 62vw) !important;
    max-width:238px !important;
    padding:8px !important;
    border-radius:20px !important;
  }

  #qrModal.tp-qr-modal .tp-qr-ring{
    padding:7px !important;
    border-radius:24px !important;
  }

  #qrModal.tp-qr-modal .qr-meta{
    padding:10px !important;
    border-radius:19px !important;
  }

  #qrModal.tp-qr-modal .footer,
  #qrModal.tp-qr-modal #qrStatus{
    padding-left:16px !important;
    padding-right:16px !important;
    padding-bottom:16px !important;
  }
}

@media (max-height: 720px){
  #qrModal.tp-qr-modal .tp-modal-head{
    padding-top:18px !important;
  }

  #qrModal.tp-qr-modal .tp-modal-head h3{
    font-size:clamp(21px, 4vh, 28px) !important;
    margin-top:8px !important;
  }

  #qrModal.tp-qr-modal .body{
    gap:8px !important;
  }

  #qrModal.tp-qr-modal .qr-img{
    width:min(230px, 56vh, 60vw) !important;
