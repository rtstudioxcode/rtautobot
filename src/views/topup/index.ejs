
<%
  const wallets = (webWallets || []).filter(w => w && w.isActive !== false);
  const BANK_LABELS = {
    bbl:'ธนาคารกรุงเทพ', kbank:'ธนาคารกสิกรไทย', ktb:'ธนาคารกรุงไทย',
    bay:'ธนาคารกรุงศรีอยุธยา', scb:'ธนาคารไทยพาณิชย์', tmb:'ทหารไทยธนชาต (TTB)',
    cimb:'ธนาคารซีไอเอ็มบีไทย', uob:'ธนาคารยูโอบี', gsb:'ธนาคารออมสิน',
    baac:'ธ.เพื่อการเกษตรและสหกรณ์การเกษตร', kkb:'ธนาคารเกียรตินาคินภัทร',
    lhfg:'ธนาคารแลนด์ แอนด์ เฮ้าส์', icbc:'ธนาคารไอซีบีซี (ไทย)',
    tisco:'ธนาคารทิสโก้', tw:'TrueMoney Wallet', qr:'PromptPay QR',
    manual:'แอดมิน', admin:'แอดมิน'
  };
  const hasAny = wallets.length > 0;
  const completedCount = (transactions || []).filter(t => String(t.status || '').toLowerCase() === 'completed').length;
  const pendingCount = (transactions || []).filter(t => String(t.status || '').toLowerCase() === 'pending').length;
%>

<div class="topup-enterprise">
  <section class="tp-hero" aria-label="Topup header">
    <div class="tp-hero-glow tp-hero-glow-a"></div>
    <div class="tp-hero-glow tp-hero-glow-b"></div>

    <div class="tp-hero-content">
      <div>
        <div class="tp-eyebrow"><span></span> TOPUP CENTER</div>
        <h1>เติมเครดิตอัตโนมัติ</h1>
        <p>เลือกช่องทาง กรอกยอด สแกนจ่าย และรอระบบตรวจสอบยอดอัตโนมัติ</p>
      </div>

      <div class="tp-hero-metrics" aria-label="Topup summary">
        <div class="tp-metric">
          <small>ช่องทางพร้อมใช้</small>
          <b><%= wallets.length.toLocaleString('th-TH') %></b>
        </div>
        <div class="tp-metric">
          <small>เติมเครดิตสำเร็จ</small>
          <b><%= completedCount.toLocaleString('th-TH') %></b>
        </div>
        <div class="tp-metric">
          <small>รอดำเนินการ</small>
          <b><%= pendingCount.toLocaleString('th-TH') %></b>
        </div>
      </div>
    </div>
  </section>

  <div class="tabs tp-main-tabs" role="tablist" aria-label="Topup tabs">
    <button class="tab active" data-tab="tab-topup" type="button" role="tab" aria-selected="true">
      <span class="tab-ico">✦</span>
      <span>การเติมเครดิต</span>
    </button>
    <button class="tab" data-tab="tab-history" type="button" role="tab" aria-selected="false">
      <span class="tab-ico">◷</span>
      <span>ประวัติการเติมเงิน</span>
    </button>
  </div>

  <section id="tab-topup" class="tabpane show" role="tabpanel">
    <div class="tp-layout">
      <aside class="tp-side-card">
        <div class="tp-section-head compact">
          <div>
            <span>Payment methods</span>
            <h2>ช่องทางเติมเงิน</h2>
          </div>
        </div>

        <% if (!hasAny) { %>
          <div class="tp-empty">
            <div class="tp-empty-icon">⌁</div>
            <h3>ยังไม่มีช่องทางพร้อมใช้งาน</h3>
            <p>โปรดรอแอดมินเปิดช่องทางเติมเงิน</p>
          </div>
        <% } else { %>
          <div class="tab-bar tp-wallet-rail" role="tablist" aria-label="Wallet methods">
            <% wallets.forEach((w, i) => {
              const code = String(w.accountCode || '').toLowerCase();
              const isTW = code === 'tw';
              const expireText = isTW || code === 'qr' ? '5 นาที' : '15 นาที';
            %>
              <button class="tab-btn tp-wallet-tab <%= i === 0 ? 'active' : '' %>" data-tab="wallet-<%= i %>" type="button" role="tab" aria-selected="<%= i === 0 ? 'true' : 'false' %>">
                <span class="tp-wallet-icon-wrap">
                  <img src="/static/assets/payment/<%= code %>.webp" alt="<%= code %>" loading="lazy" />
                </span>
                <span class="tp-wallet-copy">
                  <strong><%= BANK_LABELS[code] || code.toUpperCase() %></strong>
                  <small><%= isTW ? 'TrueWallet QR' : 'PromptPay QR' %> · <%= expireText %></small>
                </span>
                <span class="tp-wallet-arrow">›</span>
              </button>
            <% }) %>
          </div>
        <% } %>
      </aside>

      <main class="tp-main-card">
        <% if (wallets.length === 0) { %>
          <div class="tp-empty large">
            <div class="tp-empty-icon">◌</div>
            <h3>ยังไม่มีช่องทางเติมเงินที่พร้อมใช้งาน</h3>
            <p>เมื่อเปิดใช้งานแล้ว รายการช่องทางจะปรากฏที่นี่</p>
          </div>
        <% } else { %>
          <% wallets.forEach((w, i) => {
            const code = String(w.accountCode || '').toLowerCase();
            const isTW = code === 'tw';
            const expireText = isTW || code === 'qr' ? '5 นาที' : '15 นาที';
            const methodTitle = BANK_LABELS[code] || code.toUpperCase();
          %>
            <div class="tab-content tp-wallet-panel <%= i === 0 ? 'active' : '' %>" id="wallet-<%= i %>">
              <div class="tp-payment-header">
                <div class="tp-payment-brand">
                  <div class="tp-payment-logo">
                    <img src="/static/assets/payment/<%= code %>.webp" alt="<%= code %>" loading="lazy" />
                  </div>
                  <div>
                    <span><%= isTW ? 'TrueMoney Wallet' : 'Bank Transfer' %></span>
                    <h2><%= methodTitle %></h2>
                    <p><%= w.accountName || 'RTSMM' %></p>
                  </div>
                </div>
                <div class="tp-expire-badge">
                  <small>กรุณาทำรายการใน</small>
                  <b><%= expireText %></b>
                </div>
              </div>

              <div class="tp-checkout-grid">
                <section class="tp-form-card">
                  <form
                    id="<%= isTW ? 'topupForm' : 'createTopupForm' %>-<%= i %>"
                    class="form topupForm tp-form"
                    data-wallet-code="<%= code %>"
                    data-wallet-index="<%= i %>"
                    onsubmit="return <%= isTW ? 'submitTopup(event)' : 'submitqrTopup(event)' %>"
                  >
                    <label class="tp-label" for="amount-<%= i %>">จำนวนเงินที่ต้องการเติม</label>
                    <div class="tp-amount-shell">
                      <span>฿</span>
                      <input
                        id="amount-<%= i %>"
                        name="amount"
                        type="number"
                        min="1"
                        step="1"
                        inputmode="numeric"
                        required
                        placeholder="เช่น 100"
                        autocomplete="off"
                        oninput="this.value=this.value.replace(/[^\d]/g,''); updateqrSummary(<%= i %>)"
                      />
                    </div>

                    <div class="tp-quick-grid" aria-label="Quick amounts">
                      <% [50,100,300,500,1000,3000].forEach(v => { %>
                        <button type="button" class="tp-chip" data-amount="<%= v %>">฿<%= v.toLocaleString('th-TH') %></button>
                      <% }) %>
                    </div>

                    <div class="tp-summary-strip">
                      <span>ยอดเติม</span>
                      <b>฿<span id="summaryAmount-<%= i %>">—</span></b>
                    </div>

                    <button class="tp-primary-btn" type="submit">
                      <span class="btn-shine"></span>
                      <span><%= isTW ? 'สร้าง QR TrueWallet' : 'สร้างรายการโอนเงิน' %></span>
                      <i>→</i>
                    </button>
                  </form>
                </section>

                <section class="tp-info-card">
                  <div class="tp-account-card">
                    <div class="tp-account-icon">
                      <img src="/static/assets/payment/<%= code %>.webp" alt="<%= code %>" loading="lazy" />
                    </div>
                    <div>
                      <small>บัญชีปลายทาง</small>
                      <strong><%= w.accountName || 'RTSMM' %></strong>
                      <span><%= isTW ? 'สแกน QRCode ด้วยแอป TrueMoney Wallet เท่านั้น' : 'สแกน QRCode ได้ทุกธนาคาร' %></span>
                    </div>
                  </div>

                  <div class="tp-alert-card">
                    <span>⚠</span>
                    <div>
                      <b>โปรดโอนยอดให้ตรงตามระบบ</b>
                      <p><%= isTW ? 'ใช้แอป TrueMoney Wallet สแกน QR และรอระบบตรวจสอบอัตโนมัติ' : 'ระบบจะสุ่มเศษสตางค์เพื่อจับคู่รายการ กรุณาโอนครั้งเดียวตามยอดที่แสดง' %></p>
                    </div>
                  </div>

                  <div class="tp-steps-card">
                    <h3><%= isTW ? 'วิธีเติมผ่าน TrueWallet' : 'วิธีโอนผ่านธนาคาร' %></h3>
                    <ol>
                      <li>กรอกจำนวนเงินที่ต้องการเติม</li>
                      <li>กดปุ่มสร้างรายการเติมเงิน</li>
                      <li><%= isTW ? 'เปิดแอป TrueMoney Wallet แล้วสแกน QR' : 'เปิดแอปธนาคาร แล้วสแกน QR Code' %></li>
                      <li>โอนตามยอดที่ระบบแสดงเท่านั้น</li>
                      <li>รอระบบตรวจสอบและเติมเครดิตอัตโนมัติ</li>
                    </ol>
                  </div>
                </section>
              </div>
            </div>
          <% }) %>
        <% } %>
      </main>
    </div>
  </section>

  <section id="tab-history" class="tabpane" role="tabpanel">
    <div class="tp-history-card">
      <div class="tp-section-head">
        <div>
          <span>Transaction history</span>
          <h2>ประวัติการเติมเงินล่าสุด</h2>
        </div>
        <div class="tp-history-count"><%= (transactions || []).length.toLocaleString('th-TH') %> รายการ</div>
      </div>

      <% if (transactions && transactions.length) { %>
        <table class="history-table tp-history-table d-desktop">
          <thead>
            <tr>
              <th>วันที่ / เวลา</th>
              <th>ช่องทาง</th>
              <th class="right">จำนวนเงิน</th>
              <th class="right">สถานะ</th>
            </tr>
          </thead>
          <tbody>
          <% for (var i = 0; i < transactions.length; i++) {
               var tx = transactions[i];
               var methodCode = String(tx.method || '').toLowerCase();
               var methodName = BANK_LABELS[methodCode] || 'ไม่ระบุ';
               var st = String(tx.status || '').toLowerCase();
               var statusLabel = (st === 'completed') ? 'สำเร็จ'
                               : (st === 'pending')   ? 'รอดำเนินการ'
                               : (st === 'failed')    ? 'ล้มเหลว'
                               : (st === 'reject')    ? 'ยกเลิก'
                               : (st === 'canceled' || st === 'cancelled') ? 'ยกเลิก' : st;
               var ts = tx.createdAt;
               var amountNum = Number(tx.amount) || 0;
          %>
            <tr data-status="<%= st %>">
              <td class="mono">
                <%= new Date(ts).toLocaleString('th-TH',{ timeZone:'Asia/Bangkok', year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit' }) %>
              </td>
              <td>
                <span class="method tp-method">
                  <img class="method-ico" src="/static/assets/payment/<%= methodCode %>.webp" alt="<%= methodName %>" width="24" height="24" loading="lazy" />
                  <span><%= methodName %></span>
                </span>
              </td>
              <td class="amount right"><span class="money">฿<%= amountNum.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) %></span></td>
              <td class="status-cell right">
                <span class="pill sm st-<%= st %>">
                  <i class="st-ico" aria-hidden="true"></i>
                  <span class="txt"><%= statusLabel %></span>
                </span>
              </td>
            </tr>
          <% } %>
          </tbody>
        </table>

        <div class="history-list tp-history-list d-mobile">
        <% for (var j = 0; j < transactions.length; j++) {
             var t = transactions[j];
             var mCode = String(t.method || '').toLowerCase();
             var mName = BANK_LABELS[mCode] || 'ไม่ระบุ';
             var st2 = String(t.status || '').toLowerCase();
             var stLabel = (st2 === 'completed') ? 'สำเร็จ'
                         : (st2 === 'pending')   ? 'รอดำเนินการ'
                         : (st2 === 'failed')    ? 'ล้มเหลว'
                         : (st2 === 'reject')    ? 'ยกเลิก'
                         : (st2 === 'canceled' || st2 === 'cancelled') ? 'ยกเลิก' : st2;
             var ts2 = t.createdAt;
             var amt = Number(t.amount) || 0;
        %>
          <details class="hx-card" data-status="<%= st2 %>">
            <summary class="hx-head">
              <span class="hx-date mono"><%= new Date(ts2).toLocaleString('th-TH',{ timeZone:'Asia/Bangkok', year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit' }) %></span>
              <button class="hx-toggle" type="button" aria-label="toggle"></button>
            </summary>
            <div class="hx-body">
              <div class="hx-row"><div class="hx-label">ช่องทาง</div><div class="hx-val method"><img class="method-ico" src="/static/assets/payment/<%= mCode %>.webp" alt="<%= mName %>" width="22" height="22" loading="lazy"/><span><%= mName %></span></div></div>
              <div class="hx-row"><div class="hx-label">จำนวนเงิน</div><div class="hx-val money">฿<%= amt.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) %></div></div>
              <div class="hx-row"><div class="hx-label">สถานะ</div><div class="hx-val"><span class="pill sm st-<%= st2 %>"><i class="st-ico" aria-hidden="true"></i><span class="txt"><%= stLabel %></span></span></div></div>
            </div>
          </details>
        <% } %>
        </div>
      <% } else { %>
        <div class="tp-empty large">
          <div class="tp-empty-icon">◌</div>
          <h3>ยังไม่มีรายการเติมเงิน</h3>
          <p>เมื่อมีการเติมเครดิต รายการล่าสุดจะแสดงที่นี่</p>
        </div>
      <% } %>
    </div>
  </section>

  <div id="qrModal" class="hidden modal tp-qr-modal">
    <div class="overlay" data-close="1"></div>
    <div class="dialog" role="dialog" aria-modal="true" aria-labelledby="qrTitle">
      <button class="icon close" id="qrClose" aria-label="ปิด">×</button>
      <div class="tp-modal-head">
        <div class="tp-modal-clock" aria-hidden="true">
          <span class="clock-face">
            <i class="clock-hand hour"></i>
            <i class="clock-hand minute"></i>
            <i class="clock-hand second"></i>
            <i class="clock-center"></i>
          </span>
        </div>
        <span id="qrCountdown" aria-live="polite">หมดอายุใน 05:00</span>
        <h3 id="qrTitle">สแกน QRCode เพื่อเติมเงิน</h3>
      </div>

      <div class="body">
        <div class="qr-img-wrap">
          <div class="tp-qr-ring"><img id="qrImage" src="" alt="QR Code" class="qr-img" /></div>
        </div>

        <div id="qrMeta" class="qr-meta">
          <div data-for="bankOnly">
            <div class="tp-pay-amount">ยอดที่ต้องโอน: <b><span id="qrAmount">—</span> บาท</b></div>
            <div class="tp-warning-line">โปรดโอนตามยอดที่แสดงเท่านั้น ไม่งั้นเครดิตไม่เข้า</div>
            <div class="tp-expire-line">ระยะเวลาทำรายการ: <span id="qrExpireHintBank">—</span></div>
          </div>

          <div data-for="twOnly" style="display:none">
            <div class="tp-pay-amount">ยอดเติม: <b><span id="qrAmountTw"></span> บาท</b></div>
            <div class="tp-warning-line">โปรดโอนในระยะเวลาที่กำหนด ห้ามปิดหน้านี้จนกว่าจะสำเร็จ</div>
            <div class="tp-expire-line">ระยะเวลาทำรายการ: <span id="qrExpireHintTw">—</span></div>
          </div>
        </div>
      </div>

      <div class="footer" id="qrFooterTw" style="display:none">
</div>

      <div id="qrStatus" class="mt"></div>
    </div>
  </div>

  <div id="resp" class="mt"></div>
</div>

<dialog id="topupNoticeModal" class="toast-modal tp-enterprise-notice" aria-labelledby="topupNoticeTitle" aria-describedby="topupNoticeText">
  <div class="toast-card" role="alertdialog">
    <div class="notice-glow notice-glow-a" aria-hidden="true"></div>
    <div class="notice-glow notice-glow-b" aria-hidden="true"></div>

    <div class="toast-headbar">
      <div class="toast-badge" aria-hidden="true">
        <span class="notice-badge-core">⚠</span>
        <span class="notice-badge-ring"></span>
      </div>
      <div class="toast-headtxt">
        <span class="notice-kicker">Payment Notice</span>
        <h3 class="toast-title" id="topupNoticeTitle">แจ้งเตือนก่อนเติมเงิน</h3>
        <div class="muted" id="topupNoticeText">อ่านเงื่อนไขสำคัญก่อนสร้างรายการ เพื่อให้ระบบตรวจยอดได้อัตโนมัติ</div>
      </div>
    </div>

    <div class="toast-body">
      <ul class="notice-list">
        <li><span class="notice-dot">01</span><span>ในส่วนการเติมเงินแบบสแกน QR Code ของธนาคาร</span></li>
        <li><span class="notice-dot">02</span><span>ผู้ใช้งานต้องกรอกจำนวนให้ตรงกับหน้าเว็บ</span></li>
        <li><span class="notice-dot">03</span><span>หากกรอกจำนวนไม่ตรง ระบบจะไม่สามารถเติมเครดิตให้อัตโนมัติ</span></li>
        <li><span class="notice-dot">04</span><span>หลีกเลี่ยงการโอนเงินช่วง 23:30 - 01:30 น. เพราะระบบธนาคารอัปเดตข้อมูลช้า</span></li>
        <li><span class="notice-dot">05</span><span>หากเติมเงินไม่เข้าเกิน 1 ชั่วโมง ให้ติดต่อไลน์แจ้งแอดมินทันที</span></li>
      </ul>

      <label class="notice-check-row" for="topupNoticeDontShow">
        <input id="topupNoticeDontShow" type="checkbox" />
        <span class="notice-check-ui" aria-hidden="true"></span>
        <span class="notice-check-copy">
          <b>ไม่แสดงอีกในวันนี้</b>
          <small>ระบบจะจำค่าบนอุปกรณ์นี้เป็นเวลา 24 ชั่วโมง</small>
        </span>
      </label>
    </div>

    <div class="toast-actions">
      <button class="pill primary notice-accept-btn" id="topupNoticeClose" type="button">
        <span class="btn-shine"></span>
        <span>ปิดและยอมรับ</span>
        <i aria-hidden="true">→</i>
      </button>
    </div>
  </div>
</dialog>

<script>
(function(){
  const KEY = 'topup_notice_suppress_until_v1';
  const modal = document.getElementById('topupNoticeModal');
  const chk = document.getElementById('topupNoticeDontShow');
  const btnClose = document.getElementById('topupNoticeClose');

  function shouldShow(){
    try {
      const v = localStorage.getItem(KEY);
      if (!v) return true;
      const ts = Number(v);
      if (!Number.isFinite(ts)) return true;
      return Date.now() > ts;
    } catch(e){ return true; }
  }

  function setSuppressFor1Day(){
    try { localStorage.setItem(KEY, String(Date.now() + 86400000)); } catch(e){}
  }

  function openNotice(){
    if (!modal || modal.open) return;
    modal.classList.remove('is-closing');
    try { modal.showModal(); } catch(e){}
  }

  function closeNotice(){
    if (!modal || !modal.open) return;
    if (chk && chk.checked) setSuppressFor1Day();
    modal.classList.add('is-closing');
    window.setTimeout(() => {
      try { if (modal.open) modal.close(); } catch(e){}
      modal.classList.remove('is-closing');
    }, 260);
  }

  document.addEventListener('DOMContentLoaded', () => {
    try { if (shouldShow()) setTimeout(openNotice, 160); } catch(e){}
  });

  btnClose?.addEventListener('click', closeNotice);
  modal?.addEventListener('cancel', (ev) => { ev.preventDefault(); closeNotice(); });
})();
</script>

<script>
  let currentTxId = null;
  let txWatcher = null;

  function startTxWatcher(txId, timeoutSec = 300){
    stopTxWatcher();
    const started = Date.now();
    let delay = 3000;
    const tick = async () => {
      try{
        if (timeoutSec > 0 && Date.now() - started > timeoutSec*1000) { stopTxWatcher(); setQrExpiredState(txId); return; }
        if (document.hidden) { txWatcher = setTimeout(tick, 10000); return; }
        const r = await fetch(`/topup/tx/${txId}?_=${Date.now()}`, { cache: 'no-store' });
        if (!r.ok) { txWatcher = setTimeout(tick, delay); return; }
        const j = await r.json();
        if (j?.ok && ['completed','failed','cancelled','canceled','reject'].includes(j.status)) {
          stopTxWatcher(); closeQrModal();
          if (j.status === 'completed') {
            const amt = j.amount ?? j.paidAmount ?? j.displayAmount ?? j.total ?? j.credit ?? null;
            const fmt = n => Number(n).toLocaleString(undefined,{ minimumFractionDigits:2, maximumFractionDigits:2 });
            if (typeof notify?.success === 'function') notify.success('เติมเงินสำเร็จ', amt != null ? `เพิ่มเครดิต ฿${fmt(amt)}` : '');
            setTimeout(()=> location.reload(), 900);
          } else {
            const msg = (j.status === 'failed') ? 'การชำระล้มเหลว กรุณาลองใหม่' : 'รายการถูกยกเลิก';
            if (typeof notify?.error === 'function') notify.error('ไม่สำเร็จ', msg); else alert(msg);
          }
          return;
        }
        const age = Date.now() - started;
        delay = age > 120000 ? 10000 : age > 45000 ? 6000 : 3000;
      }catch(e){}
      txWatcher = setTimeout(tick, delay);
    };
    tick();
  }

  function stopTxWatcher(){ if (txWatcher) clearTimeout(txWatcher); txWatcher = null; }
  function fmtMoney(n){ try { return Number(n).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }); } catch { return n; } }
  function updateqrSummary(i){
    const v = parseFloat(document.getElementById(`amount-${i}`)?.value || '0');
    const el = document.getElementById(`summaryAmount-${i}`);
    if (!el) return;
    el.textContent = v >= 1 ? fmtMoney(Math.floor(v)) : '—';
  }
  function closeQr(i){ const box = document.getElementById(`qrBox-${i}`); if (box) box.style.display = 'none'; }

  async function submitqrTopup(ev){
    ev.preventDefault();
    const form = ev.currentTarget;
    const i = form.dataset.walletIndex;
    const walletCode = String(form.dataset.walletCode || '').toLowerCase();
    const amountEl = document.getElementById(`amount-${i}`);
    const base = Math.floor(Number(amountEl?.value || 0));
    if (!Number.isFinite(base) || base < 1) {
      const msg = 'จำนวนเงินขั้นต่ำ 1 บาท';
      window.showMsg ? window.showMsg({ variant:'error', title:'จำนวนเงินไม่ถูกต้อง', text: msg }) : alert(msg);
      return false;
    }
    try {
      const res = await fetch('/topup/create', { method:'POST', headers:{ 'Content-Type':'application/json' }, body: JSON.stringify({ amount: base, method: walletCode, accountCode: walletCode, walletCode }) });
      const j = await res.json();
      if (!res.ok || !j?.ok) {
        const err = j?.error || j?.message || 'สร้างคำสั่งเติมเงินไม่สำเร็จ';
        window.showMsg ? window.showMsg({ variant:'error', title:'ไม่สำเร็จ', text: err }) : alert(err);
        return false;
      }
      currentTxId = j.txId || j.id || j.pendingTxId;
      if (j?.mustCancelOld || j?.expiredPending) { await showExpiredPendingModal(j, walletCode); return false; }
      const finalAmount = Number(j.displayAmount ?? j.payAmount ?? j.amount ?? base);
      const fallbackQrMap = {
        kbank: '/static/assets/payment/qr-kbank.jpg',
        scb: '/static/assets/payment/qr-scb.jpg',
        qr: '/static/assets/payment/qrcode.png',
      };
      const qrUrl = j.qrUrl || fallbackQrMap[walletCode] || fallbackQrMap[j.method] || '';
      const img = document.getElementById('qrImage');
      if (img && qrUrl) {
        img.onerror = () => console.error('[TOPUP QR IMAGE LOAD FAILED]', qrUrl);
        img.src = `${qrUrl}?v=${Date.now()}`;
      }
      const amtEl = document.getElementById('qrAmount');
      if (amtEl) amtEl.textContent = finalAmount.toLocaleString(undefined, { minimumFractionDigits:2, maximumFractionDigits:2 });
      openQrModal('bank', Number(j.expiresIn || 300));
      startTxWatcher(currentTxId, Number(j.expiresIn || 300));
    } catch (err) {
      const msg = `ขัดข้อง: ${err.message}`;
      window.showMsg ? window.showMsg({ variant:'error', title:'ไม่สำเร็จ', text: msg }) : alert(msg);
    }
    return false;
  }
</script>

<script>
  const $ = (s, r = document) => r.querySelector(s);
  const fmt = (n) => Number(n || 0).toLocaleString(undefined, { minimumFractionDigits: 2 });

  document.querySelectorAll('.tabs .tab').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tabs .tab').forEach((b) => { b.classList.remove('active'); b.setAttribute('aria-selected','false'); });
      document.querySelectorAll('.tabpane').forEach((p) => p.classList.remove('show'));
      btn.classList.add('active'); btn.setAttribute('aria-selected','true');
      document.getElementById(btn.dataset.tab)?.classList.add('show');
    });
  });

  document.querySelectorAll('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach((b) => { b.classList.remove('active'); b.setAttribute('aria-selected','false'); });
      document.querySelectorAll('.tab-content').forEach((c) => c.classList.remove('active'));
      btn.classList.add('active'); btn.setAttribute('aria-selected','true');
      document.getElementById(btn.dataset.tab)?.classList.add('active');
    });
  });

  document.querySelectorAll('.tp-chip').forEach((chip) => {
    chip.addEventListener('click', () => {
      const form = chip.closest('form');
      const input = form?.querySelector('input[name="amount"]');
      if (!input) return;
      input.value = chip.dataset.amount || '';
      input.dispatchEvent(new Event('input', { bubbles:true }));
      form.querySelectorAll('.tp-chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
    });
  });

  function computeSubtotal(base, walletCode){ return Math.round(base * 100) / 100; }
  function fmt2(n){ try { return Number(n).toLocaleString(undefined,{ minimumFractionDigits:2, maximumFractionDigits:2 }); } catch { return n; } }
  function bindTopupSummary(form){
    const amt = form.querySelector('input[name="amount"]');
    const sum = form.querySelector('[id^="summaryAmount-"]');
    if (!amt || !sum) return;
    const walletCode = form.dataset.walletCode || '';
    const update = () => {
      const base = Number(amt.value || 0);
      if (!Number.isFinite(base) || base < 1){ sum.textContent = '—'; return; }
      sum.textContent = fmt2(computeSubtotal(base, walletCode));
    };
    amt.addEventListener('input', update); amt.addEventListener('change', update); update();
  }
  document.querySelectorAll('.topupForm').forEach(bindTopupSummary);

  let qrTimerId = null;
  let qrExpireAt = null;
  function formatMMSS(msLeft){ const s = Math.max(0, Math.ceil(msLeft/1000)); return `${String(Math.floor(s/60)).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`; }
  function formatExpireHint(seconds){ const sec = Math.max(1, Number(seconds || 300)); return `${Math.ceil(sec / 60)} นาที`; }
  function setExpireHint(mode, seconds){ const text = formatExpireHint(seconds); const bankHint = document.getElementById('qrExpireHintBank'); const twHint = document.getElementById('qrExpireHintTw'); if (bankHint) bankHint.textContent = text; if (twHint) twHint.textContent = text; }
  function clearQrCountdown(){ if (qrTimerId) clearInterval(qrTimerId); qrTimerId = null; const el = document.getElementById('qrCountdown'); if (el) el.textContent = 'หมดอายุใน --:--'; }
  function setQrMode(mode){
    window.qrMode = mode;
    document.querySelectorAll('#qrMeta [data-for="bankOnly"]').forEach(e => e.style.display = (mode === 'bank' ? '' : 'none'));
    document.querySelectorAll('#qrMeta [data-for="twOnly"]').forEach(e => e.style.display = (mode === 'tw' ? '' : 'none'));
    const footerTw = document.getElementById('qrFooterTw'); if (footerTw) footerTw.style.display = 'none';
  }
  function setQrExpiredState(txId){
    const img = document.getElementById('qrImage');
    const ring = img?.closest?.('.tp-qr-ring');
    if (img) img.classList.add('tp-qr-expired');
    if (ring) ring.classList.add('tp-qr-expired-ring');
    const status = document.getElementById('qrStatus');
    if (status) {
      status.innerHTML = `
        <div class="tp-expired-box">
          <b>รายการนี้หมดเวลาแล้ว</b>
          <span>กรุณายกเลิกรายการเก่าก่อนทำรายการใหม่</span>
          <button type="button" class="tp-cancel-old-btn" data-cancel-topup="${String(txId || '')}">ยกเลิกรายการเก่า</button>
        </div>`;
    }
  }

  function clearQrExpiredState(){
    const img = document.getElementById('qrImage');
    const ring = img?.closest?.('.tp-qr-ring');
    if (img) img.classList.remove('tp-qr-expired');
    if (ring) ring.classList.remove('tp-qr-expired-ring');
    const status = document.getElementById('qrStatus');
    if (status) status.innerHTML = '';
  }

  async function showExpiredPendingModal(tx, walletCode = ''){
    currentTxId = tx.txId || tx.id || tx.pendingTxId || currentTxId;
    window.currentTxId = currentTxId;
    stopTxWatcher();
    clearQrCountdown();
    const mode = String(tx.method || walletCode || '').toLowerCase() === 'tw' ? 'tw' : 'bank';
    setQrMode(mode);
    setExpireHint(mode, Number(tx.expireMinutes || 5) * 60);
    const finalAmount = Number(tx.displayAmount ?? tx.payAmount ?? tx.amount ?? 0);
    const img = document.getElementById('qrImage');
    if (img) {
      const fallbackQrMap = { kbank:'/static/assets/payment/qr-kbank.jpg', scb:'/static/assets/payment/qr-scb.jpg', qr:'/static/assets/payment/qrcode.png' };
      const qrUrl = tx.qrUrl || fallbackQrMap[String(tx.method || walletCode).toLowerCase()] || `https://api.qrserver.com/v1/create-qr-code/?size=512x512&data=${encodeURIComponent('EXPIRED TOPUP ' + (currentTxId || ''))}`;
      img.src = qrUrl.includes('?') ? `${qrUrl}&expired=${Date.now()}` : `${qrUrl}?expired=${Date.now()}`;
    }
    document.getElementById('qrMethod')?.replaceChildren(document.createTextNode(mode === 'tw' ? 'TrueMoney Wallet' : String(tx.method || walletCode || 'PromptPay').toUpperCase()));
    document.getElementById('qrName')?.replaceChildren(document.createTextNode('รายการเก่าที่ยังไม่ได้ยกเลิก'));
    document.getElementById('qrNumber')?.replaceChildren(document.createTextNode('-'));
    const amtEl = document.getElementById(mode === 'tw' ? 'qrAmountTw' : 'qrAmount');
    if (amtEl) amtEl.textContent = finalAmount.toLocaleString(undefined, { minimumFractionDigits:2, maximumFractionDigits:2 });
    const cd = document.getElementById('qrCountdown');
    if (cd) cd.textContent = 'หมดเวลาแล้ว';
    document.getElementById('qrModal')?.classList.remove('hidden');
    setQrExpiredState(currentTxId);
  }

  document.addEventListener('click', async (ev) => {
    const btn = ev.target.closest('[data-cancel-topup]');
    if (!btn) return;
    const txId = btn.dataset.cancelTopup || currentTxId || window.currentTxId;
    if (!txId) return;
    btn.disabled = true;
    btn.textContent = 'กำลังยกเลิก...';
    try {
      const r = await fetch(`/topup/cancel/${encodeURIComponent(txId)}`, { method:'POST', headers:{ 'Content-Type':'application/json' } });
      const j = await r.json().catch(() => ({}));
      if (!r.ok || !j?.ok) throw new Error(j?.message || 'ยกเลิกไม่สำเร็จ');
      window.showMsg ? window.showMsg({ variant:'success', title:'ยกเลิกรายการแล้ว', text:'สามารถสร้างรายการเติมเงินใหม่ได้เลย' }) : alert('ยกเลิกรายการแล้ว');
      closeQrModal();
      setTimeout(() => location.reload(), 500);
    } catch (err) {
      btn.disabled = false;
      btn.textContent = 'ยกเลิกรายการเก่า';
      window.showMsg ? window.showMsg({ variant:'error', title:'ไม่สำเร็จ', text:err.message }) : alert(err.message);
    }
  });

  function startQrCountdown(seconds = 300){
    clearQrCountdown();
    const el = document.getElementById('qrCountdown');
    qrExpireAt = Date.now() + seconds * 1000;
    const tick = () => {
      const left = qrExpireAt - Date.now();
      if (left <= 0){ clearQrCountdown(); if (el) el.textContent = 'หมดเวลาแล้ว'; setQrExpiredState(currentTxId || window.currentTxId); return; }
      if (el) el.textContent = `หมดอายุใน ${formatMMSS(left)}`;
    };
    tick(); qrTimerId = setInterval(tick, 1000);
  }
  function openQrModal(mode = 'bank', seconds = 300) {
    const safeSeconds = Math.max(1, Number(seconds || 300));
    setQrMode(mode); setExpireHint(mode, safeSeconds); clearQrExpiredState();
    const m = document.getElementById('qrModal'); m?.classList.remove('hidden');
    const status = document.getElementById('qrStatus'); if (status) status.innerHTML = '';
    startQrCountdown(safeSeconds);
  }
  function closeQrModal(){
    const m = document.getElementById('qrModal'); m?.classList.add('hidden');
    const status = document.getElementById('qrStatus'); if (status) status.innerHTML = '';
    clearQrCountdown(); stopTxWatcher();
  }
  document.getElementById('qrClose')?.addEventListener('click', closeQrModal);
  document.getElementById('qrModal')?.addEventListener('click', (e)=>{ if (e.target.dataset.close === '1') closeQrModal(); });

  let TW_LOCK = false;
  async function submitTopup(ev) {
    ev.preventDefault();
    if (TW_LOCK) return false;
    TW_LOCK = true;
    try {
      const form = ev.currentTarget || ev.target;
      const walletCode = form.dataset.walletCode;
      const amountEl = form.querySelector('input[name="amount"]');
      const base = Math.floor(Number(amountEl?.value || 0));
      if (walletCode !== 'tw') { document.querySelector('#resp').innerHTML = `<div class="tp-inline-error">❌ วิธีนี้รองรับเฉพาะ TrueWallet</div>`; TW_LOCK = false; return false; }
      if (!Number.isFinite(base) || base < 1) { document.querySelector('#resp').innerHTML = `<div class="tp-inline-error">❌ จำนวนเงินขั้นต่ำ 1 บาท</div>`; TW_LOCK = false; return false; }

      const cRes = await fetch('/topup/create', { method:'POST', headers:{ 'Content-Type':'application/json' }, body: JSON.stringify({ amount: base, method:'tw', accountCode:'tw', walletCode:'tw' }) });
      const c = await cRes.json();
      if (!cRes.ok || !c?.ok) {
        if (c?.pendingTxId) window.currentTxId = c.pendingTxId;
        else { const err = c?.error || 'สร้างคำสั่งเติมเงินไม่สำเร็จ'; window.showMsg ? window.showMsg({ variant:'error', title:'ไม่สำเร็จ', text:err }) : alert(err); TW_LOCK = false; return false; }
      } else window.currentTxId = c.txId || c.id || c.pendingTxId;
      currentTxId = window.currentTxId;
      if (c?.mustCancelOld || c?.expiredPending) { await showExpiredPendingModal(c, 'tw'); TW_LOCK = false; return false; }

      const finalPayAmount = Number(c?.displayAmount ?? c?.payAmount ?? c?.amount ?? base);
      const gRes = await fetch('/topup/truewallet/gen/link', { method:'POST', headers:{ 'Content-Type':'application/json' }, body: JSON.stringify({ amount: finalPayAmount }) });
      const g = await gRes.json();
      if (!gRes.ok || !g?.url) { const err = g?.message || 'ไม่สามารถสร้างลิงก์ TrueWallet ได้'; window.showMsg ? window.showMsg({ variant:'error', title:'ไม่สำเร็จ', text:err }) : alert(err); TW_LOCK = false; return false; }

      try { stopTxWatcher(); } catch {}
      const img = document.getElementById('qrImage');
      if (img) img.src = `https://api.qrserver.com/v1/create-qr-code/?size=512x512&data=${encodeURIComponent(g.url)}`;
      document.getElementById('qrMethod')?.replaceChildren(document.createTextNode('TrueMoney Wallet'));
      document.getElementById('qrName')?.replaceChildren(document.createTextNode(g.accountName || 'RTSMM'));
      document.getElementById('qrNumber')?.replaceChildren(document.createTextNode(g.accountNumber || '-'));
      document.getElementById('qrAmountTw')?.replaceChildren(document.createTextNode(finalPayAmount.toLocaleString(undefined, { minimumFractionDigits:2, maximumFractionDigits:2 })));
      const expireSec = Number(c?.expiresIn || 300);
      openQrModal('tw', expireSec);
      startTxWatcher(window.currentTxId, expireSec);
      return false;
    } catch (err) {
      const msg = `ขัดข้อง: ${err.message}`;
      window.showMsg ? window.showMsg({ variant:'error', title:'ไม่สำเร็จ', text: msg }) : alert(msg);
      return false;
    } finally { TW_LOCK = false; }
  }
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.history-list .hx-card[open]').forEach(el => el.removeAttribute('open'));
  });
</script>

<style>
/* =========================================================
   TOPUP ENTERPRISE HIGH-END UI
   Theme-aware: uses layout variables first, with safe fallback.
   Supported layout vars: --page, --card, --text, --muted, --border, --accent
========================================================= */
.topup-enterprise{
  --tp-page: var(--page, #08090d);
  --tp-card: var(--card, #12141b);
  --tp-card-2: color-mix(in srgb, var(--card, #12141b) 86%, #ffffff 5%);
  --tp-text: var(--text, #f6f2e8);
  --tp-muted: var(--muted, #9aa1ad);
  --tp-border: var(--border, rgba(255,255,255,.10));
  --tp-accent: var(--accent, #e8bc53);
  --tp-accent-2: #f7da7c;
  --tp-danger: #ff6262;
  --tp-success: #4ade80;
  --tp-shadow: rgba(0,0,0,.34);
  --tp-soft: rgba(255,255,255,.055);
  color: var(--tp-text);
  position: relative;
  isolation: isolate;
  padding: clamp(12px, 2vw, 24px) 0 34px;
}
:where(html[data-theme="light"], html.light, body.light, [data-theme="light"]) .topup-enterprise{
  --tp-page: var(--page, #f6f7fb);
  --tp-card: var(--card, #ffffff);
  --tp-card-2: #fbfcff;
  --tp-text: var(--text, #151820);
  --tp-muted: var(--muted, #667085);
  --tp-border: var(--border, rgba(15,23,42,.12));
  --tp-soft: rgba(15,23,42,.045);
  --tp-shadow: rgba(15,23,42,.12);
}
.topup-enterprise *{ box-sizing:border-box; }
.topup-enterprise button,
.topup-enterprise input{ font: inherit; }

.tp-hero{
  position: relative;
  overflow: hidden;
  border: 1px solid var(--tp-border);
  border-radius: 30px;
  padding: clamp(22px, 3.2vw, 42px);
  background:
    radial-gradient(circle at 14% 0%, color-mix(in srgb, var(--tp-accent) 22%, transparent) 0%, transparent 34%),
    radial-gradient(circle at 88% 18%, rgba(255,255,255,.13) 0%, transparent 30%),
    linear-gradient(135deg, color-mix(in srgb, var(--tp-card) 82%, #000 18%), var(--tp-card-2));
  box-shadow: 0 24px 70px var(--tp-shadow), inset 0 1px 0 rgba(255,255,255,.08);
  margin-bottom: 18px;
}
.tp-hero-glow{ position:absolute; border-radius:999px; filter: blur(8px); opacity:.55; pointer-events:none; animation: tpFloat 7s ease-in-out infinite; }
.tp-hero-glow-a{ width:220px; height:220px; background:color-mix(in srgb, var(--tp-accent) 32%, transparent); right:8%; top:-90px; }
.tp-hero-glow-b{ width:150px; height:150px; background:rgba(99,102,241,.20); left:12%; bottom:-75px; animation-delay:-2.4s; }
@keyframes tpFloat{ 0%,100%{ transform:translate3d(0,0,0) scale(1); } 50%{ transform:translate3d(0,12px,0) scale(1.05); } }
.tp-hero-content{ position:relative; display:flex; justify-content:space-between; gap:28px; align-items:flex-end; }
.tp-eyebrow{ display:inline-flex; align-items:center; gap:10px; color:var(--tp-accent-2); font-size:13px; font-weight:800; text-transform:uppercase; letter-spacing:.12em; margin-bottom:12px; }
.tp-eyebrow span{ width:9px; height:9px; border-radius:50%; background:var(--tp-accent); box-shadow:0 0 18px var(--tp-accent); }
.tp-hero h1{ margin:0; font-size:clamp(28px, 4vw, 48px); letter-spacing:-.04em; line-height:1.04; }
.tp-hero p{ margin:12px 0 0; color:var(--tp-muted); max-width:720px; line-height:1.65; }
.tp-hero-metrics{ display:grid; grid-template-columns:repeat(3, minmax(92px,1fr)); gap:10px; min-width:min(420px,100%); }
.tp-metric{ padding:14px 16px; border-radius:18px; border:1px solid var(--tp-border); background:rgba(255,255,255,.05); backdrop-filter:blur(12px); }
.tp-metric small{ display:block; color:var(--tp-muted); font-size:12px; margin-bottom:4px; }
.tp-metric b{ font-size:24px; color:var(--tp-text); }

.tabs.tp-main-tabs{
  width:100%; display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:14px; padding:8px; border-radius:24px;
  background:linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.018)), color-mix(in srgb, var(--tp-card) 88%, transparent);
  border:1px solid var(--tp-border); box-shadow:0 18px 42px var(--tp-shadow), inset 0 1px 0 rgba(255,255,255,.06); margin:0 0 18px;
  backdrop-filter:blur(14px);
}
.tabs .tab{
  position:relative; width:100%; border:0; border-radius:18px; padding:16px 18px; cursor:pointer; color:var(--tp-muted); background:transparent;
  display:flex; align-items:center; justify-content:center; gap:10px; font-weight:600; transition:transform .22s ease, color .22s ease, background .22s ease, box-shadow .22s ease;
}
.tabs .tab:hover{ transform:translateY(-1px); color:var(--tp-text); background:var(--tp-soft); }
.tabs .tab.active{ color:#17130a; background:linear-gradient(135deg, #ffe28a, #e8bc53 54%, #bd8626); box-shadow:0 14px 30px color-mix(in srgb, var(--tp-accent) 27%, transparent), inset 0 1px 0 rgba(255,255,255,.52); }
.tabs .tab::after,.tabs .tab.active::after{ display:none!important; content:none!important; }
.tab-ico{ display:grid; place-items:center; width:22px; height:22px; border-radius:999px; background:rgba(0,0,0,.12); }
.tabpane{ display:none; animation:tpFadeUp .34s ease both; }
.tabpane.show{ display:block; }
@keyframes tpFadeUp{ from{ opacity:0; transform:translateY(10px); } to{ opacity:1; transform:none; } }

.tp-layout{ display:grid; grid-template-columns:minmax(280px, 360px) minmax(0,1fr); gap:18px; align-items:start; }
.tp-side-card,.tp-main-card,.tp-history-card{ border:1px solid var(--tp-border); border-radius:28px; background:linear-gradient(180deg, color-mix(in srgb, var(--tp-card) 92%, #fff 3%), var(--tp-card)); box-shadow:0 20px 54px var(--tp-shadow), inset 0 1px 0 rgba(255,255,255,.055); }
.tp-side-card{ padding:18px; position:sticky; top:16px; }
.tp-main-card,.tp-history-card{ padding:clamp(16px,2vw,22px); overflow:hidden; }
.tp-section-head{ display:flex; justify-content:space-between; align-items:center; gap:14px; margin-bottom:18px; }
.tp-section-head span{ display:block; color:var(--tp-accent); font-size:12px; font-weight:900; letter-spacing:.12em; text-transform:uppercase; margin-bottom:4px; }
.tp-section-head h2{ margin:0; font-size:clamp(20px,2vw,26px); letter-spacing:-.03em; }
