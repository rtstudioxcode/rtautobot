  <style>
    :root{
      --tos-bg: var(--page, var(--theme-bg, #f6f8fc));
      --tos-card: var(--card, var(--theme-surface, #ffffff));
      --tos-card-2: var(--theme-surface-2, #ffffff);
      --tos-text: var(--text, var(--theme-dark, #172033));
      --tos-muted: var(--muted, var(--theme-muted, #64748b));
      --tos-border: var(--border, var(--theme-border, rgba(15,23,42,.12)));
      --tos-accent: var(--accent, var(--theme-primary, #d9aa32));
      --tos-accent-2: var(--theme-accent, #7c3aed);
      --tos-green: #22c55e;
      --tos-blue: #38bdf8;
      --tos-danger: #fb7185;
      --tos-shadow: 0 28px 70px rgba(15,23,42,.13);
      --tos-radius: 30px;
      --tos-font: "Inter", "Noto Sans Thai", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      --tos-grad: linear-gradient(135deg, #ffe18a 0%, #d8a027 52%, #8d6416 100%);
    }

    html[data-theme="dark"], html.dark, html[data-bs-theme="dark"]{
      --tos-bg: var(--page, #06070a);
      --tos-card: var(--card, #15161b);
      --tos-card-2: #1b1c22;
      --tos-text: var(--text, #fff7e6);
      --tos-muted: var(--muted, #d8c79d);
      --tos-border: var(--border, rgba(255,255,255,.095));
      --tos-accent: var(--accent, #f5c84b);
      --tos-accent-2: #a78bfa;
      --tos-shadow: 0 38px 110px rgba(0,0,0,.46);
      color-scheme: dark;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:var(--tos-font);
      background:
        radial-gradient(950px 520px at 8% 4%, color-mix(in srgb, var(--tos-accent) 16%, transparent), transparent 62%),
        radial-gradient(920px 520px at 88% 12%, color-mix(in srgb, var(--tos-accent-2) 14%, transparent), transparent 60%),
        linear-gradient(180deg, color-mix(in srgb, var(--tos-bg) 92%, #10151f 8%) 0%, var(--tos-bg) 48%, var(--tos-bg) 100%);
      color:var(--tos-text);
      -webkit-font-smoothing:antialiased;
      text-rendering:optimizeLegibility;
    }
    a{color:inherit;text-decoration:none}
    ::selection{background:color-mix(in srgb,var(--tos-accent) 42%, transparent);color:var(--tos-text)}

    .tos-page{min-height:100vh;position:relative;overflow:hidden;padding:32px clamp(14px,2.5vw,44px) 0}
    .tos-page::before,
    .tos-page::after{content:"";position:fixed;pointer-events:none;z-index:0;border-radius:999px;filter:blur(20px);opacity:.72}
    .tos-page::before{width:420px;height:420px;left:-160px;top:120px;background:radial-gradient(circle,color-mix(in srgb,var(--tos-accent) 18%, transparent),transparent 66%)}
    .tos-page::after{width:520px;height:520px;right:-210px;bottom:-180px;background:radial-gradient(circle,color-mix(in srgb,var(--tos-blue) 13%, transparent),transparent 68%)}
    .tos-wrap{position:relative;z-index:1;width:min(1480px,100%);margin:0 auto}

    .tos-hero{
      position:relative;overflow:hidden;border:1px solid var(--tos-border);border-radius:36px;padding:clamp(28px,5vw,72px);box-shadow:var(--tos-shadow);
      background:
        radial-gradient(900px 420px at 82% 18%, color-mix(in srgb,var(--tos-accent-2) 12%, transparent), transparent 62%),
        radial-gradient(700px 330px at 5% 18%, color-mix(in srgb,var(--tos-accent) 18%, transparent), transparent 58%),
