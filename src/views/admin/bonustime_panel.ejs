}
async function loadYearlySummary(year) { try { const res = await fetch(`/admin/bonustime/yearly.json?year=${encodeURIComponent(year)}`); const raw = await res.json().catch(() => ({})); if (!res.ok || !raw.ok) return renderYearlySummary({ ...yearlyInitial, yearlyTotalRevenue: 0, yearlyPkg1Revenue: 0, yearlyPkg2Revenue: 0, yearlyOrderCount: 0, yearlyPkg1Count: 0, yearlyPkg2Count: 0, yearlyBestMonth: null, yearlyMonthly: [], year }); renderYearlySummary(raw); } catch { renderYearlySummary({ ...yearlyInitial, yearlyTotalRevenue: 0, yearlyPkg1Revenue: 0, yearlyPkg2Revenue: 0, yearlyOrderCount: 0, yearlyPkg1Count: 0, yearlyPkg2Count: 0, yearlyBestMonth: null, yearlyMonthly: [], year }); } }
