<script>
(() => {
  function syncBonustimeSwitchLabel(input) {
    if (!input || !input.classList || !input.classList.contains("bt-switch-input")) return;
    const row = input.closest(".bt-switch-row");
    const label = row?.querySelector(".bt-switch-label");
    if (!label) return;
    label.textContent = input.checked
      ? (input.dataset.on || "เปิด")
      : (input.dataset.off || "ปิด");
  }

  document.addEventListener("change", (event) => {
    const input = event.target.closest?.(".bt-switch-input");
    if (!input) return;
    syncBonustimeSwitchLabel(input);
  });

  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".bt-switch-input").forEach(syncBonustimeSwitchLabel);
  });
})();
</script>

