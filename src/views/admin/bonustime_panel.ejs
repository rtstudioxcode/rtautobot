<section class="page bonustime container bonustime-admin"
  data-update-endpoint="<%- typeof updateEndpoint !== 'undefined' ? updateEndpoint : '/admin/bonustime/tenant' %>">

  <!-- ===== Enterprise Hero: Bonustime Admin ===== -->
  <section class="btx-hero" aria-label="Bonustime Control Center">
    <div class="btx-hero-glow btx-hero-glow-a" aria-hidden="true"></div>
    <div class="btx-hero-glow btx-hero-glow-b" aria-hidden="true"></div>

    <div class="btx-hero-content">
      <span class="btx-kicker">✦ BONUSTIME CONTROL CENTER</span>
      <h1>Bonustime Panel</h1>
      <p>จัดการ Service, Serial Key, รายการเช่า และสรุปยอดขายแบบมืออาชีพในหน้าเดียว — เร็ว ลื่น และอ่านสถานะได้ชัดเจนทุกออเดอร์</p>
    </div>

    <div class="btx-hero-metrics" aria-label="ข้อมูลภาพรวม">
      <div class="btx-metric-card">
        <span>Services ทั้งหมด</span>
        <strong><%= (records || []).length.toLocaleString('th-TH') %></strong>
      </div>
      <div class="btx-metric-card">
        <span>ยังไม่ขาย</span>
        <strong><%= (records || []).filter(r => !r.serial_key).length.toLocaleString('th-TH') %></strong>
      </div>
      <div class="btx-metric-card">
        <span>ขายแล้ว</span>
        <strong><%= (records || []).filter(r => r.serial_key).length.toLocaleString('th-TH') %></strong>
      </div>
    </div>
  </section>

  <!-- แถบ Tab แบบเดียวกับหน้า bonustime -->
  <div class="bt-tabbar">
    <button class="bt-tab active" data-tab="orders">
      <span>รายการเช่า Service</span>
    </button>
    <button class="bt-tab" data-tab="summary">
      <span>สรุปยอดขายรายเดือน</span>
    </button>
  </div>

  <!-- TAB 1: รายการเช่า / Serial Key -->
  <section id="tab-orders" class="tabpane show">
    <%
      // ───────────────────────────────────────────────
      // แยก package ล่วงหน้า
      // ───────────────────────────────────────────────
      const pkg1 = [];   // Package 1 = สล็อต+บาคาร่า (LOTTO_ENABLED = false)
      const pkg2 = [];   // Package 2 = สล็อต+บาคาร่า+หวย (LOTTO_ENABLED = true)

      (records || []).forEach(rec => {
        if (rec.LOTTO_ENABLED) pkg2.push(rec);
        else pkg1.push(rec);
      });

      // นับ unsold
      let unsoldTotal = 0;
      let unsoldPkg1 = 0;
      let unsoldPkg2 = 0;

      (records || []).forEach(r => {
        if (!r.serial_key) {
          unsoldTotal++;
          if (r.LOTTO_ENABLED) unsoldPkg2++;
          else unsoldPkg1++;
        }
      });
    %>

    <header class="page-head">
      <div class="bt-head-left">
        <h1>รายการออเดอร์</h1>
      </div>

      <div class="bt-add-wrapper">
        <button id="btnAddTenant" class="bt-add-btn">
          <span class="bt-add-icon">＋</span>
          <span>เพิ่ม Service ใหม่</span>
        </button>
      </div>
    </header>

    <p class="unsold-summary">
      Services ที่เหลือ
      <strong><%= unsoldTotal %></strong> ออเดอร์ ·
      Package 1:
      <strong><%= unsoldPkg1 %> รายการ</strong> |
      Package 2:
      <strong><%= unsoldPkg2 %> รายการ</strong>
    </p>

    <%
      function renderPackage(title, list) {
    %>
      <section class="bt-section">
        <h2 class="bt-section-title">
          <%= title %>
          <span class="count">(<%= list.length %> รายการ)</span>
        </h2>

        <% if (!list.length) { %>
          <div class="card">
            <p class="muted">ไม่มีรายการในหมวดนี้</p>
          </div>
        <% } else { %>

          <div class="bt-admin-list">
            <% list.forEach((rec) => { %>

              <article
                class="bonustime-card admin"
                data-tenant-id="<%= rec.tenantId %>"
                data-serial="<%= rec.serial_key || '' %>">

                <!-- ========== HEADER (กดพับ/ขยาย) ========== -->
                <header class="collapse-head">
                  <div class="tenant">
                    <div class="tenant-name">
                      <%= rec.NAME || rec.name || ('Service: ' + (rec.tenantId || '-')) %>
                    </div>

                    <div class="tenant-meta small muted">
                      Service: <span><%= rec.serviceKey || rec.tenantId || '-' %></span>
                      <% if (rec.serial_key) { %>
                        · Serial: <span><%= rec.serial_key %></span>
                      <% } %>
                      <% if (rec.username) { %>
                        · Owner: <span><%= rec.username %></span>
                      <% } %>
                    </div>
                  </div>

                  <div class="status-right">
                    <% if (rec.serial_key) { %>
                      <div class="status-pill sold">
                        ขายไปแล้ว
                        <!-- <% if (rec.licenseDisabled) { %>
                          · ไม่มีวันหมดอายุ
                        <% } else if (rec.expiresAtLabel) { %>
                          · หมดอายุ <%= rec.expiresAtLabel %>
                        <% } %> -->
                      </div>

                      <%
                        const _licenseDisabled = Boolean(
                          rec.licenseDisabled ||
                          rec.LICENSE_DISABLED === true ||
                          rec.LICENSE_DISABLED === 'true' ||
                          rec.LICENSE_DISABLED === '1'
                        );
                      %>
                      <div
                        class="expiry-pill"
                        data-expiry="<%= _licenseDisabled ? '' : (rec.expiresAtInput || '') %>"
                        data-expiry-enabled="<%= _licenseDisabled ? '0' : '1' %>"
                        data-no-expiry="<%= _licenseDisabled ? '1' : '0' %>">
                        <%= _licenseDisabled ? 'ไม่มีวันหมดอายุ' : 'กำลังคำนวณ…' %>
                      </div>

                    <% } else { %>
                      <div class="status-pill free">
                        ยังไม่ขาย
                      </div>
                    <% } %>

                    <button type="button" class="bt-delete-btn" title="ลบ Service นี้">
                      ลบ
                    </button>

                    <% if (rec.resetEligible) { %>
                      <button type="button" class="bt-reset-btn" title="รีเซ็ต Service ที่หมดอายุเกิน 30 วัน">
                        รีเซ็ต
                      </button>
                    <% } %>

                    <div class="collapse-icon" aria-hidden="true">⌃</div>
                  </div>
                </header>

                <!-- ========== BODY (ฟอร์มแก้ไข auto-save) ========== -->
                <div class="collapse-body">
                  <div class="bt-grid">

                    <div class="bt-field">
                      <label>ชื่อ Server (NAME)</label>
                      <input
                        class="bt-edit"
                        data-field="NAME"
                        type="text"
                        value="<%= rec.NAME || '' %>">
                    </div>

                    <div class="bt-field">
                      <label>Service</label>
                      <input type="text" value="<%= rec.serviceKey || rec.tenantId || '' %>" readonly>
                    </div>

                    <div class="bt-field">
                      <label>Serial Key</label>
                      <input
                        class="bt-edit"
                        data-field="serial_key"
                        type="text"
                        value="<%= rec.serial_key || '' %>">
                    </div>

                    <div class="bt-field">
                      <label>เจ้าของ Service</label>
                      <input
                        type="text"
                        value="<%= rec.username || '-' %>"
                        readonly
                        class="owner-readonly">
                    </div>

                    <div class="bt-field">
                      <label>วันหมดอายุ</label>
                      <input
                        class="bt-edit"
                        data-field="expiresAt"
                        type="date"
                        value="<%= rec.licenseDisabled ? '' : (rec.expiresAtInput || '') %>"
                        <%= rec.licenseDisabled ? 'disabled' : '' %> >
                    </div>

                    <div class="bt-field bt-field-wide">
                      <label>ชื่อเจ้าของ</label>
                      <input
                        class="bt-edit"
                        data-field="ownerName"
                        type="text"
                        value="<%= rec.username || '-' %>">
                    </div>

                    <div class="bt-field bt-field-wide full-link-field">
                      <label>ลิงก์เชื่อมต่อ (Webhook)</label>
                      <div class="link-row full-link">
                        <input
                          class="bt-edit"
                          data-field="LINK"
                          type="text"
                          value="<%= rec.LINK || '' %>">
                        <button type="button" class="bt-copy-link" data-link="<%= rec.LINK || '' %>">
                          คัดลอก
                        </button>
                      </div>
                    </div>

                    <div class="bt-field bt-field-wide">
                      <label>โลโก้</label>
                      <input class="bt-edit" data-field="LOGO" type="text" value="<%= rec.LOGO || '' %>">
                    </div>

                    <div class="bt-field">
                      <label>ลิงก์เข้าสู่ระบบ</label>
                      <input class="bt-edit" data-field="LOGIN_URL" type="text" value="<%= rec.LOGIN_URL || '' %>">
                    </div>

                    <div class="bt-field">
                      <label>ลิงก์สมัครสมาชิก</label>
                      <input class="bt-edit" data-field="SIGNUP_URL" type="text" value="<%= rec.SIGNUP_URL || '' %>">
                    </div>

                    <div class="bt-field">
                      <label>ลิงก์ไลน์ติดต่อ</label>
                      <input class="bt-edit" data-field="LINE_ADMIN" type="text" value="<%= rec.LINE_ADMIN || '' %>">
                    </div>

                    <div class="bt-field bt-toggle-field">
                      <label>หวย</label>
                      <label class="bt-switch-row" aria-label="เปิดหรือปิดระบบหวย">
                        <input
                          class="bt-edit bt-switch-input"
                          data-field="LOTTO_ENABLED"
                          data-on="เปิดใช้งานหวย"
                          data-off="ปิดใช้งานหวย"
                          type="checkbox"
                          value="true"
                          <%= rec.LOTTO_ENABLED ? 'checked' : '' %>>
                        <span class="bt-switch-ui" aria-hidden="true"></span>
                        <span class="bt-switch-label"><%= rec.LOTTO_ENABLED ? 'เปิดใช้งานหวย' : 'ปิดใช้งานหวย' %></span>
                      </label>
                    </div>

                    <div class="bt-field bt-toggle-field">
                      <label>ระบบวันหมดอายุ</label>
                      <label class="bt-switch-row" aria-label="เปิดหรือปิดระบบวันหมดอายุ">
                        <input
                          class="bt-edit bt-switch-input"
                          data-field="LICENSE_DISABLED"
                          data-invert="true"
                          data-on="เปิดระบบวันหมดอายุ"
                          data-off="ปิดระบบวันหมดอายุ"
                          type="checkbox"
                          value="false"
                          <%= !rec.LICENSE_DISABLED ? 'checked' : '' %>>
                        <span class="bt-switch-ui" aria-hidden="true"></span>
                        <span class="bt-switch-label"><%= !rec.LICENSE_DISABLED ? 'เปิดระบบวันหมดอายุ' : 'ปิดระบบวันหมดอายุ' %></span>
                      </label>
                    </div>

                    <div class="bt-field">
                      <label>วันเริ่มต้นใช้งาน</label>
                      <input class="bt-edit" data-field="LICENSE_START_DATE" type="text" value="<%= rec.LICENSE_START_DATE || '' %>">
                    </div>

                    <div class="bt-field">
                      <label>ระยะเวลาใช้งาน (วัน)</label>
                      <input class="bt-edit" data-field="LICENSE_DURATION_DAYS" type="number" value="<%= rec.LICENSE_DURATION_DAYS || 0 %>">
                    </div>

                    <div class="bt-field bt-field-wide">
                      <label>CHANNEL_ACCESS_TOKEN</label>
                      <textarea class="bt-edit" data-field="CHANNEL_ACCESS_TOKEN" rows="2"><%= rec.CHANNEL_ACCESS_TOKEN || '' %></textarea>
                    </div>

                    <div class="bt-field bt-field-wide">
                      <label>CHANNEL_SECRET</label>
                      <input class="bt-edit" data-field="CHANNEL_SECRET" type="text" value="<%= rec.CHANNEL_SECRET || '' %>">
                    </div>

                    <div class="bt-field bt-field-wide">
                      <label>โน้ตภายใน</label>
                      <textarea class="bt-edit" data-field="note" rows="2"><%= rec.note || '' %></textarea>
                    </div>

                  </div>
                  
                  <div class="bt-admin-actions">
                      <button type="button" class="bt-action-btn primary" onclick="openServerMonitor('<%= rec.publicTenantKey || rec.tenantId %>')">
                          <i class="fa-solid fa-terminal"></i> <span>ดูรายงานเซิฟเวอร์</span>
                      </button>
                      
                      <button type="button" class="bt-action-btn restart" onclick="confirmRestartServer('<%= rec.publicTenantKey || rec.tenantId %>')">
                          <i class="fa-solid fa-rotate"></i> <span>รีสตาร์ท Server</span>
                      </button>

                      <button type="button" class="bt-action-btn redeploy" onclick="confirmRedeploy('<%= rec.publicTenantKey || rec.tenantId %>')">
                          <i class="fa-solid fa-cloud-arrow-up"></i> <span>Re-Deploy</span>
                      </button>

                      <div class="bt-flex-spacer"></div>
                  </div>

                </div>
              </article>

            <% }) %>
          </div>
        <% } %>
      </section>
    <%
      } // END function renderPackage
    %>

    <!-- เรียก render ทั้ง 2 group -->
    <%- renderPackage("Package 1 — สล็อต + บาคาร่า", pkg1) %>
    <%- renderPackage("Package 2 — สล็อต + บาคาร่า + หวย", pkg2) %>

  </section>

  <!-- Modal เพิ่มรายการ Bonustime -->
  <dialog id="addTenantModal">
    <form method="dialog" class="modal-form" id="addTenantForm">
      <h2 style="text-align:center;">เพิ่ม Service ใหม่</h2>

      <label>
        Service ที่ระบบจะสร้างให้อัตโนมัติ
        <input id="addTenantPreview" name="tenantPreview" type="text" readonly value="เลือกประเภทแพ็กเกจก่อนบันทึก">
        <small class="muted">ระบบจะตั้งชื่อแบบ pk1server1 / pk2server1 ต่อจากเลขล่าสุดใน MongoDB และสร้าง Webhook ให้ทันที</small>
      </label>

      <label class="bt-add-toggle-block">
        <span>หวย</span>
        <span class="bt-switch-row bt-switch-row--add" aria-label="เปิดหรือปิดระบบหวยสำหรับ Service ใหม่">
          <input
            class="bt-switch-input"
            id="addTenantLotto"
            name="lotto"
            type="checkbox"
            value="true"
            data-on="เปิดใช้งานหวย"
            data-off="ปิดใช้งานหวย">
          <span class="bt-switch-ui" aria-hidden="true"></span>
          <span class="bt-switch-label">ปิดใช้งานหวย</span>
        </span>
      </label>

      <label>
        ลิงก์เชื่อมต่อ (Webhook / LineOA Message API)
        <input id="addTenantLinkPreview" name="linkPreview" type="text" readonly value="ระบบจะสร้างให้หลังบันทึก">
      </label>

      <div class="modal-actions">
        <button type="button" class="btn" id="btnAddTenantCancel">ยกเลิก</button>
        <button type="submit" class="btn primary">บันทึก</button>
      </div>
    </form>
  </dialog>

  <!-- Tab 2: Ultra Mode Summary -->
  <section id="tab-summary" class="tabpane ultra-summary">
    <!-- HEADER + MONTH SELECTOR -->
    <header class="ultra-summary-head">
        <div class="ultra-summary-title">
        <h2>สรุปยอด Bonustime รายเดือน</h2>
        <p class="muted small">เลือกเดือนด้านขวาเพื่อดูยอดขาย</p>
        </div>

        <div class="ultra-month-select">
        <!-- <label for="monthSelect">เลือกเดือน</label> -->
        <select id="monthSelect">
            <!-- options เติมจาก JS -->
        </select>
        </div>
    </header>

    <!-- SUMMARY CARDS -->
    <div class="ultra-cards">
        <!-- ยอดขายรวม -->
        <section class="ultra-card glass" id="cardTotal">
          <h3>ยอดขายรวมเดือนนี้</h3>
          <div class="ultra-value">
            ฿ <span id="totalRevenue"><%= totalRevenue.toLocaleString() %></span>
          </div>
          <div class="ultra-trend <%= totalRevenue > 0 ? 'up' : 'flat' %>">
            <span class="dot"></span>
            <span class="label" id="labelTotal">
              <%= totalRevenue > 0 ? 'มีรายได้' : 'ยังไม่มีรายการ' %>
            </span>
          </div>
          <canvas class="spark" id="sparkTotal"></canvas>
        </section>

        <!-- Package 1 -->
        <section class="ultra-card glass" id="cardPkg1">
          <h3>Package 1 (สล็อต+บาคาร่า)</h3>
          <div class="ultra-value">
            ฿ <span id="pkg1Revenue"><%= pkg1Revenue.toLocaleString() %></span>
          </div>
          <div class="ultra-trend <%= pkg1Revenue > 0 ? 'up' : 'flat' %>">
            <span class="dot"></span>
            <span class="label" id="labelPkg1">
              <% if (pkg1Count > 0) { %>
                มี <%= pkg1Count %> รายการ
              <% } else { %>
                ยังไม่มีการขาย
              <% } %>
            </span>
          </div>
          <canvas class="spark" id="sparkPkg1"></canvas>
        </section>

        <!-- Package 2 -->
        <section class="ultra-card glass" id="cardPkg2">
          <h3>Package 2 (สล็อต+บาคาร่า+หวย)</h3>
          <div class="ultra-value">
            ฿ <span id="pkg2Revenue"><%= pkg2Revenue.toLocaleString() %></span>
          </div>
          <div class="ultra-trend <%= pkg2Revenue > 0 ? 'up' : 'flat' %>">
            <span class="dot"></span>
            <span class="label" id="labelPkg2">
              <% if (pkg2Count > 0) { %>
                มี <%= pkg2Count %> รายการ
              <% } else { %>
                ยังไม่มีการขาย
              <% } %>
            </span>
          </div>
          <canvas class="spark" id="sparkPkg2"></canvas>
        </section>

        <!-- จำนวนออเดอร์ -->
        <section class="ultra-card glass" id="cardOrders">
          <h3>จำนวนออเดอร์รวม</h3>
          <div class="ultra-value">
            <span id="orderCount"><%= orderCount %></span> ออเดอร์
          </div>
          <div class="ultra-trend <%= orderCount > 0 ? 'up' : 'flat' %>">
            <span class="dot"></span>
            <span class="label" id="labelOrders">
              <% if (orderCount > 0) { %>
                ทั้งหมด <%= orderCount %> รายการ
              <% } else { %>
                ยังไม่มีคำสั่งซื้อ
              <% } %>
            </span>
          </div>
          <canvas class="spark" id="sparkOrders"></canvas>
        </section>
    </div>

    <!-- CHARTS GRID -->
    <div class="ultra-charts-grid">
        <!-- MAIN CHART: DAILY SALES -->
        <section class="ultra-chart glass">
        <div class="ultra-chart-head">
            <h3>ยอดขายรายวัน (รวม)</h3>
        </div>
        <div class="ultra-chart-body">
            <canvas id="chartDaily"></canvas>
        </div>
        </section>

        <!-- SUB CHART: PKG COMPARISON -->
        <section class="ultra-chart glass">
        <div class="ultra-chart-head">
            <h3>ยอดขายแยกตามแพ็กเกจ</h3>
        </div>
        <div class="ultra-chart-body">
            <canvas id="chartPkgCompare"></canvas>
        </div>
        </section>
    </div>

    <!-- TOP 5 DAYS -->
    <section class="ultra-topdays glass">
      <h3>Top 5 วันขายดีที่สุดในเดือนนี้</h3>

      <div id="topDaysList" class="topdays-list">
          <% const topDays = Array.isArray(top5) ? top5 : (() => { try { return JSON.parse(top5 || "[]"); } catch { return []; } })(); %>

          <% if (!topDays.length) { %>
              <div class="muted" style="padding: 18px; text-align:center;">
                  ยังไม่มียอดการขายของเดือนนี้
              </div>
          <% } else { %>
              <% topDays.forEach((day, index) => { %>
                  <div class="top-item">
                      <div class="rank"><%= index + 1 %></div>
                      <div class="label">วันที่ <%= day.day %></div>
                      <div class="bar">
                          <div style="width: <%= totalRevenue > 0 ? (day.amount / totalRevenue) * 100 : 0 %>%"></div>
                      </div>
                      <div class="amount">฿ <%= day.amount.toLocaleString() %></div>
                  </div>
              <% }) %>
          <% } %>
      </div>
  </section>

    <!-- YEARLY SUMMARY -->
    <section class="ultra-yearly glass" aria-label="สรุปยอดขายรายปี Bonustime">
      <div class="ultra-yearly-head">
        <div>
          <h3>สรุปยอดขายรายปี</h3>
          <p class="muted small">ดูภาพรวมรายได้ Bonustime ทั้งปี แยกยอดรวม แพ็กเกจ และเดือนที่ทำยอดดีที่สุด</p>
        </div>
        <label class="ultra-year-select" for="yearSelect">
          <span>เลือกปี</span>
          <select id="yearSelect">
            <% const _yearNow = Number(typeof currentYear !== 'undefined' ? currentYear : new Date().getFullYear()); %>
            <% for (let y = _yearNow; y >= _yearNow - 4; y--) { %>
              <option value="<%= y %>" <%= y === _yearNow ? 'selected' : '' %>><%= y + 543 %></option>
            <% } %>
          </select>
        </label>
      </div>

      <div class="ultra-year-cards">
        <section class="ultra-card glass" id="yearCardTotal">
          <h3>ยอดขายรวมทั้งปี</h3>
          <div class="ultra-value">฿ <span id="yearlyTotalRevenue"><%= Number(yearlyTotalRevenue || 0).toLocaleString() %></span></div>
          <div class="ultra-trend <%= Number(yearlyTotalRevenue || 0) > 0 ? 'up' : 'flat' %>"><span class="dot"></span><span class="label" id="yearlyTotalLabel"><%= Number(yearlyOrderCount || 0) > 0 ? `ทั้งหมด ${Number(yearlyOrderCount || 0).toLocaleString('th-TH')} ออเดอร์` : 'ยังไม่มีรายการในปีนี้' %></span></div>
        </section>
        <section class="ultra-card glass" id="yearCardPkg1">
          <h3>Package 1 ทั้งปี</h3>
          <div class="ultra-value">฿ <span id="yearlyPkg1Revenue"><%= Number(yearlyPkg1Revenue || 0).toLocaleString() %></span></div>
