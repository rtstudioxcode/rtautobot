// ============================= RAILWAY =============================
let currentLogType = 'deploy';


function escapeHtmlRailway(value = '') {
    return String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
}

function railwayErrorText(data, fallback = 'ไม่สามารถเชื่อมต่อ Railway API ได้') {
    if (!data) return fallback;
    if (typeof data === 'string') return data || fallback;
    const parts = [data.message, data.error, data.status, data.details]
        .filter(Boolean)
        .map(x => typeof x === 'string' ? x : JSON.stringify(x));
    return parts.join('\n') || fallback;
}

// ฟังก์ชันปิดหน้าต่างและโหลดประวัติใหม่ (แก้ปัญหาข้อมูลหาย)
function closeMonitorAndRefresh() {
    const modal = document.getElementById('railwayMonitorModal');
    modal.close(); // ปิด Modal
    if(logInterval) clearInterval(logInterval); // หยุด Loop ดึง Log
    
    // สำคัญ: เรียกโหลดประวัติใหม่เพื่อให้รายการในการ์ดไม่หาย
    loadBonustimeHistory(); 
}

async function openServerMonitor(tenantId) {
    const modal = document.getElementById('railwayMonitorModal');
    const logBox = document.getElementById('logContainer');
    document.getElementById('monitorTitle').textContent = `รายงาน Server: ${tenantId}`;
    currentDeploymentId = null;
    window.currentBtTenantId = tenantId;
    currentServiceId = null;
    currentEnvironmentId = null;

    modal.showModal();
    logBox.innerHTML = '<div style="padding:20px; color:#9ca3af;">กำลังดึงข้อมูล Service...</div>';

    try {
        const res = await fetch(`/railway/service-info/${encodeURIComponent(tenantId)}`, { cache:'no-store', headers:{ 'accept':'application/json' } });
        const info = await res.json().catch(() => ({}));

        if (!res.ok || info.ok === false) {
            throw new Error(railwayErrorText(info));
        }

        window.currentBtTenantId = info.tenantId || tenantId;
        document.getElementById('monitorTitle').textContent = `รายงาน Server: ${window.currentBtTenantId}`;
        currentDeploymentId = info.deploymentId || null;
        currentServiceId = info.serviceId || null;
        currentEnvironmentId = info.environmentId || null;
        switchLogTab('deploy');

        if(logInterval) clearInterval(logInterval);
        logInterval = setInterval(() => {
            if (document.hidden) return;
            if (currentLogType === 'deploy') fetchLogs();
            else fetchHttpLogs();
        }, 8000);
    } catch (err) {
        logBox.innerHTML = `<div style="padding:20px; color:#fca5a5; white-space:pre-wrap;">${escapeHtmlRailway(err?.message || 'ไม่สามารถเชื่อมต่อ Railway API ได้')}</div>`;
    }
}
const noLogHtml = `
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 300px; color: #9ca3af; text-align: center;">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="opacity: 0.1; margin-bottom: 16px;">
            <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/>
            <path d="M7 8h10M7 12h10M7 16h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <div style="font-size: 16px; font-weight: 500; color: #f9fafb;">ยังไม่มีรายงานของ Server นี้ในเวลานี้</div>
    </div>
`;

// ฟังก์ชันดึงและวาด Deploy Logs แบบ Railway
function translateError(msg) {
    if (!msg) return msg;

    const text = msg.toLowerCase();

    // 🔴 LINE LIMIT
    if (text.includes('monthly limit') || text.includes('status: 429')) {
        return '🚫 LINE API: ส่งข้อความเกินลิมิตรายเดือนแล้ว กรุณาอัปเกรดแพ็กเกจหริือซื้อข้อความ LINE เพิ่ม';
    }

    // 🔴 LICENSE
    if (text.includes('license') && text.includes('expired')) {
        return '⛔ ระบบหมดอายุแล้ว กรุณาต่ออายุการใช้งาน';
    }

    // 🔴 TIMEOUT API
    if (text.includes('econnaborted') || text.includes('timeout')) {
        return '⚠️ เซิฟเวอร์ปลายทางไม่ตอบสนอง (Timeout) กรุณาลองใหม่อีกครั้ง หรือรีสตาร์ทระบบ';
    }

    // 🔴 MONGODB
    if (text.includes('mongonetworktimeout') || text.includes('poolcleared')) {
        return '💥 Database หลุดการเชื่อมต่อ (MongoDB Timeout) แนะนำให้รีสตาร์ท Server';
    }

    return msg;
}

async function fetchLogs() {
    const logBox = document.getElementById('logContainer');
    if (!currentDeploymentId) {
        logBox.innerHTML = '<div style="padding:20px; color:#fca5a5;">ไม่พบ Deployment ID ของ Service นี้</div>';
        return;
    }

    try {
        const res = await fetch(`/railway/logs/deploy/${encodeURIComponent(currentDeploymentId)}?tenantId=${encodeURIComponent(window.currentBtTenantId || '')}`, { cache:'no-store', headers:{ 'accept':'application/json' } });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || data.ok === false) {
            logBox.innerHTML = `<div style="padding:20px; color:#fca5a5; white-space:pre-wrap;">${escapeHtmlRailway(railwayErrorText(data, 'โหลด Railway logs ไม่สำเร็จ'))}</div>`;
            return;
        }
        const logs = Array.isArray(data.logs) ? data.logs : [];

        if (!logs.length) {
            logBox.innerHTML = noLogHtml;
            return;
        }

        const grouped = [];
        let buffer = [];
        for (const l of logs) {
            const msg = (l.message || '').trim();
            if (msg.includes('{') && buffer.length) {
                grouped.push(buffer);
                buffer = [];
            }
            buffer.push(l);
            if (msg.includes('}')) {
                grouped.push(buffer);
                buffer = [];
            }
        }
        if (buffer.length) grouped.push(buffer);

        logBox.innerHTML = grouped.map(group => {
            const first = group[0] || {};
            const raw = group.map(x => x.message || '').join('\n');
            const msg = translateError(raw);
            const lower = raw.toLowerCase();
            const isError = lower.includes('error') || lower.includes('failed') || lower.includes('429') || lower.includes('timeout');
            const isWarn = lower.includes('warn') || lower.includes('warning');
            let markColor = '#3b82f6', rowBg = 'transparent', textColor = '#d1d5db';
            if (isError) { markColor = '#ef4444'; rowBg = 'rgba(239,68,68,0.08)'; textColor = '#fca5a5'; }
            else if (isWarn) { markColor = '#05b84f'; rowBg = 'rgba(6, 199, 85,0.08)'; textColor = '#08b84f'; }
            const time = first.timestamp ? new Date(first.timestamp).toLocaleTimeString('th-TH', { hour12: false }) : '--:--:--';
            return `
                <div style="display:flex; gap:8px; padding:4px 12px; border-left:2px solid ${markColor}; background:${rowBg}; margin:0; line-height:1.2;">
                    <span style="color:#6b7280; font-size:11px; font-family:monospace; white-space:nowrap;">${escapeHtmlRailway(time)}</span>
                    <pre style="margin:0; color:${textColor}; font-size:12px; font-family:monospace; white-space:pre-wrap;">${escapeHtmlRailway(msg)}</pre>
                </div>`;
        }).join('');
        logBox.scrollTop = logBox.scrollHeight;
    } catch (e) {
        logBox.innerHTML = `<div style="padding:20px; color:#fca5a5; white-space:pre-wrap;">${escapeHtmlRailway(e?.message || 'โหลด Railway logs ไม่สำเร็จ')}</div>`;
    }
}
function switchLogTab(type) {
    currentLogType = type;
    document.getElementById('tab-btn-deploy').classList.toggle('active', type === 'deploy');
    
    const logBox = document.getElementById('logContainer');
    logBox.innerHTML = '<div style="padding:20px; color:#4b5563;">กำลังโหลด...</div>';
    
    if (type === 'deploy') fetchLogs();
    else fetchHttpLogs();
}

// ฟังก์ชันกลางสำหรับเรียกใช้ UI Confirm ที่สวยงามขึ้น
function showCustomConfirm({ title, desc, icon, color, bgColor, btnText, onConfirm }) {
    const modal = document.getElementById('btConfirmModal');
    const submitBtn = document.getElementById('uiConfirmSubmitBtn');
    const iconCircle = document.getElementById('uiConfirmIconCircle');
    
    document.getElementById('uiConfirmTitleText').textContent = title;
    document.getElementById('uiConfirmDescText').textContent = desc;
    
    // ตั้งค่าไอคอนและสีวงกลม
    iconCircle.innerHTML = icon;
    iconCircle.style.color = color;
    iconCircle.style.borderColor = color;
    iconCircle.style.background = bgColor || 'rgba(255,255,255,0.03)';
    
    // ตั้งค่าปุ่มยืนยัน
    submitBtn.textContent = btnText || "ยืนยัน";
    submitBtn.style.background = color || "#6366f1"; // Default เป็นสี Indigo
    
    // ล้าง Event เดิมก่อนใส่ใหม่
    const newSubmitBtn = submitBtn.cloneNode(true);
    submitBtn.parentNode.replaceChild(newSubmitBtn, submitBtn);

    newSubmitBtn.addEventListener('click', async () => {
        newSubmitBtn.disabled = true;
        newSubmitBtn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> กำลังดำเนินการ...';
        await onConfirm();
        newSubmitBtn.disabled = false;
        newSubmitBtn.textContent = btnText || "ยืนยัน";
        modal.close();
    });

    modal.showModal();
}

// 1. ฟังก์ชัน Restart (ธีมสีฟ้า)
async function confirmRestartServer(tenantId) {
    showCustomConfirm({
        title: "Restart System",
        desc: `คุณต้องการสั่ง Restart บริการของ ${tenantId} ใช่หรือไม่? ระบบจะหยุดทำงานชั่วคราว`,
        icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2v6h-6"></path><path d="M3 12a9 9 0 0 1 15-6.7L21 8"></path><path d="M3 22v-6h6"></path><path d="M21 12a9 9 0 0 1-15 6.7L3 16"></path></svg>`,
        color: "#38bdf8",
        bgColor: "rgba(56, 189, 248, 0.1)",
        btnText: "Restart ระบบ",
        onConfirm: async () => {
            try {
                const infoRes = await fetch(`/railway/service-info/${encodeURIComponent(tenantId)}`, { cache:'no-store', headers:{ 'accept':'application/json' } });
                const info = await infoRes.json().catch(() => ({}));
                if(!infoRes.ok || info.ok === false) throw new Error(railwayErrorText(info, 'ไม่พบข้อมูล Railway Service'));
                if(!info.serviceId || !info.environmentId) throw new Error('ไม่พบข้อมูล Service ID / Environment ID');

                const res = await fetch('/railway/restart', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ serviceId: info.serviceId, environmentId: info.environmentId, deploymentId: info.deploymentId, tenantId })
                });
                const out = await res.json().catch(() => ({}));
                if(res.ok && out.ok !== false) {
                    if (window.notify) notify.success("สำเร็จ", "สั่ง Restart เรียบร้อย!");
                    else alert("สั่ง Restart เรียบร้อย!");
                    switchLogTab('deploy');
                } else {
                    throw new Error(railwayErrorText(out, "ไม่สามารถสั่ง Restart ได้"));
                }
            } catch (err) {
                if (window.notify) notify.error("ผิดพลาด", err.message);
                else alert("Error: " + err.message);
            }
        }
    });
}
// 2. ฟังก์ชัน Redeploy (ธีมสีส้ม)
async function confirmRedeploy(tenantId) {
