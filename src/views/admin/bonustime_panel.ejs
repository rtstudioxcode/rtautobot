<script>
// ================== TAB SWITCH ==================
(() => {
  const root = document.querySelector('.bonustime-panel, .bonustime-admin, .bt-page') || document;

  const tabs = root.querySelectorAll(':scope > .bt-tabbar .bt-tab, :scope .bt-main-tabs .bt-tab');
  const panes = root.querySelectorAll(':scope > .tabpane');

  tabs.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab || btn.dataset.target;
      if (!tab) return;

      tabs.forEach((b) => b.classList.toggle('active', b === btn));
      panes.forEach((p) => {
        p.classList.toggle('show', p.id === 'tab-' + tab || p.id === 'section-' + tab);
      });
    });
  });
})();

// ================== ACCORDION ==================
(function () {
  const root = document.querySelector(".bonustime-admin");
  if (!root) return;

  root.addEventListener("click", (e) => {
    const card = e.target.closest(".bonustime-card.admin");
    if (!card) return;

    // ไม่ toggle ถ้าคลิกบน input/textarea/button/label/a/select
    if (e.target.closest("input, textarea, button, label, a, select")) return;

    card.classList.toggle("open");
  });
})();

// ================== AUTO-SAVE ==================
(function () {
  const root = document.querySelector(".bonustime-admin");
  if (!root) return;

  const endpointBase = root.dataset.updateEndpoint || "/admin/bonustime/tenant";
  const DEBOUNCE_MS = 500;
  const timers = new Map();

  function queueSave(input) {
    const card = input.closest(".bonustime-card.admin");
    if (!card) return;

    const tenantId = card.dataset.tenantId;
    const field = input.dataset.field;
    if (!tenantId || !field) return;

    const key = tenantId + "::" + field;
    if (timers.has(key)) clearTimeout(timers.get(key));

    const value = input.type === "checkbox"
      ? ((input.dataset.invert === "true") ? String(!input.checked) : String(input.checked))
      : input.value;

    if (input.type === "checkbox") {
      const label = input.closest(".bt-switch-row")?.querySelector(".bt-switch-label");
      if (label) label.textContent = input.checked ? (input.dataset.on || "เปิด") : (input.dataset.off || "ปิด");

      if (field === "LICENSE_DISABLED") {
        const expiryInput = card.querySelector('[data-field="expiresAt"]');
        if (expiryInput) expiryInput.disabled = !input.checked;
      }
    }

    input.classList.add("saving");

    const t = setTimeout(() => {
      saveField(tenantId, field, value, input);
      timers.delete(key);
    }, DEBOUNCE_MS);

    timers.set(key, t);
  }

  async function saveField(tenantId, field, value, input) {
    try {
      const res = await fetch(
        endpointBase + "/" + encodeURIComponent(tenantId),
        {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ field, value }),
        }
      );

      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.ok) {
        throw new Error(data.error || "บันทึกไม่สำเร็จ");
      }

      input.classList.remove("saving");
      input.classList.add("saved");
      setTimeout(() => input.classList.remove("saved"), 900);

      if (window.notify && notify.success) {
        notify.success("บันทึกสำเร็จ", "อัปเดตข้อมูลเรียบร้อยแล้ว");
      }
    } catch (err) {
      // console.error(err);
      input.classList.remove("saving");
      input.classList.add("error");
      if (window.notify && notify.error) {
        notify.error("บันทึกไม่สำเร็จ", "กรุณาลองใหม่อีกครั้ง");
      } else {
        alert("บันทึกไม่สำเร็จ");
      }
    }
  }

  root.addEventListener("input", (e) => {
    const el = e.target.closest(".bt-edit");
    if (!el) return;
    queueSave(el);
  });

  root.addEventListener("change", (e) => {
    const el = e.target.closest(".bt-edit");
    if (!el) return;
    queueSave(el);
  });
})();

// ================== ADD NEW TENANT ==================
(function () {
  const root = document.querySelector(".bonustime-admin");
  if (!root) return;

  const endpointBase = root.dataset.updateEndpoint || "/admin/bonustime/tenant";

  const btnAdd = document.getElementById("btnAddTenant");
  const dlg = document.getElementById("addTenantModal");
  const form = document.getElementById("addTenantForm");
  const btnCancel = document.getElementById("btnAddTenantCancel");

  if (!btnAdd || !dlg || !form) return;

  btnAdd.addEventListener("click", () => {
    form.reset();
    dlg.showModal();
  });

  btnCancel.addEventListener("click", () => dlg.close());

  dlg.addEventListener("click", (e) => {
    if (e.target === dlg) dlg.close();
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const fd = new FormData(form);
    const lotto = form.querySelector('[name="lotto"]')?.checked ? "true" : "false";

    try {
      const res = await fetch(endpointBase, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          LOTTO_ENABLED: lotto === "true",
        }),
      });

      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.ok) {
        throw new Error(data.error || "สร้างรายการไม่สำเร็จ");
      }

      dlg.close();
      if (window.notify && notify.success) {
        notify.success("เพิ่ม Service แล้ว", "สร้าง Tenant ใหม่สำเร็จ");
      }
      window.location.reload();
    } catch (err) {
      // console.error(err);
      if (window.notify && notify.error) {
        notify.error("สร้างรายการไม่สำเร็จ", err.message || "กรุณาลองใหม่อีกครั้ง");
      } else {
        alert("สร้างรายการไม่สำเร็จ: " + (err.message || ""));
      }
    }
  });
})();

// ================== DELETE TENANT (ปุ่มลบ Service) ==================
(function () {
  const root = document.querySelector(".bonustime-admin");
  if (!root) return;

  const endpointBase = root.dataset.updateEndpoint || "/admin/bonustime/tenant";

  root.addEventListener("click", async (e) => {
    const btn = e.target.closest(".bt-delete-btn");
    if (!btn) return;

    const card = btn.closest(".bonustime-card.admin");
    if (!card) return;

    const tenantId = card.dataset.tenantId;
    if (!tenantId) return;

    const name =
      card.querySelector(".tenant-name")?.textContent?.trim() || tenantId;

    // ใช้ uiConfirm จาก layout.ejs ถ้ามี
    let confirmed = false;
    if (window.uiConfirm) {
      confirmed = await uiConfirm({
        variant: "danger",
        title: "ยืนยันลบ Service",
        sub: `คุณต้องการลบ Service นี้ (${name}) ออกจากระบบถาวรหรือไม่ ?`,
        okText: "ลบ Service",
        cancelText: "ยกเลิก",
        focus: "cancel",
      });
    } else {
      // fallback ถ้า uiConfirm ใช้ไม่ได้
      confirmed = window.confirm(
        `คุณต้องการลบ Service นี้ (${name}) ออกจากระบบถาวรหรือไม่ ?`
      );
    }

    if (!confirmed) return;

    try {
      const res = await fetch(
        `${endpointBase}/${encodeURIComponent(tenantId)}`,
        { method: "DELETE" }
      );
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.ok) {
        throw new Error(data.error || "ลบไม่สำเร็จ");
      }

      card.remove();

      if (window.notify && notify.success) {
        notify.success("ลบสำเร็จ", "ลบ Service นี้ออกจากรายชื่อเรียบร้อยแล้ว");
      }
    } catch (err) {
      // console.error(err);
      if (window.notify && notify.error) {
        notify.error("ลบไม่สำเร็จ", err.message || "กรุณาลองใหม่อีกครั้ง");
      } else {
        alert("ลบไม่สำเร็จ: " + (err.message || ""));
      }
    }
  });
})();

// ================== RESET EXPIRED TENANT ==================
(function () {
  const root = document.querySelector(".bonustime-admin");
  if (!root) return;

  const endpointBase = root.dataset.updateEndpoint || "/admin/bonustime/tenant";

  root.addEventListener("click", async (e) => {
    const btn = e.target.closest(".bt-reset-btn");
    if (!btn) return;

    const card = btn.closest(".bonustime-card.admin");
    if (!card) return;

    const tenantId = card.dataset.tenantId;
    if (!tenantId) return;

    const name = card.querySelector(".tenant-name")?.textContent?.trim() || tenantId;

    let confirmed = false;
    if (window.uiConfirm) {
      confirmed = await uiConfirm({
        variant: "warn",
        title: "ยืนยันรีเซ็ต Service",
        sub: `รีเซ็ต ${name} ให้กลับเป็น Service ว่างพร้อมขายใหม่หรือไม่? ระบบจะลบ Serial Key และข้อมูลเจ้าของเดิมออก`,
        okText: "รีเซ็ต Service",
        cancelText: "ยกเลิก",
        focus: "cancel",
      });
    } else {
      confirmed = window.confirm(`รีเซ็ต ${name} ให้กลับเป็น Service ว่างพร้อมขายใหม่หรือไม่?`);
    }

    if (!confirmed) return;

    btn.disabled = true;
    btn.textContent = "กำลังรีเซ็ต…";

    try {
      const res = await fetch(`${endpointBase}/${encodeURIComponent(tenantId)}/reset`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.ok) throw new Error(data.error || "รีเซ็ตไม่สำเร็จ");

      if (window.notify && notify.success) {
        notify.success("รีเซ็ตสำเร็จ", "Service กลับเป็นรายการพร้อมขายใหม่แล้ว");
      }
      window.location.reload();
    } catch (err) {
      btn.disabled = false;
      btn.textContent = "รีเซ็ต";
      if (window.notify && notify.error) {
        notify.error("รีเซ็ตไม่สำเร็จ", err.message || "กรุณาลองใหม่อีกครั้ง");
      } else {
        alert("รีเซ็ตไม่สำเร็จ: " + (err.message || ""));
      }
    }
  });
})();

// ================== COPY LINK BUTTON ==================
(function () {
  const root = document.querySelector(".bonustime-admin");
  if (!root) return;

  root.addEventListener("click", async (e) => {
    const btn = e.target.closest(".bt-copy-link");
    if (!btn) return;

    const link = btn.dataset.link || btn.previousElementSibling?.value || "";
    if (!link) {
      if (window.notify && notify.error) {
        notify.error("คัดลอกไม่สำเร็จ", "ยังไม่มีลิงก์ให้คัดลอก");
      } else {
        alert("ยังไม่มีลิงก์ให้คัดลอก");
      }
      return;
    }

    try {
      await navigator.clipboard.writeText(link);
      if (window.notify && notify.success) {
        notify.success("คัดลอกแล้ว", "คัดลอกลิงก์เชื่อมต่อเรียบร้อย");
      }
    } catch {
      if (window.notify && notify.error) {
        notify.error("คัดลอกไม่สำเร็จ", "กรุณาลองใหม่อีกครั้ง");
      }
    }
  });
})();

// ================== EXPIRY COUNTDOWN BADGES ==================
(function () {
  const pills = document.querySelectorAll(
    ".bonustime-admin .expiry-pill"
  );
  if (!pills.length) return;

  function setNoExpiry(el) {
    el.textContent = "ไม่มีวันหมดอายุ";
    el.classList.remove("expired", "active");
    el.classList.add("no-expiry");

    const statusPill = el.closest(".status-right")?.querySelector(".status-pill");
    statusPill?.classList.remove("expired");
  }

  function updateAll() {
    const now = new Date();

    pills.forEach((el) => {
      const dateStr = (el.dataset.expiry || "").trim();
      const noExpiry =
        el.dataset.noExpiry === "1" ||
        el.dataset.noExpiry === "true" ||
        el.dataset.expiryEnabled === "0" ||
        el.dataset.expiryEnabled === "false" ||
        !dateStr;

      if (noExpiry) {
        setNoExpiry(el);
        return;
      }

      // นับถึง 23:59:59 ของวันหมดอายุ
      const end = new Date(dateStr + "T23:59:59");
      if (isNaN(end.getTime())) {
        setNoExpiry(el);
        return;
      }

      const diffMs = end.getTime() - now.getTime();

      if (diffMs <= 0) {
        el.textContent = "หมดอายุแล้ว";
        el.classList.add("expired");
        el.classList.remove("active", "no-expiry");

        el.closest(".status-right")
          ?.querySelector(".status-pill")
          ?.classList.add("expired");

        return;
      }

      const totalMinutes = Math.floor(diffMs / 60000);
      const days = Math.floor(totalMinutes / (60 * 24));
      const hours = Math.floor((totalMinutes - days * 60 * 24) / 60);
      const minutes = totalMinutes % 60;

      let label = "เหลือ ";
      if (days > 0) {
        label += `${days} วัน `;
      }
      label += `${String(hours).padStart(2, "0")} ชม. `;
      label += `${String(minutes).padStart(2, "0")} นาที`;

      el.textContent = label;
      el.classList.remove("expired", "no-expiry");
      el.classList.add("active");

      el.closest(".status-right")
        ?.querySelector(".status-pill")
        ?.classList.remove("expired");
    });
  }

  updateAll();
  setInterval(updateAll, 30_000);
})();

