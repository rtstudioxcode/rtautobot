}

/* Tab bar */
.bonustime-admin .bt-tabbar {
  display: flex;
  border-bottom: 1px solid var(--border, #262932);
  margin: 10px 0 18px;
}
.bonustime-admin .bt-tab {
  flex: 1;
  position: relative;
  padding: 8px 10px 10px;
  border: none;
  background: transparent;
  color: var(--muted, #9ca3af);
  font-size: 14px;
  cursor: pointer;
  text-align: center;
}
.bonustime-admin .bt-tab span {
  position: relative;
  z-index: 1;
}
.bonustime-admin .bt-tab::after {
  content: "";
  position: absolute;
  inset-inline: 0;
  bottom: -1px;
  height: 2px;
  background: transparent;
  transition: background 0.18s ease;
}
.bonustime-admin .bt-tab.active {
  color: var(--accent, #05b84f);
  font-weight: 300;
}
.bonustime-admin .bt-tab.active::after {
  background: var(--accent, #05b84f);
}
.bonustime-admin .tabpane {
  display: none;
}
.bonustime-admin .tabpane.show {
  display: block;
}

/* List */
.bonustime-admin .bt-admin-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.bonustime-admin .bonustime-card.admin {
  background: var(--card);
  border: 1px solid #05b84f40;
  border-radius: 18px;
  padding: 14px 16px;
  font-size: 14px;
  color: var(--text);
  transition:
    background 0.15s ease,
    border-color 0.15s ease,
    box-shadow 0.15s ease;
  width: 100%;
  max-width: 1980px;
  margin-inline: auto;
}
.bonustime-admin .bonustime-card.admin:hover {
  border-color: var(--accent, #05b84f);
  box-shadow: 0 0 0 1px rgba(6, 199, 85, 0.08);
}
.bonustime-admin .bonustime-card.admin .collapse-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  cursor: pointer;
  gap: 12px;
}
.bonustime-admin .bonustime-card.admin .tenant-name {
  font-weight: 300;
  font-size: 15px;
}
.bonustime-admin .bonustime-card.admin .tenant-meta {
  margin-top: 2px;
}
.bonustime-admin .bonustime-card.admin .status-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8px;
}
.bonustime-admin .bonustime-card.admin .status-pill {
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: var(--page);
  color: var(--muted);
  white-space: nowrap;
}
.bonustime-admin .bonustime-card.admin .status-pill.sold {
  background: rgba(34, 197, 94, 0.08);
  color: #4ade80;
  border-color: rgba(34, 197, 94, 0.4);
}
.bonustime-admin .bonustime-card.admin .status-pill.free {
  background: rgba(148, 163, 184, 0.1);
  color: #e5e7eb;
}
/* badge นับถอยหลัง */
.bonustime-admin .expiry-pill {
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 999px;
  border: 1px solid rgba(6, 199, 85, 0.7);
  background: rgba(6, 199, 85, 0.15);
  color: #21b95c;
  white-space: nowrap;
}

/* ถ้าหมดอายุแล้ว */
.bonustime-admin .expiry-pill.expired {
  border-color: rgba(248, 113, 113, 0.9);
  background: rgba(127, 29, 29, 0.9);
  color: #fee2e2;
}

/* ถ้า Service ไม่เปิดระบบวันหมดอายุ */
.bonustime-admin .expiry-pill.no-expiry {
  border-color: rgba(6, 199, 85, 0.52);
  background: rgba(6, 199, 85, 0.10);
  color: #08b84f;
}

/* ปุ่มลบ Service */
.bt-delete-btn {
  border-radius: 999px;
  border: 1px solid rgba(248, 113, 113, 0.6);
  background: rgba(127, 29, 29, 0.9);
  color: #fee2e2;
  font-size: 12px;
  padding: 4px 10px;
  cursor: pointer;
  transition:
    background 0.15s ease,
    border-color 0.15s ease,
    transform 0.1s ease,
    box-shadow 0.1s ease;
}
.bt-delete-btn:hover {
  background: rgba(185, 28, 28, 1);
  border-color: rgba(248, 113, 113, 1);
  box-shadow: 0 0 0 1px rgba(248, 113, 113, 0.4);
}
.bt-delete-btn:active {
  transform: translateY(1px);
  box-shadow: none;
}


/* ปุ่มรีเซ็ต Service ที่หมดอายุเกิน 30 วัน */
.bt-reset-btn {
  border-radius: 999px;
  border: 1px solid rgba(6, 199, 85, 0.62);
  background: linear-gradient(135deg, rgba(6, 199, 85, 0.18), rgba(0, 184, 74, 0.10));
  color: #08b84f;
  font-size: 12px;
  padding: 4px 10px;
  cursor: pointer;
  transition: background 0.15s ease, border-color 0.15s ease, transform 0.1s ease, box-shadow 0.1s ease;
}
.bt-reset-btn:hover {
  background: linear-gradient(135deg, rgba(6, 199, 85, 0.34), rgba(0, 184, 74, 0.20));
  border-color: rgba(6, 199, 85, 0.95);
  box-shadow: 0 0 0 1px rgba(6, 199, 85, 0.22), 0 10px 24px rgba(0, 184, 74, 0.14);
}
.bt-reset-btn:active {
  transform: translateY(1px);
  box-shadow: none;
}

/* caret */
.bonustime-admin .bonustime-card.admin .collapse-icon {
  font-size: 12px;
  transform: rotate(180deg);
  transition: transform 0.15s ease;
  opacity: 0.7;
}
.bonustime-admin .bonustime-card.admin .collapse-body {
  border-top: 1px solid var(--border);
  margin-top: 10px;
  padding-top: 10px;
  display: none;
}
.bonustime-admin .bonustime-card.admin.open .collapse-body {
  display: block;
}
.bonustime-admin .bonustime-card.admin.open .collapse-icon {
  transform: rotate(0deg);
}

/* grid */
.bonustime-admin .bt-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px 16px;
}
.bonustime-admin .bt-field {
  display: flex;
  flex-direction: column;
  gap: 4px;
  font-size: 13px;
}
.bonustime-admin .bt-field-wide {
  grid-column: 1 / -1;
}
.bonustime-admin .bt-field label {
  color: var(--muted);
}
.bonustime-admin .bt-field input,
.bonustime-admin .bt-field textarea,
.bonustime-admin .bt-field select {
  border-radius: 10px;
  border: 1px solid var(--border);
  background: var(--page);
  color: var(--text);
  padding: 6px 8px;
  font: inherit;
  resize: vertical;
}
.bonustime-admin .bt-field input[readonly] {
  opacity: 0.8;
  cursor: default;
}

/* row link + copy */
.link-row {
  display: flex;
  gap: 8px;
}
.bt-copy-link {
  border-radius: 999px;
  border: 1px solid var(--border);
  background: var(--page);
  color: var(--accent);
  font-size: 12px;
  padding: 4px 10px;
  cursor: pointer;
  white-space: nowrap;
}
.bt-copy-link:hover {
  border-color: var(--accent);
}

/* สถานะ input ขณะบันทึก */
.bonustime-admin .bt-edit.saving {
  border-color: rgba(59, 130, 246, 0.7);
}
.bonustime-admin .bt-edit.saved {
  border-color: rgba(34, 197, 94, 0.85);
}
.bonustime-admin .bt-edit.error {
  border-color: rgba(239, 68, 68, 0.85);
}

/* Add button + modal */
.bt-add-wrapper {
  display: flex;
  justify-content: flex-end;
  margin: 8px 0 18px;
}
.bt-add-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 22px;
  border-radius: 999px;
  border: none;
  cursor: pointer;
  background: linear-gradient(135deg, #05b84f, #05b84f);
  color: #111827;
  font-size: 14px;
  font-weight: 300;
  letter-spacing: 0.02em;
  box-shadow: 0 8px 18px rgba(6, 199, 85, 0.25);
  transition:
    transform 0.15s ease,
    box-shadow 0.15s ease,
    background 0.15s ease,
    filter 0.15s ease;
}
.bt-add-btn .bt-add-icon {
  width: 22px;
  height: 22px;
  border-radius: 999px;
  display: grid;
  place-items: center;
  background: rgba(17, 24, 39, 0.08);
  font-size: 16px;
}
.bt-add-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 12px 24px rgba(6, 199, 85, 0.3);
  filter: brightness(1.02);
}
.bt-add-btn:active {
  transform: translateY(0);
  box-shadow: 0 6px 14px rgba(0, 0, 0, 0.45);
  filter: brightness(0.96);
}

#addTenantModal {
  border: none;
  border-radius: 16px;
  padding: 0;
  background: transparent;
}
#addTenantModal::backdrop {
  background: rgba(0, 0, 0, 0.6);
}
#addTenantForm.modal-form {
  background: var(--card);
  color: var(--text);
  padding: 18px 18px 14px;
  border-radius: 16px;
  min-width: min(360px, 90vw);
  display: flex;
  flex-direction: column;
  gap: 10px;
}
#addTenantForm label {
  font-size: 13px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  color: var(--muted);
}
#addTenantForm input,
#addTenantForm select {
  border-radius: 10px;
  border: 1px solid var(--border);
  background: var(--page);
  color: var(--text);
  padding: 6px 8px;
  font: inherit;
}
#addTenantForm .modal-actions {
  margin-top: 10px;
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}

/* Responsive */
@media (max-width: 768px) {
  .bonustime-admin {
    padding-left: 0;
    padding-right: 0;
  }
  .bonustime-admin .bt-tabbar {
    width: 100%;
    margin: 0 0 16px 0;
    padding-inline: 12px;
  }
  .bonustime-admin .bt-tab {
    flex: 1 1 auto;
    width: 100%;
  }
  .bonustime-admin .bt-admin-list {
    align-items: center;
  }
  .bonustime-admin .bonustime-card.admin {
    width: 99%;
    max-width: 720px;
    padding: 12px 12px;
  }
  .bonustime-admin .bt-grid {
    grid-template-columns: 1fr;
  }
  .bonustime-admin .bonustime-card.admin .status-right {
    align-items: flex-start;
  }
}
@media (max-width: 480px) {
  .bonustime-admin .bt-tabbar {
    padding-inline: 8px;
  }
  .bonustime-admin .bonustime-card.admin {
    width: 99%;
    max-width: 100%;
    border-radius: 14px;
  }
}

/* ================================
 * ULTRA SUMMARY TAB (BONUSTIME)
 * ================================ */
.ultra-summary {
  --ultra-gap: 8px;
  --ultra-radius: 18px;
  --ultra-card-bg: var(--card, #14151a);
  --ultra-border: var(--border, #262730);
  --ultra-text: var(--text, #ffffff);
  --ultra-muted: var(--muted, #a1a1aa);
  --ultra-accent: var(--accent, #05b84f);
  --ultra-bg-soft: rgba(6, 199, 85, 0.06);

  padding-top: 10px;
  padding-bottom: 18px;
  display: flex;
  flex-direction: column;
  gap: var(--ultra-gap);
}

/* HEADER */
.ultra-summary-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 8px;
}

.ultra-summary-title h2 {
  font-size: clamp(18px, 2.2vw, 22px);
  margin: 0;
}

.ultra-summary-title p {
  margin: 4px 0 0;
  color: var(--ultra-muted);
}

/* MONTH SELECTOR */
.ultra-month-select {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
}

.ultra-month-select label {
  color: var(--ultra-muted);
}

.ultra-month-select select {
  background: var(--ultra-card-bg);
  color: var(--ultra-text);
  border-radius: 999px;
  border: 1px solid var(--ultra-border);
  padding: 6px 14px;
  font-size: 14px;
}

/* SUMMARY CARDS */
.ultra-cards {
  display: grid;
  margin-bottom: 20px;
  grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
  gap: var(--ultra-gap);
}

.ultra-card.glass {
  background: linear-gradient(135deg, rgba(24, 24, 27, 0.96), rgba(15, 23, 42, 0.96));
  border-radius: var(--ultra-radius);
  border: 1px solid var(--ultra-border);
  padding: 14px 16px 12px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.ultra-card h3 {
  font-size: 14px;
  font-weight: 500;
  margin: 0;
  color: var(--ultra-muted);
}

.ultra-card .ultra-value {
  font-size: clamp(22px, 2.4vw, 26px);
  font-weight: 600;
  color: var(--ultra-text);
}

.ultra-card .ultra-value span {
  font-variant-numeric: tabular-nums;
}

.ultra-trend {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--ultra-muted);
}

.ultra-trend .dot {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: var(--ultra-muted);
}

.ultra-trend.up .dot {
  background: #4ade80;
}

.ultra-trend.flat .dot {
  background: #a1a1aa;
}

/* mini spark charts on cards */
.ultra-card .spark {
  margin-top: 8px;
  width: 100% !important;
  height: 60px !important;   /* ถ้าเตี้ยไป/สูงไปลอง 50–70px ตามชอบ */
}

/* CHART GRID */
.ultra-charts-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
  margin-bottom: 22px;  
  gap: var(--ultra-gap);
}

@media (max-width: 960px) {
  .ultra-charts-grid {
    grid-template-columns: minmax(0, 1fr);
  }
}

/* MAIN / SUB CHART SECTIONS */
.ultra-chart.glass {
  background: radial-gradient(circle at top left, rgba(6, 199, 85, 0.12), transparent 46%),
              var(--ultra-card-bg);
  border-radius: var(--ultra-radius);
  border: 1px solid var(--ultra-border);
  padding: 12px 16px 14px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-height: 230px;
}

.ultra-chart-head h3 {
  margin: 0;
  font-size: 14px;
  color: var(--ultra-muted);
}

.ultra-chart-body {
  margin-top: 4px;
  flex: 1;
  display: flex;
  align-items: stretch;
}

.ultra-chart-body canvas {
  width: 100% !important;
  height: auto !important;
  aspect-ratio: 16 / 7;
  max-height: 260px;
  display: block;
}

/* TOP 5 DAYS */
.ultra-topdays.glass {
  background: var(--ultra-card-bg);
  border-radius: var(--ultra-radius);
  border: 1px solid var(--ultra-border);
  padding: 14px 16px;
  margin-top: 4px;
}

.ultra-topdays h3 {
  margin: 0 0 10px;
  font-size: 14px;
  color: var(--ultra-muted);
}

.topdays-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.topdays-list .top-item {
  display: grid;
  grid-template-columns: 28px minmax(0, 1.4fr) minmax(0, 2fr) max-content;
  gap: 8px;
  align-items: center;
  font-size: 13px;
}

.topdays-list .rank {
  width: 22px;
  height: 22px;
  border-radius: 999px;
  display: grid;
  place-items: center;
  background: var(--ultra-bg-soft);
  color: var(--ultra-accent);
  font-size: 12px;
}

.topdays-list .label {
  color: var(--ultra-text);
}

.topdays-list .bar {
  height: 6px;
  border-radius: 999px;
  background: rgba(39, 39, 42, 0.9);
  overflow: hidden;
}

.topdays-list .bar > div {
  height: 100%;
  background: linear-gradient(90deg, #05b84f, #08b84f);
  border-radius: inherit;
}

.topdays-list .amount {
  font-variant-numeric: tabular-nums;
  color: var(--ultra-muted);
  white-space: nowrap;
}

/* small screens */
@media (max-width: 640px) {
  .ultra-summary-head {
    flex-direction: column;
    align-items: flex-start;
  }

  .topdays-list .top-item {
    grid-template-columns: 24px minmax(0, 1fr);
    grid-template-rows: auto auto;
    column-gap: 8px;
    row-gap: 4px;
  }
  .topdays-list .bar {
    grid-column: 2 / -1;
  }
  .topdays-list .amount {
    grid-column: 2 / -1;
    justify-self: flex-end;
  }
}

.spark-tooltip {
  pointer-events: none;
  will-change: transform, opacity;
}


/* ============================
  MOBILE FIX: Pill ไม่ล้นอีกต่อไป
============================ */
@media (max-width: 640px) {

  /* บีบ collapse-head ให้เป็น column ทั้งชุด */
  .collapse-head {
    display: flex !important;
    flex-direction: column !important;
    align-items: flex-start !important;
    width: 100% !important;
    gap: 10px;
  }

  /* ฝั่งชื่อ service */
  .collapse-head .tenant {
    width: 100% !important;
  }

  /* ฝั่ง pill + ปุ่มลบ */
  .collapse-head .status-right {
    width: 100% !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: flex-start !important;
    gap: 8px !important;
    position: relative !important;
  }

  /* pill ทั้งหมด */
  .status-pill,
  .expiry-pill {
    width: 100% !important;
    text-align: center !important;
    display: block !important;
  }

  /* ปุ่มลบ */
  .bt-delete-btn {
    align-self: flex-end !important;
    margin-top: 4px !important;
    position: relative !important;
    width: 100% !important;
    z-index: 3 !important;
  }

  /* collapse icon */
  .collapse-icon {
    align-self: flex-end !important;
    position: relative !important;
    z-index: 3 !important;
  }

  .bt-field input[type="date"] {
    width: 100% !important;
    max-width: 100% !important;
    box-sizing: border-box !important;
    -webkit-appearance: none; /* ปิด UI บังคับของ iOS */
    padding-right: 12px;      /* กันล้นขอบขวา */
  }

  /* ถ้าตัว grid บีบอยู่ ให้บังคับให้ field เป็นบล็อกเต็มแถว */
  .bt-field {
    width: 100% !important;
  }
}

/* Desktop — แสดงแบบเต็มแถว (Current behavior OK) */
.full-link-field .link-row.full-link {
  display: flex;
  width: 100%;
  gap: 10px;
}

.full-link-field input.bt-edit {
  flex: 1 1 auto;
  width: 100%;
}

.full-link-field .bt-copy-link {
  flex-shrink: 0;
  white-space: nowrap;
  padding: 0 14px;
}

/* Mobile — ปรับกลับให้ปุ่มอยู่ข้างหลังช่องเหมือนเดิม */
@media (max-width: 768px) {
  .full-link-field .link-row.full-link {
    flex-direction: row;       /* ← ใช้แถวเดียว */
    align-items: center;
    gap: 8px;
  }

  .full-link-field input.bt-edit {
    flex: 1 1 auto;
  }

  .full-link-field .bt-copy-link {
    width: auto;               /* ไม่เต็มหน้าจอ */
    padding: 8px 12px;
  }
}

#railwayMonitorModal {
    border: none !important;
    outline: none !important;
    padding: 0;
    background: transparent;
}

/* ลบขอบตอนที่ Modal ถูกโฟกัส */
#railwayMonitorModal:focus-visible {
    outline: none;
}

.bt-monitor-dialog {
    border: none !important;
    outline: none !important;
    padding: 0;
    background: transparent;
    max-width: 900px;
    width: 95vw;
}

.bt-monitor-dialog::backdrop {
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
}

/* 2. ตัวกล่องเนื้อหาภายใน */
.monitor-wrapper {
    background: #0b0d11;
    border: 1px solid #2d3139;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 85vh; /* ไม่ให้สูงเกินหน้าจอมือถือ */
}

/* 3. Header */
.monitor-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 18px;
    border-bottom: 1px solid #1f2937;
    background: #0b0d11;
}

.monitor-header .header-left {
    display: flex;
    align-items: center;
    gap: 10px;
}

.monitor-header h2 {
    color: #fff;
    margin: 0;
    font-size: 15px;
    font-weight: 500;
}

.monitor-header .close-btn {
    background: none;
    border: none;
    color: #9ca3af;
    cursor: pointer;
    font-size: 24px;
    line-height: 1;
    padding: 0;
}

/* 4. Tabs */
.monitor-tabs {
    display: flex;
    background: #0f1116;
    border-bottom: 1px solid #1f2937;
    padding: 0 8px;
}

.monitor-tabs .bt-tab {
    flex: 1;
    padding: 12px 5px;
    font-size: 13px;
    border: none;
    background: transparent;
    color: #9ca3af;
    cursor: pointer;
    border-bottom: 2px solid transparent;
}

.monitor-tabs .bt-tab.active {
    color: #05b84f;
