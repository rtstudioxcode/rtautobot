};
let yearlyChartInstance = null;
function setYearText(id, value) { const el = document.getElementById(id); if (el) el.textContent = value; }
function updateYearCardTrend(id, active) { const block = document.querySelector(`#${id} .ultra-trend`); if (!block) return; block.classList.remove('up', 'flat'); block.classList.add(active ? 'up' : 'flat'); }
function monthShortTH(month) { return monthNamesTH[Math.max(0, Math.min(11, Number(month || 1) - 1))] || String(month || '-'); }
function renderYearlySummary(payload = yearlyInitial) {
  const total = Number(payload.yearlyTotalRevenue || 0);
  const pkg1 = Number(payload.yearlyPkg1Revenue || 0);
  const pkg2 = Number(payload.yearlyPkg2Revenue || 0);
  const orderCount = Number(payload.yearlyOrderCount || 0);
  const pkg1Count = Number(payload.yearlyPkg1Count || 0);
  const pkg2Count = Number(payload.yearlyPkg2Count || 0);
  const best = payload.yearlyBestMonth || null;
  const yearBE = Number(payload.year || yearlyInitial.year) + 543;
  setYearText('yearlyTotalRevenue', total.toLocaleString());
  setYearText('yearlyPkg1Revenue', pkg1.toLocaleString());
  setYearText('yearlyPkg2Revenue', pkg2.toLocaleString());
  setYearText('yearlyTotalLabel', orderCount > 0 ? `ทั้งหมด ${orderCount.toLocaleString('th-TH')} ออเดอร์` : 'ยังไม่มีรายการในปีนี้');
  setYearText('yearlyPkg1Label', pkg1Count > 0 ? `${pkg1Count.toLocaleString('th-TH')} รายการ` : 'ยังไม่มีการขาย');
  setYearText('yearlyPkg2Label', pkg2Count > 0 ? `${pkg2Count.toLocaleString('th-TH')} รายการ` : 'ยังไม่มีการขาย');
  if (best && Number(best.total || 0) > 0) { setYearText('yearlyBestMonth', `${monthShortTH(best.month)} ${yearBE}`); setYearText('yearlyBestLabel', `฿ ${Number(best.total || 0).toLocaleString('th-TH')} · ${Number(best.count || 0).toLocaleString('th-TH')} ออเดอร์`); }
  else { setYearText('yearlyBestMonth', '-'); setYearText('yearlyBestLabel', 'รอข้อมูลยอดขาย'); }
  updateYearCardTrend('yearCardTotal', total > 0); updateYearCardTrend('yearCardPkg1', pkg1 > 0); updateYearCardTrend('yearCardPkg2', pkg2 > 0); updateYearCardTrend('yearCardBest', !!best && Number(best.total || 0) > 0);
  renderYearlyChart(payload.yearlyMonthly || []);
}
function renderYearlyChart(rows = []) {
