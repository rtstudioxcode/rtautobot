        btnText: "เริ่ม Re-Deploy",
        onConfirm: async () => {
            try {
                const infoRes = await fetch(`/railway/service-info/${encodeURIComponent(tenantId)}`, { cache:'no-store', headers:{ 'accept':'application/json' } });
                const info = await infoRes.json().catch(() => ({}));
                if(!infoRes.ok || info.ok === false) throw new Error(railwayErrorText(info, 'ไม่พบข้อมูล Railway Service'));
                if(!info.serviceId || !info.environmentId) throw new Error('ไม่พบข้อมูล Service ID / Environment ID');

                const res = await fetch('/railway/redeploy', {
                    method: 'POST',
