// ================== SPARK TOOLTIP ==================
function getOrCreateSparkTooltip(chart) {
  let tooltipEl = chart.canvas.__sparkTooltipEl;
  if (!tooltipEl) {
    tooltipEl = document.createElement("div");
    tooltipEl.className = "spark-tooltip";
    tooltipEl.style.position = "absolute";
    tooltipEl.style.pointerEvents = "none";
    tooltipEl.style.zIndex = 20;
    tooltipEl.style.transform = "translate(-50%, -170%)";
    document.body.appendChild(tooltipEl);
    chart.canvas.__sparkTooltipEl = tooltipEl;
  }
  return tooltipEl;
}

function externalSparkTooltip(context) {
  const { chart, tooltip } = context;
  const tooltipEl = getOrCreateSparkTooltip(chart);

  if (!tooltip || tooltip.opacity === 0 || !tooltip.dataPoints?.length) {
    tooltipEl.style.opacity = 0;
    return;
  }

  const dp = tooltip.dataPoints[0];
  const raw = Number(dp.raw || 0);
  const valueText = "฿ " + raw.toLocaleString();
  const color = dp.dataset.borderColor || "#05b84f";

  tooltipEl.innerHTML = valueText;
  tooltipEl.style.opacity = 1;
  tooltipEl.style.background = "rgba(0, 0, 0, 0.9)";
  tooltipEl.style.border = "1px solid " + color;
  tooltipEl.style.borderRadius = "999px";
  tooltipEl.style.padding = "4px 10px";
  tooltipEl.style.color = "#fff";
  tooltipEl.style.fontFamily =
    "'Prompt', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif";
  tooltipEl.style.fontSize = "10px";
  tooltipEl.style.fontWeight = "600";
  tooltipEl.style.whiteSpace = "nowrap";
  tooltipEl.style.boxShadow = "0 0 12px rgba(0,0,0,0.45)";

  const canvasRect = chart.canvas.getBoundingClientRect();
  const left = canvasRect.left + window.pageXOffset + tooltip.caretX;
  const top  = canvasRect.top  + window.pageYOffset + tooltip.caretY;

  tooltipEl.style.left = left + "px";
  tooltipEl.style.top  = top  + "px";
}

// ================== SPARK LINES ==================
function makeSpark(canvasId, data, color) {
  const el = document.getElementById(canvasId);
  if (!el) return;

  // ทำลายกราฟเก่าก่อนทุกครั้ง
  if (el.__chart) {
    el.__chart.destroy();
    el.__chart = null;
  }

  // ถ้าไม่มีข้อมูล → ใช้กราฟเส้นตรง
  let arr = [];

  if (!Array.isArray(data) || data.length === 0) {
    arr = [0, 0];
  } else if (data.every(v => Number(v) === 0)) {
    arr = [0, 0];
  } else {
    arr = data.slice();
    if (arr.length === 1) arr = [arr[0], arr[0]];
  }

  el.__chart = new Chart(el, {
    type: "line",
    data: {
      labels: arr.map((_, i) => i + 1),
      datasets: [{
        data: arr,
        borderColor: color,
        borderWidth: 1.8,
        fill: false,
        tension: 0.35,
        pointRadius: 0,
        pointHitRadius: 8,
      }],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          enabled: false,
          external: externalSparkTooltip,
        },
      },
      interaction: { mode: "index", intersect: false },
      scales: {
        x: { display: false, grid: { display: false } },
        y: { display: false, grid: { display: false }, beginAtZero: false },
      },
      layout: { padding: { left: 4, right: 4, top: 4, bottom: 4 } },
    },
  });
}

