  // ❗สำคัญมาก: คำนวณ isFlatDaily ใหม่หลังจากแก้ dailyData แล้ว
  const isFlatDaily = dailyData.every(v => Number(v) === 0);

  // -------- DAILY LINE --------
  destroyChart("chartDaily");
  const c1 = document.getElementById("chartDaily");
  if (c1 && Array.isArray(dailyData) && dailyData.length) {
    const ctx1 = c1.getContext("2d");

    const labels =
      Array.isArray(dailyLabels) &&
      dailyLabels.length === dailyData.length
        ? dailyLabels
        : dailyData.map((_, i) => i + 1);
    let suggestedMin, suggestedMax;

    const minVal = Math.min(...dailyData);
    const maxVal = Math.max(...dailyData);
    const range = maxVal - minVal || maxVal || 1;

    if (isFlatDaily) {
      // ถ้าไม่มีข้อมูลเลย → กราฟเป็นเส้นตรง
      suggestedMin = 0;
      suggestedMax = 1; // ต้องไม่เป็น 0 ทั้งคู่ ไม่งั้น Chart.js ไม่วาด
    } else {
      const minVal = Math.min(...dailyData);
      const maxVal = Math.max(...dailyData);
