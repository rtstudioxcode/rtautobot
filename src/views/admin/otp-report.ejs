  transition:transform .22s ease,border-color .22s ease,box-shadow .22s ease;
}
.hero-stat:hover{ transform:translateY(-3px); border-color:color-mix(in srgb,var(--or-accent) 42%,var(--or-border)); box-shadow:0 18px 34px color-mix(in srgb,var(--or-accent) 14%,transparent); }
.hero-stat span{ display:block;color:var(--or-muted);font-size:12px;font-weight:900;letter-spacing:.04em; }
.hero-stat strong{ display:block;margin-top:8px;color:var(--or-accent-2);font-size:clamp(22px,2vw,34px);line-height:1;font-weight:950; }

/* ===== Tabs ===== */
.admin-otp-report > .tabs{
  width:100%;display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px;
  padding:7px;margin:0 0 18px;border-radius:22px;
  background:linear-gradient(180deg,rgba(255,255,255,.045),rgba(255,255,255,.016)),var(--or-card);
  border:1px solid var(--or-border);
  box-shadow:0 14px 36px var(--or-shadow),inset 0 1px 0 rgba(255,255,255,.06);
  animation:orRise .58s ease both .04s;
}
.admin-otp-report .tab{
  position:relative;border:0;border-radius:16px;min-height:50px;padding:10px 16px;
  color:var(--or-muted);background:transparent;cursor:pointer;font-weight:900;
  display:flex;align-items:center;justify-content:center;gap:10px;
  transition:transform .2s ease,background .2s ease,color .2s ease,box-shadow .2s ease;
}
.admin-otp-report .tab::after{display:none!important;content:none!important;}
.admin-otp-report .tab:hover{ transform:translateY(-1px);color:var(--or-text);background:color-mix(in srgb,var(--or-soft) 80%,transparent); }
.admin-otp-report .tab.active{
  color:#17130a;background:var(--or-gold);
  box-shadow:0 12px 28px color-mix(in srgb,var(--or-accent) 24%,transparent),inset 0 1px 0 rgba(255,255,255,.55);
}
.admin-otp-report .tabpane{ display:none; animation:orRise .36s ease both; }
.admin-otp-report .tabpane.show{ display:block; }

/* ===== Controls ===== */
.orders-controls,
.month-toolbar,
.page-head,
.admin-otp-report .card,
.admin-otp-report .card2,
.orders-wrap,
.m-orders .m-item{
  border:1px solid var(--or-border);
  background:linear-gradient(180deg,rgba(255,255,255,.045),rgba(255,255,255,.014)),var(--or-card);
  box-shadow:0 18px 46px var(--or-shadow), inset 0 1px 0 rgba(255,255,255,.055);
}
.orders-controls{
  display:grid;grid-template-columns:auto minmax(260px,1fr) auto;gap:12px;align-items:center;
  padding:16px;border-radius:24px;margin-bottom:14px;animation:orRise .58s ease both .08s;
}
.orders-controls .left{ display:flex;align-items:center;gap:10px;color:var(--or-muted);font-weight:900; }
.orders-controls .right{ display:flex;align-items:center;gap:8px;justify-content:flex-end; }
.orders-controls select,
.orders-controls .input,
.month-ctrl input{
  height:46px;border-radius:16px;border:1px solid color-mix(in srgb,var(--or-border) 88%,var(--or-accent) 12%);
  background:color-mix(in srgb,var(--or-page) 78%,transparent);
  color:var(--or-text);outline:none;padding:0 14px;font-weight:850;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.04);
  transition:border-color .2s ease,box-shadow .2s ease,transform .2s ease;
}
.orders-controls select{ min-width:92px;cursor:pointer; }
.orders-controls .input{ width:100%; }
.orders-controls select:focus,
.orders-controls .input:focus,
.month-ctrl input:focus{
  border-color:color-mix(in srgb,var(--or-accent) 64%,var(--or-border));
  box-shadow:0 0 0 4px color-mix(in srgb,var(--or-accent) 14%,transparent), inset 0 1px 0 rgba(255,255,255,.05);
}
.pg-btn,
.btn,
.icon-btn,
.mp-nav{
  min-width:42px;height:42px;border:1px solid var(--or-border);border-radius:14px;
  background:var(--or-soft);color:var(--or-text);font-weight:950;cursor:pointer;
  transition:transform .18s ease,background .18s ease,border-color .18s ease,opacity .18s ease;
}
.pg-btn:hover,.btn:hover,.icon-btn:hover,.mp-nav:hover{ transform:translateY(-1px);border-color:color-mix(in srgb,var(--or-accent) 44%,var(--or-border)); }
.pg-btn:disabled{ opacity:.38;cursor:not-allowed;transform:none; }
#pageInfo,#pageInfoMobile{ color:var(--or-accent-2);font-weight:900;padding:0 6px; }
.btn.primary,.btn:not(.ghost){ background:var(--or-gold);color:#17130a;border:0;box-shadow:0 10px 22px color-mix(in srgb,var(--or-accent) 18%,transparent); }

/* ===== Table ===== */
.orders-wrap,.admin-otp-report .card{ border-radius:26px;overflow:hidden;animation:orRise .6s ease both .12s; }
.table-wrap,.orders-wrap{ overflow:auto; }
.tbl{ width:100%;border-collapse:separate;border-spacing:0;min-width:960px;color:var(--or-text); }
.tbl thead th{
  position:sticky;top:0;z-index:2;
  padding:16px 14px;text-align:left;color:var(--or-accent-2);
  font-size:13px;letter-spacing:.02em;background:color-mix(in srgb,var(--or-card) 96%,#000 8%);
  border-bottom:1px solid var(--or-border);white-space:nowrap;
}
.tbl tbody td{ padding:15px 14px;border-bottom:1px solid color-mix(in srgb,var(--or-border) 72%,transparent);vertical-align:middle; }
.tbl tbody tr{ transition:background .18s ease, transform .18s ease; }
.tbl tbody tr:hover{ background:color-mix(in srgb,var(--or-accent) 8%,transparent); }
.tbl.zebra tbody tr:nth-child(even){ background:color-mix(in srgb,var(--or-soft) 38%,transparent); }
.tbl-head-month th{ background:linear-gradient(90deg,transparent,color-mix(in srgb,var(--or-accent) 12%,transparent),transparent)!important; }
.flag{ display:inline-flex;vertical-align:middle;margin-right:6px; }
.flag img{ width:22px;height:22px;border-radius:999px;object-fit:cover;box-shadow:0 0 0 1px var(--or-border); }
.copy{ display:inline-grid;place-items:center;width:30px;height:30px;margin-left:6px;border:0;border-radius:10px;background:color-mix(in srgb,var(--or-blue) 14%,transparent);cursor:pointer;transition:transform .18s ease,background .18s ease; }
.copy:hover{ transform:translateY(-1px) scale(1.04);background:color-mix(in srgb,var(--or-blue) 24%,transparent); }
.copy img{ width:16px;height:16px;object-fit:contain; }
.badge.app{ display:inline-flex;align-items:center;min-height:30px;padding:6px 10px;border-radius:999px;background:color-mix(in srgb,var(--or-violet) 16%,transparent);border:1px solid color-mix(in srgb,var(--or-violet) 30%,var(--or-border));color:var(--or-text);font-weight:900; }
.otp b{ color:var(--or-accent-2);font-size:1.04em; }
.otp.none{ color:var(--or-muted); }
.ts{ margin-top:5px;color:var(--or-muted);font-size:12px;font-weight:800; }
.pill{
  display:inline-flex;align-items:center;justify-content:center;gap:7px;min-height:32px;padding:7px 11px;border-radius:999px;
  font-weight:950;font-size:12px;white-space:nowrap;border:1px solid var(--or-border);
  background:var(--or-soft);color:var(--or-text);box-shadow:inset 0 1px 0 rgba(255,255,255,.08);
}
.pill.success{ background:linear-gradient(135deg,#16a34a,#0f7a3d);border-color:rgba(67,224,129,.45);color:#ecfff4; }
.pill.processing{ background:linear-gradient(135deg,#f59e0b,#c47f05);border-color:rgba(255,226,138,.45);color:#181108; }
.pill.refunded,.pill.timeout,.pill.failed{ background:linear-gradient(135deg,#ef4444,#8f1d2f);border-color:rgba(255,85,116,.48);color:#fff1f3; }
.countdown{ margin-top:7px;color:var(--or-muted);font-size:11px;font-weight:800; }
.countdown.warn{ color:#ffd66b; }
.countdown.danger{ color:var(--or-red); }

/* ===== Mobile cards ===== */
.m-orders{ display:none; }
.m-item{ border-radius:22px;margin:12px 0;overflow:hidden;animation:orRise .38s ease both; }
.m-head{ padding:14px;cursor:pointer; }
.m-head .row1,.m-head .row2,.m-body .pair{ display:flex;align-items:center;justify-content:space-between;gap:10px; }
.m-head .row1{ margin-bottom:10px; }
.m-head .oid{ color:var(--or-accent-2);font-weight:950; }
.m-head .when{ color:var(--or-muted);font-size:12px; }
.m-head .toggle{ width:34px;height:34px;border:1px solid var(--or-border);border-radius:12px;background:var(--or-soft);color:var(--or-text);font-weight:950; }
.m-body{ padding:0 14px 14px;display:grid;gap:8px; }
.m-item.collapsed .m-body{ display:none; }
.m-body .pair{ padding:11px 12px;border:1px solid var(--or-border);border-radius:14px;background:color-mix(in srgb,var(--or-soft) 70%,transparent); }
.mobile-only{ display:none; }

/* ===== Summary ===== */
.page-head{ border-radius:26px;padding:22px;margin-bottom:14px; }
.page-title h1{ margin:0;color:var(--or-text);font-size:clamp(26px,3vw,42px);letter-spacing:-.04em; }
.grid.cards{ display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px;margin:0 0 14px; }
.card2{ border-radius:24px;padding:20px;min-height:140px;position:relative;overflow:hidden;animation:orRise .58s ease both; }
.card2::after{ content:"";position:absolute;right:-60px;bottom:-70px;width:190px;height:190px;background:radial-gradient(circle,color-mix(in srgb,var(--or-accent) 16%,transparent),transparent 62%); }
.card-head.row-head{ display:flex;justify-content:space-between;align-items:center;gap:10px; }
.card-head h3{ margin:0;color:var(--or-muted);font-size:13px; }
.metric-badge{ padding:5px 9px;border-radius:999px;background:color-mix(in srgb,var(--or-accent) 12%,transparent);border:1px solid color-mix(in srgb,var(--or-accent) 24%,var(--or-border));font-size:11px;font-weight:950;color:var(--or-accent-2); }
.big{ margin-top:16px;font-size:clamp(24px,2.5vw,38px);font-weight:950;letter-spacing:-.03em;color:var(--or-text); }
.month-toolbar{ display:flex;align-items:center;justify-content:center;gap:10px;border-radius:24px;padding:14px;margin:0 0 14px;position:relative;z-index:20; }
.month-ctrl{ display:flex;align-items:center;gap:8px; }
.month-ctrl input{ width:160px;text-align:center; }
.icon-btn{ width:46px; }

/* Month Picker: true top layer */
.mp-popup{ position:fixed;inset:0;z-index:99999;pointer-events:none; }
.mp-popup:not([hidden]){ display:block; }
.mp-card{
  position:fixed;pointer-events:auto;min-width:330px;border:1px solid var(--or-border);border-radius:24px;
  background:linear-gradient(180deg,color-mix(in srgb,var(--or-card) 98%,transparent),color-mix(in srgb,var(--or-card-2) 98%,transparent));
  box-shadow:0 28px 80px rgba(0,0,0,.55),inset 0 1px 0 rgba(255,255,255,.08);padding:16px;color:var(--or-text);
}
.mp-head{ display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:12px; }
.mp-year{ color:var(--or-accent-2);font-size:20px;font-weight:950; }
.mp-grid{ display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px; }
.mp-m{ height:42px;border:1px solid var(--or-border);border-radius:14px;background:var(--or-soft);color:var(--or-text);font-weight:900;cursor:pointer;transition:.18s ease; }
.mp-m:hover{ transform:translateY(-1px);border-color:color-mix(in srgb,var(--or-accent) 45%,var(--or-border)); }
.mp-m.active{ background:var(--or-gold);color:#17130a;border:0; }
.mp-m.current{ box-shadow:0 0 0 2px color-mix(in srgb,var(--or-blue) 35%,transparent) inset; }
.mp-actions{ display:flex;align-items:center;gap:8px; }
.mp-actions .spacer{ flex:1; }

/* Scrollbar */
.admin-otp-report *::-webkit-scrollbar{ width:9px;height:9px; }
.admin-otp-report *::-webkit-scrollbar-track{ background:color-mix(in srgb,var(--or-card) 70%,transparent);border-radius:999px; }
.admin-otp-report *::-webkit-scrollbar-thumb{ background:linear-gradient(180deg,var(--or-accent-2),#bd8626);border-radius:999px; }

/* ===== Light mode polishing ===== */
:where([data-theme="light"],.light,body.light,body[data-bs-theme="light"]) .admin-otp-report{
  --or-shadow: rgba(30,24,10,.12);
}
:where([data-theme="light"],.light,body.light,body[data-bs-theme="light"]) .admin-otp-report .tbl thead th{
  background:color-mix(in srgb,var(--or-card) 96%,#fff 10%);
}
:where([data-theme="light"],.light,body.light,body[data-bs-theme="light"]) .admin-otp-report .hero-copy p{ color:color-mix(in srgb,var(--or-muted) 72%,#8b6a16); }

/* ===== Responsive ===== */
@media (max-width:1180px){
  .otp-report-hero{ grid-template-columns:1fr; }
  .hero-stats{ grid-template-columns:repeat(4,minmax(0,1fr)); }
  .grid.cards{ grid-template-columns:repeat(2,minmax(0,1fr)); }
  .orders-controls{ grid-template-columns:1fr; }
  .orders-controls .right{ justify-content:flex-start; }
}
@media (max-width:760px){
  .admin-otp-report{ padding-inline:0; }
  .otp-report-hero{ padding:22px;border-radius:26px; }
  .hero-stats{ grid-template-columns:repeat(2,minmax(0,1fr)); }
  .admin-otp-report > .tabs{ grid-template-columns:1fr; }
  .orders-wrap{ display:none; }
  .m-orders{ display:block; }
  #ordersControlsDesktop{ display:none; }
  .mobile-only{ display:grid; }
  .orders-controls.mobile-only{ grid-template-columns:1fr; }
  .grid.cards{ grid-template-columns:1fr; }
  .month-toolbar{ flex-wrap:wrap; }
  .mp-card{ min-width:min(330px,calc(100vw - 24px)); }
}
@media (max-width:480px){
  .otp-report-hero{ padding:18px; }
  .hero-copy h1{ font-size:34px; }
  .hero-stats{ gap:8px; }
  .hero-stat{ min-height:84px;padding:13px; }
  .hero-stat strong{ font-size:22px; }
  .m-head .row2{ align-items:flex-start;flex-direction:column; }
  .month-ctrl input{ width:132px; }
}

/* ===== Custom Dropdown: per-page selector, fixed top layer ===== */
.admin-otp-report .or-native-select-hidden{
  position:absolute!important;
  width:1px!important;
  height:1px!important;
  opacity:0!important;
  pointer-events:none!important;
  overflow:hidden!important;
}
.admin-otp-report .otp-dd-wrap{
  position:relative;
  display:inline-flex;
  align-items:center;
  flex:0 0 auto;
}
.admin-otp-report .otp-dd-btn{
  height:46px;
  min-width:96px;
  border-radius:16px;
  border:1px solid color-mix(in srgb,var(--or-border) 72%,var(--or-accent) 28%);
  background:
    linear-gradient(180deg,rgba(255,255,255,.045),rgba(255,255,255,.012)),
    color-mix(in srgb,var(--or-page) 82%,transparent);
  color:var(--or-text);
  padding:0 13px 0 16px;
  display:inline-flex;
  align-items:center;
  justify-content:space-between;
  gap:14px;
  font-weight:950;
  cursor:pointer;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.05),0 8px 20px color-mix(in srgb,var(--or-shadow) 72%,transparent);
  transition:transform .18s ease,border-color .18s ease,box-shadow .18s ease,background .18s ease;
}
.admin-otp-report .otp-dd-btn:hover,
.admin-otp-report .otp-dd-btn.is-open{
  transform:translateY(-1px);
  border-color:color-mix(in srgb,var(--or-accent) 72%,var(--or-border));
  box-shadow:0 0 0 4px color-mix(in srgb,var(--or-accent) 12%,transparent),0 12px 26px color-mix(in srgb,var(--or-shadow) 78%,transparent);
}
.admin-otp-report .otp-dd-btn i{
  font-style:normal;
  font-size:12px;
  color:var(--or-accent-2);
  transition:transform .18s ease;
}
.admin-otp-report .otp-dd-btn.is-open i{ transform:rotate(180deg); }
.otp-dd-menu{
  position:fixed!important;
  z-index:2147483647!important;
  max-height:min(280px, calc(100dvh - 24px));
  overflow:auto;
  padding:7px;
  border-radius:16px;
  border:1px solid color-mix(in srgb,var(--or-border, rgba(255,255,255,.14)) 70%,var(--or-accent, #e8bc53) 30%);
  background:
    linear-gradient(180deg,rgba(255,255,255,.07),rgba(255,255,255,.025)),
    color-mix(in srgb,var(--or-card, #191a20) 96%,#000 4%);
  color:var(--or-text, #fff7e7);
  box-shadow:0 26px 70px rgba(0,0,0,.55),inset 0 1px 0 rgba(255,255,255,.08);
  backdrop-filter:blur(18px) saturate(1.2);
  animation:otpDdPop .16s ease both;
}
.otp-dd-option{
  width:100%;
  border:0;
  border-radius:12px;
  min-height:36px;
  padding:8px 12px;
  text-align:left;
  color:inherit;
  background:transparent;
  cursor:pointer;
  font-weight:900;
  transition:background .14s ease,color .14s ease,transform .14s ease;
}
.otp-dd-option:hover{
  transform:translateX(2px);
  background:color-mix(in srgb,var(--or-accent, #e8bc53) 18%,transparent);
}
.otp-dd-option.is-selected{
  color:#17130a;
  background:linear-gradient(135deg,#ffe28a,#e8bc53 58%,#bd8626);
  box-shadow:inset 0 1px 0 rgba(255,255,255,.48);
}
@keyframes otpDdPop{
  from{opacity:0;transform:translateY(-6px) scale(.985);}
  to{opacity:1;transform:translateY(0) scale(1);}
}
@media (max-width: 640px){
  .admin-otp-report .otp-dd-btn{height:42px;min-width:86px;border-radius:14px;}
}



/* =========================================================
   OTP Summary Period Control — matches reportsummary/topup-report
   ========================================================= */
.otp-period-control-card{
  position:relative;
  overflow:hidden;
  isolation:isolate;
  display:grid;
  gap:18px;
  margin:18px 0 18px;
  padding:20px;
  border:1px solid color-mix(in srgb,var(--or-border) 88%, rgba(255,255,255,.06));
  border-radius:30px;
  background:
    radial-gradient(760px 260px at 8% 0%, color-mix(in srgb,var(--or-accent) 14%, transparent), transparent 62%),
    radial-gradient(520px 240px at 94% 100%, rgba(84,116,255,.11), transparent 60%),
    linear-gradient(145deg, rgba(255,255,255,.06), rgba(255,255,255,.018) 52%, rgba(0,0,0,.10)),
    color-mix(in srgb,var(--or-card) 94%, transparent);
  box-shadow:0 24px 64px var(--or-shadow), inset 0 1px 0 rgba(255,255,255,.07);
  animation:orRise .58s ease both;
}
.otp-period-control-card::before{
  content:"";
  position:absolute;
  inset:0;
  background:linear-gradient(90deg, transparent, rgba(255,255,255,.045), transparent);
  opacity:.28;
  pointer-events:none;
}
.otp-period-glow{
  position:absolute;
  z-index:-1;
  left:-100px;
  top:-170px;
  width:340px;
  height:340px;
  border-radius:999px;
  background:radial-gradient(circle, color-mix(in srgb,var(--or-accent) 22%, transparent), transparent 68%);
  filter:blur(18px);
  opacity:.82;
  pointer-events:none;
}
.otp-period-glow--right{
  left:auto;
  right:-110px;
  top:auto;
  bottom:-190px;
  background:radial-gradient(circle, rgba(96,120,255,.18), transparent 70%);
}
.otp-period-head{
  position:relative;
  z-index:1;
  display:grid;
  grid-template-columns:minmax(260px,1fr) minmax(260px,.72fr) auto;
  align-items:center;
  gap:16px;
}
.otp-period-title-wrap{
  display:flex;
  align-items:flex-start;
  gap:15px;
  min-width:0;
}
.otp-period-icon{
  flex:0 0 58px;
  width:58px;
  height:58px;
  display:grid;
  place-items:center;
  border-radius:19px;
  border:1px solid color-mix(in srgb,var(--or-accent) 30%, var(--or-border));
  background:linear-gradient(145deg, color-mix(in srgb,var(--or-accent) 18%, transparent), rgba(255,255,255,.035));
  box-shadow:0 18px 38px color-mix(in srgb,var(--or-accent) 15%, transparent), inset 0 1px 0 rgba(255,255,255,.10);
  font-size:24px;
}
.otp-period-kicker{
  display:inline-flex;
  align-items:center;
  width:max-content;
  max-width:100%;
  margin-bottom:8px;
  padding:6px 12px;
  border-radius:999px;
  border:1px solid color-mix(in srgb,var(--or-accent) 34%, var(--or-border));
  background:color-mix(in srgb,var(--or-accent) 10%, transparent);
  color:var(--or-accent-2);
  font-size:11px;
  font-weight:900;
  letter-spacing:.08em;
  text-transform:uppercase;
}
.otp-period-copy h2{
  margin:0;
  color:var(--or-text);
  font-size:clamp(24px,2.35vw,38px);
  line-height:1.05;
  font-weight:1000;
  letter-spacing:-.04em;
}
.otp-period-copy p{
  margin:7px 0 0;
  max-width:560px;
  color:var(--or-muted);
  font-size:13.5px;
  line-height:1.55;
  font-weight:700;
}
.otp-period-current{
  min-height:66px;
  padding:12px 18px;
  border-radius:22px;
  border:1px solid color-mix(in srgb,var(--or-border) 84%, rgba(255,255,255,.05));
  background:linear-gradient(180deg, rgba(255,255,255,.035), rgba(255,255,255,.012)), color-mix(in srgb,var(--or-card) 82%, var(--or-page));
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  text-align:center;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.06), 0 14px 30px rgba(0,0,0,.16);
}
.otp-period-current span{
  color:var(--or-muted);
  font-size:11px;
