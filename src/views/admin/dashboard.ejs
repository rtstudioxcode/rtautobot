<% const BANK_LABELS = { bbl: 'ธนาคารกรุงเทพ', kbank: 'ธนาคารกสิกรไทย', ktb:
'ธนาคารกรุงไทย', bay: 'ธนาคารกรุงศรีอยุธยา', scb: 'ธนาคารไทยพาณิชย์', tmb:
'ทหารไทยธนชาต (TTB)', cimb: 'ธนาคารซีไอเอ็มบีไทย', uob: 'ธนาคารยูโอบี', gsb:
'ธนาคารออมสิน', baac: 'ธ.เพื่อการเกษตรและสหกรณ์การเกษตร', kkb:
'ธนาคารเกียรตินาคินภัทร', lhfg: 'ธนาคารแลนด์ แอนด์ เฮ้าส์', icbc:
'ธนาคารไอซีบีซี (ไทย)', tisco: 'ธนาคารทิสโก้', tw: 'TrueMoney Wallet', qr: 'PromptPay QR' }; %>

<div class="history-wrapper card soft admin-pending-topup-enterprise">
  <div class="apt-head">
    <div class="apt-title-wrap">
      <span class="apt-kicker">✦ Pending Topup Control</span>
      <h3 class="apt-title">รายการเติมเงินที่รอดำเนินการ</h3>
      <p class="apt-subtitle">ตรวจสอบรายการโอนเงินที่รออนุมัติ เติมเครดิตให้ผู้ใช้ หรือปฏิเสธรายการได้จากจุดเดียว</p>
    </div>
    <button class="btn-lux apt-manual-btn" onclick="openManualTopupModal()">
      <span class="apt-plus">+</span> เติมเงินด้วยตนเอง
    </button>
  </div>

  <% if (transactions && transactions.length > 0) { %>

  <!-- ===== Desktop/Table view (คงของเดิม) ===== -->
  <div class="desktop-only">
    <table class="history-table apt-table">
      <thead>
        <tr>
          <th>วันที่ / เวลา</th>
          <th>ยูสเซอร์</th>
          <th>ข้อมูลผู้รับ</th>
          <th>จำนวนเงิน</th>
          <th>สถานะ</th>
          <th>จัดการ</th>
        </tr>
      </thead>
      <tbody>
        <% transactions.forEach(tx => {
             const method = tx.method?.toLowerCase() || "";
             const wallet = (webWallets || []).find(w => w.accountCode === method);
             const statusLabel =
               tx.status === "completed" ? "สำเร็จ" :
               tx.status === "pending"   ? "รอดำเนินการ" :
               (tx.status === "reject" || tx.status === "rejected") ? "ถูกปฏิเสธ" :
               tx.status === "failed"    ? "ล้มเหลว" : "ยกเลิก";
        %>
        <tr class="apt-row">
          <!-- วันที่ -->
          <td class="muted apt-date">
            <span class="apt-date-ico">🕒</span>
            <%= new Date(tx.createdAt).toLocaleString('th-TH', {
              timeZone: 'Asia/Bangkok', year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit'
            }) %>
          </td>

          <!-- ข้อมูลผู้โอน -->
          <td>
            <div class="user-inline">
              <img
                class="avatar-sm"
                src="<%= (tx.userId?.avatarUrl || '/static/assets/img/user-blue.png') %>?v=<%= tx.userId?.avatarVer || 0 %>"
                alt="<%= tx.userId?.username || tx.username || 'user' %>"
                width="28"
                height="28"
                loading="lazy"
              />
              <span class="username-text apt-user-name"><small>ยูสเซอร์</small><b><%= tx.user?.username || '-' %></b></span>
            </div>
          </td>

          <!-- ข้อมูลผู้รับ -->
          <td>
            <% if (wallet) { %>
              <div class="apt-receiver">
                <span class="apt-bank-badge"><img src="/static/assets/payment/<%= wallet.accountCode %>.webp" class="bank-logo" alt=""></span>
                <div>
                  <b><%= wallet.accountName %></b>
                  <small>เลขบัญชี: <%= wallet.accountNumber %></small>
                </div>
              </div>
            <% } else { %>
              <span class="muted">ไม่พบข้อมูลผู้รับ</span>
            <% } %>
          </td>

          <!-- จำนวนเงิน -->
          <td class="amount apt-amount">
            <span>฿<%= Number(tx.amount).toLocaleString(undefined,{ minimumFractionDigits: 2 }) %></span>
          </td>

          <!-- สถานะ -->
          <td class="apt-status-cell">
            <span class="apt-status status <%= tx.status.toLowerCase() %>"><i></i><%= statusLabel %></span>
          </td>

          <!-- Action -->
          <td>
            <div class="apt-actions">
            <button
              type="button"
              class="btn small success apt-action-fill"
              onclick="openManualTopupModal(
                '<%= tx.transactionId %>',
                <%= tx.amount %>,
                '<%= (tx.user?.username||'').replace(/'/g,'\\\'') %>',
                '<%= (tx.method || 'admin').toLowerCase() %>',
                true
              )">
              เติมให้ผู้ใช้
            </button>
            <button
              type="button"
              class="btn small danger apt-action-reject"
              onclick="rejectTx('<%= (tx._id || tx.transactionId) %>')">
              ปฏิเสธ
            </button>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- ===== Mobile/Card view (หุบ/ขยาย) ===== -->
  <div class="mobile-only tx-accordion-list apt-mobile-list">
    <% transactions.forEach(tx => {
         const method = (tx.method||'').toLowerCase();
         const wallet = (webWallets || []).find(w => w.accountCode === method);
         const statusLabel =
           tx.status === "completed" ? "สำเร็จ" :
           tx.status === "pending"   ? "รอดำเนินการ" :
           (tx.status === "reject" || tx.status === "rejected") ? "ถูกปฏิเสธ" :
           tx.status === "failed"    ? "ล้มเหลว" : "ยกเลิก";
    %>
    <div class="tx-accordion apt-mobile-card" data-open="0">
      <!-- แถวหัว (ปิดอยู่) -->
      <button class="tx-accordion__head apt-mobile-head" type="button">
        <div class="tx-accordion__title">
          <span class="tx-id" title="<%= tx.transactionId || '' %>">
            <%= tx.transactionId || '—' %>
          </span>
        </div>
        <div class="tx-accordion__meta">
          <span class="tx-date">
            <%= new Date(tx.createdAt).toLocaleString('th-TH', {
              timeZone: 'Asia/Bangkok', year:'numeric', month:'2-digit', day:'2-digit',
              hour:'2-digit', minute:'2-digit', second:'2-digit'
            }) %>
          </span>
          <span class="tx-toggle"></span>
        </div>
      </button>

      <!-- เนื้อหารายละเอียด -->
      <div class="tx-accordion__body">
        <div class="tx-row">
          <div class="tx-label">ยูสเซอร์</div>
          <div class="tx-value">
            <div class="user-inline">
              <img
                class="avatar-sm"
                src="<%= (tx.userId?.avatarUrl || '/static/assets/img/user-blue.png') %>?v=<%= tx.userId?.avatarVer || 0 %>"
                alt="<%= tx.userId?.username || tx.username || 'user' %>"
                width="28"
                height="28"
                loading="lazy"
              />
              <span class="username-text apt-user-name"><small>ยูสเซอร์</small><b><%= tx.user?.username || '-' %></b></span>
            </div>
          </div>
        </div>

        <div class="tx-row">
          <div class="tx-label">ผู้รับ</div>
          <div class="tx-value">
            <% if (wallet) { %>
              <img src="/static/assets/payment/<%= wallet.accountCode %>.webp" class="bank-logo" alt="">
              <b><%= wallet.accountName %></b><br>
              <span class="muted">เลขบัญชี: <%= wallet.accountNumber %></span>
            <% } else { %>
              <span class="muted">ไม่พบข้อมูลผู้รับ</span>
            <% } %>
          </div>
        </div>

        <div class="tx-row">
          <div class="tx-label">จำนวนเงิน</div>
          <div class="tx-value">
            <b>฿<%= Number(tx.amount).toLocaleString(undefined,{minimumFractionDigits:2}) %></b>
          </div>
        </div>

        <div class="tx-row">
          <div class="tx-label">สถานะ</div>
          <div class="tx-value">
            <span class="pill pill--<%= (tx.status||'').toLowerCase() %>"><%= statusLabel %></span>
          </div>
        </div>

        <div class="tx-actions">
          <button type="button" class="btn small success apt-action-fill" style="width:100%;"
            onclick="openManualTopupModal(
              '<%= tx.transactionId %>',
              <%= tx.amount %>,
              '<%= (tx.user?.username||'').replace(/'/g, "\\'") %>',
              '<%= (tx.method || 'admin').toLowerCase() %>',
              true
            )">
            เติมให้ผู้ใช้
          </button>
          <button type="button" class="btn small danger apt-action-reject" style="width: 100%; margin-top: 8px;"
            onclick="rejectTx('<%= (tx._id || tx.transactionId) %>')">
            ปฏิเสธ
          </button>
        </div>
      </div>
    </div>
    <% }) %>
  </div>

  <% } else { %>
    <div class="empty-history">
      <img src="/static/assets/emoji/empty.png" alt="ยังไม่มีรายการเติมเงิน" />
      <p class="muted">ยังไม่มีรายการเติมเงิน</p>
    </div>
  <% } %>
</div>

<div id="manualTopupModal" class="hidden modal manual-topup-enterprise">
  <div class="overlay manual-topup-overlay" data-close="1"></div>

  <div class="dialog manual-topup-dialog" role="dialog" aria-modal="true" aria-labelledby="manualTitle">
    <button class="manual-topup-close" id="manualTopupClose" type="button" aria-label="ปิด">×</button>

    <div class="manual-topup-hero">
      <div class="manual-topup-icon">฿</div>
      <div>
        <span class="manual-topup-kicker">Admin Topup Manual</span>
        <h2 class="manual-topup-title" id="manualTitle">เติมเงินให้ผู้ใช้</h2>
        <p class="manual-topup-subtitle">ตรวจสอบข้อมูลให้ถูกต้อง เลือก Method การเติมเงิน แล้วกดยืนยันเพื่อเพิ่มเครดิตเข้าบัญชีผู้ใช้ทันที</p>
      </div>
    </div>

    <form id="manualTopupForm" class="manual-topup-form" onsubmit="return submitManualTopup(event)">
      <section class="manual-topup-panel">
        <label class="manual-field manual-field-user">
          <span class="manual-label">ชื่อผู้ใช้</span>
          <span class="manual-hint">Username</span>
