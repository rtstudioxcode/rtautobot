<div class="eh-admin-auto eh-page-dashboard-1-ejs">

<section class="adash-hero page-head" aria-label="Admin Overview">
  <div class="adash-hero-main">
    <div class="adash-kicker">✦ Admin Panel Center</div>
    <h1>Admin Panel — หลังบ้าน</h1>
    <p>ควบคุมระบบทั้งหมดในหน้าเดียว ทั้งยอดขาย ผู้ใช้ เติมเงิน ออเดอร์ ซิงก์บริการ และรายงานสำคัญ พร้อมแดชบอร์ดที่อ่านง่ายและตอบสนองไว</p>
  </div>
  <div class="adash-hero-stats" aria-label="สรุปภาพรวม">
    <div
      id="goReportSummaryCard"
      class="adash-stat-chip"
      role="button"
      tabindex="0"
      data-href="/admin/report/summary"
    >
      <span class="ico">🛒</span>
      <strong><%= (stats?.totalSoldCount || 0).toLocaleString() %></strong>
      <small>รายการขายแล้ว</small>
    </div>
    <div
      id="goAdminUsersCard"
      class="adash-stat-chip"
      role="button"
      tabindex="0"
      data-href="/admin/users"
    >
      <span class="ico">👥</span>
      <strong><%= (stats?.userCount || 0).toLocaleString() %></strong>
      <small>สมาชิกทั้งหมด</small>
    </div>
    <div
      class="adash-stat-chip"
      role="button"
      tabindex="0"
      data-href="/admin/topup-report"
      aria-label="ไปหน้ารายงานการเติมเงินเดือนล่าสุด"
    >
      <span class="ico">💰</span>
      <strong>฿<%= Number(stats?.topupMonthSum || 0).toLocaleString(undefined,{ minimumFractionDigits: 2 }) %></strong>
      <small>
        ยอดเติม <%= stats?.topupMonthLabel || 'เดือนล่าสุด' %>
        <% if ((stats?.topupMonthCount || 0) > 0) { %>
          · <%= Number(stats.topupMonthCount).toLocaleString() %> รายการ
        <% } %>
      </small>
    </div>
  </div>
</section>
