<script id="enterprise-admin-ui-js-v1">
(() => {
  const root = document.currentScript?.closest('.eh-admin-auto') || document.querySelector('.eh-admin-auto') || document.body;
  // progressive reveal
  const revealTargets = root.querySelectorAll('.card,.card2,.page-head,.tabs,.bt-tabbar,.orders-controls,.table-wrap,.admin-table-wrap,.user-card,.bt-card,.otp-card');
  revealTargets.forEach((el, i) => { el.classList.add('eh-reveal'); el.style.setProperty('--eh-i', Math.min(i, 10)); });

  // custom dropdown for normal selects only (ไม่ยุ่งกับ select ที่ถูกซ่อน/third party)
  const closeAll = () => document.querySelectorAll('.eh-dd-menu').forEach(m => m.remove());
  const buildSelect = (select) => {
    if (!select || select.dataset.ehReady === '1' || select.multiple) return;
    if (select.closest('.dd,.ms') || select.classList.contains('eh-select-hidden')) return;
    select.dataset.ehReady = '1';
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'eh-dd-trigger';
    btn.setAttribute('aria-haspopup', 'listbox');
    const syncText = () => {
      const opt = select.options[select.selectedIndex];
      btn.textContent = opt ? opt.textContent.trim() : 'เลือก';
    };
    syncText();
    select.classList.add('eh-select-hidden');
    select.insertAdjacentElement('afterend', btn);
    const open = () => {
      closeAll();
      const r = btn.getBoundingClientRect();
      const menu = document.createElement('div');
      menu.className = 'eh-dd-menu';
      menu.setAttribute('role','listbox');
      [...select.options].forEach(opt => {
        const o = document.createElement('button');
        o.type = 'button';
        o.className = 'eh-dd-option' + (opt.selected ? ' is-selected' : '');
        o.textContent = opt.textContent.trim();
        o.dataset.value = opt.value;
        o.addEventListener('click', () => {
          select.value = opt.value;
          select.dispatchEvent(new Event('change', { bubbles:true }));
          syncText();
          closeAll();
        });
        menu.appendChild(o);
      });
      document.body.appendChild(menu);
      const mw = Math.max(r.width, 120);
      menu.style.minWidth = mw + 'px';
      let top = r.bottom + 8;
      let left = Math.min(r.left, window.innerWidth - mw - 10);
      menu.style.left = Math.max(8, left) + 'px';
      menu.style.top = top + 'px';
      const mr = menu.getBoundingClientRect();
      if (mr.bottom > window.innerHeight - 10) menu.style.top = Math.max(8, r.top - mr.height - 8) + 'px';
    };
    btn.addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); document.querySelector('.eh-dd-menu') ? closeAll() : open(); });
    select.addEventListener('change', syncText);
  };
  root.querySelectorAll('select').forEach(buildSelect);
  document.addEventListener('click', closeAll, { passive:true });
  window.addEventListener('resize', closeAll, { passive:true });
  window.addEventListener('scroll', closeAll, { passive:true });
})();
</script>


