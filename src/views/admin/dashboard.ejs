<script>
function rtAdminNotify(variant, title, text){
  if (window.notify && typeof window.notify[variant] === 'function') {
    return window.notify[variant](title, text || '');
  }
  if (window.notify && typeof window.notify.push === 'function') {
    return window.notify.push({ variant, title, text: text || '' });
  }
  if (typeof window.showMsg === 'function') {
    return window.showMsg({ variant, title, text: text || '' });
  }
  alert(text ? `${title}\n${text}` : title);
}

function normalizeMethodForManual(method){
  const m = String(method || 'admin').toLowerCase();
  return m === 'truewallet' ? 'tw' : m;
}

function setManualStatus(html){
  const el = document.getElementById('manualTopupStatus');
  if (el) el.innerHTML = html || '';
}

function openManualTopupFromButton(btn){
  const modal = document.getElementById('manualTopupModal');
  const txIdInput = document.getElementById('manualTxId');
  const usernameInput = document.getElementById('manualUsername');
  const amountInput = document.getElementById('manualAmount');
  const methodInput = document.getElementById('manualMethod');
  if (!modal || !usernameInput || !amountInput || !methodInput) return;

  const txId = btn?.dataset?.txId || '';
  const username = btn?.dataset?.username || '';
  const amount = Number(btn?.dataset?.amount || 0);
  const method = normalizeMethodForManual(btn?.dataset?.method || (txId ? 'admin' : 'admin'));

  document.getElementById('manualTopupForm')?.reset();
  setManualStatus('');

  txIdInput.value = txId;
  usernameInput.value = username;
  amountInput.value = amount > 0 ? amount.toFixed(2) : '';
  amountInput.readOnly = amount > 0;
  amountInput.style.opacity = amount > 0 ? '.72' : '1';

  if (Array.from(methodInput.options).some(o => o.value === method)) methodInput.value = method;
  else methodInput.value = 'admin';

  modal.classList.remove('hidden');
  modal.setAttribute('aria-hidden','false');
  if (username) searchUsers(username);
  else searchUsers('');
  setTimeout(() => usernameInput.focus(), 50);
}

function closeManualTopupModal(){
  const modal = document.getElementById('manualTopupModal');
  if (!modal) return;
  modal.classList.add('hidden');
  modal.setAttribute('aria-hidden','true');
  setManualStatus('');
}

function debounce(fn, wait=240){
  let t;
  return (...args) => { clearTimeout(t); t = setTimeout(() => fn(...args), wait); };
}

function renderUserDatalist(items){
  const dl = document.getElementById('manualUserList');
  if (!dl) return;
  dl.innerHTML = '';
  (items || []).forEach(u => {
    const opt = document.createElement('option');
    opt.value = u.username;
    opt.label = `${u.username}${u.email ? ' · ' + u.email : ''}`;
    dl.appendChild(opt);
  });
}

const searchUsers = debounce(async (q='') => {
  try{
    const url = q && q.length
      ? `/admin/api/users/search?q=${encodeURIComponent(q)}&limit=20`
      : `/admin/api/users/search?limit=20`;
    const r = await fetch(url);
    const j = await r.json();
    if (j?.ok) renderUserDatalist(j.items);
  }catch{}
}, 220);

document.querySelectorAll('[data-open-manual-topup]').forEach(btn => {
  btn.addEventListener('click', () => openManualTopupFromButton(btn));
});
document.querySelectorAll('[data-close-manual]').forEach(el => {
  el.addEventListener('click', closeManualTopupModal);
});
document.getElementById('manualUsername')?.addEventListener('input', (e) => searchUsers(e.target.value.trim()));
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeManualTopupModal(); });

document.getElementById('manualTopupForm')?.addEventListener('submit', async (ev) => {
  ev.preventDefault();
  const username = document.getElementById('manualUsername')?.value.trim();
  const amount = Number(document.getElementById('manualAmount')?.value || 0);
  const method = document.getElementById('manualMethod')?.value || 'admin';
  const txId = document.getElementById('manualTxId')?.value || null;
  if (!username || !(amount > 0)) {
    setManualStatus('❌ กรุณากรอกชื่อผู้ใช้และจำนวนเงินให้ครบถ้วน');
    return;
  }
  setManualStatus('⏳ กำลังทำรายการ...');
  try{
    const r = await fetch('/admin/manual-topup', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ username, amount, method, txId })
    });
    const j = await r.json().catch(()=>({}));
    if (!r.ok || !j.ok) throw new Error(j?.error || 'เติมเงินไม่สำเร็จ');
    setManualStatus(`✅ เติมเงินสำเร็จให้ ${username} จำนวน ${amount.toLocaleString()} บาท`);
    rtAdminNotify('success', 'เติมเงินสำเร็จ', 'อัปเดตเครดิตและบันทึกประวัติเรียบร้อยแล้ว');
    setTimeout(() => location.reload(), 900);
  }catch(err){
    setManualStatus('❌ ' + (err?.message || 'ทำรายการไม่สำเร็จ'));
    rtAdminNotify('error', 'ทำรายการไม่สำเร็จ', err?.message || 'กรุณาลองใหม่อีกครั้ง');
  }
});

async function rejectPendingTx(id){
  if (!id) return;
  const ok = await (window.uiConfirm?.({
    variant: 'danger',
    title: 'ยืนยันปฏิเสธรายการ?',
    sub: 'รายการนี้จะถูกเปลี่ยนเป็นสถานะปฏิเสธ และจะไม่เพิ่มเครดิตให้ผู้ใช้',
    okText: 'ปฏิเสธรายการ',
    cancelText: 'ยกเลิก',
    focus: 'cancel'
  }) || Promise.resolve(confirm('ยืนยันปฏิเสธรายการนี้?')));
  if (!ok) return;

  try{
    const r = await fetch(`/admin/topup/${encodeURIComponent(id)}/reject`, {
      method:'POST',
      headers:{'Content-Type':'application/json'}
    });
    const j = await r.json().catch(()=>({}));
    if (!r.ok || !j.ok) throw new Error(j?.error || 'ปฏิเสธไม่สำเร็จ');
    rtAdminNotify('success', 'ปฏิเสธรายการแล้ว', 'อัปเดตสถานะรายการเรียบร้อยแล้ว');
    setTimeout(()=>location.reload(), 450);
  }catch(err){
    rtAdminNotify('error', 'ทำรายการไม่สำเร็จ', err.message || 'กรุณาลองใหม่อีกครั้ง');
  }
}
</script>
