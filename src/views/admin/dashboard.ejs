<div class="rt-admin-home">
  <section class="rt-admin-hero">
    <div>
      <span class="rt-kicker">RTAUTOBOT Admin</span>
      <h1>ศูนย์จัดการ Bonustime</h1>
      <p>จัดการแพ็กเกจ Bonustime, บัญชีรับเงิน, ประวัติการเติมเครดิต และเติมเครดิตให้ลูกค้าได้จากหน้าเดียว</p>
    </div>
    <a class="rt-primary" href="/admin/bonustime-panel">เปิด Bonustime Panel</a>
  </section>

  <section class="rt-stats-grid" aria-label="ภาพรวมระบบ">
    <article>
      <span>รายได้ Bonustime</span>
      <strong>฿<%= Number(stats?.bonustimeRevenue || 0).toLocaleString(undefined,{minimumFractionDigits:2}) %></strong>
      <small><%= Number(stats?.bonustimeOrderCount || 0).toLocaleString() %> รายการ</small>
    </article>
    <article>
      <span>ยอดเติมเครดิต</span>
      <strong>฿<%= Number(stats?.topupSum || 0).toLocaleString(undefined,{minimumFractionDigits:2}) %></strong>
      <small><%= Number(stats?.topupCount || 0).toLocaleString() %> รายการของ RTAUTOBOT</small>
    </article>
    <article>
      <span>บัญชีรับเงิน</span>
      <strong><%= Number(stats?.walletCount || 0).toLocaleString() %></strong>
      <small>ช่องทางที่ตั้งค่าสำหรับเว็บนี้</small>
    </article>
    <article>
      <span>บริการ Bonustime</span>
      <strong><%= Number(stats?.serviceCount || 0).toLocaleString() %></strong>
      <small>รายการบริการที่ดูแลอยู่</small>
    </article>
  </section>

  <section class="rt-admin-grid" aria-label="เมนูหลังบ้าน">
    <a class="rt-admin-card" href="/admin/bonustime-panel">
      <i>⚡</i>
      <h2>Bonustime Panel</h2>
      <p>จัดการบริการ ลูกค้า Webhook License และข้อมูลใช้งาน Bonustime</p>
    </a>
    <a class="rt-admin-card" href="/admin/settings">
      <i>🏦</i>
      <h2>ตั้งค่าบัญชีรับเงิน</h2>
      <p>กำหนดบัญชีเติมเครดิตเฉพาะ RTAUTOBOT แยกจาก RTSMM-TH</p>
    </a>
    <a class="rt-admin-card" href="/admin/topup-report">
      <i>💳</i>
      <h2>ประวัติการเติมเงิน</h2>
      <p>ตรวจสอบรายการเติมเครดิตของ RTAUTOBOT และจัดการรายการรอดำเนินการ</p>
    </a>
    <a class="rt-admin-card" href="/admin/topup-report#manualTopupModal" data-open-manual="1">
      <i>➕</i>
      <h2>เติมเครดิตแบบแมนนวล</h2>
      <p>เพิ่มเครดิตให้ลูกค้าด้วยแอดมิน พร้อมบันทึกประวัติใน Production ของเว็บนี้</p>
    </a>
  </section>
</div>

<style>
.rt-admin-home{max-width:1180px;margin:0 auto;padding:28px 18px 60px;color:var(--text,#f8ecd2)}
.rt-admin-hero{position:relative;display:flex;align-items:center;justify-content:space-between;gap:22px;padding:30px;border:1px solid color-mix(in srgb,var(--accent,#f5c84b) 25%,transparent);border-radius:28px;background:linear-gradient(135deg,rgba(255,218,110,.14),rgba(255,255,255,.035));box-shadow:0 24px 70px rgba(0,0,0,.34);overflow:hidden}
.rt-admin-hero:before{content:"";position:absolute;inset:-60% auto auto -10%;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,rgba(247,199,72,.25),transparent 62%);pointer-events:none}.rt-admin-hero>*{position:relative}.rt-kicker{display:inline-flex;padding:7px 12px;border-radius:999px;background:rgba(247,199,72,.14);border:1px solid rgba(247,199,72,.25);color:#ffe083;font-weight:800}.rt-admin-hero h1{font-size:clamp(32px,4vw,56px);line-height:1.02;margin:14px 0 10px}.rt-admin-hero p{max-width:680px;color:var(--muted,#d4c6a4);font-weight:650}.rt-primary{white-space:nowrap;text-decoration:none;color:#17130b;background:linear-gradient(135deg,#fff2a3,#e4a81d);padding:15px 22px;border-radius:18px;font-weight:900;box-shadow:0 16px 36px rgba(228,168,29,.26)}
.rt-stats-grid,.rt-admin-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:16px;margin-top:18px}.rt-stats-grid article,.rt-admin-card{border:1px solid rgba(255,255,255,.09);border-radius:24px;background:linear-gradient(135deg,rgba(255,255,255,.07),rgba(255,255,255,.025));padding:22px;box-shadow:0 18px 48px rgba(0,0,0,.25)}.rt-stats-grid span,.rt-stats-grid small,.rt-admin-card p{color:var(--muted,#d4c6a4)}.rt-stats-grid strong{display:block;font-size:28px;color:#ffe083;margin:8px 0}.rt-admin-card{text-decoration:none;color:inherit;transition:.18s ease;min-height:190px}.rt-admin-card:hover{transform:translateY(-4px);border-color:rgba(247,199,72,.38)}.rt-admin-card i{display:grid;place-items:center;width:54px;height:54px;border-radius:18px;background:linear-gradient(135deg,#fff2a3,#e4a81d);color:#16120b;font-style:normal;font-size:24px;margin-bottom:18px}.rt-admin-card h2{font-size:22px;margin:0 0 8px}@media(max-width:920px){.rt-admin-hero{align-items:flex-start;flex-direction:column}.rt-stats-grid,.rt-admin-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:560px){.rt-admin-home{padding:18px 12px 44px}.rt-stats-grid,.rt-admin-grid{grid-template-columns:1fr}.rt-primary{width:100%;text-align:center}}
</style>

<script>
document.querySelector('[data-open-manual]')?.addEventListener('click', function(e){
  e.preventDefault();
  location.href = '/admin/topup-report?manual=1';
});
</script>
