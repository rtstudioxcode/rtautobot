<script>
  function debounce(fn, ms=250){ let t; return (...a)=>{ clearTimeout(t); t=setTimeout(()=>fn(...a), ms); }; }

  function renderUserDatalist(items){
    const dl = document.getElementById('userList');
    dl.innerHTML = '';
    (items||[]).forEach(u=>{
      const opt = document.createElement('option');
      opt.value = u.username;                      // ค่าที่จะถูกกรอก
      opt.label = `${u.username}${u.email?' · '+u.email:''}`;
      dl.appendChild(opt);
    });
  }

  const doUserSearch = debounce(async function(q){
    try{
      const url = q && q.length
        ? `/admin/api/users/search?q=${encodeURIComponent(q)}&limit=20`
        : `/admin/api/users/search?limit=20`;      // อนุญาต preload (q ว่าง)
      const r = await fetch(url);
      const j = await r.json();
      if (j?.ok) renderUserDatalist(j.items);
    }catch{}
  }, 250);

  function bindUsernameSearchOnce(){
    const el = document.getElementById('manualUsername');
    if (!el || el.__binded) return;
    el.addEventListener('input', e => doUserSearch(e.target.value.trim()));
    el.__binded = true;
  }

  (function initManualMethodOnly(){
    const hidden = document.getElementById('manualMethod');
    const root = document.getElementById('manualMethodOnly');
    if (!hidden || !root || root.__ready) return;
    root.__ready = true;

    const btn = root.querySelector('.mm-only-btn');
    const menu = root.querySelector('.mm-only-menu');
    const options = Array.from(root.querySelectorAll('.mm-only-option'));
    const field = root.closest('.manual-field');

    function clearManualDropdownLayers(except = null){
      document
        .querySelectorAll('#manualTopupModal .is-layer-top')
        .forEach(el => {
          if (el !== except && !el.contains(except)) el.classList.remove('is-layer-top');
        });
    }

    function liftManualDropdown(el){
      clearManualDropdownLayers(el);
      el?.classList?.add('is-layer-top');
      el?.closest?.('.manual-field')?.classList?.add('is-layer-top');
      el?.closest?.('.autocomplete')?.classList?.add('is-layer-top');
    }

    function setValue(value, close = true){
      const option = options.find(o => o.dataset.value === value) || options[0];
      if (!option) return;

      hidden.value = option.dataset.value;
      root.dataset.value = option.dataset.value;

      btn.innerHTML = `
        <span class="mm-only-icon">${option.dataset.icon || '💳'}</span>
        <span class="mm-only-copy">
          <b>${option.dataset.title || option.textContent.trim()}</b>
          <small>${option.dataset.sub || 'ช่องทางเติมเงิน'}</small>
        </span>
        <span class="mm-only-caret">⌄</span>
      `;

      options.forEach(o => {
        const selected = o === option;
        o.classList.toggle('is-selected', selected);
        o.setAttribute('aria-selected', String(selected));
      });

      hidden.dispatchEvent(new Event('change', { bubbles:true }));
      if (close) closeMenu();
    }

    function openMenu(){
      liftManualDropdown(root);
      document.getElementById('userSuggestBox')?.classList.add('hidden');
      document.querySelector('.manual-field-user')?.classList.remove('is-layer-top');
      document.querySelector('.manual-field-user .autocomplete')?.classList.remove('is-layer-top');

      root.classList.add('is-open');
      root.classList.add('is-layer-top');
      field?.classList.add('is-layer-top');
      btn.setAttribute('aria-expanded', 'true');

      const rect = root.getBoundingClientRect();
      const below = window.innerHeight - rect.bottom - 18;
      const above = rect.top - 18;
      const useUp = below < 230 && above > below;

      root.classList.toggle('drop-up', useUp);
      menu.style.maxHeight = `${Math.max(150, Math.min(260, useUp ? above : below))}px`;
    }

    function closeMenu(){
      root.classList.remove('is-open', 'drop-up', 'is-layer-top');
      field?.classList.remove('is-layer-top');
      btn.setAttribute('aria-expanded', 'false');
    }

    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      root.classList.contains('is-open') ? closeMenu() : openMenu();
    });

    btn.addEventListener('keydown', (e) => {
      if (['Enter', ' ', 'ArrowDown'].includes(e.key)) {
        e.preventDefault();
        openMenu();
        root.querySelector('.mm-only-option:not(:disabled)')?.focus();
      }
      if (e.key === 'Escape') closeMenu();
    });

    options.forEach(option => {
      option.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        setValue(option.dataset.value);
      });
    });

    menu.addEventListener('keydown', (e) => {
      const active = document.activeElement;
      const index = options.indexOf(active);
      if (e.key === 'Escape') {
        closeMenu();
        btn.focus();
      }
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        options[Math.min(index + 1, options.length - 1)]?.focus();
      }
      if (e.key === 'ArrowUp') {
        e.preventDefault();
        options[Math.max(index - 1, 0)]?.focus();
      }
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        active?.click?.();
      }
    });

    document.addEventListener('click', (e) => {
      if (!root.contains(e.target)) closeMenu();
    });

    window.addEventListener('resize', closeMenu);
    window.addEventListener('scroll', closeMenu, { passive:true });

    root.__setManualMethodValue = setValue;
    root.__closeManualMethodMenu = closeMenu;

    setValue(hidden.value || 'manual', false);
  })();


function openManualTopupModal(txId = null, amount = null, suggestedUsername = '', method = 'admin', lock = false){
    const modalEl = document.getElementById('manualTopupModal');
    if (modalEl && modalEl.parentElement !== document.body) {
      document.body.appendChild(modalEl);
    }

    const modal = document.getElementById("manualTopupModal");
    if (!modal) return;
    modal.classList.remove("hidden");

    loadUsersList();  // โหลด user ไว้ แต่ยังไม่แสดงจนกว่าจะคลิกช่องค้นหา

    const form    = document.getElementById("manualTopupForm");
    const status  = document.getElementById("manualTopupStatus");
    const userInp = document.getElementById("manualUsername");
    const amtInp  = document.getElementById("manualAmount");
    const mSel    = document.getElementById("manualMethod");

    if (form) form.reset();
    if (status) status.innerHTML = "";

    window.currentTxId = txId;

    // ----------------- จำนวนเงิน -----------------
    if (amtInp){
      if (amount){
        amtInp.value = Number(amount).toFixed(2);
        amtInp.readOnly = true;
        amtInp.classList.add('is-readonly');
      }else{
        amtInp.readOnly = false;
        amtInp.classList.remove('is-readonly');
      }
    }

    // ----------------- Username -----------------
    if (userInp){
      if (suggestedUsername && suggestedUsername !== 'null'){
        userInp.value = suggestedUsername;
      } else {
        userInp.value = '';
      }

      bindUsernameSearchOnce();

      // ❗ ปิดระบบ auto-show ตอนเปิด modal
      // ไม่มี doUserSearch('')
      // ไม่มี dispatchEvent(new Event("input"))

      userInp.readOnly = !!lock;
      userInp.classList.toggle('is-readonly', !!lock);
    }

    // ----------------- Method -----------------
    // รายการรอดำเนินการจะล็อกเฉพาะ user + จำนวนเงิน
    // แต่ Method ต้องให้แอดมินเลือกเองก่อนยืนยันเติมเงิน
    if (mSel){
      const nextMethod = (method || 'admin').toLowerCase();
      const methodRoot = document.getElementById('manualMethodOnly');
      const hasMethod = methodRoot
        ? !!methodRoot.querySelector(`.mm-only-option[data-value="${CSS.escape(nextMethod)}"]`)
        : true;

      mSel.value = hasMethod ? nextMethod : 'admin';
      mSel.disabled = false;
      mSel.classList.remove('is-disabled');

      if (typeof methodRoot?.__setManualMethodValue === 'function') {
        methodRoot.__setManualMethodValue(mSel.value, false);
      } else {
        mSel.dispatchEvent(new Event('change', { bubbles: true }));
      }
    }

    document.getElementById('manualMethod')?.closest('label')?.classList.add('align-top');
  }



  // ============ ช่องค้นหา: input event ============

  const userInp = document.getElementById("manualUsername");

  userInp.addEventListener("input", function () {
    const q = this.value.trim().toLowerCase();

    // ว่าง → แสดงทั้งหมด *เฉพาะตอนที่ input ถูก focus*
    if (!q) {
      if (document.activeElement === userInp) {
        renderSuggestBox(allUsers);
      } else {
        hideSuggestBox();
      }
      return;
    }

    const matches = allUsers.filter(u =>
      u.username.toLowerCase().includes(q) ||
      u.email.toLowerCase().includes(q)
    ).slice(0, 20);

    renderSuggestBox(matches);
  });

  // ============ แสดงรายการเมื่อคลิกหรือโฟกัสช่องค้นหา ============

  userInp.addEventListener("focus", () => {
    if (!userInp.value.trim()) {
      renderSuggestBox(allUsers);
    }
  });

  userInp.addEventListener("click", () => {
    if (!userInp.value.trim()) {
      renderSuggestBox(allUsers);
    }
  });

  // ============ ฟังก์ชันซ่อน suggestion box ============

  function hideSuggestBox() {
    const box = document.getElementById("userSuggestBox");
    box?.classList.add("hidden");
    box?.classList.remove("is-layer-top");
    box?.closest(".autocomplete")?.classList.remove("is-layer-top");
    box?.closest(".manual-field")?.classList.remove("is-layer-top");
  }

  function closeManualTopupModal(){
    const modal  = document.getElementById("manualTopupModal");
    const status = document.getElementById("manualTopupStatus");
    if (!modal) return;
    modal.classList.add("hidden");
    if (status) status.innerHTML = "";
  }

  // ปุ่มปิด / overlay / ESC (ผูกกับของเดิม แต่กัน null)
  document.getElementById("manualTopupClose")?.addEventListener('click', closeManualTopupModal);
  document.getElementById("manualTopupModal")?.addEventListener("click", (e)=>{
    if (e.target?.dataset?.close === "1") closeManualTopupModal();
  });
  document.addEventListener("keydown", (e)=>{
    if (e.key === "Escape") {
      const modal = document.getElementById("manualTopupModal");
      if (modal && !modal.classList.contains("hidden")) closeManualTopupModal();
    }
  });
  
  async function submitManualTopup(ev) {
    ev.preventDefault();

    const form = ev.currentTarget || ev.target;
    const username = document.getElementById("manualUsername")?.value?.trim() || "";
    const amount = parseFloat(document.getElementById("manualAmount")?.value || 0);
    const method = document.getElementById("manualMethod")?.value || "admin"; // ⬅️ ใหม่
    const txId = window.currentTxId || null;

    const $status = document.getElementById("manualTopupStatus");
    const submitBtn = form.querySelector('button[type="submit"]');

    // map เพื่อแสดงผลภาษาไทยสวยๆ
    const METHOD_LABELS = {
      admin: "แอดมิน",
      truewallet: "True Wallet",
      kbank: "KBank",
      scb: "SCB",
      qr: "PromptPay QR",
      manual: "เติมมือ",
    };

    // ตรวจค่าพื้นฐาน
    if (!username || !(amount > 0)) {
      $status.innerHTML = '<div class="card soft">❌ กรุณากรอกข้อมูลให้ครบถ้วน</div>';
      return false;
    }

    // ป้องกันกดซ้ำ
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.dataset.keep = submitBtn.textContent;
      submitBtn.textContent = "กำลังทำรายการ…";
    }
    $status.innerHTML = '<div class="muted">⏳ กำลังทำรายการ...</div>';

    try {
      const res = await fetch("/admin/manual-topup", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        // ⬇️ ส่ง method ไปด้วย
        body: JSON.stringify({ username, amount, txId, method }),
      });

      const data = await res.json();
      if (res.ok && data?.ok) {
        const thMethod = METHOD_LABELS[method] || method;
        $status.innerHTML = `
          <div class="card soft">
            ✅ เติมเงินสำเร็จให้ผู้ใช้ <b>${username}</b><br>
            <b>จำนวน:</b> ${amount.toLocaleString(undefined,{maximumFractionDigits:2})} บาท<br>
            <b>วิธีการเติม:</b> ${thMethod}
          </div>`;
        setTimeout(() => closeManualTopupModal?.(), 1500);
        setTimeout(() => window.location.reload(), 1700);
      } else {
        $status.innerHTML =
          '<div class="card soft">❌ ' + (data?.error || "เกิดข้อผิดพลาด") + "</div>";
      }
    } catch (err) {
      $status.innerHTML = '<div class="card soft">❌ ขัดข้อง: ' + (err.message || '') + "</div>";
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = submitBtn.dataset.keep || "ยืนยันเติมเงิน";
        delete submitBtn.dataset.keep;
      }
    }
    return false;
  }
  window.openManualTopupModal = openManualTopupModal;
  window.submitManualTopup = submitManualTopup;
  window.closeManualTopupModal = closeManualTopupModal;

  // Toggle หุบ/ขยายสำหรับมือถือ
  (function initTxAccordion(){
    document.querySelectorAll('.tx-accordion').forEach(card=>{
      card.querySelector('.tx-accordion__head')?.addEventListener('click', ()=>{
        card.dataset.open = (card.dataset.open === '1' ? '0' : '1');
      });
    });
  })();
</script>

