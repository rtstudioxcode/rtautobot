<%
  const pendingList = Array.isArray(pendingTransactions) ? pendingTransactions : [];
  const fmtMoney = (v) => Number(v || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const fmtDate = (v) => new Date(v || Date.now()).toLocaleString('th-TH', {
    timeZone: 'Asia/Bangkok', year: 'numeric', month: 'short', day: 'numeric',
    hour: '2-digit', minute: '2-digit', second: '2-digit'
  });
  const labelMethod = (m) => {
    const key = String(m || '').toLowerCase();
    return (methodLabels && methodLabels[key]) ||
      (key === 'truewallet' ? 'TrueMoney Wallet' : '') ||
      (key || 'ไม่ระบุ');
  };
  const MANUAL_METHOD_OPTIONS = Array.isArray(typeof methodOptions !== 'undefined' ? methodOptions : null) ? methodOptions : [
    { value:'admin', label:'Admin' }, { value:'manual', label:'เติมมือ' }, { value:'tw', label:'TrueMoney Wallet' },
    { value:'qr', label:'PromptPay QR' }, { value:'kbank', label:'กสิกรไทย' }, { value:'scb', label:'ไทยพาณิชย์' }
  ];
  const pendingCount = Number(stats?.pendingCount || 0);
  const activeServiceCount = Number(stats?.activeServiceCount || 0);
  const walletCount = Number(stats?.walletCount || 0);
  const bonustimeOrders = Number(stats?.bonustimeOrderCount || 0);
  const topupCount = Number(stats?.topupCount || 0);
%>

<div class="rt-admin-home rt-admin-v2">
  <section class="admin-hero-v2" aria-label="ภาพรวมผู้ดูแลระบบ">
    <div class="hero-copy">
      <span class="eyebrow"><i>✦</i> RTAUTOBOT CONTROL</span>
      <h1>ศูนย์จัดการ Bonustime</h1>
      <p>ดูแลแพ็กเกจ บัญชีรับเงิน รายการเติมเครดิต และงานตรวจสอบจากหน้าเดียว พร้อมเข้าสู่แผงควบคุมบริการได้ทันที</p>
      <div class="hero-actions">
        <a class="btn-green" href="/admin/bonustime-panel"><span>⚡</span> เปิด Bonustime Panel</a>
        <button class="btn-glass" type="button" data-open-manual-topup><span>＋</span> เติมเงินด้วยตนเอง</button>
      </div>
    </div>

    <div class="hero-command-card" aria-label="สถานะระบบ">
      <div class="command-orb">R</div>
      <div>
        <b>Bonustime Automation</b>
        <small>พร้อมจัดการบริการและเครดิตลูกค้า</small>
      </div>
      <div class="command-mini-grid">
        <span><strong><%= bonustimeOrders.toLocaleString() %></strong><small>ขายไปแล้ว</small></span>
        <span><strong><%= activeServiceCount.toLocaleString() %></strong><small>ทำงานอยู่</small></span>
        <span><strong><%= walletCount.toLocaleString() %></strong><small>บัญชีรับเงิน</small></span>
      </div>
    </div>
  </section>

  <section class="metric-strip" aria-label="ตัวเลขสำคัญ">
    <article class="metric-card revenue">
      <span>รายได้ Bonustime</span>
      <strong>฿<%= fmtMoney(stats?.bonustimeRevenue) %></strong>
      <small><%= bonustimeOrders.toLocaleString() %> รายการที่ขายแล้ว</small>
    </article>
    <article class="metric-card topup">
      <span>ยอดเติมเครดิต</span>
      <strong>฿<%= fmtMoney(stats?.topupSum) %></strong>
      <small><%= topupCount.toLocaleString() %> รายการสำเร็จ</small>
    </article>
    <article class="metric-card pending <%= pendingCount ? 'is-hot' : '' %>">
      <span>รายการเติมเงินรอตรวจสอบ</span>
      <strong>฿<%= fmtMoney(stats?.pendingTotal) %></strong>
      <small><%= pendingCount.toLocaleString() %> รายการ</small>
    </article>
    <article class="metric-card wallet">
      <span>บัญชีรับเงิน</span>
      <strong><%= walletCount.toLocaleString() %></strong>
      <small>ช่องทางที่เปิดในเว็บนี้</small>
    </article>
  </section>

  <section class="quick-panel-grid" aria-label="เมนูลัดหลังบ้าน">
    <a class="quick-panel primary" href="/admin/bonustime-panel">
      <span class="qp-icon">⚡</span>
      <div>
        <small>Service Control</small>
        <h2>Bonustime Panel</h2>
        <p>จัดการบริการ Serial Key Webhook License และสถานะลูกค้า</p>
      </div>
      <i>→</i>
    </a>
    <a class="quick-panel" href="/admin/settings">
      <span class="qp-icon">🏦</span>
      <div>
        <small>Payment Settings</small>
        <h2>ตั้งค่าบัญชีรับเงิน</h2>
        <p>เปิดปิดบัญชีเติมเครดิตและตั้งค่า Auto Topup ของเว็บนี้</p>
      </div>
      <i>→</i>
    </a>
    <a class="quick-panel" href="/admin/topup-report">
      <span class="qp-icon">💳</span>
      <div>
        <small>Topup Report</small>
        <h2>ประวัติการเติมเงิน</h2>
        <p>ตรวจสอบยอดเติมเครดิตและจัดการรายการย้อนหลัง</p>
      </div>
      <i>→</i>
    </a>
  </section>

  <section class="pending-board" aria-label="รายการเติมเงินรอดำเนินการ">
    <div class="pending-board-head">
      <div>
        <span class="eyebrow compact"><i>◆</i> Pending Topup</span>
        <h2>รายการเติมเงินที่รอดำเนินการ</h2>
        <p>เติมเครดิตให้ผู้ใช้หรือปฏิเสธรายการได้ทันที โดยไม่ต้องออกจากหน้าแอดมิน</p>
      </div>
      <div class="pending-summary-chip">
        <span>รอตรวจสอบ</span>
        <strong><%= pendingCount.toLocaleString() %></strong>
      </div>
    </div>

    <% if (pendingList.length) { %>
      <div class="pending-list">
        <% pendingList.forEach(tx => { %>
          <article class="pending-item">
            <div class="pi-date">
              <b><%= fmtDate(tx.createdAt).split(' ')[0] %></b>
              <small><%= fmtDate(tx.createdAt).replace(fmtDate(tx.createdAt).split(' ')[0], '').trim() %></small>
            </div>
            <div class="pi-main">
              <div class="pi-id"><%= tx.transactionId || tx._id || '—' %></div>
              <div class="pi-user">
                <img src="<%= (tx.userId?.avatarUrl || '/static/assets/avatar-default.svg') %>?v=<%= tx.userId?.avatarVer || 0 %>" alt="" width="34" height="34" loading="lazy">
                <span>
                  <b><%= tx.userId?.username || tx.username || '-' %></b>
                  <% if (tx.userId?.email) { %><small><%= tx.userId.email %></small><% } %>
                </span>
              </div>
            </div>
            <div class="pi-method"><span><%= labelMethod(tx.method) %></span></div>
            <div class="pi-amount">฿<%= fmtMoney(tx.amount) %></div>
            <div class="pi-actions">
              <button class="mini-btn success" type="button"
                data-open-manual-topup
                data-tx-id="<%= tx.transactionId || tx._id || '' %>"
                data-username="<%= tx.userId?.username || tx.username || '' %>"
                data-amount="<%= Number(tx.amount || 0) %>"
                data-method="<%= String(tx.method || 'admin').toLowerCase() %>">เติมให้ผู้ใช้</button>
              <button class="mini-btn danger" type="button" onclick="rejectPendingTx('<%= tx._id || tx.transactionId %>')">ปฏิเสธ</button>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state-v2">
        <div class="empty-icon">✓</div>
        <strong>ไม่มีรายการที่ต้องตรวจสอบ</strong>
        <span>เมื่อมีรายการเติมเครดิตรอดำเนินการ ระบบจะแสดงที่ส่วนนี้ทันที</span>
      </div>
    <% } %>
  </section>
</div>

<div id="manualTopupModal" class="rt-modal hidden" aria-hidden="true">
  <div class="rt-modal-overlay" data-close-manual="1"></div>
  <div class="rt-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="manualTopupTitle">
    <div class="rt-modal-head">
      <div>
        <span class="eyebrow compact">Manual Topup</span>
        <h2 id="manualTopupTitle">เติมเงินให้ผู้ใช้</h2>
      </div>
      <button class="rt-modal-close" type="button" data-close-manual="1" aria-label="ปิด">×</button>
    </div>

    <form id="manualTopupForm" class="rt-modal-form">
      <input type="hidden" id="manualTxId" value="">

      <label>
        <span>ชื่อผู้ใช้</span>
        <input class="rt-input" id="manualUsername" type="text" list="manualUserList" autocomplete="off" required placeholder="พิมพ์ Username หรือเลือกจากรายการ">
        <datalist id="manualUserList"></datalist>
      </label>

      <label>
        <span>จำนวนเงิน</span>
        <input class="rt-input" id="manualAmount" type="number" step="0.01" min="1" required placeholder="เช่น 100">
      </label>

      <label>
        <span>Method การเติมเงิน</span>
        <select class="rt-input" id="manualMethod" required>
          <% MANUAL_METHOD_OPTIONS.forEach(opt => { %>
            <option value="<%= opt.value %>"><%= opt.label %></option>
          <% }) %>
        </select>
      </label>

      <div class="rt-modal-note">ระบบจะเพิ่มเครดิตเข้ากระเป๋าผู้ใช้ทันที และบันทึกประวัติเป็นรายการของ RTAUTOBOT</div>
      <div id="manualTopupStatus" class="rt-modal-status"></div>

      <div class="rt-modal-actions">
        <button class="mini-btn" type="button" data-close-manual="1">ยกเลิก</button>
        <button class="mini-btn success" type="submit">ยืนยันเติมเงิน</button>
      </div>
    </form>
  </div>
</div>

