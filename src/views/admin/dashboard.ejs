   ใช้ตัวแปรจาก layout.ejs โดยตรง: --page, --card, --text, --muted, --border, --accent
   ========================================================= */
.eh-page-dashboard-1-ejs{
  --ad-page: var(--page,#08090c);
  --ad-card: var(--card,#17181e);
  --ad-text: var(--text,#fff6e6);
  --ad-muted: var(--muted,#b9ad94);
  --ad-border: color-mix(in srgb,var(--border,rgba(255,255,255,.14)) 78%,transparent);
  --ad-accent: var(--accent,#e8bc53);
  --ad-accent2:#ffe38e;
  --ad-good:#23d37b;
  --ad-bad:#ff5e73;
  --ad-info:#51a7ff;
  --ad-soft: color-mix(in srgb,var(--ad-card) 88%,transparent);
  --ad-deep: color-mix(in srgb,var(--ad-page) 78%,#000 22%);
  --ad-shadow: rgba(0,0,0,.36);
  color:var(--ad-text);
  position:relative;
  isolation:isolate;
}
.eh-page-dashboard-1-ejs::before{
  content:"";
  position:fixed;
  inset:0;
  z-index:-1;
  pointer-events:none;
  background:
    radial-gradient(760px 360px at 12% -4%, color-mix(in srgb,var(--ad-accent) 17%,transparent), transparent 64%),
    radial-gradient(720px 400px at 94% 4%, rgba(80,118,255,.13), transparent 68%),
    radial-gradient(540px 260px at 45% 110%, rgba(35,211,123,.07), transparent 62%);
}
.eh-page-dashboard-1-ejs .adash-hero{
  display:grid!important;
  grid-template-columns:minmax(0,1.55fr) minmax(330px,.85fr);
  gap:24px;
  align-items:end;
  min-height:220px;
  padding:34px clamp(22px,3.2vw,46px)!important;
  margin:0 0 22px!important;
  overflow:hidden;
}
.eh-page-dashboard-1-ejs .adash-hero::before{
  content:"";
  position:absolute;
  inset:-1px;
  background:
    linear-gradient(115deg, transparent 0 42%, rgba(255,255,255,.07) 49%, transparent 57% 100%);
  transform:translateX(-72%);
  animation:adashSheen 7s ease-in-out infinite;
  pointer-events:none;
}
.eh-page-dashboard-1-ejs .adash-kicker{
  width:max-content;
  max-width:100%;
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:8px 14px;
  border-radius:999px;
  border:1px solid color-mix(in srgb,var(--ad-accent) 46%,var(--ad-border));
  color:var(--ad-accent2);
  background:color-mix(in srgb,var(--ad-accent) 12%,transparent);
  font-weight:650;
  letter-spacing:.08em;
  text-transform:uppercase;
  font-size:12px;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.08);
}
.eh-page-dashboard-1-ejs .adash-hero h1{
  margin:16px 0 12px!important;
  font-size:clamp(42px,5vw,76px)!important;
  line-height:.96!important;
  letter-spacing:-.065em!important;
}
.eh-page-dashboard-1-ejs .adash-hero p{
  margin:0;
  max-width:850px;
  color:color-mix(in srgb,var(--ad-text) 78%,var(--ad-muted));
  font-size:clamp(15px,1.15vw,19px);
  line-height:1.8;
  font-weight:450;
}
.eh-page-dashboard-1-ejs .adash-hero-stats{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:12px;
}
.eh-page-dashboard-1-ejs .adash-stat-chip{
  min-height:96px;
  border-radius:22px;
  padding:16px;
  border:1px solid var(--ad-border);
  background:linear-gradient(180deg,rgba(255,255,255,.055),rgba(255,255,255,.018)), color-mix(in srgb,var(--ad-card) 78%,transparent);
  box-shadow:0 20px 48px rgba(0,0,0,.24), inset 0 1px 0 rgba(255,255,255,.07);
}
.eh-page-dashboard-1-ejs .adash-stat-chip .ico{font-size:22px;display:block;margin-bottom:8px;filter:drop-shadow(0 8px 16px color-mix(in srgb,var(--ad-accent) 25%,transparent));}
.eh-page-dashboard-1-ejs .adash-stat-chip strong{display:block;font-size:clamp(20px,1.7vw,30px);line-height:1;color:var(--ad-accent2);letter-spacing:-.03em;}
.eh-page-dashboard-1-ejs .adash-stat-chip small{display:block;margin-top:7px;color:var(--ad-muted)!important;font-weight:550;}

/* Dashboard cards */
.eh-page-dashboard-1-ejs .grid.cards,
.eh-page-dashboard-1-ejs .grid.cards2{
  display:grid!important;
  grid-template-columns:repeat(12,minmax(0,1fr));
  gap:16px!important;
  margin:0 0 18px!important;
}
.eh-page-dashboard-1-ejs .grid.cards > section{grid-column:span 3;}
.eh-page-dashboard-1-ejs .grid.cards2 > section{grid-column:span 4;}
/* Auto-fill dashboard rows: no empty right-side space when a row has fewer cards */
.eh-page-dashboard-1-ejs .grid.cards > section:first-child:nth-last-child(1),
.eh-page-dashboard-1-ejs .grid.cards2 > section:first-child:nth-last-child(1){
  grid-column:span 12;
}
.eh-page-dashboard-1-ejs .grid.cards > section:first-child:nth-last-child(2),
.eh-page-dashboard-1-ejs .grid.cards > section:first-child:nth-last-child(2) ~ section,
.eh-page-dashboard-1-ejs .grid.cards2 > section:first-child:nth-last-child(2),
.eh-page-dashboard-1-ejs .grid.cards2 > section:first-child:nth-last-child(2) ~ section{
  grid-column:span 6;
}
.eh-page-dashboard-1-ejs .grid.cards > section:first-child:nth-last-child(3),
.eh-page-dashboard-1-ejs .grid.cards > section:first-child:nth-last-child(3) ~ section,
.eh-page-dashboard-1-ejs .grid.cards2 > section:first-child:nth-last-child(3),
.eh-page-dashboard-1-ejs .grid.cards2 > section:first-child:nth-last-child(3) ~ section{
  grid-column:span 4;
}
.eh-page-dashboard-1-ejs .grid.cards .card,
.eh-page-dashboard-1-ejs .grid.cards .card2,
.eh-page-dashboard-1-ejs .grid.cards2 .card,
.eh-page-dashboard-1-ejs .grid.cards2 .card2,
.eh-page-dashboard-1-ejs .history-wrapper,
.eh-page-dashboard-1-ejs .manual-modal-card,
.eh-page-dashboard-1-ejs .modal-content,
.eh-page-dashboard-1-ejs .modal-box{
  position:relative;
  overflow:hidden;
  border-radius:24px!important;
  border:1px solid var(--ad-border)!important;
  background:
    radial-gradient(420px 180px at 0% 0%, color-mix(in srgb,var(--ad-accent) 10%,transparent), transparent 62%),
    linear-gradient(180deg,rgba(255,255,255,.052),rgba(255,255,255,.015)),
    color-mix(in srgb,var(--ad-card) 92%,transparent)!important;
  box-shadow:0 22px 58px var(--ad-shadow), inset 0 1px 0 rgba(255,255,255,.06)!important;
}
.eh-page-dashboard-1-ejs .grid.cards .card::after,
.eh-page-dashboard-1-ejs .grid.cards .card2::after,
.eh-page-dashboard-1-ejs .grid.cards2 .card::after,
.eh-page-dashboard-1-ejs .grid.cards2 .card2::after{
  content:"";
  position:absolute;
  inset:auto 16px 0 16px;
  height:1px;
  background:linear-gradient(90deg,transparent,color-mix(in srgb,var(--ad-accent) 42%,transparent),transparent);
  opacity:.7;
}
.eh-page-dashboard-1-ejs .card h3,
.eh-page-dashboard-1-ejs .card2 h3,
.eh-page-dashboard-1-ejs .history-wrapper h3{
  font-weight:650!important;
  letter-spacing:-.02em;
  color:var(--ad-text)!important;
}
.eh-page-dashboard-1-ejs .card-head.row-head{min-height:54px;align-items:flex-start!important;}
.eh-page-dashboard-1-ejs .metric-badge{
  background:linear-gradient(135deg,color-mix(in srgb,var(--ad-accent) 20%,var(--ad-card)),color-mix(in srgb,var(--ad-card) 92%,transparent))!important;
  color:var(--ad-accent2)!important;
  border-color:color-mix(in srgb,var(--ad-accent) 32%,var(--ad-border))!important;
}
.eh-page-dashboard-1-ejs .big{
  margin:10px 0 16px;
  color:var(--ad-accent2)!important;
  text-shadow:0 14px 34px color-mix(in srgb,var(--ad-accent) 22%,transparent);
}
.eh-page-dashboard-1-ejs .btn,
.eh-page-dashboard-1-ejs .btn-lux,
.eh-page-dashboard-1-ejs a.btn,
.eh-page-dashboard-1-ejs button.btn{
  min-height:44px!important;
  border-radius:16px!important;
  border:1px solid color-mix(in srgb,var(--ad-accent) 44%,transparent)!important;
  background:linear-gradient(135deg,#ffe38e,var(--ad-accent) 58%,#bd8626)!important;
  color:#17130a!important;
  font-weight:650!important;
  box-shadow:0 16px 36px color-mix(in srgb,var(--ad-accent) 24%,transparent), inset 0 1px 0 rgba(255,255,255,.58)!important;
  transition:transform .18s ease, filter .18s ease, box-shadow .18s ease!important;
}
.eh-page-dashboard-1-ejs .btn:hover,
.eh-page-dashboard-1-ejs .btn-lux:hover{transform:translateY(-2px);filter:saturate(1.08);box-shadow:0 20px 44px color-mix(in srgb,var(--ad-accent) 30%,transparent), inset 0 1px 0 rgba(255,255,255,.62)!important;}

/* Pending topup table */
.eh-page-dashboard-1-ejs .history-wrapper{
  margin-top:22px!important;
  padding:22px!important;
}
.eh-page-dashboard-1-ejs .history-wrapper .title.flex-between{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:14px;
  margin:0 0 18px!important;
}
.eh-page-dashboard-1-ejs .history-table{
  border-collapse:separate!important;
  border-spacing:0 10px!important;
}
.eh-page-dashboard-1-ejs .history-table thead th{
  background:transparent!important;
  border-bottom:1px solid var(--ad-border)!important;
  padding:14px 12px!important;
}
.eh-page-dashboard-1-ejs .history-table tbody tr{
  background:color-mix(in srgb,var(--ad-card) 86%,var(--ad-page));
  box-shadow:inset 0 0 0 1px color-mix(in srgb,var(--ad-border) 70%,transparent);
  transition:transform .18s ease, box-shadow .18s ease, background .18s ease;
}
.eh-page-dashboard-1-ejs .history-table tbody tr:hover{
  transform:translateY(-1px);
  background:color-mix(in srgb,var(--ad-accent) 7%,var(--ad-card));
  box-shadow:inset 0 0 0 1px color-mix(in srgb,var(--ad-accent) 26%,var(--ad-border)),0 14px 34px rgba(0,0,0,.18);
}
.eh-page-dashboard-1-ejs .history-table tbody td{padding:16px 12px!important;}
.eh-page-dashboard-1-ejs .history-table tbody td:first-child{border-radius:18px 0 0 18px;}
.eh-page-dashboard-1-ejs .history-table tbody td:last-child{border-radius:0 18px 18px 0;}
.eh-page-dashboard-1-ejs .user-inline{font-weight:550;}
.eh-page-dashboard-1-ejs .avatar-sm{width:34px;height:34px;border-radius:12px!important;}

/* Forms + manual modal */
.eh-page-dashboard-1-ejs input,
.eh-page-dashboard-1-ejs textarea,
.eh-page-dashboard-1-ejs select{
  min-height:46px!important;
  border-radius:15px!important;
  border:1px solid var(--ad-border)!important;
  background:color-mix(in srgb,var(--ad-page) 74%,var(--ad-card))!important;
  color:var(--ad-text)!important;
}
.eh-page-dashboard-1-ejs input:focus,
.eh-page-dashboard-1-ejs textarea:focus{
  border-color:color-mix(in srgb,var(--ad-accent) 58%,var(--ad-border))!important;
  box-shadow:0 0 0 4px color-mix(in srgb,var(--ad-accent) 14%,transparent)!important;
}
.eh-page-dashboard-1-ejs .manual-modal,
.eh-page-dashboard-1-ejs .modal,
.eh-page-dashboard-1-ejs [id*="modal" i]{
  backdrop-filter:blur(12px);
}
.eh-page-dashboard-1-ejs .suggest-box{z-index:2147483000!important;border:1px solid color-mix(in srgb,var(--ad-accent) 25%,var(--ad-border))!important;background:color-mix(in srgb,var(--ad-card) 96%,#000 4%)!important;border-radius:16px!important;box-shadow:0 28px 70px rgba(0,0,0,.48)!important;}
.eh-page-dashboard-1-ejs .suggest-item{border-radius:12px;margin:4px 6px;font-weight:500;}
.eh-page-dashboard-1-ejs .suggest-item:hover{background:linear-gradient(135deg,var(--ad-accent2),var(--ad-accent))!important;color:#17130a!important;}

/* light mode refinement */
html[data-theme="light"] .eh-page-dashboard-1-ejs,
body.light .eh-page-dashboard-1-ejs{
  --ad-shadow:rgba(15,23,42,.10);
  --ad-soft: color-mix(in srgb,var(--card,#fff) 94%,transparent);
}
html[data-theme="light"] .eh-page-dashboard-1-ejs .grid.cards .card,
html[data-theme="light"] .eh-page-dashboard-1-ejs .grid.cards .card2,
html[data-theme="light"] .eh-page-dashboard-1-ejs .grid.cards2 .card,
html[data-theme="light"] .eh-page-dashboard-1-ejs .grid.cards2 .card2,
html[data-theme="light"] .eh-page-dashboard-1-ejs .history-wrapper,
body.light .eh-page-dashboard-1-ejs .grid.cards .card,
body.light .eh-page-dashboard-1-ejs .grid.cards .card2,
body.light .eh-page-dashboard-1-ejs .grid.cards2 .card,
body.light .eh-page-dashboard-1-ejs .grid.cards2 .card2,
body.light .eh-page-dashboard-1-ejs .history-wrapper{
  background:linear-gradient(180deg,rgba(255,255,255,.86),rgba(255,255,255,.62)), color-mix(in srgb,var(--ad-card) 96%,transparent)!important;
}

/* motion */
.eh-page-dashboard-1-ejs .grid.cards > section,
.eh-page-dashboard-1-ejs .grid.cards2 > section,
.eh-page-dashboard-1-ejs .history-wrapper{
  animation:adashRise .48s cubic-bezier(.2,.8,.2,1) both;
}
.eh-page-dashboard-1-ejs .grid.cards > section:nth-child(2){animation-delay:.04s}.eh-page-dashboard-1-ejs .grid.cards > section:nth-child(3){animation-delay:.08s}.eh-page-dashboard-1-ejs .grid.cards > section:nth-child(4){animation-delay:.12s}
@keyframes adashRise{from{opacity:0;transform:translateY(14px);filter:blur(8px)}to{opacity:1;transform:none;filter:none}}
@keyframes adashSheen{0%,55%{transform:translateX(-72%)}75%,100%{transform:translateX(72%)}}

@media (max-width:1180px){
  .eh-page-dashboard-1-ejs .adash-hero{grid-template-columns:1fr;align-items:start;}
  .eh-page-dashboard-1-ejs .grid.cards > section{grid-column:span 6;}
  .eh-page-dashboard-1-ejs .grid.cards2 > section{grid-column:span 6;}
}
@media (max-width:720px){
  .eh-page-dashboard-1-ejs .adash-hero{padding:24px 18px!important;border-radius:24px!important;}
  .eh-page-dashboard-1-ejs .adash-hero h1{font-size:clamp(36px,12vw,52px)!important;}
  .eh-page-dashboard-1-ejs .adash-hero-stats{grid-template-columns:1fr;}
  .eh-page-dashboard-1-ejs .grid.cards,
  .eh-page-dashboard-1-ejs .grid.cards2{grid-template-columns:1fr!important;}
  .eh-page-dashboard-1-ejs .grid.cards > section,
  .eh-page-dashboard-1-ejs .grid.cards2 > section{grid-column:auto!important;}
  .eh-page-dashboard-1-ejs .history-wrapper .title.flex-between{align-items:stretch;flex-direction:column;}
  .eh-page-dashboard-1-ejs .history-table{min-width:820px;}
  .eh-page-dashboard-1-ejs .desktop-only{overflow:auto;}
}
@media (prefers-reduced-motion:reduce){
  .eh-page-dashboard-1-ejs *, .eh-page-dashboard-1-ejs::before{animation:none!important;transition:none!important;}
}

/* =========================================================
