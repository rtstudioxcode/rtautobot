<%
  const __dashServices = Array.isArray(stats?.serviceBreakdown) ? stats.serviceBreakdown : [];
  const __dashTotalSale = Number(stats?.totalSoldSale || 0);
%>
<section class="adash-sales-intel" aria-label="กราฟยอดขายรวมทุกบริการ">
  <div class="adash-sales-ambient" aria-hidden="true"></div>
  <div class="adash-sales-head">
    <div>
      <span class="adash-kicker">✦ Sales Summary</span>
      <h2>ภาพรวมรายการขายแล้วทุกบริการ</h2>
      <p>รวมยอดจาก <b>SMM</b>, <b>OTP24</b> และ <b>Apps</b> เพื่อให้ตัวเลขหลังบ้านตรงกับยอดขายจริงทั้งหมด</p>
    </div>
    <div class="adash-sales-total">
      <span>ยอดขายรวมทั้งหมด</span>
      <strong>฿<%= __dashTotalSale.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></strong>
      <small><%= Number(stats?.totalSoldCount || 0).toLocaleString() %> รายการ</small>
    </div>
  </div>

  <div class="adash-sales-grid">
    <% __dashServices.forEach((svc, idx) => { %>
      <article class="adash-sales-card adash-sales-<%= svc.key || idx %>" style="--sale:<%= Number(svc.saleBar || 0) %>%; --count:<%= Number(svc.countBar || 0) %>%; --delay:<%= idx * 80 %>ms">
        <div class="adash-sales-top">
          <span class="adash-sales-icon"><%= svc.icon || '✦' %></span>
          <div>
            <strong><%= svc.label || '-' %></strong>
            <small><%= svc.title || 'Service' %></small>
          </div>
        </div>
        <div class="adash-sales-value">฿<%= Number(svc.sale || 0).toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></div>
        <div class="adash-sales-bars" aria-hidden="true">
          <div><i style="width:var(--sale)"></i></div>
          <div class="is-count"><i style="width:var(--count)"></i></div>
        </div>
        <div class="adash-sales-meta">
          <span><b><%= Number(svc.count || 0).toLocaleString() %></b> รายการ</span>
          <span><%= Number(svc.salePct || 0).toLocaleString(undefined,{maximumFractionDigits:1}) %>% ของยอดขาย</span>
        </div>
      </article>
    <% }) %>
  </div>
</section>

