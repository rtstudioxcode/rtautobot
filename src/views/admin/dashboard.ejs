async function syncServices() {
  try {
    const res   = await fetch('/admin/sync-services', {
      method: 'POST',
      headers: { 'Accept': 'application/json' } // ขอ JSON ชัดๆ
    });

    const text  = await res.text(); // อ่านเป็นข้อความก่อน
    let data    = null;
    try { data = JSON.parse(text); } catch { /* ไม่ใช่ JSON */ }

    // ตรวจทุกเคส: HTTP ไม่ ok หรือ payload ไม่ ok
    if (!res.ok) {
      const msg = data?.error || `${res.status} ${res.statusText}: ${text}`;
      throw new Error(msg);
    }
    if (!data?.ok) {
      throw new Error(data?.error || 'Unknown error');
    }

    // สำเร็จ
    const synced = data.synced ?? data.count ?? 0;
    notify?.success?.('ซิงก์สำเร็จ', `ดึงบริการสำเร็จ ${synced.toLocaleString()} รายการ`);
    // อัปเดต UI ใต้ปุ่ม (ถ้ามี element id="syncRes")
    const el = document.getElementById('syncRes');
    if (el) el.textContent = `ดึงบริการ ${synced.toLocaleString()} รายการแล้ว`;
  } catch (err) {
    notify?.error?.('ซิงก์ล้มเหลว', String(err?.message || err));
    // console.error('[syncServices] failed:', err);
  }
}
