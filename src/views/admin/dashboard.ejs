function renderSuggestBox(list) {
  const box = document.getElementById("userSuggestBox");
  const shell = box?.closest(".autocomplete");
  const field = box?.closest(".manual-field");

  document.getElementById('manualMethodOnly')?.__closeManualMethodMenu?.();

  document
