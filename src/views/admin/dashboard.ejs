<script id="admin-dashboard-enterprise-v2-js">
(() => {
  const root = document.querySelector('.eh-page-dashboard-1-ejs');
  if (!root) return;

  // เพิ่ม data-card-index เพื่อให้จัด animation/hover ได้เนียน โดยไม่แตะ logic เดิม
  [...root.querySelectorAll('.grid.cards > section,.grid.cards2 > section')].forEach((card, i) => {
    card.style.setProperty('--ad-i', i);
    card.setAttribute('data-ad-card', String(i + 1));
  });

  // ยก dropdown custom ให้ลอยบนสุดทุกครั้ง เผื่อชนกับ modal/table layer
  const liftDropdown = () => {
    document.querySelectorAll('.eh-dd-menu,.suggest-box,.mm-only-menu').forEach(el => {
      el.style.zIndex = '2147483647';
    });
  };
  document.addEventListener('click', () => requestAnimationFrame(liftDropdown), true);
  document.addEventListener('focusin', () => requestAnimationFrame(liftDropdown), true);
})();
</script>

<script>
(() => {
  const cards = document.querySelectorAll('.adash-stat-chip[data-href], .card[data-href], .card2[data-href], .card[data-action], .card2[data-action]');
  if (!cards.length) return;

  const runCard = async (card) => {
    if (card.classList.contains('is-action-running')) return;

    const href = card.dataset.href;
    if (href) {
      window.location.href = href;
      return;
    }

    const action = card.dataset.action;
    if (!action) return;

    const fn = window[action];
    if (typeof fn !== 'function') return;

    try {
      card.classList.add('is-action-running');
      await fn();
    } finally {
      card.classList.remove('is-action-running');
    }
  };

  cards.forEach((card) => {
    card.addEventListener('click', (e) => {
      if (e.target.closest('a, button, input, select, textarea, label')) return;
      runCard(card);
    });

    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        runCard(card);
      }
    });
  });
})();
</script>
