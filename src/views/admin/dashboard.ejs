<%
  const pendingList = Array.isArray(pendingTransactions) ? pendingTransactions : [];
  const fmtMoney = (v) => Number(v || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const fmtDate = (v) => new Date(v || Date.now()).toLocaleString('th-TH', {
    timeZone: 'Asia/Bangkok', year: 'numeric', month: 'short', day: 'numeric',
    hour: '2-digit', minute: '2-digit', second: '2-digit'
  });
  const labelMethod = (m) => {
    const key = String(m || '').toLowerCase();
    return (methodLabels && methodLabels[key]) ||
      (key === 'truewallet' ? 'TrueMoney Wallet' : '') ||
      (key || 'ไม่ระบุ');
  };
  const MANUAL_METHOD_OPTIONS = Array.isArray(typeof methodOptions !== 'undefined' ? methodOptions : null) ? methodOptions : [
    { value:'admin', label:'Admin' }, { value:'manual', label:'เติมมือ' }, { value:'tw', label:'TrueMoney Wallet' },
    { value:'qr', label:'PromptPay QR' }, { value:'kbank', label:'กสิกรไทย' }, { value:'scb', label:'ไทยพาณิชย์' }
  ];
%>

<div class="rt-admin-home">
  <section class="rt-admin-hero">
    <div>
      <span class="rt-kicker">RTAUTOBOT Admin</span>
      <h1>ศูนย์จัดการ Bonustime</h1>
      <p>จัดการแพ็กเกจ Bonustime, บัญชีรับเงิน, ประวัติการเติมเครดิต และรายการรอตรวจสอบของลูกค้าได้จากหน้าเดียว</p>
    </div>
    <a class="rt-primary" href="/admin/bonustime-panel">เปิด Bonustime Panel</a>
  </section>

  <section class="rt-stats-grid" aria-label="ภาพรวมระบบ">
    <article>
      <span>รายได้ Bonustime</span>
      <strong>฿<%= fmtMoney(stats?.bonustimeRevenue) %></strong>
      <small><%= Number(stats?.bonustimeOrderCount || 0).toLocaleString() %> รายการ</small>
    </article>
    <article>
      <span>ยอดเติมเครดิต</span>
      <strong>฿<%= fmtMoney(stats?.topupSum) %></strong>
      <small><%= Number(stats?.topupCount || 0).toLocaleString() %> รายการ</small>
    </article>
    <article>
      <span>เติมเงินรอตรวจสอบ</span>
      <strong>฿<%= fmtMoney(stats?.pendingTotal) %></strong>
      <small><%= Number(stats?.pendingCount || 0).toLocaleString() %> รายการ</small>
    </article>
    <article>
      <span>บัญชีรับเงิน</span>
      <strong><%= Number(stats?.walletCount || 0).toLocaleString() %></strong>
      <small>ช่องทางที่ตั้งค่าสำหรับเว็บนี้</small>
    </article>
  </section>

  <section class="rt-admin-grid" aria-label="เมนูหลังบ้าน">
    <a class="rt-admin-card" href="/admin/bonustime-panel">
      <i>⚡</i>
      <h2>Bonustime Panel</h2>
      <p>จัดการบริการ Bonustime</p>
    </a>
    <a class="rt-admin-card" href="/admin/settings">
      <i>🏦</i>
      <h2>ตั้งค่าบัญชีรับเงิน</h2>
      <p>กำหนดบัญชีเติมเครดิต</p>
    </a>
    <a class="rt-admin-card" href="/admin/topup-report">
      <i>💳</i>
      <h2>ประวัติการเติมเงิน</h2>
      <p>ตรวจสอบรายการเติมเครดิต</p>
    </a>
  </section>

  <section class="rt-pending-panel" aria-label="รายการเติมเงินรอดำเนินการ">
    <div class="rt-pending-head">
      <div>
        <span class="rt-kicker">Pending Topup Control</span>
        <h2>รายการเติมเงินที่รอดำเนินการ</h2>
        <p>ตรวจสอบรายการเติมเงินที่รออนุมัติ เติมเครดิตให้ผู้ใช้ หรือปฏิเสธรายการได้จากจุดเดียว</p>
      </div>
      <button class="rt-primary rt-primary-sm" type="button" data-open-manual-topup>เติมเงินด้วยตนเอง</button>
    </div>

    <% if (pendingList.length) { %>
      <div class="rt-pending-table-wrap">
        <table class="rt-pending-table">
          <thead>
            <tr>
              <th>วันที่ / เวลา</th>
              <th>รหัสรายการ</th>
              <th>ผู้ใช้</th>
              <th>วิธีเติม</th>
              <th class="right">จำนวนเงิน</th>
              <th class="center">จัดการ</th>
            </tr>
          </thead>
          <tbody>
            <% pendingList.forEach(tx => { %>
              <tr>
                <td class="muted"><%= fmtDate(tx.createdAt) %></td>
                <td class="tx-id"><%= tx.transactionId || tx._id || '—' %></td>
                <td>
                  <div class="user-cell">
                    <img src="<%= (tx.userId?.avatarUrl || '/static/assets/avatar-default.svg') %>?v=<%= tx.userId?.avatarVer || 0 %>" alt="" width="32" height="32" loading="lazy">
                    <div>
                      <b><%= tx.userId?.username || tx.username || '-' %></b>
                      <% if (tx.userId?.email) { %><small><%= tx.userId.email %></small><% } %>
                    </div>
                  </div>
                </td>
                <td><span class="method-pill"><%= labelMethod(tx.method) %></span></td>
                <td class="amount right">฿<%= fmtMoney(tx.amount) %></td>
                <td>
                  <div class="row-actions">
                    <button class="mini-btn success" type="button"
                      data-open-manual-topup
                      data-tx-id="<%= tx.transactionId || tx._id || '' %>"
                      data-username="<%= tx.userId?.username || tx.username || '' %>"
                      data-amount="<%= Number(tx.amount || 0) %>"
                      data-method="<%= String(tx.method || 'admin').toLowerCase() %>">เติมให้ผู้ใช้</button>
                    <button class="mini-btn danger" type="button" onclick="rejectPendingTx('<%= tx._id || tx.transactionId %>')">ปฏิเสธ</button>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="rt-empty-pending">
        <img src="/static/assets/emoji/empty.png" alt="" aria-hidden="true">
        <strong>ยังไม่มีรายการเติมเงินที่รอดำเนินการ</strong>
        <span>เมื่อมีรายการ pending ระบบจะแสดงในส่วนนี้ทันที</span>
      </div>
    <% } %>
  </section>
</div>

<!-- Manual Topup Modal: ทำรายการได้ในหน้า /admin โดยไม่ต้องเด้งไปหน้า report -->
<div id="manualTopupModal" class="rt-modal hidden" aria-hidden="true">
  <div class="rt-modal-overlay" data-close-manual="1"></div>
  <div class="rt-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="manualTopupTitle">
    <div class="rt-modal-head">
      <div>
        <span class="rt-kicker">Manual Topup</span>
        <h2 id="manualTopupTitle">เติมเงินให้ผู้ใช้</h2>
      </div>
      <button class="rt-modal-close" type="button" data-close-manual="1" aria-label="ปิด">×</button>
    </div>

    <form id="manualTopupForm" class="rt-modal-form">
      <input type="hidden" id="manualTxId" value="">

      <label>
        <span>ชื่อผู้ใช้</span>
        <input class="rt-input" id="manualUsername" type="text" list="manualUserList" autocomplete="off" required placeholder="พิมพ์ Username หรือเลือกจากรายการ">
        <datalist id="manualUserList"></datalist>
      </label>

      <label>
        <span>จำนวนเงิน</span>
        <input class="rt-input" id="manualAmount" type="number" step="0.01" min="1" required placeholder="เช่น 100">
      </label>

      <label>
        <span>Method การเติมเงิน</span>
        <select class="rt-input" id="manualMethod" required>
          <% MANUAL_METHOD_OPTIONS.forEach(opt => { %>
            <option value="<%= opt.value %>"><%= opt.label %></option>
          <% }) %>
        </select>
      </label>

      <div class="rt-modal-note">ระบบจะเพิ่มเครดิตเข้ากระเป๋าผู้ใช้ทันที และบันทึกประวัติเป็นรายการของ RTAUTOBOT</div>
      <div id="manualTopupStatus" class="rt-modal-status"></div>

      <div class="rt-modal-actions">
        <button class="mini-btn" type="button" data-close-manual="1">ยกเลิก</button>
        <button class="mini-btn success" type="submit">ยืนยันเติมเงิน</button>
      </div>
    </form>
  </div>
</div>

<style>
