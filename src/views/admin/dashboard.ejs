/* =========================================================
   Manual Topup Modal — Enterprise High-end
========================================================= */
.manual-topup-enterprise{
  position:fixed!important;
  inset:0!important;
  z-index:2147482500!important;
  display:grid!important;
  place-items:center!important;
  padding:18px!important;
}
.manual-topup-enterprise.hidden{display:none!important}
.manual-topup-overlay{
  position:absolute!important;
  inset:0!important;
  background:
    radial-gradient(760px 420px at 25% 10%, color-mix(in srgb,var(--eh-accent,#e8bc53) 18%, transparent), transparent 68%),
    radial-gradient(620px 340px at 82% 92%, rgba(84,116,255,.16), transparent 70%),
    rgba(0,0,0,.72)!important;
  backdrop-filter:blur(18px) saturate(130%)!important;
  -webkit-backdrop-filter:blur(18px) saturate(130%)!important;
}
.manual-topup-dialog{
  position:relative!important;
  z-index:2!important;
  width:min(560px, calc(100vw - 28px))!important;
  max-height:min(92dvh, 760px)!important;
  overflow:auto!important;
  border-radius:32px!important;
  border:1px solid transparent!important;
  background:
    linear-gradient(135deg, color-mix(in srgb,var(--eh-card,#17181e) 96%,#fff 3%), color-mix(in srgb,var(--eh-page,#07080c) 90%,#000 10%)) padding-box,
    linear-gradient(115deg,var(--eh-accent,#e8bc53),#ffe797,rgba(124,99,255,.85),var(--eh-accent,#e8bc53)) border-box,
    var(--eh-card,#17181e)!important;
  box-shadow:0 38px 120px rgba(0,0,0,.56), inset 0 1px 0 rgba(255,255,255,.10)!important;
  color:var(--eh-text,#fff6e6)!important;
  padding:0!important;
  animation:manualModalIn .28s cubic-bezier(.2,.9,.2,1) both!important;
  isolation:isolate;
}
.manual-topup-dialog::before{
  content:"";
  position:absolute;
  inset:0;
  height:auto;
  border-radius:inherit;
  background:linear-gradient(90deg,var(--eh-accent,#e8bc53),#ffe797,rgba(124,99,255,.85),var(--eh-accent,#e8bc53));
  background-size:220% 100%;
  animation:manualGoldFlow 5s ease-in-out infinite;
  z-index:3;
  pointer-events:none;
  -webkit-mask:linear-gradient(#000 0 0) top/100% 4px no-repeat;
  mask:linear-gradient(#000 0 0) top/100% 4px no-repeat;
}
.manual-topup-dialog::after{
  content:"";
  position:absolute;
  right:-150px;
  top:-170px;
  width:340px;
  height:340px;
  border-radius:999px;
  background:color-mix(in srgb,var(--eh-accent,#e8bc53) 17%,transparent);
  filter:blur(34px);
  pointer-events:none;
  z-index:-1;
}
.manual-topup-close{
  position:absolute;
  top:18px;
  right:18px;
  z-index:5;
  width:46px;
  height:46px;
  border-radius:17px;
  border:1px solid color-mix(in srgb,var(--eh-border,rgba(255,255,255,.12)) 80%,transparent);
  background:rgba(255,255,255,.07);
  color:var(--eh-text,#fff6e6);
  font-size:22px;
  font-weight:950;
  cursor:pointer;
  display:grid;
  place-items:center;
  transition:transform .18s ease,background .18s ease,border-color .18s ease;
}
.manual-topup-close:hover{
  transform:translateY(-1px) rotate(5deg);
  background:rgba(255,95,95,.16);
  border-color:rgba(255,120,120,.36);
}
.manual-topup-hero{
