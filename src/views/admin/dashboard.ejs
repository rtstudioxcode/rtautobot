async function refreshOtp24(){
  const btn   = document.getElementById('btnOtp24');
  const balEl = document.getElementById('otpBal');
  const syncEl= document.getElementById('otpSync');
  const errEl = document.getElementById('otpErr');

  try{
    if (btn){ btn.disabled = true; btn.dataset._label = btn.textContent; btn.textContent = 'กำลังดึง…'; }
    if (balEl){ balEl.dataset._val = balEl.textContent; balEl.textContent = 'กำลังดึง…'; }
    if (errEl){ errEl.textContent = ''; }

    const r = await fetch('/admin/otp24hr/refresh-balance', { method: 'POST', headers:{'Accept':'application/json'} });
    const text = await r.text();
    let d = null; try { d = JSON.parse(text); } catch {}

    if (!r.ok || !d?.ok) {
      const msg = (d && (d.error || d.message)) || text || `HTTP ${r.status}`;
      throw new Error(msg);
    }

    if (balEl){
      balEl.textContent = Number(d.balance).toLocaleString(undefined,{ minimumFractionDigits: 2 }) + (d.currency?(' '+d.currency):'');
    }
    if (syncEl){
      syncEl.textContent = 'ล่าสุด: ' + new Date().toLocaleString();
    }
    if (errEl){ errEl.textContent = ''; }

    window.showMsg?.({
      variant: 'success',
      title: 'ดึงยอด OTP24 สำเร็จ',
      text: `ยอดคงเหลือ: ${Number(d.balance).toLocaleString(undefined,{ minimumFractionDigits:2 })}${d.currency?(' '+d.currency):''}`,
      okText: 'ปิด'
    });
  }catch(err){
    if (balEl && balEl.dataset._val) balEl.textContent = balEl.dataset._val;
    if (syncEl){ syncEl.textContent = 'ล่าสุด: ' + new Date().toLocaleString(); }
    if (errEl){ errEl.textContent = String(err?.message || err); }

    window.showMsg?.({
      variant: 'danger',
      title: 'ล้มเหลว',
      text: String(err?.message || err),
      okText: 'ปิด'
    });
    // console.error('refreshOtp24 error:', err);
  }finally{
    if (btn){ btn.disabled = false; if (btn.dataset._label) btn.textContent = btn.dataset._label; }
  }
}

async function syncOtpServices() {
  try {
    const res = await fetch('/admin/otp24hr/sync-services', {
      method: 'POST',
      headers: { 'content-type': 'application/json', 'accept': 'application/json' },
      body: JSON.stringify({ apiPerc: 0, addPerc: 50 })
    });
    const data = await res.json();
    if (!res.ok || !data?.ok) throw new Error(data?.error || 'sync failed');

    notify?.success?.('ซิงก์สำเร็จ', `อัปเดตแล้ว ${data.count?.toLocaleString?.() ?? data.count} รายการ`);

    // อัปเดตตัวเลขรวม
    const totalEl = document.getElementById('otpSvcTotal');
    if (totalEl) totalEl.textContent = (data.total ?? 0).toLocaleString();

    // ✅ อัปเดต “ล่าสุด: …”
    const lastEl = document.getElementById('otpSvcRes');
    if (lastEl) lastEl.textContent = `ล่าสุด: ${new Date().toLocaleString()}`;
  } catch (err) {
    notify?.error?.('ซิงก์ล้มเหลว', String(err?.message || err));
    // console.error('[syncOtpServices] failed:', err);
  }
}
</script>

