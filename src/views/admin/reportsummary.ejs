  <section class="rs-detail-board rs-anim" aria-label="รายละเอียดคำสั่งซื้อแยกตามบริการ">
    <div class="rs-detail-head">
      <div>
        <span class="rs-kicker mini"><span>✦</span> Service Order</span>
        <h2>รายละเอียดลูกค้าที่ซื้อบริการ</h2>
        <p>แยกแท็บตามบริการเพื่อเช็คได้ทันทีว่าใครซื้ออะไร รายละเอียดบริการอะไร และยอดเงินเท่าไหร่</p>
      </div>
      <span class="rs-detail-total"><%= Number(__detailTotal || 0).toLocaleString() %> รายการ</span>
    </div>

    <div class="rs-detail-tabs" role="tablist" aria-label="แท็บรายละเอียดบริการ">
      <% __detailTabs.forEach((tab, idx) => { %>
        <button class="rs-detail-tab <%= idx === 0 ? 'active' : '' %>" type="button" data-rs-tab="<%= tab.key %>" role="tab" aria-selected="<%= idx === 0 ? 'true' : 'false' %>">
          <span><%= tab.icon %></span><b><%= tab.label %></b><em><%= tab.rows.length.toLocaleString() %></em>
        </button>
      <% }) %>
    </div>

    <% __detailTabs.forEach((tab, idx) => { %>
      <div class="rs-detail-pane <%= idx === 0 ? 'active' : '' %>" data-rs-pane="<%= tab.key %>" role="tabpanel">
        <% if (tab.rows.length) { %>
          <div class="rs-order-grid">
            <% tab.rows.forEach((o, i) => { %>
              <article class="rs-order-card rs-order-<%= tab.key %>" style="--row-delay:<%= Math.min(i * 18, 420) %>ms">
                <div class="rs-order-top">
                  <div>
                    <span class="rs-order-service"><%= __cleanDisplay(o.title, 180) || '-' %></span>
                    <strong><%= o.customer || '-' %></strong>
                    <small><%= o.customerSub || '-' %></small>
                  </div>
                  <span class="rs-order-status"><%= o.status || '-' %></span>
                </div>
                <div class="rs-order-detail">
                  <% if (Array.isArray(o.detailRows) && o.detailRows.length) { %>
                    <div class="rs-secret-rows">
                      <% const __detailSeen = new Set(); %>
                      <% o.detailRows.forEach((row) => { %>
                        <% const __detailKey = __cleanDisplay([row.key, row.value].filter(Boolean).join(': '), 1000).replace(/\s+/g, ' ').replace(/(คืน(?:เครดิต|เงิน)\s*[:：]\s*)(?:฿\s*)?[0-9][0-9,]*(?:\.\d+)?\s*(?:เครดิต|บาท|THB)?/i, '$1AMOUNT').toLowerCase(); %>
                        <% if (!__isNoiseLine(row.value) && !__detailSeen.has(__detailKey)) { __detailSeen.add(__detailKey); %>
                          <div class="rs-secret-row <%= row.key ? '' : 'is-plain' %>">
                            <% if (row.key) { %><b><%= __cleanDisplay(row.key, 80) %></b><% } %>
                            <span><%= __cleanDisplay(row.value, 900) || '-' %></span>
                          </div>
                        <% } %>
                      <% }) %>
                    </div>
                  <% } else { %>
                    <%= __cleanDisplay(o.detail, 900) || '-' %>
                  <% } %>
                </div>
                <div class="rs-order-meta">
                  <span><b>เวลา</b><%= o.at || '-' %></span>
                  <span><b>Order</b><%= o.orderId || '-' %></span>
                  <span><b>จำนวน</b><%= Number(o.qty || 0).toLocaleString() %></span>
                </div>
                <div class="rs-order-extra"><%= __cleanDisplay(o.extra, 240) || '-' %></div>
                <div class="rs-order-money">
                  <% const __isRefundedOrder = String(o.status || '').toLowerCase() === 'refunded' || o.refundApplied === true; %>
                  <span><b>ต้นทุน</b>฿<%= Number(o.cost || 0).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
                  <span><b><%= __isRefundedOrder ? 'คืนเครดิต' : 'ยอดขาย' %></b>฿<%= Number(__isRefundedOrder ? (o.refundAmount || o.sale || 0) : (o.sale || 0)).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
                  <span class="<%= Number(o.profit || 0) >= 0 ? 'is-good' : 'is-bad' %>"><b>กำไร</b>฿<%= Number(o.profit || 0).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
                </div>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="rs-detail-empty">
            <strong>ยังไม่มีรายการในช่วงนี้</strong>
            <span>แท็บนี้จะมีข้อมูลทันทีเมื่อมีคำสั่งซื้อสำเร็จในช่วงที่เลือก</span>
          </div>
        <% } %>
      </div>
    <% }) %>
  </section>
</section>

<style>
/* ===============================
   Enterprise Report Summary Theme
   - Local scoped CSS only
   - Uses layout.ejs variables when available
================================= */
.report-enterprise{
