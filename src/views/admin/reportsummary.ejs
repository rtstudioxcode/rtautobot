  position:absolute;
  inset:auto 18px 14px auto;
  width:48%;
  height:58px;
  border-radius:999px;
  background:linear-gradient(90deg,transparent,color-mix(in srgb,var(--metric-color) 55%,transparent),transparent);
  transform:rotate(-10deg);
  opacity:.38;
  filter:blur(.4px);
  pointer-events:none;
}
.rs-metric-top{position:relative;z-index:2;display:flex;align-items:center;justify-content:space-between;gap:12px}
.rs-metric-icon{
  width:46px;
  height:46px;
