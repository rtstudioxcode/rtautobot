  --rs-card:var(--card,#15161c);
  --rs-card-2:color-mix(in srgb,var(--card,#15161c) 86%,var(--page,#08090d));
  --rs-soft:color-mix(in srgb,var(--card,#15161c) 78%,transparent);
  --rs-text:var(--text,#fff5df);
  --rs-muted:var(--muted,#b9ad91);
  --rs-border:var(--border,rgba(255,255,255,.11));
  --rs-accent:var(--accent,#f4c65f);
  --rs-accent-2:#d39a27;
  --rs-green:#37dc82;
  --rs-red:#ff5d72;
  --rs-blue:#48b8ff;
  --rs-shadow:rgba(0,0,0,.34);
  color:var(--rs-text);
  position:relative;
  isolation:isolate;
  padding:clamp(10px,1.4vw,18px);
}
html[data-theme="light"] .report-enterprise,
body.light .report-enterprise,
[data-bs-theme="light"] .report-enterprise{
  --rs-page:var(--page,#f6f7fb);
  --rs-card:var(--card,#ffffff);
  --rs-card-2:#f9fafc;
  --rs-soft:rgba(255,255,255,.72);
  --rs-text:var(--text,#151821);
  --rs-muted:var(--muted,#637083);
  --rs-border:var(--border,rgba(20,28,42,.12));
  --rs-shadow:rgba(30,41,59,.13);
}
.report-enterprise *{box-sizing:border-box}
.report-enterprise :where(button,input){font:inherit}

.rs-hero,
.rs-toolbar-card,
.rs-table-card,
.rs-metric{
  border:1px solid var(--rs-border);
  background:
    radial-gradient(circle at 18% 0%,color-mix(in srgb,var(--rs-accent) 16%,transparent),transparent 34%),
    linear-gradient(180deg,rgba(255,255,255,.045),rgba(255,255,255,.014)),
    var(--rs-card);
  box-shadow:0 22px 54px var(--rs-shadow), inset 0 1px 0 rgba(255,255,255,.06);
  border-radius:28px;
}
.rs-hero{
  position:relative;
  overflow:hidden;
  min-height:220px;
  padding:clamp(24px,4vw,44px);
  display:grid;
  grid-template-columns:minmax(0,1.4fr) minmax(280px,.65fr);
  gap:24px;
  align-items:end;
  animation:rsRise .58s cubic-bezier(.2,.85,.2,1) both;
}
.rs-orb{position:absolute;border-radius:999px;filter:blur(18px);opacity:.5;pointer-events:none;animation:rsFloat 8s ease-in-out infinite}
.rs-orb-a{width:220px;height:220px;right:12%;top:-110px;background:color-mix(in srgb,var(--rs-accent) 42%,transparent)}
.rs-orb-b{width:180px;height:180px;left:18%;bottom:-120px;background:rgba(126,87,255,.22);animation-delay:-2s}
.rs-kicker{display:inline-flex;align-items:center;gap:8px;width:max-content;max-width:100%;padding:8px 14px;border-radius:999px;border:1px solid color-mix(in srgb,var(--rs-accent) 46%,var(--rs-border));background:color-mix(in srgb,var(--rs-accent) 10%,transparent);color:var(--rs-accent);font-weight:600;font-size:12px;letter-spacing:.08em;text-transform:uppercase}
.rs-kicker.mini{font-size:11px;padding:6px 10px;margin-bottom:8px}
.rs-hero h1{margin:18px 0 10px;font-size:clamp(36px,5.6vw,78px);line-height:.95;font-weight:950;letter-spacing:-.055em;color:var(--rs-text)}
.rs-hero p{margin:0;max-width:760px;color:color-mix(in srgb,var(--rs-muted) 86%,var(--rs-text));font-size:clamp(15px,1.3vw,20px);line-height:1.75;font-weight:700}
.rs-hero-side{display:grid;gap:12px;grid-template-columns:1fr 1fr}
.rs-stat-chip{min-height:98px;padding:18px;border-radius:22px;border:1px solid var(--rs-border);background:linear-gradient(180deg,rgba(255,255,255,.045),rgba(255,255,255,.012));display:flex;flex-direction:column;justify-content:center;gap:6px;backdrop-filter:blur(12px);animation:rsSlide .6s cubic-bezier(.2,.85,.2,1) both .15s}
.rs-chip-label{color:var(--rs-muted);font-size:12px;font-weight:600}
.rs-stat-chip strong{font-size:clamp(20px,2vw,28px);color:var(--rs-accent)}
.rs-good{color:var(--rs-green)!important}.rs-bad{color:var(--rs-red)!important}

.rs-summary-grid{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:16px;
  margin:18px 0;
}
.rs-metric{
  --metric-color:var(--rs-accent);
  --metric-color-2:var(--rs-accent-2);
  position:relative;
  overflow:hidden;
  min-height:208px;
  padding:18px;
  display:grid;
  grid-template-rows:auto 1fr auto;
  gap:12px;
  border-radius:28px;
  animation:rsRise .54s cubic-bezier(.2,.85,.2,1) both;
  animation-delay:var(--delay,0ms);
  background:
    radial-gradient(circle at 12% 0%,color-mix(in srgb,var(--metric-color) 24%,transparent),transparent 34%),
    linear-gradient(145deg,rgba(255,255,255,.064),rgba(255,255,255,.018) 42%,rgba(0,0,0,.10)),
    var(--rs-card);
}
.rs-metric::before{
  content:"";
  position:absolute;
  inset:0;
  border-radius:inherit;
  padding:1px;
  background:linear-gradient(135deg,color-mix(in srgb,var(--metric-color) 42%,transparent),transparent 36%,color-mix(in srgb,var(--rs-border) 80%,transparent));
  -webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);
  -webkit-mask-composite:xor;
          mask-composite:exclude;
  pointer-events:none;
  opacity:.9;
}
.rs-metric::after{
  content:"";
  position:absolute;
  right:-42px;
  bottom:-74px;
  width:230px;
  height:150px;
  border-radius:50%;
  background:radial-gradient(circle,color-mix(in srgb,var(--metric-color) 30%,transparent),transparent 68%);
  filter:blur(6px);
  opacity:.8;
  pointer-events:none;
}
