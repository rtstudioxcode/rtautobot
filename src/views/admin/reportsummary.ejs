  background:linear-gradient(135deg,color-mix(in srgb,var(--metric-color) 28%,transparent),color-mix(in srgb,var(--metric-color) 11%,transparent));
  box-shadow:0 16px 32px color-mix(in srgb,var(--metric-color) 18%,transparent), inset 0 1px 0 rgba(255,255,255,.16);
}
.rs-metric-badge{
  border:1px solid color-mix(in srgb,var(--metric-color) 24%,var(--rs-border));
  background:color-mix(in srgb,var(--rs-card) 72%,transparent);
  color:color-mix(in srgb,var(--metric-color) 72%,var(--rs-text));
  border-radius:999px;
  padding:7px 11px;
  font-size:12px;
  font-weight:650;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.06);
}
.rs-metric-badge.is-good{--metric-color:var(--rs-green)}
.rs-metric-badge.is-bad{--metric-color:var(--rs-red)}
.rs-metric-body{position:relative;z-index:2;align-self:center}
.rs-metric h3{margin:0 0 8px;color:color-mix(in srgb,var(--rs-muted) 86%,var(--rs-text));font-size:14px;font-weight:650;letter-spacing:-.01em}
.rs-big{
  color:var(--metric-color);
  font-size:clamp(28px,2.9vw,42px);
  line-height:1;
  font-weight:650;
  letter-spacing:-.045em;
  text-shadow:0 10px 28px color-mix(in srgb,var(--metric-color) 18%,transparent);
  word-break:break-word;
}
.rs-big small{font-size:.55em;letter-spacing:-.02em;color:color-mix(in srgb,var(--metric-color) 86%,var(--rs-text))}
.rs-metric-body p{margin:10px 0 0;color:var(--rs-muted);font-size:12.5px;line-height:1.45;font-weight:750;max-width:94%}
.rs-metric-foot{
  position:relative;
  z-index:2;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  min-height:40px;
  padding:9px 11px;
  border-radius:16px;
  border:1px solid color-mix(in srgb,var(--metric-color) 16%,var(--rs-border));
  background:color-mix(in srgb,var(--rs-page) 34%,transparent);
}
.rs-metric-foot span{color:var(--rs-muted);font-size:11.5px;font-weight:850}
.rs-metric-foot strong{color:var(--rs-text);font-size:13px;font-weight:950;white-space:nowrap}
.rs-micro-chart{position:absolute;right:20px;bottom:70px;width:128px;height:42px;display:flex;align-items:flex-end;gap:5px;opacity:.72;pointer-events:none;z-index:1}
.rs-micro-chart i{display:block;width:16px;border-radius:999px;background:linear-gradient(180deg,color-mix(in srgb,var(--metric-color) 80%,white),color-mix(in srgb,var(--metric-color) 32%,transparent));box-shadow:0 0 18px color-mix(in srgb,var(--metric-color) 20%,transparent)}
.rs-micro-chart i:nth-child(1){height:14px}.rs-micro-chart i:nth-child(2){height:20px}.rs-micro-chart i:nth-child(3){height:28px}.rs-micro-chart i:nth-child(4){height:24px}.rs-micro-chart i:nth-child(5){height:36px}
.rs-metric-cost{--metric-color:#f1d58a;--metric-color-2:#c9a046}
.rs-metric-sale{--metric-color:var(--rs-accent);--metric-color-2:var(--rs-accent-2)}
.rs-metric-count{--metric-color:var(--rs-blue);--metric-color-2:#2563eb}
.rs-metric-profit{--metric-color:var(--rs-green);--metric-color-2:#059669}
.rs-muted{color:var(--rs-muted)}.rs-accent{color:var(--rs-accent)}.rs-info{color:var(--rs-blue)}.rs-success{color:var(--rs-green)}.rs-danger{color:var(--rs-red)}

.rs-toolbar-card{
  position:relative;
  display:grid;
  grid-template-columns:minmax(260px,1.1fr) minmax(210px,.7fr) auto;
  align-items:center;
  gap:14px;
  padding:18px;
  margin:16px 0;
  border-radius:26px;
  animation:rsRise .58s cubic-bezier(.2,.85,.2,1) both .12s;
