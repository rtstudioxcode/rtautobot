.report-enterprise .rs-detail-pane{display:none}.report-enterprise .rs-detail-pane.active{display:block}.report-enterprise .rs-order-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:13px}.report-enterprise .rs-order-card{position:relative;overflow:hidden;border:1px solid color-mix(in srgb,var(--rs-border) 88%,transparent);border-radius:24px;padding:15px;background:linear-gradient(145deg,rgba(255,255,255,.045),rgba(255,255,255,.018));animation:rsRowIn .48s cubic-bezier(.2,.85,.2,1) both var(--row-delay,0ms)}.report-enterprise .rs-order-card::before{content:"";position:absolute;inset:0 0 auto 0;height:2px;background:linear-gradient(90deg,transparent,var(--rs-accent),transparent);opacity:.45}.report-enterprise .rs-order-top{display:flex;justify-content:space-between;gap:12px;align-items:flex-start}.report-enterprise .rs-order-service{display:inline-block;color:var(--rs-accent);font-weight:950;font-size:12px;margin-bottom:5px}.report-enterprise .rs-order-top strong{display:block;color:var(--rs-text);font-size:16px}.report-enterprise .rs-order-top small{display:block;color:var(--rs-muted);margin-top:2px}.report-enterprise .rs-order-status{white-space:nowrap;padding:7px 10px;border-radius:999px;border:1px solid color-mix(in srgb,var(--rs-accent) 34%,var(--rs-border));color:var(--rs-accent);font-weight:950;font-size:11px;background:rgba(255,255,255,.035)}
.report-enterprise .rs-order-detail{margin:13px 0;padding:12px;border-radius:18px;background:rgba(0,0,0,.18);border:1px solid rgba(255,255,255,.055);color:var(--rs-text);line-height:1.55;word-break:break-word}.report-enterprise .rs-secret-rows{display:grid;gap:8px}.report-enterprise .rs-secret-row{display:grid;grid-template-columns:110px minmax(0,1fr);gap:10px;align-items:start;padding:8px 10px;border-radius:14px;background:color-mix(in srgb,var(--rs-accent) 5%,transparent);border:1px solid color-mix(in srgb,var(--rs-accent) 20%,rgba(255,255,255,.06))}.report-enterprise .rs-secret-row b{color:var(--rs-accent);font-size:12px;font-weight:950}.report-enterprise .rs-secret-row span{color:var(--rs-text);font-weight:350;word-break:break-word}.report-enterprise .rs-secret-row.is-plain{display:block}.report-enterprise .rs-secret-row.is-plain span{display:block}.report-enterprise .rs-order-meta{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px}.report-enterprise .rs-order-meta span,.report-enterprise .rs-order-money span{padding:9px;border-radius:16px;background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.055);color:var(--rs-text);font-weight:850}.report-enterprise .rs-order-meta b,.report-enterprise .rs-order-money b{display:block;color:var(--rs-muted);font-size:11px;margin-bottom:3px}.report-enterprise .rs-order-extra{margin-top:9px;color:var(--rs-muted);font-size:12px;line-height:1.55}.report-enterprise .rs-order-money{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;margin-top:11px}.report-enterprise .rs-order-money .is-good{color:#57dfa5}.report-enterprise .rs-order-money .is-bad{color:#ff7a7a}.report-enterprise .rs-detail-empty{padding:28px;border-radius:24px;border:1px dashed var(--rs-border);text-align:center;color:var(--rs-muted);background:rgba(255,255,255,.025)}.report-enterprise .rs-detail-empty strong{display:block;color:var(--rs-text);font-size:18px;margin-bottom:4px}
@keyframes rsRowIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
@media(max-width:860px){.report-enterprise .rs-order-grid{grid-template-columns:1fr}.report-enterprise .rs-order-meta,.report-enterprise .rs-order-money{grid-template-columns:1fr}.report-enterprise .rs-detail-head{flex-direction:column}.report-enterprise .rs-detail-total{align-self:flex-start}.report-enterprise .rs-chart-tip{left:auto;right:-8px;transform:translateY(8px)}.report-enterprise .rs-hover-dot:hover .rs-chart-tip,.report-enterprise .rs-hover-dot:focus-visible .rs-chart-tip{transform:translateY(0)}}

</style>

<script>
(function(){
  const MONTH_NAMES_TH = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];

  const IS_YEAR_MODE = <%- safeJson(isYearMode) %>;
  const input   = document.getElementById('monthInput');
  const btnOpen = document.getElementById('btnOpenPicker');
  const popup   = document.getElementById('monthPicker');
  const yearEl  = document.getElementById('mpYear');
  const grid    = document.getElementById('mpGrid');
  const btnPrevY= document.getElementById('mpPrevYear');
  const btnNextY= document.getElementById('mpNextYear');
  const btnOK   = document.getElementById('mpOK');
  const btnClear= document.getElementById('mpClear');
  const btnThis = document.getElementById('mpThisMonth');
  const btnPrev = document.getElementById('btnPrev');
  const btnNext = document.getElementById('btnNext');
  const btnThisMonth = document.getElementById('btnThisMonth');
  const btnModeMonth = document.getElementById('btnModeMonth');
  const btnModeYear = document.getElementById('btnModeYear');
  const toolbarEl = document.querySelector('.month-toolbar');
  const card = popup?.querySelector('.mp-card');

  if (!input || !popup || !card) return;

  const now = new Date();
  let selYear  = now.getFullYear();
  let selMonth = now.getMonth();
  let tempYear, tempMonth;

  const rawValue = (input.value || '').trim();
  if (IS_YEAR_MODE) {
    const yy = Number(rawValue.slice(0,4));
    if (yy) selYear = yy;
  } else {
    const monthStrInit = rawValue.slice(0,7);
    if (monthStrInit){
      const [yy,mm] = monthStrInit.split('-').map(n=>+n);
      if (yy && mm){ selYear = yy; selMonth = mm-1; }
    }
  }
  tempYear = selYear; tempMonth = selMonth;

  function toYYYYMM(y,m){ return `${y}-${String(m+1).padStart(2,'0')}`; }
  function goMonth(monthStr){
    const u = new URL(location.href);
    u.searchParams.set('mode', 'month');
    u.searchParams.set('month', monthStr);
    u.searchParams.delete('year');
    location.href = u.toString();
  }
  function goYear(year){
    const u = new URL(location.href);
    u.searchParams.set('mode', 'year');
    u.searchParams.set('year', String(year));
    u.searchParams.delete('month');
    location.href = u.toString();
  }
  function goSelected(){
    if (IS_YEAR_MODE) goYear(tempYear);
    else goMonth(toYYYYMM(tempYear, tempMonth));
  }
  function clamp(n,min,max){ return Math.max(min, Math.min(max, n)); }

  btnModeMonth?.addEventListener('click', ()=> goMonth(toYYYYMM(selYear, selMonth)));
  btnModeYear?.addEventListener('click', ()=> goYear(selYear));

  btnPrev?.addEventListener('click', ()=>{
    if (IS_YEAR_MODE) return goYear(selYear - 1);
    const d = new Date(selYear, selMonth-1, 1);
    goMonth(toYYYYMM(d.getFullYear(), d.getMonth()));
  });
  btnNext?.addEventListener('click', ()=>{
    if (IS_YEAR_MODE) return goYear(selYear + 1);
    const d = new Date(selYear, selMonth+1, 1);
    goMonth(toYYYYMM(d.getFullYear(), d.getMonth()));
  });
  btnThisMonth?.addEventListener('click', ()=> IS_YEAR_MODE ? goYear(now.getFullYear()) : goMonth(toYYYYMM(now.getFullYear(), now.getMonth())));

  function renderGrid(){
    if (!yearEl || !grid) return;
    yearEl.textContent = IS_YEAR_MODE ? `เลือกปี` : String(tempYear);
    grid.innerHTML = '';

    if (IS_YEAR_MODE) {
      const startYear = tempYear - 5;
      for (let i=0;i<12;i++){
        const y = startYear + i;
        const b = document.createElement('button');
        b.type='button';
        b.className = 'mp-m'
          + (y === selYear ? ' active' : '')
          + (y === now.getFullYear() ? ' current' : '');
        b.textContent = String(y + 543);
        b.setAttribute('role','gridcell');
        b.addEventListener('click', ()=>{
          tempYear = y;
          [...grid.children].forEach(c=>c.classList.remove('active'));
          b.classList.add('active');
        });
        grid.appendChild(b);
      }
      return;
    }

    for (let m=0;m<12;m++){
      const b = document.createElement('button');
      b.type='button';
      b.className = 'mp-m'
        + (m===tempMonth && tempYear===selYear ? ' active' : '')
        + (m===now.getMonth() && tempYear===now.getFullYear() ? ' current' : '');
      b.textContent = MONTH_NAMES_TH[m];
      b.setAttribute('role','gridcell');
      b.addEventListener('click', ()=>{
        tempMonth = m;
        [...grid.children].forEach(c=>c.classList.remove('active'));
        b.classList.add('active');
      });
      grid.appendChild(b);
    }
  }

  function positionAnchored(){
    const rect = toolbarEl?.getBoundingClientRect();
    const cardW = Math.min(342, Math.round(window.innerWidth * 0.92));
    const cardH = card.offsetHeight || 330;
    let left = rect ? rect.left + (rect.width/2) - (cardW/2) : (window.innerWidth-cardW)/2;
    let top = rect ? rect.bottom + 10 : (window.innerHeight-cardH)/2;
    left = clamp(left, 12, window.innerWidth - cardW - 12);
    top = clamp(top, 12, window.innerHeight - cardH - 12);
    card.style.setProperty('--mp-left', `${Math.round(left)}px`);
    card.style.setProperty('--mp-top', `${Math.round(top)}px`);
  }
  function onRelayout(){
    if (popup.hasAttribute('hidden')) return;
    positionAnchored();
  }
  function openPicker(){
    if (!popup.hasAttribute('hidden')) return;
    tempYear = selYear; tempMonth = selMonth;
    renderGrid();
    popup.removeAttribute('hidden');
    popup.setAttribute('aria-hidden','false');
    requestAnimationFrame(positionAnchored);
    setTimeout(()=> popup.querySelector('.mp-m.active, .mp-m.current, .mp-m')?.focus(), 0);
    window.addEventListener('resize', onRelayout, {passive:true});
    window.addEventListener('scroll', onRelayout, {passive:true});
  }
  function closePicker(){
    popup.setAttribute('hidden','');
    popup.setAttribute('aria-hidden','true');
    window.removeEventListener('resize', onRelayout);
    window.removeEventListener('scroll', onRelayout);
  }

  btnOpen?.addEventListener('click', openPicker);
  input?.addEventListener('click', openPicker);
  popup?.querySelector('[data-close-month-picker]')?.addEventListener('click', closePicker);
  btnPrevY?.addEventListener('click', ()=>{
    tempYear += IS_YEAR_MODE ? -12 : -1;
    renderGrid();
  });
  btnNextY?.addEventListener('click', ()=>{
    tempYear += IS_YEAR_MODE ? 12 : 1;
    renderGrid();
  });
  btnOK?.addEventListener('click', ()=>{
    closePicker();
    goSelected();
  });
  btnClear?.addEventListener('click', ()=>{
    closePicker();
    IS_YEAR_MODE ? goYear(now.getFullYear()) : goMonth(toYYYYMM(now.getFullYear(), now.getMonth()));
  });
  btnThis?.addEventListener('click', ()=>{
    tempYear = now.getFullYear(); tempMonth = now.getMonth();
    renderGrid();
  });
  window.addEventListener('keydown', (e)=>{
    if (e.key==='Escape' && !popup.hasAttribute('hidden')) closePicker();
  });

  document.querySelectorAll('[data-rs-tab]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.getAttribute('data-rs-tab');
      document.querySelectorAll('[data-rs-tab]').forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected','false'); });
      document.querySelectorAll('[data-rs-pane]').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      btn.setAttribute('aria-selected','true');
      document.querySelector(`[data-rs-pane="${key}"]`)?.classList.add('active');
    });
  });

  window.__reportPeriodPicker__ = { openPicker, closePicker, positionAnchored };
})();
</script>

<style>
@media(max-width:560px){.report-enterprise .rs-secret-row{grid-template-columns:1fr}.report-enterprise .rs-secret-row b{font-size:11px}}
</style>
