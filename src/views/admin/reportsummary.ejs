.rs-toolbar-copy strong{display:block;color:var(--rs-text);font-size:16px;font-weight:950;line-height:1.2}
.rs-toolbar-copy small{display:block;color:var(--rs-muted);font-size:12.5px;font-weight:750;margin-top:4px;line-height:1.45;max-width:460px}
.rs-current-month{
  min-height:54px;
  padding:10px 16px;
  border-radius:18px;
  border:1px solid var(--rs-border);
  background:linear-gradient(135deg,color-mix(in srgb,var(--rs-accent) 10%,transparent),color-mix(in srgb,var(--rs-soft) 86%,transparent));
  display:flex;
  align-items:center;
  justify-content:center;
  flex-direction:column;
  gap:2px;
  text-align:center;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.05);
