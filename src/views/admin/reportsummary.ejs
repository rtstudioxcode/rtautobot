<%
// monthStr รูปแบบ 'YYYY-MM' | yearStr รูปแบบ 'YYYY'
const reportModeSafe = (typeof reportMode !== 'undefined' && reportMode === 'year') ? 'year' : 'month';
const isYearMode = reportModeSafe === 'year';
const [yy, mm] = (monthStr || '').split('-').map(Number);
const selectedYear = Number(typeof yearStr !== 'undefined' && yearStr ? yearStr : (yy || new Date().getFullYear()));
const MONTHS_TH = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
const headMonthLabel = isYearMode ? `ปี ${selectedYear + 543}` : `${MONTHS_TH[(mm||1)-1]} ${Number(yy || selectedYear) + 543}`;
const totalCost = Number(monthTotals?.cost || 0);
const totalSale = Number(monthTotals?.sale || 0);
const totalCount = Number(monthTotals?.count || 0);
const totalProfit = Number(monthTotals?.profit || 0);
const profitRate = totalSale > 0 ? Math.round((totalProfit / totalSale) * 1000) / 10 : 0;
const activeBuckets = Array.isArray(rows) ? rows.filter(r => Number(r.sale || 0) || Number(r.cost || 0) || Number(r.count || 0)).length : 0;
const avgSale = activeBuckets > 0 ? totalSale / activeBuckets : 0;
const avgProfit = activeBuckets > 0 ? totalProfit / activeBuckets : 0;
const avgCost = activeBuckets > 0 ? totalCost / activeBuckets : 0;
const periodUnit = isYearMode ? 'เดือน' : 'วัน';
const detailKicker = isYearMode ? 'Monthly breakdown' : 'Daily breakdown';
const selectedPeriodValue = isYearMode ? String(selectedYear) : String(monthStr || '');
const __serviceBreakdown = Array.isArray(typeof serviceBreakdown !== 'undefined' ? serviceBreakdown : null) ? serviceBreakdown : [];
const __orderDetailsRaw = (typeof orderDetails !== 'undefined' && orderDetails) ? orderDetails : {};
const __detailTabs = [
  { key:'smm', label:'SMM', icon:'📣', rows:Array.isArray(__orderDetailsRaw.smm) ? __orderDetailsRaw.smm : [] },
  { key:'otp24', label:'OTP24', icon:'🔐', rows:Array.isArray(__orderDetailsRaw.otp24) ? __orderDetailsRaw.otp24 : [] },
  { key:'apps', label:'Apps', icon:'📱', rows:Array.isArray(__orderDetailsRaw.apps) ? __orderDetailsRaw.apps : [] },
];
const __detailTotal = __detailTabs.reduce((sum,t)=>sum + t.rows.length, 0);

function __cleanDisplay(v, max = 800) {
  return String(v ?? '')
    .replace(/&lt;\s*br\s*\/?\s*&gt;/gi, ' ')
    .replace(/&lt;\s*hr[^&]*&gt;/gi, ' ')
    .replace(/&lt;[^&]*&gt;/g, ' ')
    .replace(/<\s*br\s*\/?\s*>/gi, ' ')
    .replace(/<\s*hr[^>]*>/gi, ' ')
    .replace(/<[^>]*>/g, ' ')
    .replace(/(?:^|\s)(?:\.\/)?logstext\/[\w./-]+(?:\.txt)?(?=\s|$)/gi, ' ')
    .replace(/(?:^|\s)[─━═_\-—]{6,}(?=\s|$)/g, ' ')
    .replace(/&nbsp;/gi, ' ')
    .replace(/&amp;/gi, '&')
    .replace(/&quot;/gi, '"')
    .replace(/&#39;|&apos;/gi, "'")
    .replace(/&lt;/gi, '<')
    .replace(/&gt;/gi, '>')
    .replace(/\s+/g, ' ')
    .trim()
    .slice(0, max);
}
function __isNoiseLine(v) {
  const s = __cleanDisplay(v, 1000);
  return !s
    || /^(?:\.\/)?logstext\//i.test(s)
    || /^[─━═_\-—]{6,}$/.test(s)
    || /เพื่อความรวดเร็ว\s*\/?\s*ติดต่อสอบถาม\s*Facebook/i.test(s)
    || /^สำเร็จ$/i.test(s);
}

const __serviceMaxSale = Math.max(1, ...__serviceBreakdown.map(s => Number(s.sale || 0)));
const __serviceMaxCount = Math.max(1, ...__serviceBreakdown.map(s => Number(s.count || 0)));
const __rowMaxSale = Math.max(1, ...(Array.isArray(rows) ? rows.map(r => Number(r.sale || 0)) : [0]));
const __rowMaxProfit = Math.max(1, ...(Array.isArray(rows) ? rows.map(r => Math.abs(Number(r.profit || 0))) : [0]));

const __trendRows = Array.isArray(rows) ? rows : [];
const __trendLabels = __trendRows.map((r, idx) => isYearMode ? String(r.monthNo || idx + 1) : String(r.day || idx + 1));
const __trendSaleVals = __trendRows.map(r => Number(r.sale || 0));
const __trendCountVals = __trendRows.map(r => Number(r.count || 0));
const __trendProfitVals = __trendRows.map(r => Number(r.profit || 0));
const __trendCountMax = Math.max(1, ...__trendCountVals, 1);
const __trendProfitMin = Math.min(0, ...__trendProfitVals, 0);
const __trendProfitMax = Math.max(1, ...__trendProfitVals, 0);
const __chartW = 1180;
const __chartH = 290;
const __padLeft = 18;
const __padRight = 18;
const __padTop = 18;
const __padBottom = 38;
const __plotW = Math.max(1, __chartW - __padLeft - __padRight);
const __plotH = Math.max(1, __chartH - __padTop - __padBottom);
const __pointCount = Math.max(__trendRows.length, 1);
const __stepX = __pointCount > 1 ? (__plotW / (__pointCount - 1)) : 0;

function rsScaleY(value, min, max) {
  const range = (max - min) || 1;
  return __padTop + (__plotH - (((Number(value || 0) - min) / range) * __plotH));
}
function rsPointX(index) {
  if (__pointCount <= 1) return __padLeft + (__plotW / 2);
  return __padLeft + (__stepX * index);
}
function rsBuildSeries(values, min, max) {
  return values.map((v, i) => ({ x: rsPointX(i), y: rsScaleY(v, min, max), value: Number(v || 0), idx: i }));
}
function rsPath(points) {
  return points.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x.toFixed(2)} ${p.y.toFixed(2)}`).join(' ');
}
function rsAreaPath(points, baseY) {
  if (!points.length) return '';
  return `${rsPath(points)} L ${points[points.length - 1].x.toFixed(2)} ${baseY.toFixed(2)} L ${points[0].x.toFixed(2)} ${baseY.toFixed(2)} Z`;
}
const __salePoints = rsBuildSeries(__trendSaleVals, 0, __rowMaxSale);
const __countPoints = rsBuildSeries(__trendCountVals, 0, __trendCountMax);
const __profitPoints = rsBuildSeries(__trendProfitVals, __trendProfitMin, __trendProfitMax);
const __salePath = rsPath(__salePoints);
const __countPath = rsPath(__countPoints);
const __profitPath = rsPath(__profitPoints);
const __saleAreaPath = rsAreaPath(__salePoints, rsScaleY(0, 0, __rowMaxSale));
const __profitZeroY = rsScaleY(0, __trendProfitMin, __trendProfitMax);
const __gridLevels = [0, 0.25, 0.5, 0.75, 1].map(v => (__padTop + (__plotH * v)));
%>


<section class="report-enterprise" data-page="reportsummary">
  <section class="rs-hero" aria-label="สรุปยอดขาย">
    <div class="rs-orb rs-orb-a" aria-hidden="true"></div>
    <div class="rs-orb rs-orb-b" aria-hidden="true"></div>

    <div class="rs-hero-main">
      <div class="rs-kicker"><span>✦</span> <%= isYearMode ? 'Yearly revenue intelligence' : 'Monthly revenue intelligence' %></div>
      <h1><%= typeof title !== 'undefined' && title ? title : (isYearMode ? 'สรุปยอดขายรายปี' : 'สรุปยอดขายรายเดือน') %></h1>
      <p>ดูภาพรวมต้นทุน ยอดขาย จำนวนบริการ และกำไร พร้อมสลับมุมมองรายเดือน/รายปีได้ในหน้าเดียว</p>
    </div>

    <div class="rs-hero-side" aria-label="ภาพรวมเดือนนี้">
      <div class="rs-stat-chip">
        <span class="rs-chip-label"><%= isYearMode ? 'ปีที่เลือก' : 'เดือนที่เลือก' %></span>
        <strong><%= headMonthLabel %></strong>
      </div>
      <div class="rs-stat-chip">
        <span class="rs-chip-label">Profit Rate</span>
        <strong class="<%= totalProfit >= 0 ? 'rs-good' : 'rs-bad' %>"><%= profitRate.toLocaleString(undefined,{maximumFractionDigits:1}) %>%</strong>
      </div>
    </div>
  </section>

  <section class="rs-summary-grid" aria-label="สรุปยอดรวมตามช่วงที่เลือก">
    <article class="rs-metric rs-metric-cost rs-anim" style="--delay:0ms">
      <div class="rs-metric-glow" aria-hidden="true"></div>
      <div class="rs-metric-top">
        <span class="rs-metric-icon">🏷️</span>
        <span class="rs-metric-badge">ต้นทุน</span>
      </div>
      <div class="rs-metric-body">
        <h3>ยอดต้นทุนรวม</h3>
        <div class="rs-big">฿<%= totalCost.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></div>
        <p>ค่าใช้จ่ายรวมของบริการทั้งหมดในช่วงที่เลือก</p>
      </div>
      <div class="rs-metric-foot">
        <span>เฉลี่ย / <%= periodUnit %></span>
        <strong>฿<%= avgCost.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></strong>
      </div>
      <div class="rs-micro-chart" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div>
    </article>

    <article class="rs-metric rs-metric-sale rs-anim" style="--delay:70ms">
      <div class="rs-metric-glow" aria-hidden="true"></div>
      <div class="rs-metric-top">
        <span class="rs-metric-icon">💰</span>
        <span class="rs-metric-badge">ยอดขาย</span>
      </div>
      <div class="rs-metric-body">
        <h3>ยอดขายรวม</h3>
        <div class="rs-big">฿<%= totalSale.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></div>
        <p>รายรับรวมจากออเดอร์ทั้งหมดใน<%= isYearMode ? 'ปีที่เลือก' : 'เดือนที่เลือก' %></p>
      </div>
      <div class="rs-metric-foot">
        <span>เฉลี่ย / <%= periodUnit %></span>
        <strong>฿<%= avgSale.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></strong>
      </div>
      <div class="rs-micro-chart" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div>
    </article>

    <article class="rs-metric rs-metric-count rs-anim" style="--delay:140ms">
      <div class="rs-metric-glow" aria-hidden="true"></div>
      <div class="rs-metric-top">
        <span class="rs-metric-icon">🧾</span>
        <span class="rs-metric-badge">ออเดอร์</span>
      </div>
      <div class="rs-metric-body">
        <h3>บริการทั้งหมด</h3>
        <div class="rs-big"><%= totalCount.toLocaleString() %> <small>รายการ</small></div>
        <p>จำนวนบริการที่ถูกบันทึกในช่วงที่เลือก</p>
      </div>
      <div class="rs-metric-foot">
        <span><%= isYearMode ? 'เดือนที่มีข้อมูล' : 'วันที่มีข้อมูล' %></span>
        <strong><%= activeBuckets.toLocaleString() %> <%= periodUnit %></strong>
      </div>
      <div class="rs-micro-chart" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div>
    </article>

    <article class="rs-metric rs-metric-profit rs-anim" style="--delay:210ms">
      <div class="rs-metric-glow" aria-hidden="true"></div>
      <div class="rs-metric-top">
        <span class="rs-metric-icon">📈</span>
        <span class="rs-metric-badge <%= totalProfit >= 0 ? 'is-good' : 'is-bad' %>"><%= totalProfit >= 0 ? 'กำไร' : 'ติดลบ' %></span>
      </div>
      <div class="rs-metric-body">
        <h3>กำไรรวม</h3>
        <div class="rs-big">฿<%= totalProfit.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></div>
        <p>อัตรากำไร <%= profitRate.toLocaleString(undefined,{maximumFractionDigits:1}) %>% จากยอดขายรวม</p>
      </div>
      <div class="rs-metric-foot">
        <span>กำไรเฉลี่ย / <%= periodUnit %></span>
        <strong>฿<%= avgProfit.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></strong>
      </div>
      <div class="rs-micro-chart" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div>
    </article>
  </section>

  <section class="rs-toolbar-card rs-toolbar-card--luxury" aria-label="ตัวกรองรายงาน">
    <div class="rs-toolbar-ambient" aria-hidden="true"></div>
    <div class="rs-toolbar-ambient rs-toolbar-ambient--2" aria-hidden="true"></div>

    <div class="rs-toolbar-left">
      <div class="rs-toolbar-mark" aria-hidden="true">
        <span class="rs-toolbar-mark__icon">📅</span>
      </div>

      <div class="rs-toolbar-copy">
        <span class="rs-toolbar-mini-kicker">Enterprise Report Control</span>
        <strong>เลือกรายงาน</strong>
        <small>
          สลับรายเดือน/รายปีเพื่อดู <b>ต้นทุน</b> <b>ยอดขาย</b> และ <b>กำไร</b> แบบเจาะลึกในหน้าเดียว
        </small>
      </div>
    </div>

    <div class="rs-toolbar-center">
      <div class="rs-current-period-card" aria-label="ช่วงข้อมูลที่กำลังดู">
        <span>กำลังดูข้อมูล</span>
        <strong><%= headMonthLabel %></strong>
      </div>

      <div class="month-toolbar rs-month-toolbar-premium" role="group" aria-label="เลือกช่วงรายงาน">
        <button class="rs-btn rs-btn-ghost" id="btnPrev" type="button" aria-label="ก่อนหน้า">‹</button>

        <label class="month-ctrl rs-month-ctrl-premium">
          <input id="monthInput" type="text" value="<%= selectedPeriodValue %>" readonly aria-label="เลือกช่วงรายงาน" />
          <button class="rs-icon-btn" id="btnOpenPicker" type="button" aria-label="เปิดตัวเลือก">🗓️</button>
        </label>

        <button class="rs-btn rs-btn-ghost" id="btnNext" type="button" aria-label="ถัดไป">›</button>
        <button class="rs-btn rs-btn-primary rs-btn-today" id="btnThisMonth" type="button"><%= isYearMode ? 'ปีนี้' : 'เดือนนี้' %></button>
      </div>
    </div>

    <div class="rs-toolbar-right">
      <div class="rs-mode-switch rs-mode-switch--premium" role="group" aria-label="เลือกมุมมองรายงาน">
        <button class="rs-mode-btn <%= !isYearMode ? 'active' : '' %>" id="btnModeMonth" type="button">รายเดือน</button>
        <button class="rs-mode-btn <%= isYearMode ? 'active' : '' %>" id="btnModeYear" type="button">รายปี</button>
      </div>
    </div>
  </section>

  <!-- Popup: Month / Year Picker -->
  <div id="monthPicker" class="mp-popup" hidden aria-hidden="true">
    <div class="mp-backdrop" data-close-month-picker="1"></div>
    <div class="mp-card" role="dialog" aria-modal="true" aria-label="เลือกช่วงรายงาน">
      <div class="mp-head">
        <button class="mp-nav" id="mpPrevYear" type="button" aria-label="ปีก่อนหน้า">‹</button>
        <div class="mp-year" id="mpYear">2025</div>
        <button class="mp-nav" id="mpNextYear" type="button" aria-label="ปีถัดไป">›</button>
      </div>
      <div class="mp-grid" id="mpGrid" role="grid" aria-label="รายการเดือนหรือปี"></div>
      <div class="mp-actions">
        <button class="rs-btn rs-btn-ghost" id="mpClear" type="button">ล้าง</button>
        <div class="spacer"></div>
        <button class="rs-btn rs-btn-ghost" id="mpThisMonth" type="button"><%= isYearMode ? 'ปีนี้' : 'เดือนนี้' %></button>
        <button class="rs-btn rs-btn-primary" id="mpOK" type="button">ตกลง</button>
      </div>
    </div>
  </div>


  <section class="rs-service-intel rs-anim" aria-label="กราฟสรุปยอดตามบริการ">
    <div class="rs-service-head">
      <div>
        <span class="rs-kicker mini"><span>✦</span> Service intelligence</span>
        <h2>กราฟยอดขายตามบริการ</h2>
        <p>รวมข้อมูลจาก <b>SMM</b>, <b>OTP24</b> และ <b>Apps</b> ในช่วงที่เลือกเดียวกับรายงานด้านบน</p>
      </div>
      <div class="rs-service-total">
        <span>ยอดขายรวม</span>
        <strong>฿<%= totalSale.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></strong>
      </div>
    </div>

    <div class="rs-service-grid">
      <% (__serviceBreakdown || []).forEach((svc, idx) => {
           const sale = Number(svc.sale || 0);
           const cost = Number(svc.cost || 0);
           const count = Number(svc.count || 0);
           const profit = Number(svc.profit || 0);
           const salePct = Math.max(0, Math.min(100, (sale / __serviceMaxSale) * 100));
           const countPct = Math.max(0, Math.min(100, (count / __serviceMaxCount) * 100));
      %>
        <article class="rs-service-card rs-service-<%= svc.key || idx %>" style="--delay:<%= 260 + (idx * 80) %>ms; --sale:<%= salePct %>%; --count:<%= countPct %>%">
          <div class="rs-service-card-top">
            <span class="rs-service-icon"><%= svc.icon || '✦' %></span>
            <div>
              <strong><%= svc.label || '-' %></strong>
              <small><%= svc.title || 'Service' %></small>
            </div>
          </div>
          <div class="rs-service-money">฿<%= sale.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></div>
          <div class="rs-service-bars" aria-hidden="true">
            <div class="rs-service-bar"><span style="width:var(--sale)"></span></div>
            <div class="rs-service-bar rs-service-bar-count"><span style="width:var(--count)"></span></div>
          </div>
          <div class="rs-service-meta">
            <span><b><%= count.toLocaleString() %></b> รายการ</span>
            <span class="<%= profit >= 0 ? 'rs-good' : 'rs-bad' %>">กำไร ฿<%= profit.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></span>
          </div>
          <div class="rs-service-foot">
            <span>ต้นทุน ฿<%= cost.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></span>
            <strong><%= Number(svc.salePct || 0).toLocaleString(undefined,{maximumFractionDigits:1}) %>% ของยอดขาย</strong>
          </div>
        </article>
      <% }) %>
    </div>

    <div class="rs-trend-panel rs-trend-panel-line" aria-label="กราฟแนวโน้มตามช่วงเวลา">
      <div class="rs-trend-head rs-trend-head-line">
        <div>
          <strong><%= isYearMode ? 'แนวโน้มรายเดือน' : 'แนวโน้มรายวัน' %></strong>
          <span>กราฟเส้นสรุป ยอดขาย / กำไร / จำนวนรายการ</span>
        </div>
        <div class="rs-trend-legend" aria-label="คำอธิบายกราฟ">
          <span class="rs-legend-item sale"><i></i>ยอดขาย</span>
          <span class="rs-legend-item profit"><i></i>กำไร</span>
          <span class="rs-legend-item count"><i></i>จำนวนรายการ</span>
        </div>
      </div>

      <div class="rs-line-chart-shell">
        <div class="rs-line-side rs-line-side-left">
          <span>฿<%= __rowMaxSale.toLocaleString(undefined,{maximumFractionDigits:0}) %></span>
          <span>฿<%= (__rowMaxSale * 0.5).toLocaleString(undefined,{maximumFractionDigits:0}) %></span>
          <span>฿0</span>
        </div>

        <div class="rs-line-chart" role="img" aria-label="<%= isYearMode ? 'กราฟเส้นแนวโน้มรายเดือน' : 'กราฟเส้นแนวโน้มรายวัน' %>">
          <svg class="rs-line-svg" viewBox="0 0 <%= __chartW %> <%= __chartH %>" preserveAspectRatio="none" aria-hidden="true">
            <defs>
              <linearGradient id="rsSaleLine" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#fff0aa"/>
                <stop offset="52%" stop-color="#efc661"/>
                <stop offset="100%" stop-color="#b97712"/>
              </linearGradient>
              <linearGradient id="rsSaleFill" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="rgba(246,206,97,.34)"/>
                <stop offset="100%" stop-color="rgba(246,206,97,0)"/>
              </linearGradient>
              <linearGradient id="rsProfitLine" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#8bf7d1"/>
                <stop offset="100%" stop-color="#17ba76"/>
              </linearGradient>
              <linearGradient id="rsCountLine" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#8ee8ff"/>
                <stop offset="100%" stop-color="#4f7cff"/>
              </linearGradient>
              <filter id="rsGlowGold" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="6" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
              <filter id="rsGlowSoft" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="4.5" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
            </defs>

            <% __gridLevels.forEach((gy, idx) => { %>
              <line x1="<%= __padLeft %>" y1="<%= gy.toFixed(2) %>" x2="<%= (__chartW - __padRight) %>" y2="<%= gy.toFixed(2) %>" class="rs-svg-grid <%= idx === __gridLevels.length - 1 ? 'is-base' : '' %>" />
            <% }) %>
            <line x1="<%= __padLeft %>" y1="<%= __profitZeroY.toFixed(2) %>" x2="<%= (__chartW - __padRight) %>" y2="<%= __profitZeroY.toFixed(2) %>" class="rs-svg-zero" />

            <% __trendLabels.forEach((label, idx) => { const x = rsPointX(idx); %>
              <line x1="<%= x.toFixed(2) %>" y1="<%= __padTop %>" x2="<%= x.toFixed(2) %>" y2="<%= (__chartH - __padBottom) %>" class="rs-svg-vline" />
            <% }) %>

            <% if (__saleAreaPath) { %>
              <path d="<%= __saleAreaPath %>" class="rs-sale-area" />
            <% } %>
            <% if (__salePath) { %>
              <path d="<%= __salePath %>" class="rs-series-line rs-series-sale" />
            <% } %>
            <% if (__profitPath) { %>
              <path d="<%= __profitPath %>" class="rs-series-line rs-series-profit" />
            <% } %>
            <% if (__countPath) { %>
              <path d="<%= __countPath %>" class="rs-series-line rs-series-count" />
            <% } %>

            <% __salePoints.forEach((p, idx) => { const r = __trendRows[idx] || {}; const label = __trendLabels[idx] || String(idx + 1); %>
              <g class="rs-point-group">
                <title><%= label %> | ยอดขาย ฿<%= Number(r.sale || 0).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) %> | กำไร ฿<%= Number(r.profit || 0).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) %> | จำนวน <%= Number(r.count || 0).toLocaleString() %> รายการ</title>
                <circle cx="<%= p.x.toFixed(2) %>" cy="<%= p.y.toFixed(2) %>" r="6.2" class="rs-point rs-point-sale" />
                <% const pp = __profitPoints[idx]; if (pp) { %><circle cx="<%= pp.x.toFixed(2) %>" cy="<%= pp.y.toFixed(2) %>" r="5.1" class="rs-point rs-point-profit" /><% } %>
                <% const cp = __countPoints[idx]; if (cp) { %><circle cx="<%= cp.x.toFixed(2) %>" cy="<%= cp.y.toFixed(2) %>" r="5.1" class="rs-point rs-point-count" /><% } %>
              </g>
            <% }) %>
          </svg>

          <div class="rs-chart-hovers" aria-label="รายละเอียดจุดกราฟ">
            <% __salePoints.forEach((p, idx) => {
              const r = __trendRows[idx] || {};
              const label = __trendLabels[idx] || String(idx + 1);
              const left = (p.x / __chartW) * 100;
              const top = (p.y / __chartH) * 100;
              const tipClass = [
                top < 27 ? 'is-below' : '',
                left < 12 ? 'is-left-edge' : '',
                left > 88 ? 'is-right-edge' : ''
              ].filter(Boolean).join(' ');
            %>
              <button type="button" class="rs-hover-dot <%= tipClass %>" style="--x:<%= left.toFixed(4) %>%; --y:<%= top.toFixed(4) %>%" aria-label="<%= label %> ยอดขาย <%= Number(r.sale || 0).toLocaleString() %> บาท กำไร <%= Number(r.profit || 0).toLocaleString() %> บาท จำนวน <%= Number(r.count || 0).toLocaleString() %> รายการ">
                <span class="rs-chart-tip">
                  <b><%= isYearMode ? 'เดือน' : 'วันที่' %> <%= label %></b>
                  <span>ยอดขาย <strong>฿<%= Number(r.sale || 0).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) %></strong></span>
                  <span>กำไร <strong>฿<%= Number(r.profit || 0).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) %></strong></span>
                  <span>จำนวน <strong><%= Number(r.count || 0).toLocaleString() %> รายการ</strong></span>
                </span>
              </button>
            <% }) %>
          </div>

          <div class="rs-line-xlabels" style="--label-count:<%= Math.max(__trendLabels.length, 1) %>" aria-hidden="true">
            <% __trendLabels.forEach((label) => { %>
              <span><%= label %></span>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </section>

