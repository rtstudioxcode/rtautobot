.rs-current-month span{font-size:11px;color:var(--rs-muted);font-weight:850;letter-spacing:.04em;text-transform:uppercase}
.rs-current-month strong{font-size:16px;color:var(--rs-accent);font-weight:950;line-height:1.15}
.month-toolbar{
  display:flex;
  align-items:center;
  gap:8px;
  justify-content:flex-end;
  padding:6px;
  border-radius:21px;
  border:1px solid var(--rs-border);
  background:color-mix(in srgb,var(--rs-page) 72%,transparent);
  box-shadow:inset 0 1px 0 rgba(255,255,255,.04);
  width:max-content;
  justify-self:end;
}
.rs-btn,.rs-icon-btn{border:0;cursor:pointer;transition:transform .18s ease,box-shadow .18s ease,background .18s ease,color .18s ease,filter .18s ease}
.rs-btn{min-height:44px;padding:9px 15px;border-radius:15px;font-weight:650;color:var(--rs-text);white-space:nowrap}
.rs-btn:hover,.rs-icon-btn:hover{transform:translateY(-1px)}
.rs-btn-ghost{background:var(--rs-soft);border:1px solid var(--rs-border);color:var(--rs-text)}
.rs-btn-ghost:hover{background:color-mix(in srgb,var(--rs-soft) 82%,var(--rs-accent));box-shadow:0 10px 22px color-mix(in srgb,var(--rs-shadow) 72%,transparent)}
.rs-btn-primary{background:linear-gradient(135deg,#ffe28a,#e8bc53 55%,#bd8626);color:#17130a;box-shadow:0 14px 30px color-mix(in srgb,var(--rs-accent) 23%,transparent)}
.month-ctrl{display:flex;align-items:center;min-height:46px;border:1px solid color-mix(in srgb,var(--rs-accent) 36%,var(--rs-border));border-radius:17px;background:color-mix(in srgb,var(--rs-card) 75%,var(--rs-page));box-shadow:inset 0 1px 0 rgba(255,255,255,.05)}
.month-ctrl input{width:124px;background:transparent;border:0;outline:0;color:var(--rs-text);font-weight:650;padding:0 12px;text-align:center;cursor:pointer;letter-spacing:.02em}
.rs-icon-btn{width:40px;height:40px;margin-right:3px;border-radius:14px;background:color-mix(in srgb,var(--rs-accent) 16%,transparent);border:1px solid var(--rs-border);color:var(--rs-text)}

.rs-table-card{margin-top:16px;padding:0;overflow:hidden;animation:rsRise .58s cubic-bezier(.2,.85,.2,1) both .18s}
.rs-table-head{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 22px;border-bottom:1px solid var(--rs-border);background:linear-gradient(180deg,rgba(255,255,255,.035),transparent)}
.rs-table-head h2{margin:0;font-size:clamp(22px,2vw,30px);color:var(--rs-text)}
.rs-table-count{padding:8px 13px;border-radius:999px;border:1px solid var(--rs-border);background:var(--rs-soft);color:var(--rs-accent);font-weight:650}
.table-wrap{overflow:auto;max-width:100%}
.tbl{width:100%;border-collapse:separate;border-spacing:0;color:var(--rs-text);min-width:760px}
.tbl th,.tbl td{padding:15px 16px;border-bottom:1px solid var(--rs-border);text-align:right;transition:background .16s ease,box-shadow .16s ease,transform .16s ease;white-space:nowrap}
.tbl th:first-child,.tbl td:first-child{text-align:left}
.tbl thead th{position:sticky;top:0;z-index:5;background:color-mix(in srgb,var(--rs-card) 92%,black);color:color-mix(in srgb,var(--rs-accent) 72%,var(--rs-text));font-size:12px;text-transform:uppercase;letter-spacing:.06em;font-weight:950}
.tbl tbody tr{animation:rsRow .42s ease both;animation-delay:var(--row-delay,0ms)}
.tbl.zebra tbody tr:nth-child(odd) td{background:color-mix(in srgb,var(--rs-card) 88%,transparent)}
.tbl.zebra tbody tr:nth-child(even) td{background:color-mix(in srgb,var(--rs-card) 78%,var(--rs-page))}
.tbl.zebra tbody tr:hover td{background:color-mix(in srgb,var(--rs-accent) 9%,var(--rs-card));transform:translateY(-1px)}
.tbl.zebra tbody tr:hover td:first-child{box-shadow:inset 4px 0 0 var(--rs-accent)}
.rs-day-pill{display:inline-flex;align-items:center;justify-content:center;min-width:42px;padding:7px 11px;border-radius:999px;background:var(--rs-soft);border:1px solid var(--rs-border);font-weight:950;color:var(--rs-accent)}
.rs-num{font-weight:600}.rs-cost{color:var(--rs-muted)}.rs-sale{color:var(--rs-green)}.rs-count{color:var(--rs-blue)}
.text-success{color:var(--rs-green)!important;font-weight:650}.text-danger{color:var(--rs-red)!important;font-weight:650}
.rs-empty{padding:34px!important;text-align:center!important;background:transparent!important}
.rs-empty-box{display:grid;gap:6px;place-items:center;padding:26px;border:1px dashed var(--rs-border);border-radius:22px;background:var(--rs-soft);color:var(--rs-muted)}
.rs-empty-box strong{color:var(--rs-text);font-size:18px}

/* Month picker: true top-layer style */
.mp-popup[hidden]{display:none!important}
.mp-popup{position:fixed;inset:0;z-index:2147483000;display:block;pointer-events:none}
.mp-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.18);backdrop-filter:blur(2px);opacity:0;pointer-events:auto}
.mp-card{position:fixed;left:var(--mp-left,50%);top:var(--mp-top,50%);width:min(342px,calc(100vw - 24px));border-radius:24px;border:1px solid var(--rs-border);background:linear-gradient(180deg,color-mix(in srgb,var(--rs-card) 96%,transparent),color-mix(in srgb,var(--rs-page) 30%,var(--rs-card)));color:var(--rs-text);box-shadow:0 30px 90px rgba(0,0,0,.46),inset 0 1px 0 rgba(255,255,255,.08);padding:14px;pointer-events:auto;animation:rsPicker .2s ease both;overflow:hidden}
.mp-card::before{content:"";position:absolute;inset:-60px -80px auto auto;width:180px;height:180px;border-radius:999px;background:color-mix(in srgb,var(--rs-accent) 22%,transparent);filter:blur(20px);pointer-events:none}
.mp-head{position:relative;display:flex;align-items:center;justify-content:space-between;gap:12px;padding:4px 2px 12px;border-bottom:1px solid var(--rs-border)}
.mp-year{font-size:20px;font-weight:650;color:var(--rs-accent)}
.mp-nav{width:40px;height:40px;border-radius:14px;border:1px solid var(--rs-border);background:var(--rs-soft);color:var(--rs-text);cursor:pointer;font-size:24px;line-height:1;transition:transform .18s ease,background .18s ease}
.mp-nav:hover{transform:translateY(-1px);background:color-mix(in srgb,var(--rs-accent) 14%,transparent)}
.mp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;padding:14px 0}
.mp-m{min-height:44px;border:1px solid var(--rs-border);background:color-mix(in srgb,var(--rs-page) 55%,transparent);color:var(--rs-text);border-radius:15px;cursor:pointer;font-weight:950;transition:transform .18s ease,background .18s ease,border-color .18s ease,box-shadow .18s ease}
.mp-m:hover{transform:translateY(-1px);border-color:color-mix(in srgb,var(--rs-accent) 45%,var(--rs-border));background:color-mix(in srgb,var(--rs-accent) 12%,transparent)}
.mp-m.active{color:#17130a;background:linear-gradient(135deg,#ffe28a,#e8bc53 55%,#bd8626);border-color:transparent;box-shadow:0 10px 22px color-mix(in srgb,var(--rs-accent) 25%,transparent)}
.mp-m.current:not(.active){border-color:color-mix(in srgb,var(--rs-accent) 48%,var(--rs-border));color:var(--rs-accent)}
.mp-actions{display:flex;align-items:center;gap:8px;padding-top:12px;border-top:1px solid var(--rs-border)}
.spacer{flex:1}

@keyframes rsRise{from{opacity:0;transform:translateY(16px) scale(.985)}to{opacity:1;transform:none}}
@keyframes rsSlide{from{opacity:0;transform:translateX(18px)}to{opacity:1;transform:none}}
@keyframes rsFloat{0%,100%{transform:translate3d(0,0,0) scale(1)}50%{transform:translate3d(0,18px,0) scale(1.04)}}
@keyframes rsRow{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
@keyframes rsPicker{from{opacity:0;transform:translateY(8px) scale(.98)}to{opacity:1;transform:none}}


.rs-mode-switch{display:flex;align-items:center;gap:6px;padding:5px;border-radius:18px;border:1px solid var(--rs-border);background:color-mix(in srgb,var(--rs-page) 68%,transparent);width:max-content;justify-self:end}
.rs-mode-switch .rs-mode-btn{min-height:40px;border-radius:13px;padding:8px 13px;border:1px solid transparent;background:transparent;color:var(--rs-muted);font-weight:950;cursor:pointer;transition:transform .18s ease,background .18s ease,color .18s ease,border-color .18s ease}
.rs-mode-switch .rs-mode-btn:hover{transform:translateY(-1px);color:var(--rs-text);background:var(--rs-soft)}
.rs-mode-switch .rs-mode-btn.active{background:linear-gradient(135deg,#ffe28a,#e8bc53 55%,#bd8626);color:#17130a;box-shadow:0 10px 22px color-mix(in srgb,var(--rs-accent) 22%,transparent)}
.rs-view-link{display:inline-flex;align-items:center;justify-content:center;min-height:34px;padding:7px 12px;border-radius:999px;background:linear-gradient(135deg,#ffe28a,#e8bc53 55%,#bd8626);color:#17130a!important;text-decoration:none;font-weight:950;box-shadow:0 10px 22px color-mix(in srgb,var(--rs-accent) 18%,transparent)}
.rs-period-pill{display:inline-flex;align-items:center;justify-content:center;min-width:94px;padding:7px 12px;border-radius:999px;background:var(--rs-soft);border:1px solid var(--rs-border);font-weight:950;color:var(--rs-accent)}

@media (prefers-reduced-motion:reduce){.report-enterprise *{animation:none!important;transition:none!important}}
@media (max-width:1180px){.rs-summary-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.rs-hero{grid-template-columns:1fr}.rs-hero-side{max-width:620px}}
@media (max-width:760px){
  .report-enterprise{padding:8px}
  .rs-hero{padding:24px;border-radius:24px;min-height:auto}
  .rs-hero-side{grid-template-columns:1fr}
  .rs-summary-grid{grid-template-columns:1fr;gap:10px}
  .rs-toolbar-card{grid-template-columns:1fr;padding:14px;gap:10px}
  .rs-toolbar-card::before{display:none}
  .rs-current-month{min-height:48px;align-items:flex-start;text-align:left}
  .rs-mode-switch{width:100%;justify-content:center}
  .month-toolbar{justify-content:stretch;display:grid;grid-template-columns:44px minmax(0,1fr) 44px;gap:8px;width:100%;justify-self:stretch}
  .month-toolbar .rs-btn-primary{grid-column:1/-1}
  .month-ctrl{width:100%}.month-ctrl input{width:100%}
  .rs-table-head{align-items:flex-start;flex-direction:column}
  .tbl{min-width:0;border-spacing:0 10px;padding:0 12px 12px}
  .tbl thead{display:none}
  .tbl tbody tr{display:block;border:1px solid var(--rs-border);border-radius:20px;overflow:hidden;background:var(--rs-card);margin-bottom:10px}
  .tbl th,.tbl td{display:flex;align-items:center;justify-content:space-between;text-align:right!important;white-space:normal;border-bottom:1px solid var(--rs-border);padding:12px 14px;background:transparent!important;gap:18px}
  .tbl td:last-child{border-bottom:0}
  .tbl td::before{content:attr(data-label);color:var(--rs-muted);font-weight:900;text-align:left}
  .tbl td:first-child{justify-content:space-between!important}
  .rs-empty{display:block!important}
}
@media (max-width:420px){.rs-hero h1{font-size:36px}.rs-big{font-size:24px}.mp-grid{grid-template-columns:repeat(2,1fr)}}


