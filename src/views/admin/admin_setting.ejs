<%
const BANKS_LIST = (typeof banks !== 'undefined' && Array.isArray(banks) && banks.length)
  ? banks
  : [
      { code: 'bbl', label: 'ธนาคารกรุงเทพ' },
      { code: 'kbank', label: 'ธนาคารกสิกรไทย' },
      { code: 'ktb', label: 'ธนาคารกรุงไทย' },
      { code: 'bay', label: 'ธนาคารกรุงศรีอยุธยา' },
      { code: 'scb', label: 'ธนาคารไทยพาณิชย์' },
      { code: 'ttb', label: 'ธนาคารทหารไทยธนชาต (TTB)' },
      { code: 'gsb', label: 'ธนาคารออมสิน' },
      { code: 'baac', label: 'ธนาคารเพื่อการเกษตรและสหกรณ์การเกษตร' },
      { code: 'kkp', label: 'ธนาคารเกียรตินาคินภัทร' },
      { code: 'tw', label: 'TrueMoney Wallet' },
      { code: 'qr', label: 'PromptPay QR' },
    ];
const rows = Array.isArray(wallets) ? wallets : [];
const canWrite = canEdit !== false;
const labelMap = {};
BANKS_LIST.forEach((b) => { labelMap[String(b.code || '').toLowerCase()] = b.label; });
const walletTotal = rows.length;
const walletActive = rows.filter((w) => !!w.isActive).length;
const walletAuto = rows.filter((w) => !!w.isAuto).length;
const walletSms = rows.filter((w) => !!w.isSMS).length;
const typeLabel = (type) => String(type || 'DEPOSIT').toUpperCase() === 'WITHDRAW' ? 'บัญชีถอน' : 'บัญชีฝาก';
%>

<div class="rt-admin-settings eh-admin-auto">
  <section class="page container admin-settings">
    <header class="as-hero eh-reveal">
      <div class="as-hero__copy">
        <span class="as-kicker">✦ System Control Center</span>
        <h1>ตั้งค่าเว็บไซต์</h1>
        <p>จัดการบัญชีรับเงินของ  สำหรับระบบเติมเครดิตอัตโนมัติ</p>
      </div>

      <div class="as-hero__stats" aria-label="ภาพรวมบัญชีรับเงิน">
        <div class="as-stat">
          <span>โหมดแก้ไข</span>
          <strong><%= canWrite ? 'เปิดใช้งาน' : 'อ่านอย่างเดียว' %></strong>
        </div>
        <div class="as-stat">
          <span>บัญชีรับเงิน</span>
          <strong><%= walletTotal %></strong>
        </div>
        <div class="as-stat">
          <span>กำลังใช้งาน</span>
          <strong><%= walletActive %></strong>
        </div>
        <div class="as-stat">
          <span>Auto Topup</span>
          <strong><%= walletAuto %></strong>
        </div>
      </div>
    </header>

    <section id="tab-wallets" class="tabpane show">
      <form class="card mt admin-card" method="post" action="/admin/settings/wallets">
        <input type="hidden" name="_section" value="wallets">

        <header class="admin-card__header">
          <div>
            <h2>ตั้งค่าบัญชีรับเงินของเว็บ</h2>
            <p class="muted">TrueWallet / KBank / SCB / PromptPay QR ฯลฯ ใช้สำหรับระบบเติมเงินอัตโนมัติของ</p>
          </div>
          <div class="admin-card__badge <%= canWrite ? 'admin-card__badge--ok' : 'admin-card__badge--readonly' %>">
            <%= canWrite ? 'สามารถแก้ไขได้' : 'READONLY' %>
          </div>
        </header>

        <div class="fieldset">
          <div class="fieldset__header">
            <h3>บัญชีที่มีอยู่ในระบบ</h3>
            <p class="muted">แก้ไขชื่อบัญชี เลขบัญชี Secret และสถานะการใช้งานได้จากตรงนี้</p>
          </div>

          <% if (!rows.length) { %>
            <div class="empty-wallet-state">
              <div class="empty-wallet-state__icon">🏦</div>
              <strong>ยังไม่เพิ่มบัญชีรับเงิน</strong>
              <p>เพิ่มบัญชีแรกจากฟอร์มด้านล่างเพื่อเริ่มใช้งานระบบเติมเครดิต</p>
            </div>
          <% } %>

          <div class="grid cards gap-md wallets-grid">
            <% rows.forEach(function(w, idx){
              const code = String(w.accountCode || '').toLowerCase();
              const label = labelMap[code] || String(code || 'wallet').toUpperCase();
              const accType = String(w.type || 'DEPOSIT').toUpperCase();
            %>
              <div class="card bank-card">
                <input type="hidden" name="wallets[<%= idx %>][id]" value="<%= w._id %>">
                <input type="hidden" name="wallets[<%= idx %>][accountCode]" value="<%= code %>">
                <input type="hidden" name="wallets[<%= idx %>][type]" value="<%= accType %>">

                <div class="bank-card__header">
                  <div class="bank-title">
                    <div class="bank-name"><%= label %></div>
                    <div class="bank-meta">
                      <span class="bank-code"><%= code.toUpperCase() %></span>
                      <span class="bank-dot"></span>
                      <span class="bank-type"><%= typeLabel(accType) %></span>
                    </div>
                  </div>

                  <div class="bank-card__actions">
                    <div class="bank-pill <%= w.isActive ? 'bank-pill--on' : 'bank-pill--off' %>">
                      <%= w.isActive ? 'กำลังใช้งาน' : 'ปิดใช้งาน' %>
                    </div>

                    <% if (canWrite) { %>
                      <button
                        type="submit"
                        name="wallets[<%= idx %>][_delete]"
                        value="1"
                        class="bank-delete-btn"
                        onclick="return confirm('ยืนยันลบบัญชีนี้หรือไม่ ?');"
                      >
                        ลบบัญชี
                      </button>
                    <% } %>
                  </div>
                </div>

                <div class="form-group mt-sm">
                  <label>ชื่อบัญชี</label>
                  <input
                    type="text"
                    name="wallets[<%= idx %>][accountName]"
                    value="<%= w.accountName || '' %>"
                    <%= canWrite ? '' : 'readonly' %>
                  >
                </div>

                <div class="form-group mt-xs">
                  <label>เลขบัญชี / เบอร์</label>
                  <input
                    type="text"
                    name="wallets[<%= idx %>][accountNumber]"
                    value="<%= w.accountNumber || '' %>"
                    <%= canWrite ? '' : 'readonly' %>
                  >
                </div>

                <div class="toggles toggles-existing">
                  <label class="checkbox">
                    <input
                      type="checkbox"
                      name="wallets[<%= idx %>][isActive]"
                      value="1"
                      data-id="<%= w._id %>"
                      data-field="isActive"
                      <%= w.isActive ? 'checked' : '' %>
                      <%= canWrite ? '' : 'disabled' %>
                    >
                    <span>ใช้งาน</span>
                  </label>

                  <label class="checkbox">
                    <input
                      type="checkbox"
                      name="wallets[<%= idx %>][isSMS]"
                      value="1"
                      data-id="<%= w._id %>"
                      data-field="isSMS"
                      <%= w.isSMS ? 'checked' : '' %>
                      <%= canWrite ? '' : 'disabled' %>
                    >
                    <span>อ่าน SMS</span>
                  </label>

                  <label class="checkbox">
                    <input
                      type="checkbox"
                      name="wallets[<%= idx %>][isAuto]"
                      value="1"
                      data-id="<%= w._id %>"
                      data-field="isAuto"
                      <%= w.isAuto ? 'checked' : '' %>
                      <%= canWrite ? '' : 'disabled' %>
                    >
                    <span>Auto Topup</span>
                  </label>
                </div>

                <div class="form-group mt-sm">
                  <label>secret</label>
                  <input
                    type="text"
                    name="wallets[<%= idx %>][secret]"
                    value="<%= w.secret || '' %>"
                    <%= canWrite ? '' : 'readonly' %>
                  >
                </div>
              </div>
            <% }); %>
          </div>
        </div>

        <% if (canWrite) { %>
          <div class="fieldset mt-xl add-wallet-fieldset">
            <div class="fieldset__header">
              <h3>เพิ่มบัญชีใหม่</h3>
              <p class="muted">สร้างบัญชีธนาคารหรือ TrueMoney Wallet สำหรับรับเงินเติมเครดิตของ </p>
            </div>

            <div class="grid cols-2 gap-md">
              <div class="form-group">
                <label>ชื่อบัญชี</label>
                <input type="text" name="newWallet[accountName]" placeholder="เช่น บัญชีเติมเงินหลัก">
              </div>

              <div class="form-group">
                <label>ประเภทบัญชี</label>
                <select name="newWallet[type]">
                  <option value="DEPOSIT" selected>บัญชีฝาก</option>
                  <option value="WITHDRAW">บัญชีถอน</option>
                </select>
              </div>
            </div>

            <div class="grid cols-2 gap-md mt-sm">
              <div class="form-group">
                <label>บัญชีธนาคาร / Wallet</label>
                <select name="newWallet[accountCode]">
                  <option value="" disabled selected>เลือกธนาคารหรือ TrueMoney Wallet</option>
                  <% BANKS_LIST.forEach(function(b){ %>
                    <option value="<%= b.code %>"><%= b.label %></option>
                  <% }); %>
                </select>
              </div>

              <div class="form-group">
                <label>เลขบัญชี / เบอร์</label>
                <input type="text" name="newWallet[accountNumber]" placeholder="เลขบัญชีหรือเบอร์มือถือ">
              </div>
            </div>

            <div class="form-group mt-sm">
              <label>secret</label>
              <input type="text" name="newWallet[secret]" placeholder="โทเคน / secret key">
            </div>

            <div class="toggles toggles-new">
              <label class="checkbox"><input type="checkbox" name="newWallet[isActive]" checked><span>ใช้งาน</span></label>
              <label class="checkbox"><input type="checkbox" name="newWallet[isSMS]"><span>อ่าน SMS</span></label>
              <label class="checkbox"><input type="checkbox" name="newWallet[isAuto]" checked><span>Auto Topup</span></label>
            </div>
          </div>
        <% } %>

        <div class="mt-xl admin-card__footer">
          <button type="submit" class="btn primary settings-save-btn" <%= canWrite ? '' : 'disabled' %>>
            <span class="settings-save-btn__glow"></span>
            <span class="settings-save-btn__label">บันทึกข้อมูล</span>
          </button>
        </div>
      </form>
    </section>
  </section>
</div>

<script>
(() => {
  const notifyOk = (msg) => {
    if (window.notify?.success) window.notify.success(msg);
    else if (window.notify?.push) window.notify.push({ type: 'success', message: msg });
  };
  const notifyErr = (msg) => {
    if (window.notify?.error) window.notify.error(msg);
    else if (window.notify?.push) window.notify.push({ type: 'error', message: msg });
  };

  const ToggleSound = (() => {
    let ctx;
    const getCtx = () => ctx || (ctx = new (window.AudioContext || window.webkitAudioContext)());
    function play(freqStart, freqEnd) {
      const c = getCtx();
      const o = c.createOscillator();
      const g = c.createGain();
      o.type = 'sine';
      o.frequency.setValueAtTime(freqStart, c.currentTime);
      o.frequency.exponentialRampToValueAtTime(freqEnd, c.currentTime + 0.06);
      g.gain.setValueAtTime(0.0001, c.currentTime);
      g.gain.exponentialRampToValueAtTime(0.05, c.currentTime + 0.01);
      g.gain.exponentialRampToValueAtTime(0.0001, c.currentTime + 0.12);
      o.connect(g).connect(c.destination);
      o.start();
      o.stop(c.currentTime + 0.12);
    }
    return { on: () => play(720, 1120), off: () => play(620, 340) };
  })();

  document.querySelectorAll('.toggles-existing input[data-id][data-field]').forEach((el) => {
    let abortController = null;
    el.addEventListener('change', async () => {
      if (el.disabled || el.dataset.busy === '1') return;
      const id = el.dataset.id;
      const field = el.dataset.field;
      const value = el.checked;
      if (!id || !field) return;

      const card = el.closest('.bank-card');
      const statusPill = card?.querySelector('.bank-pill');
      const prevChecked = !value;

      try {
        if (value) ToggleSound.on(); else ToggleSound.off();
        if (navigator.vibrate) navigator.vibrate(8);
      } catch {}

      if (abortController) abortController.abort();
      abortController = new AbortController();
      el.dataset.busy = '1';
      el.classList.add('optimistic');
      setTimeout(() => { if (el.dataset.busy === '1') el.classList.add('loading'); }, 120);

      try {
        const res = await fetch('/admin/api/wallet/update-toggle', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, field, value }),
          signal: abortController.signal,
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data.ok) throw new Error(data.message || `HTTP ${res.status}`);

        if (data.wallet) {
          const map = { isActive: data.wallet.isActive, isSMS: data.wallet.isSMS, isAuto: data.wallet.isAuto };
          card?.querySelectorAll('.toggles-existing input[data-field]').forEach((input) => {
            const f = input.dataset.field;
            if (map[f] !== undefined) input.checked = !!map[f];
          });
          if (statusPill) {
            statusPill.textContent = data.wallet.isActive ? 'กำลังใช้งาน' : 'ปิดใช้งาน';
            statusPill.classList.toggle('bank-pill--on', !!data.wallet.isActive);
            statusPill.classList.toggle('bank-pill--off', !data.wallet.isActive);
          }
        }
        el.classList.remove('loading');
        el.classList.add('toggle-success');
        setTimeout(() => el.classList.remove('toggle-success'), 450);
      } catch (err) {
        if (err.name === 'AbortError') return;
        el.checked = prevChecked;
        el.classList.remove('loading');
        el.classList.add('toggle-error');
        notifyErr(err.message || 'อัปเดตสถานะไม่สำเร็จ');
        setTimeout(() => el.classList.remove('toggle-error'), 500);
      } finally {
        el.classList.remove('optimistic');
        delete el.dataset.busy;
      }
    });
  });
})();
</script>

