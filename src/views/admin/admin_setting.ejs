<%
// canEdit = dev เท่านั้น (ส่งมาจาก route)
// secure  = doc จาก collection secure_config
// wallets = list จาก Topup (type: DEPOSIT)
const cfg = secure || {};
const ipv  = cfg.ipv  || {};
const mail = cfg.mail || {};
const otp  = cfg.otp  || {};
const otp24 = cfg.otp24 || {};
const turnstile = cfg.turnstile || {};
const system = cfg.system || {};
const jobs = cfg.jobs || {};
const botBlock = cfg.botBlock || {};
const railway = cfg.railway || {};
const telegram = cfg.telegram || {};
const brand = cfg.brand || {};
const sessionCfg = cfg.session || {};
const security = cfg.security || {};
const boolVal = (obj, key, def = false) => {
  const v = obj?.[key];
  if (v === undefined || v === null || v === '') return def;
  if (typeof v === 'boolean') return v;
  return ['1', 'true', 'yes', 'on'].includes(String(v).trim().toLowerCase());
};
const numVal = (obj, key, def = '') => {
  const v = obj?.[key];
  if (v === undefined || v === null || v === '') return def;
  const n = Number(v);
  return Number.isFinite(n) ? n : def;
};
const strVal = (obj, key, def = '') => {
  const v = obj?.[key];
  return (v === undefined || v === null) ? def : String(v);
};
const secBool = (key, def = true) => {
  const v = security[key];
  if (v === undefined || v === null || v === '') return def;
  if (typeof v === 'boolean') return v;
  return ['1', 'true', 'yes', 'on'].includes(String(v).trim().toLowerCase());
};
const sysBool = (key, def = true) => {
  const v = system[key];
  if (v === undefined || v === null || v === '') return def;
  if (typeof v === 'boolean') return v;
  return ['1', 'true', 'yes', 'on'].includes(String(v).trim().toLowerCase());
};
const sysNum = (key, def = 3000) => {
  const n = Number(system[key]);
  return Number.isFinite(n) && n > 0 ? n : def;
};
// รายชื่อธนาคาร/วอลเล็ท (จะใช้ banks จาก route ถ้ามีส่งมา, ถ้าไม่มีก็ใช้ default นี้)
const BANKS_LIST = (typeof banks !== 'undefined' && Array.isArray(banks) && banks.length)
  ? banks
  : [
      { code: "bbl",   label: "ธนาคารกรุงเทพ" },
      { code: "kbank", label: "ธนาคารกสิกรไทย" },
      { code: "ktb",   label: "ธนาคารกรุงไทย" },
      { code: "bay",   label: "ธนาคารกรุงศรีอยุธยา" },
      { code: "scb",   label: "ธนาคารไทยพาณิชย์" },
      { code: "tmb",   label: "ธนาคารทหารไทยธนชาต (TTB)" },
      { code: "cimb",  label: "ธนาคารซีไอเอ็มบีไทย" },
      { code: "uob",   label: "ธนาคารยูโอบี" },
      { code: "gsb",   label: "ธนาคารออมสิน" },
      { code: "baac",  label: "ธนาคารเพื่อการเกษตรและสหกรณ์การเกษตร" },
      { code: "sme",   label: "ธนาคารพัฒนาวิสาหกิจขนาดกลางและขนาดย่อมแห่งประเทศไทย" },
      { code: "tisco", label: "ธนาคารทิสโก้" },
      { code: "kkb",   label: "ธนาคารเกียรตินาคินภัทร" },
      { code: "lhfg",  label: "ธนาคารแลนด์ แอนด์ เฮ้าส์" },
      { code: "icbl",  label: "ธนาคารไอซีบีซี (ไทย)" },
      { code: "mizuho",label: "ธนาคารมิซูโฮ คอร์ปอเรต" },
      { code: "scbt", label: "ธนาคารสแตนดาร์ดชาร์เตอร์ด (ไทย)" },
      { code: "citi", label: "ธนาคารซิตี้แบงก์ ประเทศไทย" },
      { code: "tw",   label: "TrueMoney Wallet" },
      { code: "qr",   label: "PromptPay QR" },
    ];
const WALLET_TOTAL = Array.isArray(wallets) ? wallets.length : 0;
const WALLET_ACTIVE = Array.isArray(wallets) ? wallets.filter(w => !!w.isActive).length : 0;
const WALLET_AUTO = Array.isArray(wallets) ? wallets.filter(w => !!w.isAuto).length : 0;
%>
<div class="eh-admin-auto eh-page-admin-setting-1-ejs">


<section class="page container admin-settings">

  <header class="as-hero eh-reveal">
    <div class="as-hero__copy">
      <span class="as-kicker">✦ System Control Center</span>
      <h1>ตั้งค่าเว็บไซต์</h1>
      <p>จัดการคอนฟิกหลัก บัญชีรับเงิน และระบบอัตโนมัติทั้งหมดในหน้าเดียว ปลอดภัย อ่านง่าย และพร้อมใช้งานระดับองค์กร</p>
    </div>
    <div class="as-hero__stats" aria-label="ภาพรวมระบบ">
      <div class="as-stat">
        <span>โหมดแก้ไข</span>
        <strong><%= canEdit ? 'เปิดใช้งาน' : 'อ่านอย่างเดียว' %></strong>
      </div>
      <div class="as-stat">
        <span>บัญชีรับเงิน</span>
        <strong><%= WALLET_TOTAL %></strong>
      </div>
      <div class="as-stat">
        <span>กำลังใช้งาน</span>
        <strong><%= WALLET_ACTIVE %></strong>
      </div>
      <div class="as-stat">
        <span>Auto Topup</span>
        <strong><%= WALLET_AUTO %></strong>
      </div>
    </div>
  </header>

  <!-- แถบแท็บแบบยาวเต็มหน้าจอ -->
  <div class="bt-tabbar bt-tabbar--full">
    <button class="bt-tab active" data-tab="site">
      <span>⚙️ ตั้งค่าข้อมูลเว็บไซต์</span>
    </button>
    <button class="bt-tab" data-tab="wallets">
      <span>🏦 ตั้งค่าบัญชีเว็บ</span>
    </button>
  </div>

  <!-- ========== TAB 1: secure_config ========== -->
  <section id="tab-site" class="tabpane show">
    <form class="card mt admin-card" method="post" action="/admin/settings/secure">
      <input type="hidden" name="_section" value="secure">

      <header class="admin-card__header">
        <div>
          <h2>การตั้งค่าหลักของระบบ</h2>
          <!-- <p class="muted">
            ดึงจาก collection <code>secure_config</code> ใช้สำหรับเชื่อมต่อผู้ให้บริการหลักของเว็บ
          </p> -->
        </div>
        <div class="admin-card__badge <%= canEdit ? 'admin-card__badge--ok' : 'admin-card__badge--readonly' %>">
          <%= canEdit ? 'DEV MODE — สามารถแก้ไขได้' : 'READONLY — ต้องเป็น DEV เท่านั้น' %>
        </div>
      </header>

      <!-- IPlusView -->
      <div class="fieldset mt-lg">
        <div class="fieldset__header">
          <h3>IPlusView API</h3>
          <p class="muted">ตั้งค่า API สำหรับยิงคำสั่งไปยังผู้ให้บริการ IPlusView</p>
        </div>
        <div class="grid cols-2 gap-md fieldset__grid">
          <div class="form-group">
            <label>iPlusView ลิงก์ API</label>
            <input
              type="text"
              name="ipv_apiBase"
              value="<%= ipv.apiBase || '' %>"
              <%= canEdit ? '' : 'readonly' %>
            >
          </div>
          <div class="form-group">
            <label>iPlusView API คีย์</label>
            <input
              type="text"
              name="ipv_apiKey"
              value="<%= ipv.apiKey || '' %>"
              <%= canEdit ? '' : 'readonly' %>
            >
          </div>
        </div>
      </div>

      <!-- MAIL -->
      <div class="fieldset mt-lg">
        <div class="fieldset__header">
          <h3>อีเมล (SMTP)</h3>
          <p class="muted">ใช้สำหรับส่ง OTP / แจ้งเตือนไปยังผู้ใช้</p>
        </div>
        <div class="grid cols-2 gap-md fieldset__grid">
          <div class="form-group">
            <label>โฮสต์อีเมล SMTP</label>
            <input
              type="text"
              name="mail_host"
              value="<%= mail.host || '' %>"
              <%= canEdit ? '' : 'readonly' %>
            >
          </div>
          <div class="form-group">
            <label>พอร์ต SMTP</label>
            <input
              type="number"
              name="mail_port"
              value="<%= mail.port || '' %>"
              <%= canEdit ? '' : 'readonly' %>
            >
          </div>
        </div>
        <div class="grid cols-2 gap-md mt-sm fieldset__grid">
          <div class="form-group">
            <label>อีเมลผู้ส่ง</label>
            <input
              type="text"
              name="mail_user"
              value="<%= mail.user || '' %>"
              <%= canEdit ? '' : 'readonly' %>
            >
          </div>
          <div class="form-group">
            <label>รหัสผ่านอีเมล / App Password</label>
            <input
              type="text"
              name="mail_pass"
              value="<%= mail.pass || '' %>"
              <%= canEdit ? '' : 'readonly' %>
            >
          </div>
        </div>
        <div class="form-group mt-sm fieldset__single">
          <label>ชื่อผู้ส่งอีเมล</label>
          <input
            type="text"
            name="mail_from"
            value="<%= mail.from || '' %>"
            <%= canEdit ? '' : 'readonly' %>
          >
        </div>
        <div class="grid cols-2 gap-md mt-sm fieldset__grid">
          <label class="checkbox">
            <input type="hidden" name="mail_debug" value="0">
            <input
              type="checkbox"
              name="mail_debug"
              value="1"
              <%= boolVal(mail, 'debug', false) ? 'checked' : '' %>
              <%= canEdit ? '' : 'disabled' %>
            >
            <span>เปิดโหมด Debug อีเมล</span>
          </label>
          <label class="checkbox">
            <input type="hidden" name="mail_secure" value="0">
            <input
              type="checkbox"
              name="mail_secure"
              value="1"
              <%= boolVal(mail, 'secure', false) ? 'checked' : '' %>
              <%= canEdit ? '' : 'disabled' %>
            >
            <span>ใช้การเชื่อมต่ออีเมลแบบ Secure</span>
          </label>
        </div>
      </div>

      <!-- OTP -->
      <div class="fieldset mt-lg">
        <div class="fieldset__header">
          <h3>OTP ภายในเว็บ</h3>
          <p class="muted">ควบคุมอายุ OTP, คูลดาวน์ และจำนวนครั้งที่พิมพ์ผิดได้</p>
        </div>
        <div class="grid cols-3 gap-md fieldset__grid">
          <div class="form-group">
            <label>อายุ OTP ภายในเว็บ (วินาที)</label>
            <input
              type="number"
              name="otp_ttlSec"
              value="<%= otp.ttlSec || '' %>"
              <%= canEdit ? '' : 'readonly' %>
            >
          </div>
          <div class="form-group">
            <label>เวลารอก่อนส่ง OTP ใหม่ (วินาที)</label>
            <input
              type="number"
              name="otp_resendCooldownSec"
              value="<%= otp.resendCooldownSec || '' %>"
              <%= canEdit ? '' : 'readonly' %>
            >
          </div>
          <div class="form-group">
            <label>จำนวนครั้งที่กรอก OTP ผิดได้</label>
            <input
              type="number"
              name="otp_maxAttempts"
              value="<%= otp.maxAttempts || '' %>"
              <%= canEdit ? '' : 'readonly' %>
            >
          </div>
        </div>
      </div>

      <!-- General -->
      <div class="fieldset mt-lg">
        <div class="fieldset__header">
          <h3>ค่าทั่วไปของเว็บ</h3>
          <p class="muted">พอร์ตที่ใช้รันเซิร์ฟเวอร์และ secret ต่าง ๆ ของระบบ</p>
        </div>
        <div class="grid cols-2 gap-md fieldset__grid">
          <div class="form-group">
            <label>พอร์ตเว็บไซต์</label>
            <input
              type="number"
              name="port"
              value="<%= cfg.port || '' %>"
              <%= canEdit ? '' : 'readonly' %>
            >
          </div>
          <div class="form-group">
            <label>คีย์ลับ Session</label>
            <input
              type="text"
              name="sessionSecret"
              value="<%= cfg.sessionSecret || '' %>"
              <%= canEdit ? '' : 'readonly' %>
            >
          </div>
        </div>
        <div class="form-group mt-sm fieldset__single">
          <label>คีย์ลับสร้างลิงก์ TrueWallet</label>
          <input
            type="text"
            name="TW_GEN_LINK_SECRET"
            value="<%= cfg.TW_GEN_LINK_SECRET || '' %>"
            <%= canEdit ? '' : 'readonly' %>
          >
        </div>
        <div class="grid cols-2 gap-md mt-sm fieldset__grid">
          <div class="form-group">
            <label>ลิงก์หลักของเว็บไซต์</label>
            <input type="text" name="brand_url" value="<%= brand.url || '' %>" <%= canEdit ? '' : 'readonly' %>>
          </div>
          <div class="form-group">
            <label>ชื่อ Cookie Session</label>
            <input type="text" name="session_name" value="<%= sessionCfg.name || '' %>" <%= canEdit ? '' : 'readonly' %>>
          </div>
        </div>
      </div>

      <!-- OTP24 -->
      <div class="fieldset mt-lg">
        <div class="fieldset__header">
          <h3>OTP24hr API</h3>
          <p class="muted">ใช้สำหรับซื้อเบอร์ OTP ผ่านระบบ OTP24hr</p>
        </div>
        <div class="grid cols-2 gap-md fieldset__grid">
          <div class="form-group">
            <label>OTP24hr ลิงก์ API</label>
            <input type="text" name="otp24_apiBase" value="<%= otp24.apiBase || '' %>" <%= canEdit ? '' : 'readonly' %>>
          </div>
          <div class="form-group">
            <label>OTP24hr API คีย์</label>
            <input type="text" name="otp24_apiKey" value="<%= otp24.apiKey || '' %>" <%= canEdit ? '' : 'readonly' %>>
          </div>
        </div>
      </div>

      <!-- Turnstile -->
      <div class="fieldset mt-lg">
        <div class="fieldset__header">
          <h3>Cloudflare Turnstile</h3>
          <p class="muted">ตั้งค่า CAPTCHA ป้องกันบอทตอนสมัคร / ล็อกอิน</p>
        </div>
        <div class="grid cols-2 gap-md fieldset__grid">
          <div class="form-group">
            <label>Cloudflare Turnstile Site Key</label>
            <input type="text" name="turnstile_siteKey" value="<%= turnstile.siteKey || '' %>" <%= canEdit ? '' : 'readonly' %>>
          </div>
          <div class="form-group">
            <label>Cloudflare Turnstile Secret Key</label>
            <input type="text" name="turnstile_secretKey" value="<%= turnstile.secretKey || '' %>" <%= canEdit ? '' : 'readonly' %>>
          </div>
        </div>
      </div>

      <!-- Railway / Telegram -->
      <div class="fieldset mt-lg">
        <div class="fieldset__header">
          <h3>Railway / Telegram แจ้งเตือน</h3>
          <p class="muted">คีย์สำหรับควบคุม Railway และแจ้งเตือนผ่าน Telegram</p>
        </div>
        <div class="grid cols-2 gap-md fieldset__grid">
          <div class="form-group">
            <label>Railway API Token</label>
            <input type="text" name="railway_apiToken" value="<%= railway.apiToken || '' %>" <%= canEdit ? '' : 'readonly' %>>
          </div>
          <div class="form-group">
            <label>Railway Project ID</label>
            <input type="text" name="railway_projectId" value="<%= railway.projectId || '' %>" <%= canEdit ? '' : 'readonly' %>>
          </div>
          <div class="form-group">
            <label>Telegram Bot Token</label>
            <input type="text" name="telegram_botToken" value="<%= telegram.botToken || '' %>" <%= canEdit ? '' : 'readonly' %>>
          </div>
          <div class="form-group">
            <label>Telegram Channel ID</label>
            <input type="text" name="telegram_channelId" value="<%= telegram.channelId || '' %>" <%= canEdit ? '' : 'readonly' %>>
          </div>
        </div>
      </div>

      <!-- System -->
      <div class="fieldset mt-lg">
        <div class="fieldset__header">
          <h3>ระบบหลัก</h3>
          <p class="muted">ค่า runtime หลักของระบบและ worker</p>
        </div>
        <div class="grid cols-3 gap-md fieldset__grid">
          <div class="form-group"><label>เขตเวลาของระบบ</label><input type="text" name="system_tz" value="<%= system.tz || 'Asia/Bangkok' %>" <%= canEdit ? '' : 'readonly' %>></div>
          <div class="form-group"><label>จำนวนงานที่ Worker ทำพร้อมกัน</label><input type="number" name="system_workerConcurrency" value="<%= numVal(system, 'workerConcurrency', 5) %>" <%= canEdit ? '' : 'readonly' %>></div>
          <div class="form-group"><label>คีย์ลับ JWT</label><input type="text" name="system_jwtSecret" value="<%= system.jwtSecret || '' %>" <%= canEdit ? '' : 'readonly' %>></div>
          <div class="form-group"><label>รอบรีโหลด Secure Config (มิลลิวินาที)</label><input type="number" min="1000" step="500" name="system_secureConfigReloadIntervalMs" value="<%= sysNum('secureConfigReloadIntervalMs', 5000) %>" <%= canEdit ? '' : 'readonly' %>></div>
        </div>
        <div class="grid cols-3 gap-md mt-sm fieldset__grid">
          <label class="checkbox"><input type="hidden" name="system_globalLogEnabled" value="0"><input type="checkbox" name="system_globalLogEnabled" value="1" <%= sysBool('globalLogEnabled', false) ? 'checked' : '' %> <%= canEdit ? '' : 'disabled' %>><span>เปิดบันทึก Log หลักของระบบ</span></label>
          <label class="checkbox"><input type="hidden" name="system_syncIndexes" value="0"><input type="checkbox" name="system_syncIndexes" value="1" <%= sysBool('syncIndexes', true) ? 'checked' : '' %> <%= canEdit ? '' : 'disabled' %>><span>ซิงก์ Index ฐานข้อมูลอัตโนมัติ</span></label>
          <label class="checkbox"><input type="hidden" name="system_secureConfigAutoReloadEnabled" value="0"><input type="checkbox" name="system_secureConfigAutoReloadEnabled" value="1" <%= sysBool('secureConfigAutoReloadEnabled', true) ? 'checked' : '' %> <%= canEdit ? '' : 'disabled' %>><span>รีโหลด Secure Config อัตโนมัติ</span></label>
        </div>
      </div>

      <!-- Jobs -->
      <div class="fieldset mt-lg">
        <div class="fieldset__header">
          <h3>งานเบื้องหลัง / Cron</h3>
          <p class="muted">ตั้งค่ารอบการทำงานของ queue, sweeper, sync และ cron ต่าง ๆ</p>
        </div>
        <div class="grid cols-3 gap-md fieldset__grid">
          <div class="form-group"><label>รอบเช็คสถานะออเดอร์ (มิลลิวินาที)</label><input type="number" name="jobs_orderStatusTickMs" value="<%= numVal(jobs, 'orderStatusTickMs', 60000) %>" <%= canEdit ? '' : 'readonly' %>></div>
          <div class="form-group"><label>จำนวนงานเช็คออเดอร์พร้อมกัน</label><input type="number" name="jobs_orderStatusConcurrency" value="<%= numVal(jobs, 'orderStatusConcurrency', 20) %>" <%= canEdit ? '' : 'readonly' %>></div>
          <div class="form-group"><label>จำนวนออเดอร์สูงสุดต่อรอบ</label><input type="number" name="jobs_orderStatusBatchLimit" value="<%= numVal(jobs, 'orderStatusBatchLimit', 300) %>" <%= canEdit ? '' : 'readonly' %>></div>
          <div class="form-group"><label>รอบสแกนสถานะเร็ว (มิลลิวินาที)</label><input type="number" name="jobs_orderStatusFastScanMs" value="<%= numVal(jobs, 'orderStatusFastScanMs', 2000) %>" <%= canEdit ? '' : 'readonly' %>></div>
          <div class="form-group"><label>เวลายกเลิกออเดอร์อัตโนมัติ (มิลลิวินาที)</label><input type="number" name="jobs_orderStatusAutoCancelAfterMs" value="<%= numVal(jobs, 'orderStatusAutoCancelAfterMs', 43200000) %>" <%= canEdit ? '' : 'readonly' %>></div>
          <div class="form-group"><label>รอบตรวจออเดอร์ OTP24 (มิลลิวินาที)</label><input type="number" name="jobs_otp24SweeperIntervalMs" value="<%= numVal(jobs, 'otp24SweeperIntervalMs', 3000) %>" <%= canEdit ? '' : 'readonly' %>></div>
          <div class="form-group"><label>จำนวนรายการ OTP24 ต่อรอบ</label><input type="number" name="jobs_otp24SweeperBatchLimit" value="<%= numVal(jobs, 'otp24SweeperBatchLimit', 100) %>" <%= canEdit ? '' : 'readonly' %>></div>
          <div class="form-group"><label>จำนวนงาน OTP24 พร้อมกัน</label><input type="number" name="jobs_otp24SweeperConcurrency" value="<%= numVal(jobs, 'otp24SweeperConcurrency', 3) %>" <%= canEdit ? '' : 'readonly' %>></div>
          <div class="form-group"><label>รอบตรวจงาน Telegram (มิลลิวินาที)</label><input type="number" name="jobs_telegramCheckIntervalMs" value="<%= numVal(jobs, 'telegramCheckIntervalMs', 5000) %>" <%= canEdit ? '' : 'readonly' %>></div>
          <div class="form-group"><label>จำนวนรายการ Telegram ต่อรอบ</label><input type="number" name="jobs_telegramCheckBatchLimit" value="<%= numVal(jobs, 'telegramCheckBatchLimit', 150) %>" <%= canEdit ? '' : 'readonly' %>></div>
          <div class="form-group"><label>เวลา Cron ซิงก์บริการรายวัน</label><input type="text" name="jobs_dailyChangeSyncCron" value="<%= jobs.dailyChangeSyncCron || '0 7 * * *' %>" <%= canEdit ? '' : 'readonly' %>></div>
