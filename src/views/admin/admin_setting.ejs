<script>
  // ================== TAB SWITCH ==================
  (function () {
    const tabs = document.querySelectorAll(".bt-tabbar .bt-tab");
    const panes = document.querySelectorAll(".tabpane");

    tabs.forEach((btn) => {
      btn.addEventListener("click", () => {
        const tab = btn.dataset.tab;

        // เปลี่ยน active ที่ปุ่ม
        tabs.forEach((b) => b.classList.toggle("active", b === btn));

        // โชว์/ซ่อน pane ตาม id = "tab-" + data-tab
        panes.forEach((p) => {
          p.classList.toggle("show", p.id === "tab-" + tab);
        });
      });
    });
  })();
</script>

<script>
(() => {

  // 🔊 ===== SOUND ENGINE =====
  const ToggleSound = (() => {
    let ctx;
    const getCtx = () => ctx || (ctx = new (window.AudioContext || window.webkitAudioContext)());

    function play(freqStart, freqEnd) {
      const c = getCtx();
      const o = c.createOscillator();
      const g = c.createGain();

      o.type = 'sine';
      o.frequency.setValueAtTime(freqStart, c.currentTime);
      o.frequency.exponentialRampToValueAtTime(freqEnd, c.currentTime + 0.06);

      g.gain.setValueAtTime(0.0001, c.currentTime);
      g.gain.exponentialRampToValueAtTime(0.06, c.currentTime + 0.01);
      g.gain.exponentialRampToValueAtTime(0.0001, c.currentTime + 0.12);

      o.connect(g).connect(c.destination);
      o.start();
      o.stop(c.currentTime + 0.12);
    }

    return {
      on: () => play(700, 1100),   // 🔵 เปิด
      off: () => play(600, 350)    // ⚫ ปิด
    };
  })();


  const toggles = document.querySelectorAll('.toggles-existing input[data-id][data-field]');

  toggles.forEach((el) => {

    let abortController = null;

    el.addEventListener('change', async () => {

      if (el.disabled || el.dataset.busy === '1') return;

      const id = el.dataset.id;
      const field = el.dataset.field;
      const value = el.checked;

      if (!id || !field) return;

      const card = el.closest('.bank-card');
      const statusPill = card?.querySelector('.bank-pill');
      const prevChecked = !value;

      // 🔊 เล่นเสียงทันที (optimistic UX)
      try {
        if (value) ToggleSound.on();
        else ToggleSound.off();

        // 📳 สั่นมือถือ (ถ้ามี)
        if (navigator.vibrate) navigator.vibrate(8);

      } catch {}

      // cancel request เก่า
      if (abortController) abortController.abort();
      abortController = new AbortController();

      el.dataset.busy = '1';
      el.classList.add('optimistic');

      // delay loading (กันกระชาก)
      setTimeout(() => {
        if (el.dataset.busy === '1') {
          el.classList.add('loading');
        }
      }, 120);

      try {
        const res = await fetch('/admin/api/wallet/update-toggle', {
          method: 'POST',
          credentials: 'same-origin',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ id, field, value }),
          signal: abortController.signal
        });

        const data = await res.json().catch(() => ({}));

        if (!res.ok || !data.ok) {
          throw new Error(data.message || `HTTP ${res.status}`);
        }

        // sync ค่า
        if (data.wallet) {
          const map = {
            isActive: data.wallet.isActive,
            isSMS: data.wallet.isSMS,
            isAuto: data.wallet.isAuto,
          };

          card?.querySelectorAll('.toggles-existing input[data-field]')
            .forEach(input => {
              const f = input.dataset.field;
              if (map[f] !== undefined) {
                input.checked = !!map[f];
              }
            });

          // update pill
          if (statusPill) {
            statusPill.style.opacity = 0.4;

            setTimeout(() => {
              statusPill.textContent = data.wallet.isActive ? 'กำลังใช้งาน' : 'ปิดใช้งาน';
              statusPill.classList.toggle('bank-pill--on', data.wallet.isActive);
              statusPill.classList.toggle('bank-pill--off', !data.wallet.isActive);
              statusPill.style.opacity = 1;
            }, 120);
          }
        }

        // success effect
        el.classList.remove('loading');
        el.classList.add('toggle-success');

        setTimeout(() => {
          el.classList.remove('toggle-success');
        }, 450);

      } catch (err) {

        if (err.name === 'AbortError') return;

        // rollback
        el.checked = prevChecked;

        el.classList.remove('loading');
        el.classList.add('toggle-error');

        setTimeout(() => {
          el.classList.remove('toggle-error');
        }, 500);
      }

      el.classList.remove('optimistic');
      delete el.dataset.busy;
    });
  });
})();
</script>

