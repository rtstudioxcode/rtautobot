<%
const BANKS_LIST = [
  { code: 'tw', label: 'TrueMoney Wallet' },
  { code: 'qr', label: 'PromptPay QR' },
  { code: 'kbank', label: 'ธนาคารกสิกรไทย' },
  { code: 'scb', label: 'ธนาคารไทยพาณิชย์' },
  { code: 'bbl', label: 'ธนาคารกรุงเทพ' },
  { code: 'ktb', label: 'ธนาคารกรุงไทย' },
  { code: 'bay', label: 'ธนาคารกรุงศรีอยุธยา' },
  { code: 'gsb', label: 'ธนาคารออมสิน' },
];
const rows = Array.isArray(wallets) ? wallets : [];
%>
<div class="rt-wallet-settings">
  <section class="rt-wallet-hero">
    <div>
      <span>Payment Settings</span>
      <h1>ตั้งค่าบัญชีรับเงิน RTAUTOBOT</h1>
      <p>บัญชีในหน้านี้ใช้สำหรับรับเงินเติมเครดิตบนเว็บ RTAUTOBOT เท่านั้น แยกการแสดงผลออกจากบัญชีของ RTSMM-TH</p>
    </div>
    <a class="btn ghost" href="/admin">กลับหน้าแอดมิน</a>
  </section>

  <form method="post" action="/admin/settings/wallets" class="rt-wallet-form">
    <section class="rt-wallet-card">
      <div class="rt-card-head">
        <div>
          <h2>บัญชีรับเงินที่ใช้งานอยู่</h2>
          <p>เปิด/ปิดช่องทาง เติม Secret สำหรับ Webhook และระบุเลขบัญชีที่จะแสดงให้ลูกค้า</p>
        </div>
        <button class="rt-save" type="submit">บันทึกการตั้งค่า</button>
      </div>

      <% if (!rows.length) { %>
        <div class="rt-empty">ยังไม่มีบัญชีรับเงินของ RTAUTOBOT เพิ่มบัญชีแรกได้จากฟอร์มด้านล่าง</div>
      <% } %>

      <div class="rt-wallet-list">
        <% rows.forEach((w, i) => { %>
          <article class="rt-wallet-row">
            <input type="hidden" name="wallets[<%= i %>][id]" value="<%= w._id %>">
            <div class="rt-row-main">
              <label>ชื่อบัญชี
                <input name="wallets[<%= i %>][accountName]" value="<%= w.accountName || '' %>" placeholder="เช่น RTAUTOBOT">
              </label>
              <label>เลขบัญชี / เบอร์ / PromptPay
                <input name="wallets[<%= i %>][accountNumber]" value="<%= w.accountNumber || '' %>" placeholder="เลขบัญชีหรือเบอร์รับเงิน">
              </label>
              <label>ช่องทาง
                <select name="wallets[<%= i %>][accountCode]">
                  <% BANKS_LIST.forEach(b => { %>
                    <option value="<%= b.code %>" <%= String(w.accountCode||'') === b.code ? 'selected' : '' %>><%= b.label %></option>
                  <% }) %>
                </select>
              </label>
              <label>Webhook Secret
                <input name="wallets[<%= i %>][secret]" value="<%= w.secret || '' %>" placeholder="ใช้กับ webhook ธนาคาร/วอลเล็ท">
              </label>
            </div>
            <div class="rt-row-flags">
              <label><input type="checkbox" name="wallets[<%= i %>][isActive]" value="1" <%= w.isActive ? 'checked' : '' %>> เปิดใช้งาน</label>
              <label><input type="checkbox" name="wallets[<%= i %>][isSMS]" value="1" <%= w.isSMS ? 'checked' : '' %>> รับจาก SMS/Webhook</label>
              <label><input type="checkbox" name="wallets[<%= i %>][isAuto]" value="1" <%= w.isAuto ? 'checked' : '' %>> จับคู่อัตโนมัติ</label>
              <label class="rt-danger"><input type="checkbox" name="wallets[<%= i %>][_delete]" value="1"> ลบบัญชีนี้</label>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="rt-wallet-card">
      <div class="rt-card-head compact">
        <div>
          <h2>เพิ่มบัญชีรับเงินใหม่</h2>
          <p>บัญชีใหม่จะถูกบันทึกใน Production ของ RTAUTOBOT โดยอัตโนมัติ</p>
        </div>
      </div>
      <div class="rt-row-main new-wallet">
        <label>ชื่อบัญชี
          <input name="newWallet[accountName]" placeholder="เช่น RTAUTOBOT">
        </label>
        <label>เลขบัญชี / เบอร์ / PromptPay
          <input name="newWallet[accountNumber]" placeholder="เลขบัญชีหรือเบอร์รับเงิน">
        </label>
        <label>ช่องทาง
          <select name="newWallet[accountCode]">
            <% BANKS_LIST.forEach(b => { %><option value="<%= b.code %>"><%= b.label %></option><% }) %>
          </select>
        </label>
        <label>Webhook Secret
          <input name="newWallet[secret]" placeholder="เว้นว่างได้ หากยังไม่ใช้ webhook">
        </label>
      </div>
      <div class="rt-row-flags">
        <label><input type="checkbox" name="newWallet[isActive]" value="1" checked> เปิดใช้งาน</label>
        <label><input type="checkbox" name="newWallet[isSMS]" value="1"> รับจาก SMS/Webhook</label>
        <label><input type="checkbox" name="newWallet[isAuto]" value="1" checked> จับคู่อัตโนมัติ</label>
      </div>
      <button class="rt-save bottom" type="submit">บันทึกบัญชี</button>
    </section>
  </form>
</div>

<style>
.rt-wallet-settings{max-width:1180px;margin:0 auto;padding:28px 16px 60px;color:var(--text,#f8ecd2)}.rt-wallet-hero,.rt-wallet-card{border:1px solid rgba(246,199,72,.22);border-radius:28px;background:linear-gradient(135deg,rgba(255,255,255,.07),rgba(255,255,255,.025));box-shadow:0 22px 60px rgba(0,0,0,.28)}.rt-wallet-hero{display:flex;justify-content:space-between;align-items:center;gap:18px;padding:28px}.rt-wallet-hero span{color:#ffe083;font-weight:900}.rt-wallet-hero h1{margin:8px 0 8px;font-size:clamp(28px,4vw,46px)}.rt-wallet-hero p,.rt-card-head p,.rt-empty{color:var(--muted,#d8c89e);font-weight:650}.rt-wallet-card{padding:24px;margin-top:18px}.rt-card-head{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:18px}.rt-card-head h2{margin:0 0 6px}.rt-save,.btn.ghost{border:0;border-radius:16px;padding:13px 18px;font-weight:900;cursor:pointer;text-decoration:none}.rt-save{color:#17130b;background:linear-gradient(135deg,#fff2a3,#dda21b)}.btn.ghost{color:#ffe083;border:1px solid rgba(246,199,72,.28);background:rgba(255,255,255,.045)}.rt-wallet-list{display:grid;gap:14px}.rt-wallet-row{padding:18px;border:1px solid rgba(255,255,255,.08);border-radius:22px;background:rgba(0,0,0,.16)}.rt-row-main{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}.rt-row-main label{display:grid;gap:7px;color:#ffe6a3;font-weight:800}.rt-row-main input,.rt-row-main select{width:100%;border:1px solid rgba(255,255,255,.12);border-radius:14px;background:rgba(5,6,10,.72);color:var(--text,#fff);padding:12px 13px;outline:none}.rt-row-main input:focus,.rt-row-main select:focus{border-color:rgba(246,199,72,.55)}.rt-row-flags{display:flex;gap:12px;flex-wrap:wrap;margin-top:14px}.rt-row-flags label{padding:9px 12px;border-radius:999px;background:rgba(255,255,255,.055);border:1px solid rgba(255,255,255,.08);color:var(--muted,#d8c89e);font-weight:800}.rt-row-flags input{accent-color:#e4a81d}.rt-danger{color:#ffb5a8!important}.rt-empty{padding:20px;border:1px dashed rgba(246,199,72,.28);border-radius:18px;margin-bottom:14px;text-align:center}.bottom{margin-top:18px}@media(max-width:900px){.rt-wallet-hero,.rt-card-head{align-items:flex-start;flex-direction:column}.rt-row-main{grid-template-columns:1fr 1fr}}@media(max-width:560px){.rt-wallet-settings{padding:18px 12px 42px}.rt-row-main{grid-template-columns:1fr}.rt-save,.btn.ghost{width:100%;text-align:center}}
</style>
