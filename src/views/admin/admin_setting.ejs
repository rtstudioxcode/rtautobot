/* shimmer */
.toggles input.loading::after {
  opacity: 1;
  background: linear-gradient(
    120deg,
    transparent 30%,
    rgba(255,255,255,0.4) 50%,
    transparent 70%
  );
  animation: shimmer 0.8s linear infinite;
}

/* ===== success ===== */
.toggles input.toggle-success {
  box-shadow: inset 0 0 0 2px rgba(109, 201, 126, 0.7);
}

/* ===== error ===== */
.toggles input.toggle-error {
  box-shadow: inset 0 0 0 2px rgba(255, 80, 80, 0.7);
}

/* ===== text ===== */
.toggles span {
  transition: color 0.2s ease;
}

.toggles input:checked + span {
  color: #4da3ff;
}

/* ===== animations ===== */
@keyframes shimmer {
  0% { transform: translateX(-120%); }
  100% { transform: translateX(120%); }
}

@keyframes ripple {
  0% { transform: scale(1); opacity: 0.6; }
  100% { transform: scale(1.5); opacity: 0; }
}

/* ===== TITLE WRAP ===== */
.bank-title {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

/* ===== NAME ===== */
.bank-name {
  font-size: 15px;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 0.02em;
}

/* ===== META LINE ===== */
.bank-meta {
  display: flex;
  align-items: center;
  gap: 6px;

  font-size: 11px;
  color: rgba(255,255,255,0.55);
}

/* ===== CODE ===== */
.bank-meta .bank-code {
  font-weight: 500;
  letter-spacing: 0.08em;
  color: rgba(255,255,255,0.65);
}

/* ===== DOT ===== */
.bank-dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
}

/* ===== TYPE ===== */
.bank-meta .bank-type {
  font-size: 11px;
  color: rgba(255,255,255,0.45);
}

/* ===== HEADER ALIGN FIX ===== */
.bank-card__title {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

/* ===== spacing improve ===== */
.bank-card__header {
  align-items: flex-start;
}
