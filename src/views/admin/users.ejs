<script>
(function(){
  const $ = (s, el=document)=>el.querySelector(s);
  const usersGrid = $('#usersGrid');
  const modal = $('#userModal');

  const m = {
    root: modal,
    avatar: $('#mAvatar', modal),
    username: $('#mUsername', modal),
    email: $('#mEmail', modal),
    nameInput: $('#mNameInput', modal),
    roleSelect: $('#mRoleSelect', modal),
    emailVerifiedChk: $('#mEmailVerifiedChk', modal),
    balanceInput: $('#mBalanceInput', modal),
    levelName: $('#mLevelName', modal),
    totalSpent: $('#mTotalSpent', modal),
    points: $('#mPoints', modal),
    totalOrders: $('#mTotalOrders', modal),
    createdAt: $('#mCreatedAt', modal),
    updatedAt: $('#mUpdatedAt', modal),
    serialKey: $('#mSerialKey', modal),
    close: $('#mClose', modal),
    saveNote: $('#saveNote', modal),
  };

  let currentId = null;
  let saveTimer = null;
  const DEBOUNCE_MS = 600;

  const roleCustom = {
    root: $('#mRoleCustomSelect', modal),
    btn: $('#mRoleCustomBtn', modal),
    value: $('#mRoleCustomValue', modal),
    menu: $('#mRoleCustomMenu', modal),
  };

  // ย้าย dropdown menu ออกไปไว้ใต้ <body> เพื่อให้ position:fixed อ้างอิง viewport จริง
  // ไม่โดน transform/overflow ของ modal ทำให้ตำแหน่งเพี้ยนหรือจมหลัง layer อื่น
  if (roleCustom.menu && roleCustom.menu.parentElement !== document.body) {
    roleCustom.menu.classList.add('au-select-portal');
    document.body.appendChild(roleCustom.menu);
  }

  function syncRoleMenuThemeVars(){
    if (!roleCustom.menu || !modal) return;
    const cs = getComputedStyle(modal);
    ['--au-page','--au-card','--au-text','--au-muted','--au-border','--au-accent','--au-accent-2'].forEach(k=>{
      const v = cs.getPropertyValue(k);
      if (v) roleCustom.menu.style.setProperty(k, v.trim());
    });
  }

  function setRoleCustomValue(value, silent = false){
    const v = String(value || 'user').toLowerCase() === 'admin' ? 'admin' : 'user';
    if (m.roleSelect) m.roleSelect.value = v;
    if (roleCustom.root) roleCustom.root.dataset.value = v;
    if (roleCustom.value) roleCustom.value.textContent = v;

    roleCustom.menu?.querySelectorAll('.au-custom-option').forEach(opt => {
      const active = opt.dataset.value === v;
      opt.classList.toggle('selected', active);
      opt.setAttribute('aria-selected', active ? 'true' : 'false');
    });

    if (!silent) scheduleSave();
  }

  function positionRoleMenu(){
    if (!roleCustom.btn || !roleCustom.menu) return;
    const r = roleCustom.btn.getBoundingClientRect();
    const gap = 8;
    const menu = roleCustom.menu;

    const width = Math.max(Math.round(r.width), 180);
    const left = Math.min(
      Math.max(12, Math.round(r.left)),
      Math.max(12, window.innerWidth - width - 12)
    );

    menu.style.width = width + 'px';
    menu.style.left = left + 'px';

    const wasOpen = menu.classList.contains('open');
    if (!wasOpen) {
      menu.style.visibility = 'hidden';
      menu.classList.add('open');
    }

    const menuHeight = Math.min(menu.scrollHeight || 150, Math.max(120, window.innerHeight - 24));
    const canOpenDown = r.bottom + gap + menuHeight <= window.innerHeight - 12;
    const top = canOpenDown ? (r.bottom + gap) : Math.max(12, r.top - gap - menuHeight);
    menu.style.top = Math.round(top) + 'px';

    if (!wasOpen) {
      menu.classList.remove('open');
      menu.style.visibility = '';
    }
  }

  function openRoleMenu(){
    syncRoleMenuThemeVars();
    roleCustom.root?.classList.add('open');
    roleCustom.menu?.classList.add('open');
    roleCustom.btn?.setAttribute('aria-expanded', 'true');
    positionRoleMenu();
  }

  function closeRoleMenu(){
    roleCustom.root?.classList.remove('open');
    roleCustom.menu?.classList.remove('open');
    roleCustom.btn?.setAttribute('aria-expanded', 'false');
  }

  roleCustom.btn?.addEventListener('click', (e)=>{
    e.preventDefault();
    e.stopPropagation();
    if (roleCustom.root?.classList.contains('open')) closeRoleMenu();
    else openRoleMenu();
  });

  roleCustom.menu?.addEventListener('click', (e)=>{
    const opt = e.target.closest('.au-custom-option');
    if (!opt) return;
    e.preventDefault();
    setRoleCustomValue(opt.dataset.value);
    closeRoleMenu();
    roleCustom.btn?.focus();
  });

  roleCustom.menu?.addEventListener('keydown', (e)=>{
    const opts = Array.from(roleCustom.menu.querySelectorAll('.au-custom-option'));
    const idx = opts.indexOf(document.activeElement);
    if (e.key === 'Escape') {
      e.preventDefault();
      closeRoleMenu();
      roleCustom.btn?.focus();
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      (opts[idx + 1] || opts[0])?.focus();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      (opts[idx - 1] || opts[opts.length - 1])?.focus();
    }
  });

  document.addEventListener('click', (e)=>{
    if (!roleCustom.root?.contains(e.target) && !roleCustom.menu?.contains(e.target)) closeRoleMenu();
  });

  window.addEventListener('resize', positionRoleMenu, { passive:true });
  window.addEventListener('scroll', positionRoleMenu, { passive:true });
  modal?.querySelector('.au-modal-body')?.addEventListener('scroll', positionRoleMenu, { passive:true });


  function toTHB(v){
    const n = Number(v || 0);
    return '฿' + n.toLocaleString('th-TH', { maximumFractionDigits: 2 });
  }
  function fmtDate(d){
    if (!d) return '—';
    try { return new Date(d).toLocaleString('th-TH'); }
    catch { return String(d); }
  }
  function num(v){ const n = Number(v); return Number.isFinite(n) ? n : 0; }
  function fmtTHB(n){ return '฿' + Number(n||0).toLocaleString('th-TH',{maximumFractionDigits:2}); }
  function fmtInt(n){ return Number(n||0).toLocaleString('th-TH'); }

  function getAffRatePct(u){
    const lock  = Number(u?.affiliate?.rateLockedPct);
    const admin = Number(u?.affiliate?.ratePct);
    let pct = 5;
    if (Number.isFinite(lock)) pct = lock;
    else if (Number.isFinite(admin)) pct = admin;
    return Math.max(5, Math.min(40, pct));
  }

  function fillAffiliateSection(u){
    const rate = getAffRatePct(u);
    const refs = num(u?.affiliate?.referredCount);
    const earn = num(u?.affiliate?.earningsTHB);
    const elRate = document.getElementById('mAffRate');
    const elRefs = document.getElementById('mAffRefs');
    const elEarn = document.getElementById('mAffEarn');
    if (elRate) elRate.textContent = rate.toFixed(0) + ' %';
    if (elRefs) elRefs.textContent = fmtInt(refs) + ' คน';
    if (elEarn) elEarn.textContent = fmtTHB(earn);
  }

  async function openUserModal(userId){
    const res = await fetch(`/admin/users/${encodeURIComponent(userId)}.json`, { credentials: 'same-origin' });
    const j = await res.json();
    if (!res.ok || !j?.ok) { alert(j?.error || 'โหลดข้อมูลไม่สำเร็จ'); return; }
    const u = j.user || {};
    currentId = u._id;

    m.avatar.src = u.avatarUrl || '/static/assets/img/user-blue.png';
    m.username.textContent = u.username || '—';
    m.email.textContent = u.email || '—';
    m.nameInput.value = u.name || '';
    setRoleCustomValue((u.role || 'user').toLowerCase(), true);
    m.emailVerifiedChk.checked = !!u.emailVerified;
    m.balanceInput.value = Number(u.balance ?? 0).toFixed(2);
    m.levelName.textContent = u.levelName || '—';
    m.totalSpent.textContent = toTHB(u.totalSpent);
    m.points.textContent = Number(u.points||0).toLocaleString('th-TH', { maximumFractionDigits: 2 });
    m.totalOrders.textContent = Number(u.totalOrders||0).toLocaleString('th-TH');
    m.createdAt.textContent = fmtDate(u.createdAt);
    m.updatedAt.textContent = fmtDate(u.updatedAt || u.createdAt);
    if (m.serialKey) m.serialKey.textContent = u.serial_key || '—';
    fillAffiliateSection(u);

    m.saveNote.textContent = 'พร้อมบันทึกอัตโนมัติ';
    m.saveNote.className = 'au-save-note';
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.documentElement.style.overflow = 'hidden';
    setTimeout(()=>m.nameInput?.focus(), 60);
  }

  function scheduleSave(){
    if (!currentId) return;
    m.saveNote.textContent = 'กำลังเตรียมบันทึก...';
    m.saveNote.className = 'au-save-note saving';
    if (saveTimer) clearTimeout(saveTimer);
    saveTimer = setTimeout(doSave, DEBOUNCE_MS);
  }

  async function doSave(){
    if (!currentId) return;
    m.saveNote.textContent = 'กำลังบันทึก...';
    m.saveNote.className = 'au-save-note saving';
    const payload = {
      name: m.nameInput.value.trim(),
      role: m.roleSelect.value,
      emailVerified: !!m.emailVerifiedChk.checked,
      balance: Number(m.balanceInput.value || 0),
    };
    try {
      const res = await fetch(`/admin/users/${encodeURIComponent(currentId)}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify(payload)
      });
      const j = await res.json();
      if (!res.ok || !j?.ok) throw new Error(j?.error || 'บันทึกไม่สำเร็จ');
      const u = j.user || {};
      m.updatedAt.textContent = fmtDate(u.updatedAt || new Date());
      syncCard(u);
      m.saveNote.textContent = 'บันทึกแล้ว';
      m.saveNote.className = 'au-save-note ok';
    } catch (err) {
      m.saveNote.textContent = 'บันทึกไม่สำเร็จ';
      m.saveNote.className = 'au-save-note err';
    }
  }

  function syncCard(u){
    const card = document.querySelector(`.au-user-card[data-user-id="${CSS.escape(currentId)}"]`);
    if (!card) return;
    const bal = card.querySelector('.balance');
    if (bal) bal.textContent = toTHB(u.balance);
    const roleBadge = card.querySelector('.au-badge.role');
    if (roleBadge) {
      const role = String(u.role || 'user').toLowerCase();
      roleBadge.textContent = role;
      roleBadge.className = `au-badge role role-${role}`;
    }
    const presence = card.querySelector('.au-presence');
    if (presence) {
      presence.classList.toggle('ok', !!u.emailVerified);
      presence.classList.toggle('warn', !u.emailVerified);
      presence.title = u.emailVerified ? 'ยืนยันอีเมลแล้ว' : 'ยังไม่ยืนยันอีเมล';
    }
    const line = card.querySelector('.au-badge-line');
    if (line) {
      const oldStatus = line.querySelector('.au-badge.ok, .au-badge.warn');
      if (oldStatus) oldStatus.remove();
      const el = document.createElement('span');
      el.className = u.emailVerified ? 'au-badge ok' : 'au-badge warn';
      el.textContent = u.emailVerified ? 'ยืนยันอีเมลแล้ว' : 'ยังไม่ยืนยันอีเมล';
      line.prepend(el);
    }
  }

  m.roleSelect?.addEventListener('change', ()=>setRoleCustomValue(m.roleSelect.value));

  ['input','change'].forEach(ev=>{
    m.nameInput?.addEventListener(ev, scheduleSave);
    m.roleSelect?.addEventListener(ev, scheduleSave);
    m.emailVerifiedChk?.addEventListener(ev, scheduleSave);
    m.balanceInput?.addEventListener(ev, scheduleSave);
  });

  usersGrid?.addEventListener('click', (e)=>{
    const card = e.target.closest('.au-user-card');
    if (!card) return;
    const id = card.getAttribute('data-user-id');
    if (id) openUserModal(id);
  });
  usersGrid?.addEventListener('keydown', (e)=>{
    const card = e.target.closest('.au-user-card');
    if (!card) return;
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      const id = card.getAttribute('data-user-id');
      if (id) openUserModal(id);
    }
  });

  m.close?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e)=>{
    if (e.target?.dataset?.closeModal === '1') closeModal();
  });
  document.addEventListener('keydown', (e)=>{
    if (e.key === 'Escape' && modal?.classList.contains('open')) closeModal();
    if (e.key === '/' && !/input|textarea|select/i.test(document.activeElement.tagName)) {
      e.preventDefault();
      searchInput?.focus();
    }
  });
  function closeModal(){
    if (saveTimer) clearTimeout(saveTimer);
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.documentElement.style.overflow = '';
    currentId = null;
  }

  const searchInput = document.getElementById('userSearch');
  const emptyState  = document.getElementById('emptyState');
  function normalizeText(s){
    if (!s) return '';
    return s.normalize('NFKD').replace(/\p{M}+/gu, '').toLowerCase().trim();
  }
  function filterUsers(){
    const raw = searchInput?.value ?? '';
    const q = normalizeText(raw);
    const cards = Array.from(document.querySelectorAll('.au-users-grid .au-user-card'));
    if (!cards.length) return;
    if (raw.trim().length === 0){
      for (const c of cards){ c.style.display = ''; }
      if (emptyState) emptyState.hidden = true;
      return;
    }
    let visible = 0;
    for (const c of cards){
      const keys = normalizeText(c.getAttribute('data-keys') || '');
      const hit = keys.includes(q);
      c.style.display = hit ? '' : 'none';
      if (hit) visible++;
    }
    if (emptyState) emptyState.hidden = visible > 0;
  }
  searchInput?.addEventListener('input', filterUsers);
  if (emptyState) emptyState.hidden = true;
})();
</script>
