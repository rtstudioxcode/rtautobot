<% const BANK_LABELS = {
  bbl:'ธนาคารกรุงเทพ', kbank:'ธนาคารกสิกรไทย', ktb:'ธนาคารกรุงไทย',
  bay:'ธนาคารกรุงศรีอยุธยา', scb:'ธนาคารไทยพาณิชย์', tmb:'ทหารไทยธนชาต (TTB)',
  cimb:'ธนาคารซีไอเอ็มบีไทย', uob:'ธนาคารยูโอบี', gsb:'ธนาคารออมสิน',
  baac:'ธ.เพื่อการเกษตรและสหกรณ์การเกษตร', kkb:'ธนาคารเกียรตินาคินภัทร',
  lhfg:'ธนาคารแลนด์ แอนด์ เฮ้าส์', icbc:'ธนาคารไอซีบีซี (ไทย)', tisco:'ธนาคารทิสโก้',
  tw:'TrueMoney Wallet', qr:'PromptPay QR'
};
const REPORT_MODE = (typeof reportMode !== 'undefined' && reportMode === 'year') ? 'year' : 'month';
const IS_YEAR_MODE = REPORT_MODE === 'year';
const SELECTED_YEAR = Number(typeof selectedYear !== 'undefined' ? selectedYear : new Date().getFullYear());
const SELECTED_LABEL = typeof selectedLabel !== 'undefined' && selectedLabel ? selectedLabel : '';
const YEARLY_ROWS = Array.isArray(typeof yearlyRows !== 'undefined' ? yearlyRows : null) ? yearlyRows : [];
%>

<div class="topup-report-page">
<section class="page-head">
  <div class="page-title">
    <h1>ประวัติการเติมเงินทั้งหมด</h1>
    <small class="muted">หลังบ้าน → รายการเติมเงินทั้งหมด</small>
  </div>
</section>

<!-- สรุปยอดเติมเงินที่สำเร็จทั้งเว็บ -->
<div class="grid cards">
  <% if (typeof sumNoAdmin !== 'undefined' && sumNoAdmin > 0) { %>
    <section class="card">
      <div class="card-head row-head">
        <h3>ยอดเติมรวมทั้งหมด (ไม่รวมแอดมิน)<%= SELECTED_LABEL ? ' • ' + SELECTED_LABEL : '' %></h3>
        <div class="head-right">
          <span class="metric-badge" style="color:#cc8110; padding:2px 18px;">
            <%= (countNoAdmin || 0).toLocaleString() %> รายการ
          </span>
        </div>
      </div>
      <div class="big" style="color:#35cc10; padding:6px 2px;">
        ฿<%= Number(sumNoAdmin || 0).toLocaleString(undefined, { minimumFractionDigits: 2 }) %>
      </div>
    </section>
  <% } %>
</div>

<div class="grid cards">
  <% if (Array.isArray(methodTotals) && methodTotals.length) { %>
    <% methodTotals.forEach(m => { %>
      <section class="card2">
        <div class="card-head row-head">
          <h3>ยอดเติมรวม <%= m.label %><%= SELECTED_LABEL ? ' • ' + SELECTED_LABEL : '' %></h3>
          <div class="head-right">
            <span class="metric-badge" style="color:#cc8110; padding:2px 18px;">
              <%= (m.count || 0).toLocaleString() %> รายการ
            </span>
          </div>
        </div>
        <div class="big" style="color:#35cc10; padding:6px 2px;">
          ฿<%= Number(m.sum || 0).toLocaleString(undefined, { minimumFractionDigits: 2 }) %>
        </div>
      </section>
    <% }) %>
  <% } %>
</div>

<!-- ✔️ Section เลือกเดือน/ปี -->
<section class="period-control-card" aria-label="เลือกเดือนหรือปีรายงาน">
  <div class="period-control-glow" aria-hidden="true"></div>
  <div class="period-control-glow period-control-glow--right" aria-hidden="true"></div>

  <div class="period-control-head">
    <div class="period-title-wrap">
      <span class="period-icon" aria-hidden="true">📅</span>
      <div class="period-copy">
        <span class="period-kicker">Report Period</span>
        <h2>เลือกเดือน/ปี</h2>
        <p>สลับมุมมองรายเดือนหรือรายปี แล้วเลือกช่วงเวลาที่ต้องการดูรายงานเติมเงิน</p>
      </div>
    </div>

    <div class="period-current">
      <span>กำลังดูข้อมูล</span>
      <strong><%= SELECTED_LABEL || (IS_YEAR_MODE ? `ปี ${SELECTED_YEAR + 543}` : monthStr) %></strong>
    </div>

    <div class="report-mode-tabs" role="tablist" aria-label="เลือกมุมมองรายงาน">
      <button class="btn ghost <%= !IS_YEAR_MODE ? 'active' : '' %>" id="btnModeMonth" type="button">รายเดือน</button>
      <button class="btn ghost <%= IS_YEAR_MODE ? 'active' : '' %>" id="btnModeYear" type="button">รายปี</button>
    </div>
  </div>

  <div class="period-control-body">
    <div class="month-toolbar" role="group" aria-label="เลือกช่วงเวลา">
      <button class="btn ghost" id="btnPrev" type="button" aria-label="ก่อนหน้า">◀︎</button>
      <label class="month-ctrl">
        <input id="monthInput" type="text" value="<%= IS_YEAR_MODE ? SELECTED_YEAR : monthStr %>" readonly aria-label="เลือกช่วงเวลา" />
        <button class="icon-btn" id="btnOpenPicker" type="button" aria-label="เปิดตัวเลือกช่วงเวลา">📅</button>
      </label>
      <button class="btn ghost" id="btnNext" type="button" aria-label="ถัดไป">▶︎</button>
      <button class="btn" id="btnThisMonth" type="button"><%= IS_YEAR_MODE ? 'ปีนี้' : 'เดือนนี้' %></button>
    </div>
  </div>
</section>

<!-- Popup: Month/Year Picker — แยกออกจาก period-control-card เหมือนหน้า reportsummary เพื่อไม่ให้โดน overflow/transform ของ section ตัด -->
<div id="monthPicker" class="mp-popup" hidden aria-hidden="true">
  <div class="mp-backdrop" data-close-month-picker="1"></div>
  <div class="mp-card" role="dialog" aria-modal="true" aria-label="เลือกช่วงเวลา">
    <div class="mp-head">
      <button class="mp-nav" id="mpPrevYear" type="button" aria-label="ปีก่อนหน้า">‹</button>
      <div class="mp-year" id="mpYear">2025</div>
      <button class="mp-nav" id="mpNextYear" type="button" aria-label="ปีถัดไป">›</button>
    </div>
    <div class="mp-grid" id="mpGrid" role="grid" aria-label="รายชื่อเดือนหรือปี">
      <!-- เติมด้วยสคริปต์ -->
    </div>
    <div class="mp-actions">
      <button class="btn ghost" id="mpClear" type="button">ล้าง</button>
      <div class="spacer"></div>
      <button class="btn ghost" id="mpThisMonth" type="button"><%= IS_YEAR_MODE ? 'ปีนี้' : 'เดือนนี้' %></button>
      <button class="btn primary" id="mpOK" type="button">ตกลง</button>
    </div>
  </div>
</div>

<%
// monthStr รูปแบบ 'YYYY-MM'
const [yy, mm] = (monthStr || '').split('-').map(Number);
const MONTHS_TH = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
const headMonthLabel = IS_YEAR_MODE
  ? `ปี ${SELECTED_YEAR + 543}`
  : `${MONTHS_TH[(mm||1)-1]} ${yy + 543}`;
%>

<div class="history-wrapper card soft">
  <div class="title flex-between" style="align-items:center; gap:10px;">
    <h3 style="margin:0;"><%= IS_YEAR_MODE ? `สรุปเติมเงินรายเดือน ${headMonthLabel}` : 'ทุกรายการเติมเงิน' %></h3>
    <% if (IS_YEAR_MODE) { %>
      <span class="metric-badge">รวม <%= (countNoAdmin || 0).toLocaleString('th-TH') %> รายการสำเร็จ</span>
    <% } %>
  </div>

  <% if (IS_YEAR_MODE) { %>
    <% const hasYearRows = YEARLY_ROWS.some(r => Number(r.count || 0) > 0); %>
    <% if (hasYearRows) { %>
      <!-- ===== Yearly Desktop/Table view ===== -->
      <div class="table-wrap desktop-only">
        <table class="history-table yearly-table">
          <thead>
            <tr>
              <th>เดือน</th>
              <th style="text-align:center;">จำนวนรายการเติม</th>
              <th style="text-align:right;">ยอดรวมไม่รวมแอดมิน</th>
              <th style="text-align:left;">ยอดแยกตาม Method</th>
              <th style="text-align:right;">ยอดรวม Completed</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% YEARLY_ROWS.forEach(row => { %>
              <tr class="<%= Number(row.count || 0) <= 0 ? 'is-empty-month' : '' %>">
                <td>
                  <b class="month-name"><%= row.label %></b>
                  <div class="muted"><%= row.month %></div>
                </td>
                <td style="text-align:center;">
                  <span class="metric-badge"><%= Number(row.noAdminCount || 0).toLocaleString('th-TH') %> รายการ</span>
                </td>
                <td class="amount">฿<%= Number(row.noAdminSum || 0).toLocaleString(undefined,{ minimumFractionDigits: 2 }) %></td>
                <td>
                  <% if (Array.isArray(row.methods) && row.methods.length) { %>
                    <div class="method-chip-list">
                      <% row.methods.forEach(m => { %>
                        <span class="method-chip">
                          <b><%= m.label %></b>
                          <em><%= Number(m.count || 0).toLocaleString('th-TH') %> รายการ</em>
                          <strong>฿<%= Number(m.sum || 0).toLocaleString(undefined,{ minimumFractionDigits: 2 }) %></strong>
                        </span>
                      <% }) %>
                    </div>
                  <% } else { %>
                    <span class="muted">ไม่มีรายการสำเร็จ</span>
                  <% } %>
                </td>
                <td class="amount">฿<%= Number(row.sum || 0).toLocaleString(undefined,{ minimumFractionDigits: 2 }) %></td>
                <td style="text-align:right;">
                  <a class="btn small ghost" href="?month=<%= row.month %>&mode=month">ดูรายการ</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- ===== Yearly Mobile/Card accordion ===== -->
      <div class="mobile-only tx-accordion-list" style="margin-top:10px;">
        <% YEARLY_ROWS.forEach(row => { %>
          <div class="tx-accordion" data-open="0">
            <button class="tx-accordion__head" type="button">
              <div class="tx-accordion__title">
                <span class="tx-id"><%= row.label %></span>
              </div>
              <div class="tx-accordion__meta">
                <span class="tx-date"><%= Number(row.noAdminCount || 0).toLocaleString('th-TH') %> รายการ</span>
                <span class="tx-toggle"></span>
              </div>
            </button>
            <div class="tx-accordion__body">
              <div class="tx-row">
                <div class="tx-label">ยอดรวมไม่รวมแอดมิน</div>
                <div class="tx-value"><b>฿<%= Number(row.noAdminSum || 0).toLocaleString(undefined,{minimumFractionDigits:2}) %></b></div>
              </div>
              <div class="tx-row">
                <div class="tx-label">Completed ทั้งหมด</div>
                <div class="tx-value"><b>฿<%= Number(row.sum || 0).toLocaleString(undefined,{minimumFractionDigits:2}) %></b></div>
              </div>
              <div class="tx-row">
                <div class="tx-label">Method</div>
                <div class="tx-value">
                  <% if (Array.isArray(row.methods) && row.methods.length) { %>
                    <div class="method-chip-list">
                      <% row.methods.forEach(m => { %>
                        <span class="method-chip">
                          <b><%= m.label %></b>
                          <em><%= Number(m.count || 0).toLocaleString('th-TH') %> รายการ</em>
                          <strong>฿<%= Number(m.sum || 0).toLocaleString(undefined,{ minimumFractionDigits: 2 }) %></strong>
                        </span>
                      <% }) %>
                    </div>
                  <% } else { %>
                    <span class="muted">ไม่มีรายการสำเร็จ</span>
                  <% } %>
                </div>
              </div>
              <div class="tx-actions">
                <a class="btn small ghost" style="width:100%; text-align:center;" href="?month=<%= row.month %>&mode=month">ดูรายการเดือนนี้</a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-history" role="status" aria-live="polite">
        <img src="/static/assets/emoji/empty.png" alt="" aria-hidden="true">
        <div class="empty-title">ปีนี้ยังไม่มีรายการเติมเงินสำเร็จ</div>
        <div class="empty-sub">เลือกปีอื่น หรือกลับไปดูแบบรายเดือน</div>
      </div>
    <% } %>

  <% } else if (transactions && transactions.length) { %>

  <!-- ===== Desktop/Table view ===== -->
  <div class="table-wrap desktop-only">
    <table class="history-table">
      <thead>
        <tr>
          <th>วันที่ / เวลา</th>
          <th>รหัสรายการ</th>
          <th>ผู้ใช้</th>
          <th style="text-align:left;">วิธีเติม</th>
          <th>ข้อมูลผู้โอน</th>
          <th style="text-align:right;">จำนวนเงิน</th>
          <th style="text-align:center;">สถานะ</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% transactions.forEach(tx => {
             const method = (tx.method||'').toLowerCase();
             const statusLabel =
                (tx.status === "completed" || tx.status === "completed") ? "สำเร็จ" :
                (tx.status === "pending" || tx.status === "pending") ? "รอดำเนินการ" :
                (tx.status === "reject" || tx.status === "rejected") ? "ถูกปฏิเสธ" :
                tx.status === "failed"    ? "ล้มเหลว" : "ยกเลิก";
        %>
        <tr>
          <td class="muted">
            <%= new Date(tx.createdAt).toLocaleString('th-TH', {
              timeZone: 'Asia/Bangkok', year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit', second:'2-digit'
            }) %>
          </td>
          <td title="<%= tx.transactionId || '' %>"><%= tx.transactionId || '—' %></td>
          <td>
            <div class="user-cell">
                <img
                class="avatar-sm"
                src="<%= (tx.userId?.avatarUrl || '/static/assets/img/user-blue.png') %>?v=<%= tx.userId?.avatarVer || 0 %>"
                alt="<%= tx.userId?.username || tx.username || 'user' %>" width="28" height="28" loading="lazy"/>
                <div class="user-meta">
                    <b class="user-name"><%= (tx.userId?.username || tx.username || '-') %></b>
                    <% if (tx.userId?.email) { %>
                    <span class="user-email muted"><%= tx.userId.email %></span>
                    <% } %>
                </div>
            </div>
          </td>
          <td>
            <% const m = (tx.method || '').toLowerCase(); %>
            <%=
              (m === 'tw' || m === 'truewallet') ? 'True Wallet' :
              (m === 'kbank') ? 'กสิกรไทย' :
              (m === 'scb') ? 'ไทยพานิชย์' :
              (m === 'qr') ? 'PromptPay QR' :
              (m === 'admin') ? 'Admin' :
              (m === 'manual') ? 'เติมมือ' :
              (m || '—')
            %>
          </td>
          <td>
            <% if (method === 'truewallet' || method === 'tw') { %>
              <img src="/static/assets/payment/tw.webp" class="bank-logo" />
              <b>TrueWallet</b>
              <div class="muted">เบอร์ผู้โอน: <%= tx.senderNumber || '-' %></div>
            <% } else { %>
              <img src="/static/assets/payment/mobilebanking.png" class="bank-logo" />
              <b><%= BANK_LABELS[tx.senderBank] || 'ไม่ระบุธนาคาร' %></b>
              <div class="muted">เลขท้ายบัญชีผู้โอน: <%= tx.senderLast6 || '-' %></div>
            <% } %>
          </td>
          <td class="amount">฿<%= Number(tx.amount).toLocaleString(undefined,{ minimumFractionDigits: 2 }) %></td>
          <td class="status <%= (tx.status||'').toLowerCase() %>"><%= statusLabel %></td>
          <td>
            <% if ((tx.status||'') === 'pending') { %>
            <button class="btn small success"
              onclick="openManualTopupModal('<%= tx.transactionId %>', <%= tx.amount %>, '<%= (tx.userId?.username || tx.username || '').replace(/'/g, '\\\\' ) %>')">
              เติมให้ผู้ใช้
            </button>
            <button class="btn small danger" onclick="rejectTx('<%= (tx._id || tx.transactionId) %>')">
              ปฏิเสธ
            </button>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- ===== Mobile/Card accordion ===== -->
  <div class="mobile-only tx-accordion-list" style="margin-top:10px;">
    <% transactions.forEach(tx => {
         const method = (tx.method||'').toLowerCase();
         const statusLabel =
           (tx.status === "completed" || tx.status === "completed") ? "สำเร็จ" :
           (tx.status === "pending" || tx.status === "pending") ? "รอดำเนินการ" :
           (tx.status === "reject" || tx.status === "rejected") ? "ถูกปฏิเสธ" :
           tx.status === "failed"    ? "ล้มเหลว" : "ยกเลิก";
    %>
    <div class="tx-accordion" data-open="0">
      <button class="tx-accordion__head" type="button">
        <div class="tx-accordion__title">
          <span class="tx-id" title="<%= tx.transactionId || '' %>"><%= tx.transactionId || '—' %></span>
        </div>
        <div class="tx-accordion__meta">
          <span class="tx-date">
            <%= new Date(tx.createdAt).toLocaleString('th-TH', {
              timeZone: 'Asia/Bangkok', year:'numeric', month:'2-digit', day:'2-digit',
              hour:'2-digit', minute:'2-digit', second:'2-digit'
            }) %>
          </span>
          <span class="tx-toggle"></span>
        </div>
      </button>
      <div class="tx-accordion__body">
        <div class="tx-row">
            <div class="tx-label">ผู้ใช้</div>
            <div class="tx-value">
                <div class="user-cell">
                <img
                    class="avatar-sm"
                    src="<%= (tx.userId?.avatarUrl || '/static/assets/img/user-blue.png') %>?v=<%= tx.userId?.avatarVer || 0 %>"
                    alt="<%= tx.userId?.username || tx.username || 'user' %>" width="28" height="28" loading="lazy"/>
                    <div class="user-meta">
                        <b class="user-name"><%= (tx.userId?.username || tx.username || '-') %></b>
                        <% if (tx.userId?.email) { %>
                        <span class="user-email muted"><%= tx.userId.email %></span>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="tx-row">
          <div class="tx-label">ผู้โอน</div>
          <div class="tx-value">
            <% if (method === 'truewallet' || method === 'tw') { %>
              <img src="/static/assets/payment/tw.webp" class="bank-logo" alt="">
              <b>TrueWallet</b><br>
              <span class="muted">เบอร์ผู้โอน: <%= tx.senderNumber || '-' %></span>
            <% } else { %>
              <img src="/static/assets/payment/mobilebanking.png" class="bank-logo" alt="">
              <b><%= BANK_LABELS[tx.senderBank] || 'ไม่ระบุธนาคาร' %></b><br>
              <span class="muted">เลขท้ายบัญชีผู้โอน: <%= tx.senderLast6 || '-' %></span>
            <% } %>
          </div>
        </div>

        <div class="tx-row">
          <div class="tx-label">วิธีเติม</div>
          <div class="tx-value">
            <% const m = (tx.method || '').toLowerCase(); %>
            <%=
              (m === 'tw' || m === 'truewallet') ? 'True Wallet' :
              (m === 'kbank') ? 'กสิกรไทย' :
              (m === 'scb') ? 'ไทยพานิชย์' :
              (m === 'qr') ? 'PromptPay QR' :
              (m === 'admin') ? 'Admin' :
              (m === 'manual') ? 'เติมมือ' :
              (m || '—')
            %>
          </div>
        </div>

        <div class="tx-row">
          <div class="tx-label">จำนวนเงิน</div>
          <div class="tx-value"><b>฿<%= Number(tx.amount).toLocaleString(undefined,{minimumFractionDigits:2}) %></b></div>
        </div>

        <div class="tx-row">
          <div class="tx-label">สถานะ</div>
          <div class="tx-value">
            <span class="pill pill--<%= (tx.status||'').toLowerCase() %>"><%= statusLabel %></span>
          </div>
        </div>

        <div class="tx-actions">
          <% if ((tx.status||'') === 'pending') { %>
          <button class="btn small success" style="width: 100%;"
            onclick="openManualTopupModal('<%= tx.transactionId %>', <%= tx.amount %>, '<%= (tx.userId?.username || tx.username || '').replace(/'/g, '\\\\') %>')">
            เติมให้ผู้ใช้
          </button>
          <button class="btn small danger" style="width: 100%; margin-top: 8px;"
            onclick="rejectTx('<%= (tx._id || tx.transactionId) %>')">
            ปฏิเสธ
          </button>
          <% } %>
        </div>
      </div>
    </div>
    <% }) %>
  </div>

  <% } else { %>
    <div class="empty-history" role="status" aria-live="polite">
      <img src="/static/assets/emoji/empty.png" alt="" aria-hidden="true">
      <div class="empty-title">ยังไม่มีรายการเติมเงิน</div>
      <div class="empty-sub">เมื่อมีรายการ ระบบจะแสดงที่นี่โดยอัตโนมัติ</div>
    </div>
  <% } %>
</div>

<!-- Manual Topup Modal -->
<div id="manualTopupModal" class="hidden modal">
  <div class="overlay" data-close="1"></div>
  <div class="dialog" role="dialog" aria-modal="true" aria-labelledby="manualTitle">
    <div class="hdr">
      <div class="title" id="manualTitle">เติมเงินให้ผู้ใช้</div>
