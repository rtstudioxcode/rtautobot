<%
const q = query || {};

function esc(v) {
  return String(v ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#039;");
}

function fmtDate(d) {
  if (!d) return "-";
  try {
    return new Date(d).toLocaleString("th-TH", {
      timeZone: "Asia/Bangkok",
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
    });
  } catch {
    return "-";
  }
}

function getGeo(item) {
  return item.geo || item.blockGeo || item.blockedGeo || {};
}

function getCountry(item) {
  const g = getGeo(item);
  return g.country || item.country || "-";
}

function getCountryCode(item) {
  const g = getGeo(item);
  return g.countryCode || item.countryCode || item.country || "";
}

function getCity(item) {
  const g = getGeo(item);
  return g.city || item.city || "-";
}

function getRegion(item) {
  const g = getGeo(item);
  return g.regionName || g.region || "";
}

function getIsp(item) {
  const g = getGeo(item);
  return g.isp || g.org || g.as || "-";
}

function getGeoStatus(item) {
  const g = getGeo(item);
  return g.status || item.geoStatus || "-";
}

function hasMap(item) {
  const g = getGeo(item);
  return Number.isFinite(Number(g.lat)) && Number.isFinite(Number(g.lon));
}

function mapUrl(item) {
  const g = getGeo(item);
  if (!hasMap(item)) return "#";
  return `https://www.google.com/maps?q=${encodeURIComponent(`${g.lat},${g.lon}`)}`;
}

/**
 * รองรับหลายรูปแบบ:
 * 1) item.blockedIp
 * 2) item.block
 * 3) item.ban
 * 4) fields ตรงใน log item
 */
function getBlock(item) {
  return (
    item.blockedIp ||
    item.block ||
    item.ban ||
    item.blockInfo ||
    item.ipBlock ||
    null
  );
}

function getBlockStatus(item) {
  const block = getBlock(item);

  return String(
    block?.status ||
    item.blockStatus ||
    item.ipBlockStatus ||
    item.banStatus ||
    ""
  ).toLowerCase();
}

function getBlockedUntil(item) {
  const block = getBlock(item);

  return (
    block?.expiresAt ||
    block?.blockedUntil ||
    block?.expireAt ||
    item.blockExpiresAt ||
    item.ipBlockedUntil ||
    item.expiresAt ||
    item.blockedUntil ||
    null
  );
}

function getBlockedAt(item) {
  const block = getBlock(item);

  return (
    block?.bannedAt ||
    block?.blockedAt ||
    block?.createdAt ||
    item.blockedAt ||
    item.bannedAt ||
    item.ipBlockedAt ||
    null
  );
}

function getBlockReason(item) {
  const block = getBlock(item);

  return (
    block?.reason ||
    block?.blockReason ||
    item.reason ||
    item.blockReason ||
    ""
  );
}

function getBlockRule(item) {
  const block = getBlock(item);

  return (
    block?.rule ||
    item.rule ||
    "-"
  );
}

function getReleasedAt(item) {
  const block = getBlock(item);

  return (
    block?.releasedAt ||
    block?.unblockedAt ||
    item.releasedAt ||
    item.unblockedAt ||
    item.manualUnblockedAt ||
    null
  );
}

function isExpiredBlock(item) {
  const until = getBlockedUntil(item);
  if (!until) return false;

  const t = new Date(until).getTime();
  return Number.isFinite(t) && t <= Date.now();
}

function isBlocked(item) {
  const block = getBlock(item);
  const status = getBlockStatus(item);

  if (["active", "blocked", "banned"].includes(status)) {
    const until = getBlockedUntil(item);

    if (!until) return true;

    const t = new Date(until).getTime();
    return Number.isFinite(t) && t > Date.now();
  }

  if (item.isBlocked === true) return true;
  if (item.blocked === true) return true;
  if (block?.isBlocked === true) return true;
  if (block?.blocked === true) return true;

  const until = getBlockedUntil(item);
  if (until) {
    const t = new Date(until).getTime();
    return Number.isFinite(t) && t > Date.now();
  }

  return false;
}

function blockTypeText(item) {
  const status = getBlockStatus(item);
  const releasedAt = getReleasedAt(item);
  const until = getBlockedUntil(item);

  if (releasedAt || status === "released" || status === "unblocked") {
    return "ปลดแบนแล้ว";
  }

  if (isExpiredBlock(item)) {
    return "หมดอายุแล้ว";
  }

  if (isBlocked(item)) {
    if (until) return "กำลังแบน";
    return "แบนแล้ว";
  }

  return "เก็บ Log";
}

function blockClass(item) {
  const status = getBlockStatus(item);

  if (status === "released" || status === "unblocked" || getReleasedAt(item)) {
    return "neutral";
  }

  if (isExpiredBlock(item)) return "warn";
  if (isBlocked(item)) return "danger";

  return "ok";
}

function remainText(item) {
  const until = getBlockedUntil(item);
  if (!until) return "";

  const ms = new Date(until).getTime() - Date.now();
  if (!Number.isFinite(ms)) return "";

  if (ms <= 0) return "หมดเวลาแล้ว";

  const min = Math.ceil(ms / 60000);

  if (min < 60) return `เหลือ ${min} นาที`;

  const hr = Math.floor(min / 60);
  const mm = min % 60;

  if (hr < 24) return `เหลือ ${hr} ชม. ${mm} นาที`;

  const day = Math.floor(hr / 24);
  const hh = hr % 24;

  return `เหลือ ${day} วัน ${hh} ชม.`;
}

function makeQuery(extra = {}) {
  const params = new URLSearchParams();

  const data = {
    ip: q.ip || "",
    path: q.path || "",
    country: q.country || "",
    city: q.city || "",
    rule: q.rule || "",
    geoStatus: q.geoStatus || "",
    limit,
    page,
    ...extra,
  };

  for (const [k, v] of Object.entries(data)) {
    if (v !== undefined && v !== null && String(v) !== "") {
      params.set(k, String(v));
    }
  }

  return params.toString();
}
%>


<%
  const activeBlockedCount = (items || []).filter(item => isBlocked(item)).length;
  const releasedCount = (items || []).filter(item => blockClass(item) === "released").length;
  const logOnlyCount = Math.max(0, Number(total || 0) - activeBlockedCount - releasedCount);
%>

<div class="security-shell bot-block-page">
  <section class="hero-card">
    <div class="hero-glow"></div>

    <div class="hero-main">
      <div class="hero-kicker">
        <span class="pulse-dot"></span>
        Security Center
      </div>

      <h1>Bot Block Logs</h1>
      <p>
        ระบบตรวจจับ Request แปลก ๆ เช่น <code>/.env</code>, <code>phpinfo.php</code>, scanner และ bot probe
        พร้อมสถานะแบน IP, Geo IP
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="/admin/security/bot-blocks?<%= makeQuery({ format: 'json' }) %>" target="_blank" rel="noopener">
          ดูข้อมูล JSON
        </a>
        <a class="btn btn-ghost" href="/admin/security/bot-blocks">
          รีเฟรช
        </a>
      </div>
    </div>

    <div class="metric-grid">
      <article class="metric-card">
        <span class="metric-label">รายการ Logs</span>
        <strong><%= Number(total || 0).toLocaleString("th-TH") %></strong>
        <small>รายการ Logs ทั้งหมด</small>
      </article>

      <article class="metric-card hot">
        <span class="metric-label">Hit ทั้งหมด</span>
        <strong><%= Number(totalHits || 0).toLocaleString("th-TH") %></strong>
        <small>
          Logs: <%= Number(logHits || 0).toLocaleString("th-TH") %>
          +
          Blocked IP: <%= Number(blockedHits || 0).toLocaleString("th-TH") %>
        </small>
      </article>

      <article class="metric-card danger">
        <span class="metric-label">แบนแล้ว</span>
        <strong><%= Number(activeBlockedTotal || 0).toLocaleString("th-TH") %></strong>
        <small>IP ที่โดนแบนทั้งหมด</small>
      </article>

      <article class="metric-card quiet">
        <span class="metric-label">Blocked IP ทั้งหมด</span>
        <strong><%= Number(blockedIpTotal || 0).toLocaleString("th-TH") %></strong>
        <small>
          โดนแบน <%= Number(activeBlockedTotal || 0).toLocaleString("th-TH") %>
          /
          ยังไม่โดนแบน <%= Number(releasedBlockedTotal || 0).toLocaleString("th-TH") %>
        </small>
      </article>
    </div>
  </section>

  <section class="filter-panel">
    <div class="panel-head">
      <div>
        <h2>ค้นหาและกรองข้อมูล</h2>
        <p>เลือก IP, Path, ประเทศ, เมือง หรือ Rule</p>
      </div>
      <span class="panel-chip">Page <%= page %> / <%= totalPages %></span>
    </div>

    <form method="GET" action="/admin/security/bot-blocks" class="filter-form">
      <div class="filter-grid">
        <label class="field">
          <span>IP Address</span>
          <input name="ip" value="<%= esc(q.ip) %>" placeholder="เช่น 1.2.3.4" autocomplete="off">
        </label>

        <label class="field field-wide">
          <span>Path / URI</span>
          <input name="path" value="<%= esc(q.path) %>" placeholder=".env, phpinfo.php, backup.zip" autocomplete="off">
        </label>

        <label class="field">
          <span>ประเทศ</span>
          <input name="country" value="<%= esc(q.country) %>" placeholder="TH, Thailand, Singapore" autocomplete="off">
        </label>

        <label class="field">
          <span>เมือง</span>
          <input name="city" value="<%= esc(q.city) %>" placeholder="Bangkok, Singapore" autocomplete="off">
        </label>

        <label class="field">
          <span>Rule</span>
          <select name="rule">
            <option value="">ทั้งหมด</option>
            <% (rules || []).forEach(r => { %>
              <option value="<%= esc(r) %>" <%= q.rule === r ? "selected" : "" %>><%= r %></option>
            <% }) %>
          </select>
        </label>

        <label class="field">
          <span>Geo Status</span>
          <select name="geoStatus">
            <option value="">ทั้งหมด</option>
            <% (geoStatuses || []).forEach(s => { %>
              <option value="<%= esc(s) %>" <%= q.geoStatus === s ? "selected" : "" %>><%= s %></option>
            <% }) %>
          </select>
        </label>

        <label class="field">
          <span>Limit</span>
          <select name="limit">
            <% [10, 25, 50, 100].forEach(n => { %>
              <option value="<%= n %>" <%= Number(limit) === n ? "selected" : "" %>><%= n %></option>
            <% }) %>
          </select>
        </label>
      </div>

      <div class="filter-actions">
        <button class="btn btn-primary" type="submit">ค้นหา</button>
        <a class="btn btn-ghost" href="/admin/security/bot-blocks">ล้างตัวกรอง</a>
        <a class="btn btn-soft" href="/admin/security/bot-blocks?<%= makeQuery({ format: 'json' }) %>" target="_blank" rel="noopener">เปิด JSON</a>
      </div>
    </form>
  </section>

  <section class="data-panel">
    <div class="panel-head table-head">
      <div>
        <h2>รายการที่ถูกระบบตรวจจับ</h2>
        <p>แสดงสถานะ BotBlock</p>
      </div>
      <div class="legend">
        <span><i class="dot danger"></i> แบนแล้ว</span>
        <span><i class="dot success"></i> เก็บ Log</span>
        <span><i class="dot muted"></i> ปลดแล้ว/หมดอายุ</span>
      </div>
    </div>

    <div class="table-scroll">
      <table class="security-table">
        <colgroup>
          <col class="col-time">
          <col class="col-ip">
          <col class="col-geo">
          <col class="col-status">
          <col class="col-request">
          <col class="col-rule">
          <col class="col-ua">
          <col class="col-action">
        </colgroup>
        <thead>
          <tr>
            <th>เวลาล่าสุด</th>
            <th>IP / Network</th>
            <th>สถานที่</th>
            <th>สถานะแบน</th>
            <th>Request</th>
            <th>Rule</th>
            <th>User-Agent</th>
            <th class="right">จัดการ</th>
          </tr>
        </thead>

        <tbody>
          <% if (!items || !items.length) { %>
            <tr>
              <td colspan="8">
                <div class="empty-state">
                  <div class="empty-icon">🛡️</div>
                  <h3>ยังไม่มีรายการ Bot Block</h3>
                  <p>ระบบยังไม่เจอ Request แปลก ๆ ในตัวกรองนี้ ถือว่าเว็บยังเงียบ หรือบอทกำลังพักกินกาแฟ</p>
                </div>
              </td>
            </tr>
          <% } %>

          <% (items || []).forEach(item => {
            const g = getGeo(item);
            const countryCode = getCountryCode(item);
            const blockedNow = isBlocked(item);
            const bClass = blockClass(item);
            const bText = blockTypeText(item);
            const remain = remainText(item);
            const blockedUntil = getBlockedUntil(item);
            const blockedAt = getBlockedAt(item);
            const releasedAt = getReleasedAt(item);
            const reason = getBlockReason(item);
            const ruleName = getBlockRule(item);
            const hitCount = Number(item.combinedHitCount || item.count || 1);
            const logHitCount = Number(item.logHitCount || item.count || 1);
            const ipBlockedHits = Number(item.ipBlockedHits || 0);
            const requestUrl = item.originalUrl || item.path || "-";
            const uaRaw = String(item.userAgent || item.sampleUserAgent || "").replace(/\s+/g, " ").trim();
            const uaText = uaRaw || "-";
            const uaShort = uaText.length > 78 ? uaText.slice(0, 78) + "…" : uaText;
            const uaLower = uaText.toLowerCase();
            const uaType = /postman|curl|wget|python|go-http|httpclient|axios|scrapy|spider|crawler|bot|scanner/.test(uaLower)
              ? "Tool / Bot"
              : /android|iphone|ipad|mobile/.test(uaLower)
                ? "Mobile"
                : /chrome|firefox|safari|edg|edge|opera/.test(uaLower)
                  ? "Browser"
                  : "Unknown";
            const uaTone = uaType === "Tool / Bot" ? "danger" : uaType === "Browser" || uaType === "Mobile" ? "success" : "muted";
          %>
            <tr class="<%= blockedNow ? 'row-danger' : '' %>" data-id="<%= item._id %>">
              <td class="time-cell">
                <strong><%= fmtDate(item.lastSeenAt || item.createdAt) %></strong>
                <small>เริ่ม: <%= fmtDate(item.firstSeenAt || item.createdAt) %></small>
                <span class="hit-pill" title="Log <%= logHitCount.toLocaleString('th-TH') %> + Blocked IP <%= ipBlockedHits.toLocaleString('th-TH') %>">
                  <%= hitCount.toLocaleString("th-TH") %> ครั้ง
                </span>
              </td>

              <td class="ip-cell">
                <div class="ip-main">
                  <code><%= item.ip || "-" %></code>
                  <% if (blockedNow) { %>
                    <span class="mini-dot danger"></span>
                  <% } %>
                </div>

                <% if (item.cfRay) { %>
                  <small>CF-Ray: <%= esc(item.cfRay) %></small>
                <% } %>

                <% if (g.isp || g.org || g.as) { %>
                  <small><%= esc(g.isp || g.org || g.as) %></small>
                <% } %>
              </td>

              <td class="geo-cell">
                <span class="geo-status <%= getGeoStatus(item) === 'success' ? 'success' : 'warning' %>">
                  <%= esc(getGeoStatus(item)) %>
                </span>

                <strong>🌎 <%= esc(getCity(item)) %><%= getRegion(item) ? ", " + esc(getRegion(item)) : "" %>, <%= esc(getCountry(item)) %></strong>

                <div class="tag-row">
                  <% if (countryCode) { %><span><%= esc(countryCode) %></span><% } %>
                  <% if (g.timezone) { %><span><%= esc(g.timezone) %></span><% } %>
                </div>

                <% if (hasMap(item)) { %>
                  <a class="map-link" href="<%= mapUrl(item) %>" target="_blank" rel="noopener noreferrer">เปิด Google Maps</a>
                <% } %>
              </td>

              <td class="block-cell">
                <span class="status-pill <%= bClass %>"><%= bText %></span>

                <% if (blockedAt) { %>
                  <small>เริ่มแบน: <%= fmtDate(blockedAt) %></small>
                <% } %>

                <% if (blockedUntil) { %>
                  <small>หมดอายุ: <%= fmtDate(blockedUntil) %></small>
                  <small><%= remain %></small>
                <% } %>

                <% if (reason) { %>
                  <small>เหตุผล: <%= esc(reason) %></small>
                <% } %>

                <% if (releasedAt) { %>
                  <small>ปลดแบน: <%= fmtDate(releasedAt) %></small>
                <% } %>
              </td>

              <td class="request-cell">
                <div>
                  <span class="method-pill"><%= esc(item.method || "-") %></span>
                  <strong><%= esc(requestUrl) %></strong>
                </div>

                <% if (item.host) { %>
                  <small>Host: <%= esc(item.host) %></small>
                <% } %>

                <% if (item.decodedPath && item.decodedPath !== item.path) { %>
                  <small>Decoded: <%= esc(item.decodedPath) %></small>
                <% } %>
              </td>

              <td>
                <span class="rule-pill"><%= esc(ruleName) %></span>
              </td>

              <td class="ua-cell">
                <div class="ua-card">
                  <div class="ua-top">
                    <span class="ua-badge <%= uaTone %>"><%= esc(uaType) %></span>
                    <button
                      type="button"
                      class="mini-copy"
                      data-action="copy-ua"
                      data-ua="<%= esc(uaText) %>"
                      aria-label="คัดลอก User-Agent"
                    >คัดลอก</button>
                  </div>

                  <details class="ua-details">
                    <summary title="<%= esc(uaText) %>"><%= esc(uaShort) %></summary>
                  </details>

                  <% if (item.referer) { %>
                    <div class="ref-box" title="<%= esc(item.referer) %>">
                      <span>Ref</span>
                      <em><%= esc(item.referer) %></em>
                    </div>
                  <% } %>
                </div>
              </td>

              <td class="action-cell right">
                <div class="action-stack">
                  <% if (blockedNow) { %>
                    <button type="button" class="icon-btn danger" data-action="release-ip" data-ip="<%= esc(item.ip) %>">
                      ปลดแบน IP
                    </button>
                  <% } else { %>
                    <span class="state-note">ไม่อยู่ในสถานะแบน</span>
                  <% } %>

                  <button type="button" class="icon-btn" data-action="copy-ip" data-ip="<%= esc(item.ip) %>">
                    คัดลอก IP
                  </button>

                  <button type="button" class="icon-btn" data-action="copy-url" data-url="<%= esc(item.originalUrl || item.path || '') %>">
                    คัดลอก URL
                  </button>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="mobile-log-list" aria-label="Mobile BotBlock list">
      <% if (!items || !items.length) { %>
        <div class="mobile-empty">
          <div class="empty-icon">🛡️</div>
          <h3>ยังไม่มีรายการ Bot Block</h3>
          <p>ระบบยังไม่เจอ Request แปลก ๆ ในตัวกรองนี้</p>
        </div>
      <% } %>

      <% (items || []).forEach(item => {
        const g = getGeo(item);
        const countryCode = getCountryCode(item);
        const blockedNow = isBlocked(item);
        const bClass = blockClass(item);
        const bText = blockTypeText(item);
        const remain = remainText(item);
        const blockedUntil = getBlockedUntil(item);
        const blockedAt = getBlockedAt(item);
        const releasedAt = getReleasedAt(item);
        const reason = getBlockReason(item);
        const ruleName = getBlockRule(item);
        const hitCount = Number(item.combinedHitCount || item.count || 1);
        const logHitCount = Number(item.logHitCount || item.count || 1);
        const ipBlockedHits = Number(item.ipBlockedHits || 0);
        const requestUrl = item.originalUrl || item.path || "-";
        const uaRaw = String(item.userAgent || item.sampleUserAgent || "").replace(/\s+/g, " ").trim();
        const uaText = uaRaw || "-";
        const uaShort = uaText.length > 110 ? uaText.slice(0, 110) + "…" : uaText;
        const uaLower = uaText.toLowerCase();
        const uaType = /postman|curl|wget|python|go-http|httpclient|axios|scrapy|spider|crawler|bot|scanner/.test(uaLower)
          ? "Tool / Bot"
          : /android|iphone|ipad|mobile/.test(uaLower)
            ? "Mobile"
            : /chrome|firefox|safari|edg|edge|opera/.test(uaLower)
              ? "Browser"
              : "Unknown";
        const uaTone = uaType === "Tool / Bot" ? "danger" : uaType === "Browser" || uaType === "Mobile" ? "success" : "muted";
      %>
        <article class="mobile-log-card <%= blockedNow ? 'is-blocked' : '' %>" data-id="<%= item._id %>">
          <div class="mobile-card-top">
            <div class="mobile-ip-wrap">
              <span class="mobile-label">IP / Network</span>
              <div class="mobile-ip-line">
                <code><%= item.ip || "-" %></code>
                <% if (blockedNow) { %><span class="mini-dot danger"></span><% } %>
              </div>
              <% if (item.cfRay) { %><small>CF-Ray: <%= esc(item.cfRay) %></small><% } %>
            </div>
            <span class="status-pill <%= bClass %>"><%= bText %></span>
          </div>

          <div class="mobile-meta-grid">
            <div class="mobile-meta-box">
              <span>เวลาล่าสุด</span>
              <strong><%= fmtDate(item.lastSeenAt || item.createdAt) %></strong>
              <em>เริ่ม: <%= fmtDate(item.firstSeenAt || item.createdAt) %></em>
            </div>
            <div class="mobile-meta-box">
              <span>จำนวนครั้ง</span>
              <strong><%= hitCount.toLocaleString("th-TH") %> ครั้ง</strong>
              <em>Log <%= logHitCount.toLocaleString("th-TH") %> + Blocked IP <%= ipBlockedHits.toLocaleString("th-TH") %></em>
              <em><%= esc(ruleName) %></em>
            </div>
          </div>

          <div class="mobile-section compact">
            <div class="mobile-section-title">Request</div>
            <div class="mobile-request-line">
              <span class="method-pill"><%= esc(item.method || "-") %></span>
              <strong><%= esc(requestUrl) %></strong>
            </div>
            <% if (item.host) { %><small>Host: <%= esc(item.host) %></small><% } %>
            <% if (item.decodedPath && item.decodedPath !== item.path) { %><small>Decoded: <%= esc(item.decodedPath) %></small><% } %>
          </div>

          <div class="mobile-section">
            <div class="mobile-section-title">สถานที่</div>
            <div class="mobile-geo-head">
              <span class="geo-status <%= getGeoStatus(item) === 'success' ? 'success' : 'warning' %>"><%= esc(getGeoStatus(item)) %></span>
              <strong>🌎 <%= esc(getCity(item)) %><%= getRegion(item) ? ", " + esc(getRegion(item)) : "" %>, <%= esc(getCountry(item)) %></strong>
            </div>
            <div class="tag-row">
              <% if (countryCode) { %><span><%= esc(countryCode) %></span><% } %>
              <% if (g.timezone) { %><span><%= esc(g.timezone) %></span><% } %>
            </div>
            <% if (g.isp || g.org || g.as) { %><small><%= esc(g.isp || g.org || g.as) %></small><% } %>
            <% if (hasMap(item)) { %><a class="map-link" href="<%= mapUrl(item) %>" target="_blank" rel="noopener noreferrer">เปิด Google Maps</a><% } %>
          </div>

          <div class="mobile-section">
            <div class="mobile-section-title">User-Agent</div>
            <div class="ua-card mobile-ua-card">
              <div class="ua-top">
                <span class="ua-badge <%= uaTone %>"><%= esc(uaType) %></span>
                <button type="button" class="mini-copy" data-action="copy-ua" data-ua="<%= esc(uaText) %>" aria-label="คัดลอก User-Agent">คัดลอก</button>
              </div>
              <details class="ua-details">
                <summary title="<%= esc(uaText) %>"><%= esc(uaShort) %></summary>
              </details>
              <% if (item.referer) { %>
                <div class="ref-box" title="<%= esc(item.referer) %>">
                  <span>Ref</span>
                  <em><%= esc(item.referer) %></em>
                </div>
              <% } %>
            </div>
          </div>

          <% if (blockedAt || blockedUntil || reason || releasedAt) { %>
            <div class="mobile-section mobile-status-notes">
              <div class="mobile-section-title">รายละเอียดสถานะ</div>
              <% if (blockedAt) { %><small>เริ่มแบน: <%= fmtDate(blockedAt) %></small><% } %>
              <% if (blockedUntil) { %><small>หมดอายุ: <%= fmtDate(blockedUntil) %> • <%= remain %></small><% } %>
              <% if (reason) { %><small>เหตุผล: <%= esc(reason) %></small><% } %>
              <% if (releasedAt) { %><small>ปลดแบน: <%= fmtDate(releasedAt) %></small><% } %>
            </div>
          <% } %>

          <div class="mobile-actions">
            <% if (blockedNow) { %>
              <button type="button" class="icon-btn danger" data-action="release-ip" data-ip="<%= esc(item.ip) %>">ปลดแบน IP</button>
            <% } else { %>
              <span class="state-note">ไม่อยู่ในสถานะแบน</span>
            <% } %>
            <button type="button" class="icon-btn" data-action="copy-ip" data-ip="<%= esc(item.ip) %>">คัดลอก IP</button>
            <button type="button" class="icon-btn" data-action="copy-url" data-url="<%= esc(item.originalUrl || item.path || '') %>">คัดลอก URL</button>
          </div>
        </article>
      <% }) %>
    </div>

  </section>

  <nav class="pager">
    <% if (page > 1) { %>
