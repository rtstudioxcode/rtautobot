    <% } else { %>
      <span></span>
    <% } %>

    <strong>หน้า <%= page %> / <%= totalPages %></strong>

    <% if (page < totalPages) { %>
      <a class="btn btn-ghost" href="/admin/security/bot-blocks?<%= makeQuery({ page: page + 1 }) %>">ถัดไป →</a>
    <% } else { %>
      <span></span>
    <% } %>
  </nav>
</div>

<script>
(() => {
  const toast = (message, type = "ok", title = "") => {
    const variantMap = {
      ok: "success",
      success: "success",
      warn: "warning",
      warning: "warning",
      err: "error",
      error: "error",
      danger: "error",
      info: "info",
    };

    const variant = variantMap[type] || "info";
    const fallbackTitle = {
      success: "สำเร็จ",
      warning: "แจ้งเตือน",
      error: "ไม่สำเร็จ",
      info: "แจ้งเตือน",
    }[variant];

    if (typeof window.showMsg === "function") {
      window.showMsg({
        variant,
        title: title || fallbackTitle,
        text: message,
      });
      return;
    }

    if (window.notify && typeof window.notify[variant] === "function") {
      window.notify[variant](title || fallbackTitle, message);
      return;
    }

    alert(message);
  };

  const uiConfirm = async ({
    title = "ยืนยันการทำรายการ",
    text = "",
    okText = "ยืนยัน",
    cancelText = "ยกเลิก",
    variant = "danger",
  } = {}) => {
    if (typeof window.uiConfirm === "function") {
      return await window.uiConfirm({
        variant,
        title,
        sub: text,
        okText,
        cancelText,
        focus: "cancel",
      });
    }

    if (typeof window.confirm === "function") {
      return window.confirm(text || title);
    }

    return false;
  };

  const copyText = async (text, label) => {
    const value = String(text || "").trim();
    if (!value) return toast("ไม่มีข้อมูลให้คัดลอก", "warn");

    try {
      await navigator.clipboard.writeText(value);
      toast(`คัดลอก${label}แล้ว`);
    } catch (err) {
      const tmp = document.createElement("textarea");
      tmp.value = value;
      tmp.style.position = "fixed";
      tmp.style.opacity = "0";
      document.body.appendChild(tmp);
      tmp.select();
      document.execCommand("copy");
      tmp.remove();
      toast(`คัดลอก${label}แล้ว`);
    }
  };

  const releaseIp = async (ip, btn) => {
    const cleanIp = String(ip || "").trim();
    if (!cleanIp) return toast("ไม่พบ IP", "warn");

    const confirmed = await uiConfirm({
      variant: "danger",
      title: "ปลดแบน IP",
      text: `ต้องการปลดแบน IP ${cleanIp} ใช่ไหม?`,
      okText: "ปลดแบน IP",
      cancelText: "ยกเลิก",
    });

    if (!confirmed) return;

    const oldText = btn?.textContent || "ปลดแบน IP";

    if (btn) {
      btn.disabled = true;
      btn.textContent = "กำลังปลด...";
    }

    try {
      const res = await fetch("/admin/security/bot-blocks/release-ip", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json",
        },
        body: JSON.stringify({ ip: cleanIp }),
      });

      const data = await res.json().catch(() => ({}));

      if (!res.ok || !data.ok) {
        throw new Error(data.message || "ปลดแบนไม่สำเร็จ");
      }

      toast(`ปลดแบน ${cleanIp} แล้ว`, "success", "ปลดแบนสำเร็จ");

      setTimeout(() => {
        window.location.reload();
      }, 650);
    } catch (err) {
      if (btn) {
        btn.disabled = false;
        btn.textContent = oldText;
      }

      toast(err.message || "เกิดข้อผิดพลาด", "error", "ปลดแบนไม่สำเร็จ");
    }
  };

  document.addEventListener("click", (ev) => {
    const btn = ev.target.closest("[data-action]");
    if (!btn) return;

    const action = btn.dataset.action;

    if (action === "copy-ip") {
      copyText(btn.dataset.ip, " IP");
      return;
    }

    if (action === "copy-url") {
      copyText(btn.dataset.url, " URL");
      return;
    }

    if (action === "copy-ua") {
      copyText(btn.dataset.ua, " User-Agent");
      return;
    }

    if (action === "release-ip") {
      releaseIp(btn.dataset.ip, btn);
    }
  });
})();
</script>


