<%
const __secret = String(typeof secret !== 'undefined' ? secret : '');
const pageTitleText = 'เครื่องมือ 2FA';
%>

<style>
/* ======================================================
   RTSMM-TH / OTP24 Apps — 2FA Enterprise High-end Page
   Scoped only: .twofa-pro
====================================================== */
.twofa-pro{
  --tf-gold:#f7c95f;
  --tf-gold-2:#d79a32;
  --tf-gold-3:#8f6220;
  --tf-ink:var(--text,#f8f1df);
  --tf-muted:var(--muted,#b9ad9a);
  --tf-page:var(--page,#070707);
  --tf-card:color-mix(in srgb,var(--card,#15120d) 82%,transparent);
  --tf-line:color-mix(in srgb,var(--border,rgba(247,201,95,.22)) 65%,rgba(247,201,95,.28));
  --tf-soft:rgba(247,201,95,.12);
  --tf-danger:#ff6b5f;
  --tf-success:#27d783;
  color:var(--tf-ink);
  position:relative;
  isolation:isolate;
  padding-bottom:clamp(44px,6vw,86px);
}
.twofa-pro::before{
  content:"";
  position:fixed;
  inset:0;
  pointer-events:none;
  z-index:-1;
  background:
    radial-gradient(circle at 14% 22%,rgba(247,201,95,.18),transparent 34%),
    radial-gradient(circle at 86% 16%,rgba(215,154,50,.13),transparent 32%),
    radial-gradient(circle at 58% 86%,rgba(247,98,40,.08),transparent 36%);
  filter:saturate(1.05);
}
.twofa-shell{width:min(1180px,calc(100% - 28px));margin:0 auto;}
.twofa-breadcrumb{
  display:flex;align-items:center;gap:10px;flex-wrap:wrap;
  margin:4px 0 18px;font-size:13px;font-weight:850;color:var(--tf-muted);
}
.twofa-breadcrumb a{color:color-mix(in srgb,var(--tf-ink) 86%,var(--tf-gold));text-decoration:none;transition:.18s ease;}
.twofa-breadcrumb a:hover{color:var(--tf-gold);}
.twofa-hero{
  position:relative;overflow:hidden;border:1px solid var(--tf-line);border-radius:30px;
  background:
    linear-gradient(135deg,rgba(247,201,95,.12),transparent 34%),
    linear-gradient(145deg,color-mix(in srgb,var(--tf-card) 92%,#000),rgba(10,9,8,.86));
  box-shadow:0 34px 100px rgba(0,0,0,.48),0 0 42px rgba(247,201,95,.10);
  padding:clamp(22px,4vw,42px);
}
.twofa-hero::before,.twofa-hero::after{content:"";position:absolute;border-radius:999px;pointer-events:none;}
.twofa-hero::before{right:-120px;top:-150px;width:420px;height:420px;background:radial-gradient(circle,rgba(247,201,95,.25),transparent 63%);filter:blur(10px);}
.twofa-hero::after{left:-170px;bottom:-190px;width:430px;height:430px;background:radial-gradient(circle,rgba(215,154,50,.14),transparent 66%);filter:blur(12px);}
.twofa-hero-inner{position:relative;z-index:1;display:grid;grid-template-columns:minmax(0,1.05fr) minmax(320px,.95fr);gap:clamp(22px,4vw,44px);align-items:center;}
.twofa-kicker{
  width:max-content;max-width:100%;display:inline-flex;align-items:center;gap:9px;
  border:1px solid color-mix(in srgb,var(--tf-gold) 44%,transparent);
  border-radius:999px;padding:9px 14px;margin-bottom:18px;
  color:var(--tf-gold);font-size:12px;font-weight:950;letter-spacing:.08em;text-transform:uppercase;
  background:linear-gradient(135deg,rgba(247,201,95,.13),rgba(255,255,255,.03));
  box-shadow:inset 0 1px 0 rgba(255,255,255,.08);
}
.twofa-title{margin:0;font-size:clamp(38px,6vw,76px);line-height:.94;font-weight:1000;letter-spacing:-.055em;color:var(--tf-ink);}
.twofa-title span{display:block;background:linear-gradient(135deg,#fff,var(--tf-gold) 48%,#fff0c1);-webkit-background-clip:text;background-clip:text;color:transparent;text-shadow:none;}
.twofa-sub{margin:18px 0 0;max-width:720px;color:var(--tf-muted);font-size:clamp(14px,1.7vw,17px);line-height:1.8;font-weight:650;}
.twofa-stats{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:26px;}
.twofa-stat{border:1px solid rgba(247,201,95,.18);border-radius:20px;padding:15px;background:rgba(255,255,255,.035);box-shadow:inset 0 1px 0 rgba(255,255,255,.06);}
.twofa-stat strong{display:block;color:var(--tf-ink);font-size:20px;font-weight:1000;line-height:1.1;}
.twofa-stat span{display:block;margin-top:6px;color:var(--tf-muted);font-size:12px;font-weight:800;}
.twofa-orb-card{
  position:relative;min-height:340px;border:1px solid rgba(247,201,95,.24);border-radius:28px;
  background:linear-gradient(155deg,rgba(247,201,95,.13),rgba(255,255,255,.03) 34%,rgba(0,0,0,.25));
  box-shadow:0 22px 70px rgba(0,0,0,.34),inset 0 1px 0 rgba(255,255,255,.07);
  overflow:hidden;display:grid;place-items:center;padding:24px;
}
.twofa-orb-card::before{content:"";position:absolute;inset:18px;border-radius:24px;border:1px solid rgba(247,201,95,.12);}
.twofa-orb{
  width:min(230px,58vw);aspect-ratio:1;border-radius:50%;position:relative;display:grid;place-items:center;
  background:
    radial-gradient(circle at 35% 30%,#fff7c9,rgba(247,201,95,.9) 20%,rgba(176,111,21,.58) 50%,rgba(0,0,0,.18) 72%),
    conic-gradient(from 45deg,rgba(247,201,95,.2),transparent,rgba(247,201,95,.34),transparent);
  box-shadow:0 0 54px rgba(247,201,95,.22), inset 0 0 42px rgba(0,0,0,.32);
}
.twofa-orb::after{content:"2FA";font-size:clamp(42px,6vw,66px);font-weight:1000;letter-spacing:-.06em;color:#1d1408;text-shadow:0 1px 0 rgba(255,255,255,.34);}
.twofa-orb-ring{position:absolute;inset:-18px;border-radius:50%;border:1px dashed rgba(247,201,95,.45);animation:tfSpin 16s linear infinite;}
@keyframes tfSpin{to{transform:rotate(360deg)}}
.twofa-panel{
  margin-top:20px;display:grid;grid-template-columns:minmax(0,.92fr) minmax(320px,.55fr);gap:18px;align-items:start;
}
.twofa-form,.twofa-result,.twofa-help{
  border:1px solid var(--tf-line);border-radius:28px;background:linear-gradient(145deg,rgba(255,255,255,.055),rgba(0,0,0,.16));
  box-shadow:0 26px 80px rgba(0,0,0,.32),inset 0 1px 0 rgba(255,255,255,.055);overflow:hidden;
}
.twofa-form{padding:clamp(18px,3vw,28px);}
.twofa-section-head{display:flex;align-items:flex-start;justify-content:space-between;gap:18px;margin-bottom:18px;}
.twofa-section-head h2{margin:0;color:var(--tf-ink);font-size:clamp(22px,3vw,32px);font-weight:1000;letter-spacing:-.03em;}
.twofa-section-head p{margin:8px 0 0;color:var(--tf-muted);font-size:13px;line-height:1.65;font-weight:650;}
.twofa-chip{flex:0 0 auto;display:inline-flex;align-items:center;gap:7px;border:1px solid rgba(247,201,95,.28);border-radius:999px;padding:9px 12px;background:rgba(247,201,95,.09);color:var(--tf-gold);font-weight:950;font-size:12px;}
.twofa-label{display:flex;align-items:center;gap:10px;margin:18px 0 10px;color:var(--tf-ink);font-weight:950;font-size:14px;}
.twofa-label i{width:9px;height:9px;border-radius:999px;background:var(--tf-gold);box-shadow:0 0 18px rgba(247,201,95,.55);}
.twofa-input-wrap{position:relative;}
.twofa-input{
  width:100%;min-height:156px;border-radius:20px;border:1px solid color-mix(in srgb,var(--tf-line) 88%,transparent);
  background:color-mix(in srgb,var(--tf-page) 70%,transparent);color:var(--tf-ink);
  padding:18px 18px 52px;font-size:15px;font-weight:750;letter-spacing:.04em;line-height:1.7;outline:none;resize:vertical;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.04);transition:.18s ease;
}
.twofa-input::placeholder{color:color-mix(in srgb,var(--tf-muted) 70%,transparent);}
.twofa-input:focus{border-color:rgba(247,201,95,.72);box-shadow:0 0 0 4px rgba(247,201,95,.11),inset 0 1px 0 rgba(255,255,255,.06);}
.twofa-mini-actions{position:absolute;right:12px;bottom:12px;display:flex;gap:8px;}
.twofa-mini-btn{height:34px;border:1px solid rgba(247,201,95,.22);border-radius:999px;background:rgba(247,201,95,.07);color:var(--tf-gold);font-weight:950;font-size:12px;padding:0 12px;cursor:pointer;transition:.18s ease;}
.twofa-mini-btn:hover{background:rgba(247,201,95,.15);transform:translateY(-1px);}
.twofa-actions{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:12px;margin-top:14px;}
.twofa-btn{
  min-height:58px;border:1px solid rgba(247,201,95,.58);border-radius:18px;cursor:pointer;
  background:linear-gradient(135deg,var(--tf-gold-2),var(--tf-gold));color:#1b1207;font-weight:1000;font-size:15px;
  box-shadow:0 16px 36px rgba(247,201,95,.18),inset 0 1px 0 rgba(255,255,255,.32);transition:.18s ease;
}
.twofa-btn:hover{transform:translateY(-2px);box-shadow:0 20px 46px rgba(247,201,95,.27),inset 0 1px 0 rgba(255,255,255,.36);}
.twofa-btn:disabled{opacity:.65;cursor:not-allowed;transform:none;filter:saturate(.7);}
.twofa-btn.ghost{padding:0 18px;background:rgba(255,255,255,.035);color:var(--tf-ink);border-color:rgba(247,201,95,.28);box-shadow:none;}
.twofa-result{padding:clamp(18px,3vw,26px);position:sticky;top:92px;}
.code-box{position:relative;border:1px solid rgba(247,201,95,.26);border-radius:24px;background:radial-gradient(circle at 50% 0%,rgba(247,201,95,.18),transparent 44%),rgba(0,0,0,.18);padding:22px;text-align:center;overflow:hidden;}
.code-box::before{content:"";position:absolute;inset:0;background:linear-gradient(120deg,transparent,rgba(255,255,255,.05),transparent);transform:translateX(-120%);animation:tfShine 4.5s ease-in-out infinite;}
@keyframes tfShine{55%,100%{transform:translateX(120%)}}
.code-label{position:relative;color:var(--tf-muted);font-size:12px;font-weight:950;letter-spacing:.08em;text-transform:uppercase;}
.code{position:relative;margin:8px 0 8px;color:var(--tf-ink);font-size:clamp(46px,7vw,76px);line-height:1;font-weight:1000;letter-spacing:.11em;text-shadow:0 0 34px rgba(247,201,95,.27);font-variant-numeric:tabular-nums;}
.code-sub{position:relative;color:var(--tf-muted);font-size:13px;font-weight:750;min-height:22px;}
.timer-wrap{margin-top:18px;display:grid;grid-template-columns:74px 1fr;gap:14px;align-items:center;}
.timer-ring{--p:0;width:74px;height:74px;border-radius:50%;display:grid;place-items:center;background:conic-gradient(var(--tf-gold) calc(var(--p)*1%),rgba(255,255,255,.08) 0);box-shadow:inset 0 0 0 8px rgba(0,0,0,.28);}
.timer-ring span{width:54px;height:54px;border-radius:50%;display:grid;place-items:center;background:color-mix(in srgb,var(--tf-page) 86%,#000);color:var(--tf-gold);font-weight:1000;}
.timer-text strong{display:block;color:var(--tf-ink);font-weight:1000;}
.timer-text span{display:block;margin-top:3px;color:var(--tf-muted);font-size:12px;font-weight:750;line-height:1.45;}
.result-actions{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:16px;}
.copy-btn,.open-btn{height:48px;border:1px solid rgba(247,201,95,.32);border-radius:15px;background:rgba(247,201,95,.075);color:var(--tf-ink);font-weight:950;cursor:pointer;transition:.18s ease;}
.copy-btn:hover,.open-btn:hover{background:rgba(247,201,95,.16);transform:translateY(-1px);}
.twofa-help{margin-top:18px;padding:18px;}
.twofa-help h3{margin:0 0 10px;color:var(--tf-gold);font-size:15px;font-weight:1000;}
.twofa-help ul{margin:0;padding:0;list-style:none;display:grid;gap:10px;}
.twofa-help li{display:flex;gap:10px;color:var(--tf-muted);font-size:13px;font-weight:700;line-height:1.55;}
.twofa-help li::before{content:"✓";color:var(--tf-gold);font-weight:1000;}
.twofa-toast-note{margin-top:14px;border:1px solid rgba(39,215,131,.22);border-radius:18px;padding:13px 14px;background:rgba(39,215,131,.065);color:color-mix(in srgb,var(--tf-ink) 90%,#27d783);font-size:13px;font-weight:800;display:none;}
.twofa-toast-note.show{display:block;}

html[data-theme="light"] .twofa-pro{
  --tf-page:var(--page,#fbf6ea);
  --tf-card:rgba(255,255,255,.82);
  --tf-ink:var(--text,#21180c);
  --tf-muted:var(--muted,#705f45);
  --tf-line:rgba(138,96,25,.22);
}
html[data-theme="light"] .twofa-hero,
html[data-theme="light"] .twofa-form,
html[data-theme="light"] .twofa-result,
html[data-theme="light"] .twofa-help{background:linear-gradient(145deg,rgba(255,255,255,.88),rgba(248,239,220,.74));box-shadow:0 24px 70px rgba(104,76,27,.13),inset 0 1px 0 rgba(255,255,255,.7);}
html[data-theme="light"] .twofa-input{background:rgba(255,255,255,.84);}
html[data-theme="light"] .code-box{background:radial-gradient(circle at 50% 0%,rgba(215,154,50,.18),transparent 46%),rgba(255,255,255,.68);}
html[data-theme="light"] .timer-ring span{background:#fff8eb;}

@media(max-width:980px){
  .twofa-hero-inner,.twofa-panel{grid-template-columns:1fr;}
  .twofa-result{position:relative;top:auto;}
  .twofa-orb-card{min-height:260px;}
  .twofa-stats{grid-template-columns:1fr;}
}
@media(max-width:640px){
  .twofa-shell{width:min(100% - 18px,1180px)}
  .twofa-hero{border-radius:24px;padding:20px;}
  .twofa-title{font-size:clamp(36px,13vw,54px);}
  .twofa-sub{font-size:13px;}
  .twofa-section-head{display:block;}
  .twofa-chip{margin-top:12px;}
  .twofa-actions,.result-actions{grid-template-columns:1fr;}
  .timer-wrap{grid-template-columns:60px 1fr;}
  .timer-ring{width:60px;height:60px;}
  .timer-ring span{width:44px;height:44px;}
  .code{font-size:clamp(38px,13vw,58px);letter-spacing:.07em;}
}
</style>

<section class="page container twofa-pro">
  <div class="twofa-shell">
    <nav class="twofa-breadcrumb" aria-label="breadcrumb">
      <a href="/">หน้าหลัก</a><span>/</span>
      <b>เครื่องมือ 2FA</b>
    </nav>

    <header class="twofa-hero">
      <div class="twofa-hero-inner">
        <div>
          <div class="twofa-kicker">🔐 Premium 2FA Tool</div>
          <h1 class="twofa-title">สร้างรหัสยืนยัน <span>2FA แบบเรียลไทม์</span></h1>
          <p class="twofa-sub">
            วาง Secret Key ที่ได้รับจากสินค้า แล้วระบบจะดึงรหัส 6 หลักล่าสุดให้อัตโนมัติ พร้อมตัวนับเวลารอบถัดไป ใช้งานง่าย ปลอดภัย และเข้ากับระบบบัญชีพรีเมียมของคุณ
          </p>
          <div class="twofa-stats" aria-label="features">
            <div class="twofa-stat"><strong>30s</strong><span>รหัสเปลี่ยนตามรอบเวลา</span></div>
            <div class="twofa-stat"><strong>6 หลัก</strong><span>พร้อมคัดลอกในคลิกเดียว</span></div>
            <div class="twofa-stat"><strong>Private</strong><span>ไม่บันทึก Secret บนหน้าเว็บ</span></div>
          </div>
        </div>
        <aside class="twofa-orb-card" aria-hidden="true">
          <div class="twofa-orb"><i class="twofa-orb-ring"></i></div>
        </aside>
      </div>
    </header>

    <div class="twofa-panel">
      <main class="twofa-form">
        <div class="twofa-section-head">
          <div>
            <h2>กรอก 2FA Secret</h2>
            <p>รองรับ Secret จากลิงก์สินค้า เช่น <code>/2fa/SECRET</code> หรือคัดลอก Secret มาวางโดยตรง</p>
          </div>
          <span class="twofa-chip">⚡ Auto Fetch</span>
        </div>

        <label class="twofa-label" for="secretInput"><i></i> Secret Key</label>
        <div class="twofa-input-wrap">
          <textarea id="secretInput" class="twofa-input" spellcheck="false" autocomplete="off" placeholder="เช่น VP4WA6T3OH4B7RAPECLAB... หรือวางลิงก์ /2fa/..."><%= __secret %></textarea>
          <div class="twofa-mini-actions">
            <button id="pasteSecret" class="twofa-mini-btn" type="button">วาง</button>
            <button id="clearSecret" class="twofa-mini-btn" type="button">ล้าง</button>
          </div>
        </div>

        <div class="twofa-actions">
          <button id="getCode" class="twofa-btn" type="button">รับรหัส 2FA</button>
          <button id="confirmClear" class="twofa-btn ghost" type="button">รีเซ็ต</button>
        </div>

        <section class="twofa-help" aria-label="คำแนะนำ">
          <h3>คำแนะนำการใช้งาน</h3>
          <ul>
            <li>ถ้าเปิดจากลิงก์สินค้า ระบบจะกรอก Secret และดึงรหัสให้อัตโนมัติ</li>
            <li>สามารถวางทั้ง Secret ล้วน หรือ URL ที่มี `/2fa/SECRET` ได้</li>
            <li>เมื่อรหัสใกล้หมดเวลา ให้รอรอบใหม่แล้วกดดึงอีกครั้ง หรือเปิด Auto refresh ไว้</li>
          </ul>
        </section>
      </main>

      <aside class="twofa-result" aria-live="polite">
        <div class="twofa-section-head">
          <div>
            <h2>รหัสล่าสุด</h2>
            <p>ระบบจะแสดงรหัสจาก OTP24 API ตาม Secret ที่กรอก</p>
          </div>
          <span class="twofa-chip" id="statusChip">พร้อมใช้งาน</span>
        </div>

        <section class="code-box">
          <div class="code-label">2FA CODE</div>
          <div id="codeText" class="code">------</div>
          <div id="codeSub" class="code-sub">ยังไม่มีรหัสล่าสุด</div>
        </section>

        <div class="timer-wrap">
          <div id="timerRing" class="timer-ring" style="--p:0"><span id="timerNumber">--</span></div>
          <div class="timer-text">
            <strong id="timerTitle">รอการดึงรหัส</strong>
            <span id="timerDesc">หลังจากดึงรหัส ระบบจะแสดงเวลาที่เหลือของรอบ 2FA</span>
          </div>
        </div>

        <div class="result-actions">
          <button id="copyCode" class="copy-btn" type="button">📋 คัดลอกรหัส</button>
          <button id="copyLink" class="open-btn" type="button">🔗 คัดลอกลิงก์</button>
        </div>
        <div id="successNote" class="twofa-toast-note">พร้อมใช้งานแล้ว กดคัดลอกรหัสเพื่อนำไปล็อกอินได้ทันที</div>
      </aside>
    </div>
  </div>
</section>

<script>
(() => {
  const $ = (s, root = document) => root.querySelector(s);
  const secretInput = $('#secretInput');
  const getCodeBtn = $('#getCode');
  const copyCodeBtn = $('#copyCode');
  const copyLinkBtn = $('#copyLink');
  const pasteBtn = $('#pasteSecret');
  const clearBtn = $('#clearSecret');
  const confirmClearBtn = $('#confirmClear');
  const codeText = $('#codeText');
  const codeSub = $('#codeSub');
  const statusChip = $('#statusChip');
  const timerRing = $('#timerRing');
  const timerNumber = $('#timerNumber');
  const timerTitle = $('#timerTitle');
  const timerDesc = $('#timerDesc');
  const successNote = $('#successNote');
  let interval = null;
  let autoTimer = null;

  function callNotify(message, type = 'info', title = '') {
    const t = title || (type === 'success' ? 'สำเร็จ' : type === 'error' ? 'เกิดข้อผิดพลาด' : type === 'warn' ? 'แจ้งเตือน' : 'แจ้งเตือน');
    try {
      if (typeof window.notify === 'function') return window.notify(message, type);
      if (window.notify && typeof window.notify[type] === 'function') return window.notify[type](t, message);
      if (window.notify && typeof window.notify.info === 'function') return window.notify.info(t, message);
    } catch (_) {}
    console[type === 'error' ? 'error' : 'log'](message);
  }

  async function askConfirm(message) {
    try {
      if (typeof window.uiConfirm === 'function') return await window.uiConfirm(message);
      if (typeof window.UIConfirm === 'function') return await window.UIConfirm(message);
      if (window.UIConfirm && typeof window.UIConfirm.show === 'function') return await window.UIConfirm.show({ title: 'ยืนยันการทำรายการ', message });
    } catch (_) {}
    return true;
  }

  function extractSecret(raw) {
    let text = String(raw || '').trim();
    if (!text) return '';
    try { text = decodeURIComponent(text); } catch (_) {}
    const match = text.match(/(?:\/2fa\/|[?&]g=)([A-Za-z0-9%_\-\.]+)/i);
    if (match) text = match[1];
    try { text = decodeURIComponent(text); } catch (_) {}
    return text.replace(/\s+/g, '').replace(/[^A-Za-z0-9]/g, '').toUpperCase();
  }

  function setLoading(isLoading) {
    getCodeBtn.disabled = isLoading;
    getCodeBtn.textContent = isLoading ? 'กำลังดึงรหัส...' : 'รับรหัส 2FA';
    statusChip.textContent = isLoading ? 'กำลังเชื่อมต่อ' : 'พร้อมใช้งาน';
  }

  function updateCountdown() {
    const left = 30 - (Math.floor(Date.now() / 1000) % 30);
    const progress = Math.max(0, Math.min(100, ((30 - left) / 30) * 100));
    timerRing.style.setProperty('--p', String(progress));
    timerNumber.textContent = String(left);
    timerTitle.textContent = 'รหัสจะเปลี่ยนใน ' + left + ' วินาที';
    timerDesc.textContent = left <= 5 ? 'ใกล้หมดรอบแล้ว รอรหัสรอบถัดไปเพื่อความชัวร์' : 'รหัสนี้ใช้ได้ในรอบเวลาปัจจุบัน';
    if (left === 30 && codeText.textContent && codeText.textContent !== '------') {
      clearTimeout(autoTimer);
      autoTimer = setTimeout(loadCode, 600);
    }
  }

  async function loadCode() {
    const secret = extractSecret(secretInput.value);
    if (!secret) {
      callNotify('กรุณากรอก 2FA Secret ก่อน', 'warn');
      secretInput.focus();
      return;
    }
    secretInput.value = secret;
    try {
      setLoading(true);
      const res = await fetch('/api/otp24-2fa?g=' + encodeURIComponent(secret), {
        headers: { 'Accept': 'application/json' }
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.ok) throw new Error(data.error || 'ดึงรหัส 2FA ไม่สำเร็จ');
      const code = String(data.code || '').trim();
      if (!code) throw new Error('API ไม่ส่งรหัส 2FA กลับมา');
      codeText.textContent = code;
      codeSub.textContent = 'ดึงล่าสุด ' + new Date().toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      statusChip.textContent = 'เชื่อมต่อแล้ว';
      successNote.classList.add('show');
      history.replaceState(null, '', '/2fa/' + encodeURIComponent(secret));
      clearInterval(interval);
      updateCountdown();
      interval = setInterval(updateCountdown, 1000);
      callNotify('ดึงรหัส 2FA สำเร็จ', 'success');
    } catch (err) {
      codeSub.textContent = err.message || 'เกิดข้อผิดพลาด';
      statusChip.textContent = 'ไม่สำเร็จ';
      callNotify(err.message || 'ดึงรหัส 2FA ไม่สำเร็จ', 'error');
    } finally {
      setLoading(false);
    }
  }

  async function copyText(text, label) {
    const value = String(text || '').trim();
    if (!value || value === '------') return callNotify('ยังไม่มีข้อมูลให้คัดลอก', 'warn');
    try {
      await navigator.clipboard.writeText(value);
      callNotify('คัดลอก' + label + 'แล้ว', 'success');
    } catch (_) {
      const ta = document.createElement('textarea');
      ta.value = value;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      ta.remove();
      callNotify('คัดลอก' + label + 'แล้ว', 'success');
    }
  }

  getCodeBtn.addEventListener('click', loadCode);
  copyCodeBtn.addEventListener('click', () => copyText(codeText.textContent, 'รหัส'));
  copyLinkBtn.addEventListener('click', () => copyText(location.href, 'ลิงก์'));

  pasteBtn.addEventListener('click', async () => {
    try {
      const text = await navigator.clipboard.readText();
      secretInput.value = extractSecret(text) || text;
      callNotify('วาง Secret แล้ว', 'success');
    } catch (_) {
      callNotify('ไม่สามารถอ่าน Clipboard ได้', 'warn');
    }
  });

  clearBtn.addEventListener('click', () => {
    secretInput.value = '';
    secretInput.focus();
  });

  confirmClearBtn.addEventListener('click', async () => {
    const ok = await askConfirm('ต้องการล้าง Secret และรหัสที่แสดงอยู่หรือไม่?');
    if (!ok) return;
    secretInput.value = '';
    codeText.textContent = '------';
    codeSub.textContent = 'ยังไม่มีรหัสล่าสุด';
    statusChip.textContent = 'พร้อมใช้งาน';
    timerNumber.textContent = '--';
    timerRing.style.setProperty('--p', '0');
    timerTitle.textContent = 'รอการดึงรหัส';
    timerDesc.textContent = 'หลังจากดึงรหัส ระบบจะแสดงเวลาที่เหลือของรอบ 2FA';
    successNote.classList.remove('show');
    clearInterval(interval);
    clearTimeout(autoTimer);
    history.replaceState(null, '', '/2fa');
    callNotify('ล้างข้อมูลแล้ว', 'success');
  });

  secretInput.addEventListener('input', () => {
    successNote.classList.remove('show');
  });

  if (secretInput.value.trim()) {
    secretInput.value = extractSecret(secretInput.value);
    setTimeout(loadCode, 250);
  }
})();
</script>
