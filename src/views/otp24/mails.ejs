  --mx-text: var(--text, #21180d);
  --mx-muted: var(--muted, #6f6049);
  --mx-border: color-mix(in srgb, var(--border, rgba(32,24,12,.14)) 82%, transparent);
  --mx-shadow: 0 26px 70px rgba(73,52,18,.13);
}
