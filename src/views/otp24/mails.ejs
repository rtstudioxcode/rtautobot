.mailx-login{display:grid;grid-template-columns:minmax(0,1fr) 320px;gap:18px;margin-top:20px;align-items:start}.mailx-form-card,.mailx-guide{border:1px solid color-mix(in srgb,var(--mx-border) 86%,transparent);border-radius:26px;background:linear-gradient(145deg,color-mix(in srgb,var(--mx-card-strong) 92%,transparent),color-mix(in srgb,var(--mx-card) 82%,transparent));box-shadow:inset 0 1px 0 rgba(255,255,255,.06),0 16px 34px rgba(0,0,0,.16);padding:20px}.mailx-form-card h3,.mailx-guide h3{margin:0 0 14px;font-size:20px;font-weight:900}.mailx-field{margin-bottom:15px}.mailx-field label{display:flex;align-items:center;justify-content:space-between;gap:10px;margin:0 0 8px;color:var(--mx-text);font-weight:820}.mailx-field label em{font-style:normal;color:var(--mx-accent)}.mailx-input,.mailx-textarea{width:100%;border:1px solid color-mix(in srgb,var(--mx-border) 86%,transparent);border-radius:16px;background:color-mix(in srgb,var(--mx-page) 70%,transparent);color:var(--mx-text);font:inherit;font-weight:620;outline:none;box-shadow:inset 0 1px 0 rgba(255,255,255,.04);transition:border-color .2s ease,box-shadow .2s ease,background .2s ease}.mailx-input{height:52px;padding:0 15px}.mailx-textarea{min-height:132px;resize:vertical;padding:14px 15px}.mailx-input:focus,.mailx-textarea:focus{border-color:color-mix(in srgb,var(--mx-accent) 68%,var(--mx-border));box-shadow:0 0 0 5px color-mix(in srgb,var(--mx-accent) 10%,transparent)}.mailx-help{font-size:12px;color:var(--mx-muted);font-weight:650;margin-top:7px;line-height:1.45}.mailx-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:16px}.mailx-btn{height:50px;border:1px solid color-mix(in srgb,var(--mx-border) 86%,transparent);border-radius:16px;background:color-mix(in srgb,var(--mx-card) 76%,transparent);color:var(--mx-text);font:inherit;font-weight:900;padding:0 16px;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;gap:9px;transition:transform .2s ease,border-color .2s ease,box-shadow .2s ease,background .2s ease}.mailx-btn:hover{transform:translateY(-2px);border-color:color-mix(in srgb,var(--mx-accent) 48%,var(--mx-border));box-shadow:0 14px 30px rgba(0,0,0,.20)}.mailx-btn.primary{flex:1 1 220px;background:linear-gradient(135deg,#ffe38a,var(--mx-accent),var(--mx-gold-2));color:#171008;border-color:color-mix(in srgb,var(--mx-accent) 72%,transparent);box-shadow:0 18px 40px color-mix(in srgb,var(--mx-accent) 18%,transparent)}.mailx-btn.ghost{background:color-mix(in srgb,var(--mx-card) 68%,transparent)}.mailx-btn.danger{color:#ff8585;border-color:color-mix(in srgb,#ff6262 36%,var(--mx-border));background:color-mix(in srgb,#ff6262 8%,var(--mx-card))}.mailx-btn:disabled{opacity:.58;cursor:not-allowed;transform:none;box-shadow:none}.mailx-guide ul{list-style:none;margin:0;padding:0;display:grid;gap:11px}.mailx-guide li{display:flex;gap:10px;color:var(--mx-muted);font-size:13px;font-weight:650;line-height:1.55}.mailx-guide li span{width:24px;height:24px;border-radius:9px;display:grid;place-items:center;flex:0 0 24px;background:color-mix(in srgb,var(--mx-accent) 12%,transparent);color:var(--mx-accent);font-weight:900}
.mailx-result{margin-top:22px;border:1px solid color-mix(in srgb,var(--mx-accent) 18%, var(--mx-border));border-radius:var(--mx-radius-xl);background:linear-gradient(145deg,color-mix(in srgb,var(--mx-card-strong) 94%,transparent),color-mix(in srgb,var(--mx-card) 84%,transparent));box-shadow:var(--mx-shadow),inset 0 1px 0 rgba(255,255,255,.06);padding:24px}.mailx-result[hidden]{display:none!important}.mailx-result-top{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:14px;align-items:center}.mailx-mail-title{display:flex;align-items:center;gap:14px;min-width:0}.mailx-mail-icon{width:54px;height:54px;border-radius:20px;display:grid;place-items:center;background:linear-gradient(135deg,color-mix(in srgb,var(--mx-accent) 22%,var(--mx-card)),color-mix(in srgb,var(--mx-blue) 12%,var(--mx-card)));border:1px solid color-mix(in srgb,var(--mx-accent) 28%,var(--mx-border));box-shadow:inset 0 1px 0 rgba(255,255,255,.08)}.mailx-mail-title h2{margin:0 0 5px;font-size:clamp(20px,2.4vw,32px);font-weight:900;letter-spacing:-.03em;overflow:hidden;text-overflow:ellipsis}.mailx-mail-title p{margin:0;color:var(--mx-muted);font-weight:650}.mailx-result-actions{display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end}.mailx-mail-list{display:grid;gap:16px;margin-top:20px}.mailx-loader,.mailx-empty{border:1px dashed color-mix(in srgb,var(--mx-accent) 30%,var(--mx-border));border-radius:22px;padding:28px;text-align:center;color:var(--mx-muted);font-weight:820;background:color-mix(in srgb,var(--mx-card) 58%,transparent)}.mailx-spinner{width:34px;height:34px;margin:0 auto 12px;border-radius:999px;border:3px solid color-mix(in srgb,var(--mx-accent) 18%,transparent);border-top-color:var(--mx-accent);animation:mailxSpin .8s linear infinite}@keyframes mailxSpin{to{transform:rotate(360deg)}}
.mailx-item{border:1px solid color-mix(in srgb,var(--mx-border) 84%,transparent);border-radius:24px;background:linear-gradient(145deg,color-mix(in srgb,var(--mx-card) 84%,transparent),color-mix(in srgb,var(--mx-page) 56%,transparent));box-shadow:0 16px 34px rgba(0,0,0,.14),inset 0 1px 0 rgba(255,255,255,.05);overflow:hidden}.mailx-item-head{padding:17px 18px;border-bottom:1px solid color-mix(in srgb,var(--mx-border) 70%,transparent);display:grid;grid-template-columns:minmax(0,1fr) auto;gap:12px;align-items:start;background:linear-gradient(90deg,color-mix(in srgb,var(--mx-accent) 9%,transparent),transparent 72%)}.mailx-item-title{font-size:17px;font-weight:900;line-height:1.35}.mailx-item-meta{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;color:var(--mx-muted);font-size:12px;font-weight:720}.mailx-pill{display:inline-flex;align-items:center;gap:6px;border:1px solid color-mix(in srgb,var(--mx-border) 74%,transparent);border-radius:999px;padding:6px 9px;background:color-mix(in srgb,var(--mx-card) 66%,transparent)}.mailx-body-wrap{padding:18px}.mailx-body{background:#fff;color:#151515;border-radius:18px;padding:22px;overflow:auto;max-height:720px;box-shadow:inset 0 0 0 1px rgba(0,0,0,.08)}.mailx-item-actions{display:flex;gap:8px;flex-wrap:wrap;padding:0 18px 18px}.mailx-copy{height:40px;border-radius:14px;border:1px solid color-mix(in srgb,var(--mx-accent) 34%,var(--mx-border));background:color-mix(in srgb,var(--mx-accent) 8%,transparent);color:var(--mx-text);font-weight:850;padding:0 12px;cursor:pointer}.mailx-copy:hover{border-color:color-mix(in srgb,var(--mx-accent) 58%,var(--mx-border))}
