<section class="page mailx" aria-label="เครื่องมือเข้า Mail">
  <div class="mailx-aurora" aria-hidden="true"></div>
  <div class="mailx-shell">
    <header class="mailx-hero">
      <div>
        <span class="mailx-kicker">✦ Secure Mail Gateway</span>
        <h1><%= __directMode ? 'ระบบอ่านข้อความอีเมล' : 'เครื่องมือเข้า Mail พรีเมียม' %></h1>
        <p>เลือกผู้ให้บริการอีเมล กรอกข้อมูลที่ได้รับจากสินค้า แล้วเปิดกล่องข้อความเพื่อดู OTP หรือข้อมูลยืนยันตัวตนได้ทันทีผ่านระบบของคุณเอง</p>
        <nav class="mailx-crumb" aria-label="breadcrumb">
          <a href="/">หน้าหลัก</a><span>/</span><b><%= __directMode ? 'กล่องข้อความ' : 'เครื่องมือเข้า Mail' %></b>
        </nav>
      </div>
      <aside class="mailx-hero-card" aria-label="Mail features">
        <strong>MAIL</strong>
        <span>อ่าน OTP / ข้อความยืนยันแบบเรียลไทม์</span>
        <div class="mini-grid">
          <div class="mailx-mini"><b>3</b><small>Provider</small></div>
          <div class="mailx-mini"><b>24 ชั่วโมง</b><small>Auto</small></div>
        </div>
      </aside>
    </header>

    <section class="mailx-panel" id="selectPanel" <%= __directMode ? 'hidden' : '' %>>
      <div class="mailx-panel-head">
        <div class="mailx-panel-title">
          <h2>เลือกเซิร์ฟเวอร์อีเมล</h2>
          <p>เลือกประเภทเมลก่อนเข้าสู่ระบบ</p>
        </div>
      </div>

      <div class="mailx-providers" id="providerGrid">
        <button class="mailx-provider active" type="button" data-provider="outlook" aria-label="เลือก Hotmail หรือ Outlook">
          <span class="mailx-logo outlook" aria-hidden="true"></span>
          <div>
            <h3>Hotmail / Outlook</h3>
            <p>สำหรับเมล Microsoft ที่ใช้ Client ID และ Refresh Token</p>
            <div class="mailx-tagrow"><span class="mailx-tag">OAuth</span><span class="mailx-tag">Refresh Token</span></div>
          </div>
        </button>
        <button class="mailx-provider" type="button" data-provider="rambler" aria-label="เลือก Rambler.ru">
          <span class="mailx-logo rambler" aria-hidden="true"></span>
          <div>
            <h3>Rambler.ru</h3>
            <p>สำหรับบัญชี Rambler ที่ล็อกอินด้วยเมลและรหัสผ่าน</p>
            <div class="mailx-tagrow"><span class="mailx-tag">Email</span><span class="mailx-tag">Password</span></div>
          </div>
        </button>
        <button class="mailx-provider" type="button" data-provider="gmx" aria-label="เลือก GMX">
          <span class="mailx-logo gmx" aria-hidden="true"></span>
          <div>
            <h3>GMX</h3>
            <p>สำหรับบัญชี GMX ที่ต้องใช้เมลและรหัสผ่านสินค้า</p>
            <div class="mailx-tagrow"><span class="mailx-tag">Mailbox</span><span class="mailx-tag">OTP Ready</span></div>
          </div>
        </button>
      </div>

      <div class="mailx-login">
        <form id="mailLoginForm" class="mailx-form-card" autocomplete="off">
          <h3>Login Email</h3>
          <div class="mailx-field">
            <label for="mailInput">อีเมล <em>*</em></label>
            <input id="mailInput" class="mailx-input" value="<%= __mail %>" placeholder="name@example.com" autocomplete="off" required>
            <div class="mailx-help">หลัง Login สำเร็จ ระบบจะพาไปที่ <b>/mailz/email</b> และซ่อนฟอร์มนี้อัตโนมัติ</div>
          </div>

          <div class="mailx-field provider-outlook-only">
            <label for="clientIdInput">Client ID <em>*</em></label>
            <input id="clientIdInput" class="mailx-input" placeholder="Client ID" autocomplete="off">
          </div>

          <div class="mailx-field provider-outlook-only">
            <label for="refreshTokenInput">Refresh Token <em>*</em></label>
            <textarea id="refreshTokenInput" class="mailx-textarea" placeholder="วาง Refresh Token ที่ได้รับจากสินค้า"></textarea>
          </div>

          <div class="mailx-field provider-pass-only" hidden>
            <label for="passwordInput">รหัสเมล <em>*</em></label>
            <input id="passwordInput" class="mailx-input" type="password" placeholder="รหัสผ่านเมล" autocomplete="new-password">
          </div>

          <div class="mailx-actions">
            <button class="mailx-btn primary" id="loginBtn" type="submit">เข้าสู่กล่องข้อความ</button>
            <button class="mailx-btn ghost" id="clearLogin" type="button">ล้างข้อมูล</button>
          </div>
        </form>

        <aside class="mailx-guide" aria-label="คำแนะนำ">
          <h3>วิธีใช้งาน</h3>
          <ul>
            <li><span>1</span><div>เลือก Provider ให้ตรงกับอีเมลที่ได้รับหลังซื้อสินค้า</div></li>
            <li><span>2</span><div>กรอกข้อมูลที่ได้รับ เช่น เมล/รหัส หรือ Client ID/Refresh Token</div></li>
            <li><span>3</span><div>ระบบจะเปิดกล่องข้อความและดึง OTP ผ่าน API ให้ทันที</div></li>
            <li><span>✓</span><div>ลิงก์จากสินค้าแบบ <b>/mailz/email</b> จะเปิดกล่องเมลโดยตรง</div></li>
          </ul>
        </aside>
      </div>
    </section>

    <section id="mailResult" class="mailx-result" <%= __directMode ? '' : 'hidden' %>>
      <div class="mailx-result-top">
        <div class="mailx-mail-title">
          <div class="mailx-mail-icon" aria-hidden="true">✉️</div>
          <div>
            <h2>เมล: <span id="resultMail"><%= __mail %></span></h2>
            <p id="resultSub">กำลังโหลดข้อความ...</p>
          </div>
        </div>
        <div class="mailx-result-actions" id="backTools" <%= __directMode ? '' : 'hidden' %>>
          <button class="mailx-btn ghost" type="button" id="reloadMail">รีเฟรช</button>
          <button class="mailx-btn ghost" type="button" id="copyMailAddr">คัดลอกเมล</button>
          <button class="mailx-btn danger" type="button" id="backToLogin">เลือกเมลอื่น</button>
        </div>
      </div>
      <div class="mailx-line"></div>
      <div id="mailList" class="mailx-mail-list"><div class="mailx-loader"><div class="mailx-spinner"></div>กำลังโหลดข้อความ...</div></div>
    </section>
  </div>
</section>

<script>
(()=>{
  const initialMail = <%- safeJson(__mail) %>;
  const directMode = <%- safeJson(__directMode) %>;
  const $ = s => document.querySelector(s);
  const $$ = s => Array.from(document.querySelectorAll(s));
  let currentProvider = 'outlook';
  let currentItems = [];
  let loading = false;

  function notify(msg,type='info',title){
    const t = title || (type==='error'?'เกิดข้อผิดพลาด':type==='success'?'สำเร็จ':type==='warn'?'แจ้งเตือน':'แจ้งเตือน');
    if(window.notify){
      try{
        if(typeof window.notify === 'function') return window.notify(msg,type);
        const fn = window.notify[type] || window.notify.info || window.notify.success;
        if(fn) return fn(t,msg);
      }catch(_){ }
    }
    console[type === 'error' ? 'error' : 'log'](t + ': ' + msg);
  }

  async function confirmAction(message){
    const fn = window.uiConfirm || window.UIConfirm;
    if(typeof fn === 'function'){
      try{
        const result = await fn({
          title:'ยืนยันการทำรายการ',
          message,
          okText:'ยืนยัน',
          cancelText:'ยกเลิก',
          tone:'gold'
        });
        return result !== false;
      }catch(_){
        try{ return await fn('ยืนยันการทำรายการ', message); }catch(__){ return true; }
      }
    }
    return true;
  }

  function escapeHtml(s){return String(s??'').replace(/[&<>'"]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[m]));}
  function safeMailHtml(html){
    return String(html||'')
      .replace(/<script[\s\S]*?>[\s\S]*?<\/script>/gi,'')
      .replace(/<iframe[\s\S]*?>[\s\S]*?<\/iframe>/gi,'')
      .replace(/<object[\s\S]*?>[\s\S]*?<\/object>/gi,'')
      .replace(/<embed[\s\S]*?>[\s\S]*?<\/embed>/gi,'')
      .replace(/\son[a-z]+\s*=\s*(["']).*?\1/gi,'')
      .replace(/javascript:/gi,'');
  }
  function normalizeItems(data){
    if(Array.isArray(data?.items)) return data.items;
    if(Array.isArray(data?.data)) return data.data;
    if(Array.isArray(data?.mail)) return data.mail;
    if(data?.mail && typeof data.mail === 'object') return [data.mail];
    if(data?.data && typeof data.data === 'object') return [data.data];
    return [];
  }
  function setHidden(el, yes){ if(el) yes ? el.setAttribute('hidden','') : el.removeAttribute('hidden'); }
  function setLoadingButton(on){
    const btn = $('#loginBtn');
    if(!btn) return;
    btn.disabled = !!on;
    btn.textContent = on ? 'กำลังเข้าสู่กล่องข้อความ...' : 'เข้าสู่กล่องข้อความ';
  }
  function resetMailResult({ clearInput = false } = {}){
    currentItems = [];
    setHidden($('#mailResult'), true);
    if($('#resultMail')) $('#resultMail').textContent = '';
    if($('#resultSub')) $('#resultSub').textContent = '';
    if($('#mailList')) $('#mailList').innerHTML = '';
    setHidden($('#backTools'), true);
    if(clearInput){
      ['#mailInput','#clientIdInput','#refreshTokenInput','#passwordInput'].forEach(sel=>{ const el=$(sel); if(el) el.value=''; });
    }
  }
  function showLoginPanel(){
    setHidden($('#selectPanel'), false);
    resetMailResult({ clearInput:false });
  }
  function hideLoginPanel(){ setHidden($('#selectPanel'), true); }
  function clearLoginFields(){
    ['#mailInput','#clientIdInput','#refreshTokenInput','#passwordInput'].forEach(sel=>{ const el=$(sel); if(el) el.value=''; });
    resetMailResult();
    $('#mailInput')?.focus();
  }
  function setProvider(provider, opts = {}){
    const nextProvider = provider || 'outlook';
    const changed = currentProvider !== nextProvider;
    currentProvider = nextProvider;
    $$('.mailx-provider').forEach(c=>c.classList.toggle('active', c.dataset.provider===currentProvider));
    const isOutlook = currentProvider === 'outlook';
    $$('.provider-outlook-only').forEach(el=>setHidden(el,!isOutlook));
    $$('.provider-pass-only').forEach(el=>setHidden(el,isOutlook));
    if((changed && opts.clearResult !== false) || opts.forceClear){
      resetMailResult({ clearInput: !!opts.clearInput });
      setHidden($('#selectPanel'), false);
      if(location.pathname.startsWith('/mailz/')) history.pushState(null, '', '/mails');
      notify('เปลี่ยนเซิร์ฟเวอร์แล้ว กล่องเดิมถูกล้างเรียบร้อย','info');
    }
  }
  function renderMail(mail, items){
    currentItems = items || [];
    $('#resultMail').textContent = mail || '-';
    $('#resultSub').textContent = currentItems.length ? `${currentItems.length.toLocaleString('th-TH')} ข้อความในกล่องจดหมาย` : 'ไม่พบข้อความในกล่องจดหมาย';
    setHidden($('#mailResult'), false);
    setHidden($('#backTools'), false);
    if(!currentItems.length){
      $('#mailList').innerHTML = '<div class="mailx-empty">ยังไม่มีข้อความในกล่องจดหมายนี้</div>';
      return;
    }
    $('#mailList').innerHTML = currentItems.map((m,i)=>{
      const subject = m.subject || 'ไม่มีหัวข้อ';
      const from = m.from || 'ไม่ระบุผู้ส่ง';
      const date = m.date || '';
      const body = safeMailHtml(m.html || m.body || m.text || 'ไม่มีข้อความ');
      return `
        <article class="mailx-item">
          <div class="mailx-item-head">
            <div>
              <div class="mailx-item-title">${escapeHtml(subject)}</div>
              <div class="mailx-item-meta">
                <span class="mailx-pill">จาก: ${escapeHtml(from)}</span>
                ${date ? `<span class="mailx-pill">เวลา: ${escapeHtml(date)}</span>` : ''}
              </div>
            </div>
            <span class="mailx-pill">#${i+1}</span>
          </div>
          <div class="mailx-body-wrap"><div class="mailx-body">${body}</div></div>
          <div class="mailx-item-actions">
            <button class="mailx-copy" type="button" data-copy="${i}">คัดลอกข้อความ</button>
          </div>
        </article>`;
    }).join('');
    $$('[data-copy]').forEach(btn=>btn.onclick=async()=>{
      const item = currentItems[Number(btn.dataset.copy)] || {};
      await navigator.clipboard.writeText(item.html || item.body || item.text || '');
      notify('คัดลอกข้อความเมลแล้ว','success');
    });
  }
  async function loadMail(mail, {push=true}={}){
    if(loading) return;
    mail = String(mail || '').trim();
    if(!mail) return notify('กรุณากรอกอีเมล','error');
    loading = true;
    setLoadingButton(true);
    hideLoginPanel();
    setHidden($('#mailResult'), false);
    setHidden($('#backTools'), false);
    $('#resultMail').textContent = mail;
    $('#resultSub').textContent = 'กำลังโหลดข้อความ...';
    $('#mailList').innerHTML = '<div class="mailx-loader"><div class="mailx-spinner"></div>กำลังโหลดข้อความ...</div>';
    if(push) history.pushState(null,'','/mailz/'+encodeURIComponent(mail));
    try{
      const r = await fetch('/api/otp24-mail?mail='+encodeURIComponent(mail), {headers:{accept:'application/json'}});
      const data = await r.json().catch(()=>({ok:false,error:'รูปแบบข้อมูลไม่ถูกต้อง'}));
      if(!r.ok || !data.ok) throw new Error(data.error || data.msg || 'โหลดเมลไม่สำเร็จ');
      renderMail(mail, normalizeItems(data));
      notify('โหลดกล่องข้อความสำเร็จ','success');
    }catch(e){
      $('#resultSub').textContent = 'โหลดไม่สำเร็จ';
      $('#mailList').innerHTML = '<div class="mailx-empty">โหลดเมลไม่สำเร็จ<br><small>'+escapeHtml(e.message || '')+'</small></div>';
      notify(e.message || 'โหลดเมลไม่สำเร็จ','error');
    }finally{
      loading = false;
      setLoadingButton(false);
    }
  }

  $$('.mailx-provider').forEach(card=>card.addEventListener('click',()=>{
    setProvider(card.dataset.provider, { forceClear:true, clearInput:true });
    setTimeout(()=>$('#mailInput')?.focus(), 60);
  }));
  ['#mailInput','#clientIdInput','#refreshTokenInput','#passwordInput'].forEach(sel=>{
    const el = $(sel);
    if(!el) return;
    el.addEventListener('input', ()=>{
      if(!$('#mailResult')?.hasAttribute('hidden')) resetMailResult();
    });
  });
  $('#mailLoginForm')?.addEventListener('submit', e=>{
    e.preventDefault();
    const mail = $('#mailInput').value.trim();
    if(!mail) return notify('กรุณากรอกอีเมล','error');
    loadMail(mail, {push:true});
  });
  $('#clearLogin')?.addEventListener('click', clearLoginFields);
  $('#backToLogin')?.addEventListener('click', async()=>{
    const ok = await confirmAction('ต้องการกลับไปเลือกเมลอื่นใช่ไหม? กล่องข้อความปัจจุบันจะถูกซ่อน');
    if(!ok) return;
    showLoginPanel();
    clearLoginFields();
    history.pushState(null,'','/mails');
    setTimeout(()=>$('#mailInput')?.focus(),50);
  });
  $('#reloadMail')?.addEventListener('click',()=>loadMail($('#resultMail').textContent.trim() || $('#mailInput').value.trim(), {push:false}));
  $('#copyMailAddr')?.addEventListener('click',async()=>{
    const m = ($('#resultMail')?.textContent || '').trim();
    if(!m) return;
    await navigator.clipboard.writeText(m);
    notify('คัดลอกอีเมลแล้ว','success');
  });
  window.addEventListener('popstate', () => {
    const m = decodeURIComponent((location.pathname.match(/^\/mailz\/(.+)$/) || [])[1] || '');
    if(m){
      $('#mailInput') && ($('#mailInput').value = m);
      loadMail(m, {push:false});
    }else{
      showLoginPanel();
    }
  });

  setProvider('outlook', { clearResult:false });
  if(initialMail){
    $('#mailInput').value = initialMail;
    loadMail(initialMail, {push:false});
  }else if(directMode){
    setHidden($('#mailResult'), false);
    $('#mailList').innerHTML = '<div class="mailx-empty">ไม่พบอีเมลในลิงก์</div>';
  }
})();
</script>
