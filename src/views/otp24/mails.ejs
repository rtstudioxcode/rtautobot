  --mx-border: color-mix(in srgb, var(--border, rgba(255,255,255,.12)) 78%, transparent);
  --mx-accent: var(--accent, #f5c95d);
  --mx-gold: #f7d774;
  --mx-gold-2: #c48c22;
  --mx-blue: #48a8ff;
  --mx-danger: #ff6262;
  --mx-success: #4ade80;
  --mx-radius-xl: 30px;
  --mx-radius-lg: 24px;
  --mx-radius-md: 18px;
  --mx-shadow: 0 28px 90px rgba(0,0,0,.40);
