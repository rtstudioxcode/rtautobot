/* ===== OTP24 Modal (style แบบภาพตัวอย่าง) ===== */
.modal-otp24{
  min-width: 520px;
  padding: 22px 22px 18px;
  border-radius: 16px;
  border: 1px solid color-mix(in oklab, var(--elevated-border,#2e2f35), white 6%);
  background: color-mix(in oklab, var(--elevated-bg,#17181b), black 6%);
  color: var(--text-primary,#fff);
  box-shadow: 0 16px 36px rgba(0,0,0,.45);
  text-align: center;
}
@media (max-width:640px){ .modal-otp24{ min-width:unset; width:92vw; } }

.modal-otp24 .modal-title{
  margin: 0 0 12px;
  font-size: clamp(18px, 2.4vw, 22px);
  font-weight: 800;
  letter-spacing: .2px;
}

.modal-otp24 .modal-sub{
  opacity: .9;
  line-height: 1.45;
  margin-bottom: 12px;
}
.modal-otp24 .modal-label{
  margin-top: 6px;
  font-weight: 600;
}
.modal-otp24 .modal-divider{
  height: 2px;
  margin: 10px 0 14px;
  background: linear-gradient(90deg, transparent 0, #ff9b50 18%, #ffa95f 50%, #ff9b50 82%, transparent 100%);
  opacity: .9;
  border-radius: 2px;
}

/* ธงโปร่งใส เรียงหลายคอลัมน์ */
.modal-otp24 .flags-grid{
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12px;
  justify-items: center;
  margin-bottom: 18px;
}
@media (max-width:640px){
  .modal-otp24 .flags-grid{ grid-template-columns: repeat(5, 1fr); gap: 10px; }
}

/* ปุ่มธง = ไม่มีพื้นหลัง, มีเฉพาะรูปธงโค้ง + เงานิดๆ */
.modal-otp24 .flag-btn{
  width: 52px; height: 36px;
  padding: 0; border: 0;
  background: transparent;
  line-height: 0; cursor: pointer;
  position: relative; border-radius: 9px;
}
.modal-otp24 .flag-btn img{
  width: 100%; height: 100%;
  display: block; object-fit: cover;
  border-radius: inherit;
  box-shadow: 0 1px 0 rgba(255,255,255,.15), 0 4px 10px rgba(0,0,0,.25);
}

/* hover / selected = ขอบส้มเรืองนุ่ม */
.modal-otp24 .flag-btn:hover,
.modal-otp24 .flag-btn.active,
.modal-otp24 .flag-btn.selected{
  outline: 2px solid #ff9242;
  box-shadow: 0 0 0 3px rgba(255,146,66,.25);
  border-radius: 11px;
}

/* ปุ่มกด */
.modal-otp24 .actions{
  display: flex; gap: 14px; justify-content: center;
}
.modal-otp24 .btn{
  min-width: 120px; height: 40px;
  border-radius: 12px; font-weight: 400; letter-spacing:.2px;
}
.modal-otp24 .modal-primary{
  background: linear-gradient(180deg,#ff9a55 0%, #ff7f2f 100%);
  color: #fff;
  border: 1px solid rgba(255,132,58,.55);
  box-shadow: 0 6px 18px rgba(255,132,58,.35), inset 0 1px 0 rgba(255,255,255,.25);
}
.modal-otp24 .modal-primary:disabled{
  filter: grayscale(.35) brightness(.85);
  opacity: .8; cursor: not-allowed;
}
.modal-otp24 .modal-primary:hover{ filter: brightness(1.04); transform: translateY(-1px); }
.modal-otp24 .modal-primary:active{ transform: translateY(0); }

.modal-otp24 .modal-secondary{
  background: transparent;
  color: var(--text-primary,#fff);
  border: 1px solid rgba(255,132,58,.45);
  box-shadow: 0 0 0 2px rgba(255,132,58,.15) inset;
}
.modal-otp24 .modal-secondary:hover{
  background: rgba(255,132,58,.08);
}

/* กริดธง: คอลัมน์คงที่ + จัดทั้งบล็อกให้อยู่กลาง */
.modal-otp24 .flags-grid{
  display: grid;
  grid-template-columns: repeat(5, 52px); /* 6 คอลัมน์ desktop */
  gap: 12px;
  justify-content: center; /* ทำให้แถวสุดท้ายกึ่งกลาง */
  justify-items: center;   /* ตัวธงอยู่กลางแต่ละคอลัมน์ */
  margin-bottom: 18px;
}
@media (max-width:640px){
  .modal-otp24 .flags-grid{
    grid-template-columns: repeat(5, 52px); /* มือถือ 5 คอลัมน์ */
    gap: 10px;
  }
}

/* ขนาดปุ่มธง */
