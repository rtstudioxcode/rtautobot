<%
// code ธงตาม ct ของ API
const CT2CODE = {
  52:'th',187:'us',16:'gb',6:'id',10:'vn',5:'mm',1:'ua',19:'ng',62:'tr',
  3:'cn',4:'ph',24:'kh',25:'la',7:'my',21:'eg'
};
const HAS_FLAG = id => !!CT2CODE[id];
const FLAGURL  = id => HAS_FLAG(id) ? `/static/assets/otp24/${CT2CODE[id]}.png` : '';

// path รูปธง
const FLAGIMG = (id) => `/static/assets/otp24/${CT2CODE[id] || 'xx'}.png`;

// (คง FLAG เดิมไว้เผื่อใช้ที่อื่น)
const FLAG = id => ({
  52:'🇹🇭',187:'🇺🇸',16:'🇬🇧',6:'🇮🇩',10:'🇻🇳',5:'🇲🇲',1:'🇺🇦',19:'🇳🇬',62:'🇹🇷',
  3:'🇨🇳',4:'🇵🇭',24:'🇰🇭',25:'🇱🇦',7:'🇲🇾',21:'🇪🇬'
}[id] || '🏳️');

// แท็บแรกที่ควรแสดงตั้งแต่ SSR เพื่อลด FOUC ตอนเข้าหน้า /otp24?tab=orders
const OTP_INITIAL_TAB = (() => {
  try {
    const v =
      (typeof tab !== 'undefined' ? tab : '') ||
      (typeof query !== 'undefined' && query ? query.tab : '') ||
      (typeof req !== 'undefined' && req?.query ? req.query.tab : '');
    return String(v || '').toLowerCase() === 'orders' ? 'orders' : 'shop';
  } catch (_) {
    return 'shop';
  }
})();

// ตัวช่วยเช็ค OTP
const HAS_OTP = (v) => {
  try{
    const s = String(v ?? '').trim();
    return !!(s && !/^0+$/.test(s));   // ว่างหรือศูนย์ล้วน = ไม่มี
  }catch{ return false; }
};
%>

<script>
(function(){
  try{
    var u = new URL(location.href);
    if (u.searchParams.get('tab') === 'orders' || location.hash.replace('#','') === 'orders') {
      document.documentElement.classList.add('otp24-start-orders');
    }
  }catch(_){ }
})();
</script>

<style id="otp24-critical">
  /* Critical CSS ต้องอยู่ก่อน markup เพื่อกันภาพแตก/ตารางยืดก่อน style หลักโหลด */
  .otp24{ opacity:1; transition:opacity .18s ease; }
  .otp24 .tabpane{ display:none; }
  .otp24 .tabpane.show{ display:block; }
  html.otp24-start-orders .otp24 #section-shop{ display:none !important; }
  html.otp24-start-orders .otp24 #section-orders{ display:block !important; }
  html.otp24-start-orders .otp24 .tab[data-target="shop"]{ color:var(--otp-muted,#8b949e); background:transparent; box-shadow:none; }
  html.otp24-start-orders .otp24 .tab[data-target="shop"]::after{ transform:scaleX(0); }
  html.otp24-start-orders .otp24 .tab[data-target="orders"]{ color:color-mix(in srgb, var(--otp-accent,#f5c451) 88%, #fff); }
  .otp24.tab-switching .tabpane.show{ animation:otp24SmoothIn .32s cubic-bezier(.2,.8,.2,1) both; }
  body.otp24-navigating{ cursor:progress; }
  body.otp24-navigating .otp24{ pointer-events:none; }
  .otp24-route-loader{ position:fixed; inset:0; z-index:9998; display:grid; place-items:center; opacity:0; pointer-events:none; background:rgba(5,7,12,.56); backdrop-filter:blur(14px); transition:opacity .18s ease; }
  body.otp24-navigating .otp24-route-loader{ opacity:1; pointer-events:auto; }
  .otp24-route-loader__box{ min-width:220px; border:1px solid rgba(245,196,81,.28); border-radius:24px; padding:18px 22px; text-align:center; background:linear-gradient(180deg,rgba(22,24,32,.92),rgba(12,14,20,.92)); color:#fff2c7; box-shadow:0 24px 80px rgba(0,0,0,.42); }
  .otp24-route-loader__ring{ width:34px; height:34px; margin:0 auto 10px; border-radius:999px; border:3px solid rgba(245,196,81,.22); border-top-color:#f5c451; animation:otp24Spin .8s linear infinite; }
  @keyframes otp24Spin{ to{ transform:rotate(360deg); } }
  @keyframes otp24SmoothIn{ from{ opacity:0; transform:translateY(10px) scale(.992); filter:blur(6px); } to{ opacity:1; transform:translateY(0) scale(1); filter:blur(0); } }


/* HOTFIX — เรียง/แสดงสินค้าที่ถูกซื้อบ่อยสุด */
.popular-badge{
  position:absolute;
  top:8px;
  left:8px;
  z-index:4;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-height:28px;
  padding:4px 10px;
  border-radius:999px;
  border:1px solid color-mix(in srgb, var(--otp-gold, #f7d774) 46%, transparent);
  background:linear-gradient(135deg, rgba(247,215,116,.22), rgba(196,139,36,.10));
  color:color-mix(in srgb, var(--otp-gold, #f7d774) 88%, #fff);
  font-size:11px;
  font-weight:800;
  line-height:1;
  box-shadow:0 10px 26px rgba(247,215,116,.12), inset 0 1px 0 rgba(255,255,255,.08);
  backdrop-filter:blur(10px);
  pointer-events:none;
}
@media(max-width:760px){
  .popular-badge{top:6px;left:6px;font-size:10px;padding:3px 8px;min-height:24px;}
}



/* ==========================================================
   FINAL TUNE — OTP24 app cards compact & balanced
   ลดความสูง/ขนาดการ์ดให้พอดีกับโลโก้ โดยยังคง badge อยู่แนวเดียวกัน
========================================================== */
.otp24 #appsGrid.grid.cards{
  grid-template-columns:repeat(auto-fill,minmax(150px,1fr))!important;
  gap:14px!important;
  align-items:stretch!important;
}
.otp24 .card.app{
  min-height:188px!important;
  padding:13px 12px 12px!important;
  border-radius:22px!important;
  gap:8px!important;
  justify-content:center!important;
}
.otp24 .card.app:hover{
  transform:translateY(-5px) scale(1.01)!important;
}
.otp24 .app-icon{
  width:78px!important;
  height:78px!important;
  border-radius:24px!important;
  margin-top:8px!important;
}
.otp24 .app-icon img{
  width:58px!important;
  height:58px!important;
  border-radius:18px!important;
}
.otp24 .app-name{
  font-size:14.5px!important;
  line-height:1.22!important;
  min-height:auto!important;
  margin-top:2px!important;
  display:-webkit-box!important;
  -webkit-line-clamp:2!important;
  -webkit-box-orient:vertical!important;
  overflow:hidden!important;
}
.otp24 .popular-badge,
.otp24 .price-badge{
  top:10px!important;
  min-height:28px!important;
  height:28px!important;
  padding:0 10px!important;
  font-size:10.5px!important;
}
.otp24 .popular-badge{left:9px!important;}
.otp24 .price-badge{right:9px!important;}
@media(max-width:760px){
  .otp24 #appsGrid.grid.cards{
    grid-template-columns:repeat(2,minmax(0,1fr))!important;
    gap:10px!important;
  }
  .otp24 .card.app{
    min-height:166px!important;
    padding:11px 10px 10px!important;
    border-radius:20px!important;
    gap:7px!important;
  }
  .otp24 .app-icon{
    width:66px!important;
    height:66px!important;
    border-radius:20px!important;
    margin-top:7px!important;
  }
  .otp24 .app-icon img{
    width:50px!important;
    height:50px!important;
    border-radius:16px!important;
  }
  .otp24 .app-name{
    font-size:13px!important;
  }
  .otp24 .popular-badge,
  .otp24 .price-badge{
    top:8px!important;
    height:25px!important;
    min-height:25px!important;
    padding:0 8px!important;
    font-size:9.5px!important;
  }
}
</style>

<section class="page container otp24">
    <div class="otp-enterprise-hero" aria-label="OTP24 Hero">
      <div class="otp-hero-glow otp-hero-glow-a"></div>
      <div class="otp-hero-glow otp-hero-glow-b"></div>
      <div class="otp-hero-content">
        <span class="otp-kicker">OTP24 Service Center</span>
        <h1>เช่าเบอร์ OTP พรีเมียม</h1>
        <p>รับเบอร์ยืนยันตัวตนได้ทันทีในไม่กี่คลิก รองรับหลายแอปและหลายประเทศ ติดตาม OTP แบบเรียลไทม์ ใช้งานง่าย ปลอดภัย</p>
      </div>
      <div class="otp-hero-stats" aria-label="สรุปบริการ">
        <div><b><%= (products || []).length || 0 %></b><span>บริการ</span></div>
        <div><b>Realtime</b><span>ติดตาม OTP</span></div>
        <div><b>Secure</b><span>คืนเครดิตอัตโนมัติ</span></div>
      </div>
    </div>
    <div class="tabs">
        <button class="tab <%= OTP_INITIAL_TAB === 'shop' ? 'active' : '' %>" style="width: 100%;" data-target="shop"><span class="tab-ico">🛒</span><span>สั่งซื้อ OTP</span></button>
        <button class="tab <%= OTP_INITIAL_TAB === 'orders' ? 'active' : '' %>" style="width: 100%;" data-target="orders"><span class="tab-ico">📜</span><span>ประวัติการสั่งซื้อ</span></button>
    </div>

    <div class="otp24-route-loader" aria-hidden="true">
      <div class="otp24-route-loader__box">
        <div class="otp24-route-loader__ring"></div>
        <div>กำลังเปิดประวัติการสั่งซื้อ…</div>
      </div>
    </div>

    <!-- ============ SECTION 1: สั่งซื้อ OTP ============ -->
    <section id="section-shop" class="tabpane <%= OTP_INITIAL_TAB === 'shop' ? 'show' : '' %>">
        <div class="row mt">
          <input id="otpSearch" class="input" placeholder="ค้นหาแอพ…" autocomplete="off" />
        </div>
        
        <%
          // key ที่ใช้ตัดสินใจว่า “ถือว่าอันเดียวกัน”
          const keyOf = p => `${(p.alias || p.name || '').trim().toLowerCase()}|${Number(p.price||0)}`;
          const seen = new Set();
          const uniqueProducts = [];
          (products || []).forEach(p => {
            const k = keyOf(p);
            if (!seen.has(k)) { seen.add(k); uniqueProducts.push(p); }
          });
        %>
        <!-- เดิม: <div class="grid cards mt-lg"> ... มีปุ่มเช่าในแต่ละการ์ด -->
        <div class="grid cards mt-lg" id="appsGrid">
        <% uniqueProducts.forEach(p => { %>
            <section class="card app"
            data-id="<%= p._id %>"
            data-name="<%= p.name %>"
            data-price="<%= p.price %>"
            role="button"
            tabindex="0"
            aria-label="เช่า OTP สำหรับ <%= p.name %> ราคา <%= p.price.toFixed(2) %> บาท">
            <div class="price-badge">฿ <%= p.price.toFixed(2) %></div>
            <% if (Number(p.freq || 0) > 0) { %>
              <div class="popular-badge">ซื้อ <%= Number(p.freq || 0).toLocaleString('th-TH') %> ครั้ง</div>
            <% } %>
            <div class="app-icon">
                <% if (p.icon) { %>
                <img src="<%= p.icon %>" alt="<%= p.name %>" loading="lazy"/>
                <% } else { %>
                <div class="placeholder"><%= p.name?.[0] || '?' %></div>
                <% } %>
            </div>
            <div class="app-name"><%= p.name %></div>
            <!-- ตัดปุ่มเช่าออก -->
            </section>
        <% }) %>
        </div>
    </section>

    <!-- ============ SECTION 2: ประวัติ OTP (แบบภาพตัวอย่าง #3) ============ -->
    <section id="section-orders" class="tabpane <%= OTP_INITIAL_TAB === 'orders' ? 'show' : '' %>">
        <!-- Controls: per page + pager -->
        <div class="orders-controls" id="ordersControlsDesktop">
            <div class="left">
                แสดง
                <select id="perPageSelect">
                <option value="10">10</option>
                <option value="20" selected>20</option>
                <option value="50">50</option>
                <option value="100">100</option>
                </select>
                รายการ/หน้า
            </div>
            <div class="right pager">
                <button class="pg-btn" data-act="first" aria-label="หน้าแรก">«</button>
                <button class="pg-btn" data-act="prev" aria-label="ก่อนหน้า">‹</button>
                <span id="pageInfo">หน้า 1/1</span>
                <button class="pg-btn" data-act="next" aria-label="ถัดไป">›</button>
                <button class="pg-btn" data-act="last" aria-label="หน้าสุดท้าย">»</button>
            </div>
        </div>
        <div class="orders-wrap">
        <table class="tbl">
            <thead>
            <tr>
                <th>เลขออเดอร์</th>
                <th>แอป</th>
                <th>เบอร์</th>
                <th>OTP / เวลา</th>
                <th class="center">ราคา</th>
                <th class="right">สถานะ</th>
            </tr>
            </thead>
            <tbody id="ordersBody">
            <% (orders||[]).forEach(o => {
            const rawSt = String(o.status || 'processing').toLowerCase();
            const st = (rawSt === 'success' && !HAS_OTP(o.otp)) ? 'processing' : rawSt;
            const createdAtStr = new Date(o.createdAt).toISOString().replace('T',' ').slice(0,19);
            %>
            <tr data-orderid="<%= o.orderId %>" data-ct="<%= Number(o.countryId||0) %>" data-expires="<%= o.expiresAt ? new Date(o.expiresAt).toISOString() : '' %>">
                <td class="mono"><%= o.orderId || '-' %></td>
                <td>
                <span class="badge app"><%= o.appName || '—' %></span>
                </td>
                <td>
                  <div class="mono phone-cell">
                    <% 
                      const phoneStrTable = (o.displayPhone || o.phone)
                        ? (o.displayPhone || (Number(o.countryId)===52 ? String(o.phone).replace(/[^0-9]/g,'').replace(/^66/,'0') : String(o.phone)))
                        : '-';
                    %>
                    <span class="flag"><img src="<%= FLAGIMG(Number(o.countryId||0)) %>" alt="" /></span>
                    <span class="v"><%= phoneStrTable %></span>
                    <% if (o.phone) { %>
                      <button class="copy" data-copy="<%= phoneStrTable %>" aria-label="คัดลอกเบอร์">
                        <img src="/static/assets/otp24/copy.png" alt="">
                      </button>
                    <% } %>
                  </div>
                </td>

                <td>
                <% if (HAS_OTP(o.otp)) { %>
                  <div class="otp">OTP : <b><%= String(o.otp).trim() %></b>
                    <button class="copy" data-copy="<%= String(o.otp).trim() %>" aria-label="คัดลอก OTP">
                      <img src="/static/assets/otp24/copy.png" alt="" />
                    </button>
                  </div>
                <% } else { %>
                  <div class="otp none">OTP : <span class="muted">ไม่พบข้อความ</span></div>
                <% } %>
                <div class="ts">
                  <%= new Intl.DateTimeFormat('sv-SE', {
                        timeZone: 'Asia/Bangkok',
                        year: 'numeric', month: '2-digit', day: '2-digit',
                        hour: '2-digit', minute: '2-digit', second: '2-digit',
                        hour12: false
                      }).format(new Date(o.createdAt)) %>
                </div>
                </td>

                <td class="center">฿ <%= Number(o.salePrice||0).toFixed(2) %></td>

                <td class="right">
                  <div class="status-stack">
                    <span class="pill <%= st %>">
                      <%= st==='success'   ? 'สำเร็จ'
                      : st==='refunded'  ? 'คืนเครดิต'
                      : st==='timeout'   ? 'คืนเครดิต'
                      : st==='failed'    ? 'คืนเครดิต'
                      : 'กำลังรอ OTP' %>
                    </span>

                    <!-- <% if (st==='success') { %>
                      <button
                        class="pill warn btn-reuse"
                        data-orderid="<%= o.orderId %>"
                        data-app="<%= o.appName %>"
                        data-number="<%= o.phone %>"
                        data-price="<%= (Number(o.providerPrice || 0) * 2.7).toFixed(2) %>"
                        data-ct="<%= Number(o.countryId||0) %>">
                        ใช้เบอร์เดิม
                      </button>
                    <% } %> -->

                    <% if (st==='processing') { %>
                      <div class="countdown">
                        ไม่ได้รับ OTP ใน 10 นาที ระบบคืนเครดิตอัตโนมัติ
                      </div>
                    <% } %>
                  </div>
                </td>
            </tr>
            <% }) %>
            </tbody>
        </table>
        </div>

        <!-- ── Mobile: pagination controls (inside section-orders) ── -->
        <div class="orders-controls mobile-only" id="ordersControlsMobile">
        <div class="left">
            แสดง
            <select id="perPageSelectMobile">
            <option value="10">10</option>
            <option value="20" selected>20</option>
            <option value="50">50</option>
            <option value="100">100</option>
            </select>
            รายการ/หน้า
        </div>
        <div class="right pager">
            <button class="pg-btn" data-act="first">«</button>
            <button class="pg-btn" data-act="prev">‹</button>
            <span id="pageInfoMobile">หน้า 1/1</span>
            <button class="pg-btn" data-act="next">›</button>
            <button class="pg-btn" data-act="last">»</button>
        </div>
    </div>
    <!-- ลิสต์แบบมือถือ (แสดงเฉพาะจอเล็ก) -->
    <div id="mOrders" class="m-orders">
    <% (orders||[]).forEach(o => { 
        const rawSt = String(o.status || 'processing').toLowerCase();
        const st = (rawSt === 'success' && !HAS_OTP(o.otp)) ? 'processing' : rawSt;
        const createdStr = new Intl.DateTimeFormat('sv-SE', {
          timeZone: 'Asia/Bangkok',
          year: 'numeric', month: '2-digit', day: '2-digit',
          hour: '2-digit', minute: '2-digit', second: '2-digit',
          hour12: false
        }).format(new Date(o.createdAt));
        const phoneStr = o.phone
        ? (Number(o.countryId)===52 ? String(o.phone).replace(/^\+?66/,'0') : String(o.phone))
        : '-';
    %>
    <div class="m-item collapsed"
        data-orderid="<%= o.orderId %>"
        data-ct="<%= Number(o.countryId||0) %>"
        data-expires="<%= o.expiresAt ? new Date(o.expiresAt).toISOString() : '' %>">
        <!-- หัวการ์ด: แตะตรงไหนก็พับ/กาง -->
        <div class="m-head">
          <div class="row1">
              <div class="oid mono"><%= o.orderId %></div>
              <div class="when mono"><%= createdStr %></div>
              <button class="toggle" aria-label="toggle" type="button">+</button>
          </div>
          <div class="row2">
            <div class="appmobile">
              แอป: <span class="v"><%= o.appName || '—' %></span>
            </div>

            <div class="phone mono">
              เบอร์: <span class="v"><%= phoneStr %></span>
              <% if (o.phone) { %>
                <button class="copy" data-copy="<%= phoneStr %>" aria-label="คัดลอกเบอร์">
                  <img src="/static/assets/otp24/copy.png" alt="">
                </button>
              <% } %>
            </div>

            <% if (HAS_OTP(o.otp)) { %>
              <div class="otp">OTP: <b class="v"><%= String(o.otp).trim() %></b>
                <button class="copy" data-copy="<%= String(o.otp).trim() %>" aria-label="คัดลอก OTP">
                  <img src="/static/assets/otp24/copy.png" alt="">
                </button>
              </div>
            <% } else { %>
              <div class="otp none">OTP: <span class="muted v">ไม่พบข้อความ</span></div>
            <% } %>
          </div>
        </div>

        <!-- เนื้อหาเมื่อกาง -->
        <div class="m-body">
          <div class="pair">
            <span>สถานะ</span>
            <span>
              <div class="status-stack">
                <span class="pill <%= st %>">
                  <%= st==='success'   ? 'เสร็จสิ้น'
                  : st==='refunded'  ? 'คืนเครดิต'
                  : st==='timeout'   ? 'คืนเครดิต'
                  : st==='failed'    ? 'คืนเครดิต'
                  : 'กำลังรอ OTP' %>
                </span>

                <!-- <% if (st==='success') { %>
                  <button
                    class="pill warn btn-reuse"
                    data-orderid="<%= o.orderId %>"
                    data-app="<%= o.appName %>"
                    data-number="<%= o.phone %>"
                    data-price="<%= (Number(o.providerPrice || 0) * 2.7).toFixed(2) %>"
                    data-ct="<%= Number(o.countryId||0) %>">
                    ใช้เบอร์เดิม
                  </button>
                <% } %> -->

                <% if (st==='processing') { %>
                  <div class="countdown">
                    ไม่ได้รับ OTP ใน 10 นาที ระบบคืนเครดิตอัตโนมัติ
                  </div>
                <% } %>
              </div>
            </span>
          </div>
        </div>
    </div>
    <% }) %>
    </div>
    </section>

</section>

<dialog id="reuseModal">
  <form method="dialog" class="modal modal-reuse">
    <h2 class="modal-title">คุณขอ OTP เบอร์เดิม อีกครั้ง ?</h2>
    <div class="modal-divider"></div>

    <div class="kv">
      <div class="k">APP :</div>
      <div class="v" id="reuseApp">—</div>

      <div class="k">เบอร์ :</div>
      <div class="v mono phone-line">
          <span id="reuseNumber">—</span>
          <img id="reuseFlag" alt="" style="width:20px;height:14px;border-radius:3px;vertical-align:middle;display:none;">
        </span>
      </div>

      <div class="k">ราคา :</div>
      <div class="v"><span id="reusePrice">—</span> บาท</div>
    </div>

