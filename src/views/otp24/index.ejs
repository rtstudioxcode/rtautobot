<script id="otp24-custom-dropdown-layer-fix-script">
(function(){
  const SELECT_IDS = ['perPageSelect','perPageSelectMobile'];
  let openMenu = null;
  let openHost = null;

  const isLightTheme = () => {
    const html = document.documentElement;
    const body = document.body;
    const flags = [
      html.getAttribute('data-theme'),
      body?.getAttribute('data-theme'),
      body?.className || ''
    ].join(' ').toLowerCase();
    return flags.includes('light') || flags.includes('theme-light');
  };

  function closeDropdown(){
    if (openMenu) openMenu.remove();
    if (openHost) openHost.classList.remove('is-open');
    openMenu = null;
    openHost = null;
  }

  function syncAllLabels(value){
    SELECT_IDS.forEach(id => {
      const sel = document.getElementById(id);
      if (!sel) return;
      if (value != null) sel.value = String(value);
      const host = sel.__otp24DropdownHost;
      const label = host?.querySelector('.otp24-dd-value');
      if (label) label.textContent = sel.options[sel.selectedIndex]?.textContent?.trim() || sel.value || '-';
    });
  }

  function positionMenu(host, menu){
    const r = host.getBoundingClientRect();
    const margin = 8;
    const minW = Math.max(r.width, 104);
    menu.style.minWidth = `${minW}px`;
    menu.style.left = `${Math.min(Math.max(margin, r.left), window.innerWidth - minW - margin)}px`;

    // ต้อง append ก่อนเพื่อวัดความสูงจริง
    const mh = menu.offsetHeight || 220;
    let top = r.bottom + 8;
    if (top + mh + margin > window.innerHeight) {
      top = Math.max(margin, r.top - mh - 8);
    }
    menu.style.top = `${top}px`;
  }

  function openDropdown(sel){
    const host = sel.__otp24DropdownHost;
    if (!host) return;

    if (openHost === host) {
      closeDropdown();
      return;
    }

    closeDropdown();
    host.classList.add('is-open');
    openHost = host;

    const menu = document.createElement('div');
    menu.className = 'otp24-dd-menu';
    menu.setAttribute('role','listbox');
    menu.dataset.owner = sel.id;
    if (isLightTheme()) menu.dataset.theme = 'light';

    Array.from(sel.options).forEach(opt => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'otp24-dd-option' + (opt.selected ? ' is-active' : '');
      btn.setAttribute('role','option');
      btn.setAttribute('aria-selected', opt.selected ? 'true' : 'false');
      btn.dataset.value = opt.value;
      btn.textContent = opt.textContent.trim();
      btn.addEventListener('click', () => {
        const value = btn.dataset.value;
        sel.value = value;
        syncAllLabels(value);
        sel.dispatchEvent(new Event('change', { bubbles:true }));
        closeDropdown();
      });
      menu.appendChild(btn);
    });

    document.body.appendChild(menu);
    openMenu = menu;
    positionMenu(host, menu);

    const active = menu.querySelector('.is-active');
    if (active) active.scrollIntoView({ block:'nearest' });
  }

  function enhanceSelect(sel){
    if (!sel || sel.__otp24DropdownReady) return;
    sel.__otp24DropdownReady = true;
    sel.classList.add('otp24-native-select-hidden');
    sel.tabIndex = -1;
    sel.setAttribute('aria-hidden','true');

    const host = document.createElement('span');
    host.className = 'otp24-dd';
    host.innerHTML = `
      <button type="button" class="otp24-dd-btn" aria-haspopup="listbox" aria-expanded="false">
        <span class="otp24-dd-value"></span>
        <span class="otp24-dd-arrow" aria-hidden="true">▾</span>
      </button>`;
    sel.insertAdjacentElement('afterend', host);
    sel.__otp24DropdownHost = host;

    const btn = host.querySelector('.otp24-dd-btn');
    const setExpanded = () => btn.setAttribute('aria-expanded', host.classList.contains('is-open') ? 'true' : 'false');

    btn.addEventListener('click', (ev) => {
      ev.preventDefault();
      ev.stopPropagation();
      openDropdown(sel);
      requestAnimationFrame(setExpanded);
    });

    btn.addEventListener('keydown', (ev) => {
      if (['Enter',' ','ArrowDown','ArrowUp'].includes(ev.key)) {
        ev.preventDefault();
        openDropdown(sel);
        requestAnimationFrame(setExpanded);
      }
      if (ev.key === 'Escape') closeDropdown();
    });

    sel.addEventListener('change', () => syncAllLabels(sel.value));
    syncAllLabels(sel.value);
  }

  function initOtp24Dropdowns(){
    SELECT_IDS.forEach(id => enhanceSelect(document.getElementById(id)));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initOtp24Dropdowns);
  } else {
    initOtp24Dropdowns();
  }

  document.addEventListener('click', (ev) => {
    if (ev.target.closest('.otp24-dd-menu') || ev.target.closest('.otp24-dd')) return;
    closeDropdown();
  }, true);
  window.addEventListener('resize', closeDropdown, { passive:true });
  window.addEventListener('scroll', closeDropdown, { passive:true, capture:true });
  document.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape') closeDropdown();
  });
})();
</script>


