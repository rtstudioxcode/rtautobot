/* เฉพาะธงในตารางประวัติเท่านั้น */
.orders-wrap td .badge.app{ vertical-align: middle; }

.orders-wrap td .flag{
  display: inline-block;
  vertical-align: middle;   /* จับให้อยู่ระนาบเดียวกับป้ายแอพ */
  margin-left: 8px;         /* ระยะห่างจากป้าย */
  width: 24px;              /* ปรับได้ตามใจ */
  height: 18px;
  background: transparent !important;
  border: none !important;
  padding: 0;
  line-height: 0;           /* กันเด้ง */
  transform: translateY(1px); /* จูนตำแหน่งนิดหน่อย (0~2px) */
}

.orders-wrap td .flag img{
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  border-radius: 4px;
}

.orders-controls{
  margin-top: 10px;
  margin-bottom: 8px;
