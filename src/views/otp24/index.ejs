<script id="otp24-enterprise-modal-portal">
(function(){
  function portalToBody(id){
    var el = document.getElementById(id);
    if (!el || el.parentNode === document.body) return;
    document.body.appendChild(el);
  }

  function enhanceDialogBackdropClose(id){
    var dlg = document.getElementById(id);
    if (!dlg || dlg.__otp24Enhanced) return;
    dlg.__otp24Enhanced = true;
    dlg.addEventListener('click', function(e){
      if (e.target === dlg) {
        try { dlg.close(); } catch(_) {}
      }
    });
  }

  function boot(){
    ['buyModal','reuseModal','otpNoticeModal','termsModal'].forEach(portalToBody);
    ['buyModal','reuseModal','otpNoticeModal'].forEach(enhanceDialogBackdropClose);
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
  else boot();

  // กันบาง script เปิด modal ก่อน DOMContentLoaded
  setTimeout(boot, 0);
  setTimeout(boot, 250);
})();
</script>

