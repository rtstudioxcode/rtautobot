  text-align: center;                   /* จัดข้อความให้อยู่กลาง */
}
.modal-reuse .kv .k{
  font-weight: 800;
  opacity: .95;
  min-width: 78px;                      /* ความกว้าง label ใกล้เคียงภาพ */
}
.modal-reuse .kv .v{ white-space: nowrap; }

.modal-reuse .phone-line{
  display: inline-flex;
  align-items: center;
  justify-content: center;              /* เบอร์+ธงกึ่งกลางแนวนอน */
  gap: 8px;
}

.flag-ic-wrap{ display: inline-flex; align-items: center; }
.flag-ic{
  width: 28px; height: 20px;
  border-radius: 4px; object-fit: cover;
  display: inline-block;
  transform: translateY(1px);
}
.flag-emoji{ font-size: 18px; line-height: 1; transform: translateY(1px); }

/* ปุ่มคู่ล่าง */
.modal-reuse .actions{ display:flex; gap:16px; justify-content:center; }
.modal-reuse .btn{
  min-width:120px; height:42px;
  border-radius:12px; font-weight:400; letter-spacing:.2px;
}
.modal-reuse .modal-primary{
  background: linear-gradient(180deg, #ff9a55 0%, #ff7f2f 100%);
  color:#fff; border:1px solid rgba(255,132,58,.55);
  box-shadow: 0 6px 18px rgba(255,132,58,.35), inset 0 1px 0 rgba(255,255,255,.25);
}
.modal-reuse .modal-primary:hover{ filter:brightness(1.04); transform:translateY(-1px); }
.modal-reuse .modal-secondary{
  background: transparent;
  color: var(--text-primary,#fff);
  border: 1px solid rgba(255,132,58,.45);
  box-shadow: 0 0 0 2px rgba(255,132,58,.15) inset;
}
.modal-reuse .modal-secondary:hover{ background: rgba(255,132,58,.08); }

/* รองรับธีมสว่าง */
:root[data-theme="light"] .modal-reuse,
html[data-theme="light"] .modal-reuse{
  background:#1b1d22;   /* คอนทราสต์แบบภาพตัวอย่าง */
  color:#f5f7fb;
  border-color:#2c2f37;
}
:root[data-theme="light"] dialog::backdrop,
html[data-theme="light"] dialog::backdrop{
  background: rgba(0,0,0,.35);
  backdrop-filter: blur(2px);
}
#reuseFlag:not([src]){ display:none; }
/* ===== Mobile: สถานะ + ใช้เบอร์เดิม อยู่บรรทัดเดียวกัน ===== */
@media (max-width:640px){
  /* เปลี่ยน status-stack จากคอลัมน์ → แถว */
  .m-orders .status-stack{
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;          /* ถ้าพื้นที่แคบ ให้ตกรางสวยๆ */
  }

  /* ปุ่มใช้เบอร์เดิมให้กะทัดรัดขึ้น */
  .m-orders .status-stack .btn-reuse{
    margin: 0;
    padding: 6px 10px;
    line-height: 1.1;
  }

  /* ตัวนับถอยหลังให้อยู่บรรทัดถัดไปใต้แถวเดียวกัน */
  .m-orders .status-stack + .countdown{
    width: 100%;
    margin-top: 6px;
  }
}

/* เดสก์ท็อปยังคงเรียงเป็นคอลัมน์เหมือนเดิม */
@media (min-width:641px){
  .status-stack{
    display: flex;
    flex-direction: column;
    align-items: end;
    gap: 8px;
  }
}

.flash { animation: otpFlash 800ms ease-in-out 1; }
@keyframes otpFlash {
  0% { background: transparent; }
  25% { background: rgba(16,185,129,.22); }
  100% { background: transparent; }
}

/* =========================
   THEME TOKENS (Light / Dark)
   วางต่อท้ายไฟล์เดิม
   ========================= */

/* Dark (คงโทนเดิม แต่รวม token เพิ่มให้ครบ) */
html[data-theme="dark"] {
  --page-bg:          #0f1115;
  --page-text:        #f2f4f8;

  --elevated-bg:      #141518;
  --elevated-bg-2:    #17181b;  /* การ์ด/กล่อง */
  --elevated-border:  #24262b;
  --elevated-shadow:  0 12px 30px rgba(0,0,0,.40);

  --text-primary:     #f2f4f8;
  --text-muted:       #a7b0bb;

  --accent:           #2a84ff;
  --accent-contrast:  #ffffff;

  --brand-warm:       #00c3ff2a;
  --brand-warm-ink:   #09f51d;

  --success:          #10b981;
  --warn:             #f59e0b;
  --danger:           #ef4444;

  --pill-success-bg:  color-mix(in oklab, #10b981 20%, transparent);
  --pill-warn-bg:     color-mix(in oklab, #f59e0b 20%, transparent);
  --pill-info-bg:     color-mix(in oklab, #22c5f6 26%, transparent);
}

/* Light — โทน “ไม่ขาวล้วน” นุ่มตา + คอนทราสต์ชัด */
html[data-theme="light"] {
  --page-bg:          #f6f8fc;   /* พื้นหลังทั้งหน้า */
  --page-text:        #1f2328;

  /* การ์ด/กล่อง: ขาวอมฟ้าเล็กน้อย + เงาบาง */
  --elevated-bg:      #ffffff;
  --elevated-bg-2:    color-mix(in oklab, #ffffff, #e9f0ff 7%);
  --elevated-border:  #e3e8f3;
  --elevated-shadow:  0 12px 26px rgba(15,32,75,.10);

  --text-primary:     #1f2328;
  --text-muted:       #687284;

  /* น้ำเงินสด + ตัดกับพื้นอ่อน */
  --accent:           #2a84ff;
  --accent-contrast:  #ffffff;

  /* วอร์มโทนสำหรับ badge/pill */
  --brand-warm:       #00c3ff2a;
  --brand-warm-ink:   #09f51d;

  --success:          #12a86b;
  --warn:             #b36500;
  --danger:           #d92b2b;

  /* พื้น pill แบบทินท์สี อ่านง่ายในพื้นสว่าง */
  --pill-success-bg:  color-mix(in oklab, #12a86b 18%, #ffffff 88%);
  --pill-warn-bg:     color-mix(in oklab, #ffb955 26%, #ffffff 84%);
  --pill-info-bg:     color-mix(in oklab, #2a84ff 24%, #ffffff 84%);
}

/* พื้นหลัง/ตัวหนังสือรวมหน้า */
body, .page, .otp24 {
  background: var(--page-bg);
  color: var(--text-primary);
}

/* การ์ด/กล่องหลัก */
.card,
.card2,
.card.app,
.m-item,
.modal,
.modal-otp24,
.modal-reuse {
  background: var(--elevated-bg-2);
  border: 1px solid var(--elevated-border);
  box-shadow: var(--elevated-shadow);
  color: var(--text-primary);
}

/* หัวการ์ด/แถบหัวตาราง (ให้ดูไม่กลืนในธีมสว่าง) */
.tbl thead th {
  background: color-mix(in oklab, var(--elevated-bg), #e9f0ff 10%);
  color: var(--text-primary);
  border-bottom-color: var(--elevated-border);
}

/* ตาราง/คอนโทรลทั่วไป */
.tbl th, .tbl td {
  color: var(--text-primary);
  border-bottom: 1px solid var(--elevated-border);
}
.orders-controls select,
.pg-btn {
  background: var(--elevated-bg);
  color: var(--text-primary);
  border: 1px solid var(--elevated-border);
}

/* ป้ายราคา/แอป (badge อุ่น ๆ) */
.price-badge,
.badge.app {
  background: var(--brand-warm);
  color: var(--brand-warm-ink);
  border: 1px solid color-mix(in oklab, var(--brand-warm), black 12%);
}

/* ปุ่มหลัก/รอง — เคารพธีมสว่าง/มืด */
.btn {
  background: var(--accent);
  color: var(--accent-contrast);
  border: 1px solid color-mix(in oklab, var(--accent), black 18%);
}
.btn:hover { filter: brightness(1.04); }
.btn:active { filter: none; }

.btn.ghost {
  background: transparent;
  color: var(--text-primary);
  border: 1px solid var(--elevated-border);
}
html[data-theme="light"] .btn.ghost:hover {
  background: color-mix(in oklab, var(--page-bg), black 4%);
}

/* ปุ่มใน .modal-otp24 / .modal-reuse — ใช้โทนอุ่น-น้ำเงินให้อ่านชัดใน Light */
.modal-otp24 .modal-primary,
.modal-reuse .modal-primary {
  background: linear-gradient(180deg, #ff9a55 0%, #ff7f2f 100%);
  color: #fff;
  border: 1px solid rgba(255,132,58,.55);
  box-shadow: 0 6px 18px rgba(255,132,58,.30);
}
.modal-otp24 .modal-secondary,
.modal-reuse  .modal-secondary {
  background: transparent;
  color: var(--text-primary);
  border: 1px solid color-mix(in oklab, var(--brand-warm), #ffffff 40%);
  box-shadow: 0 0 0 2px color-mix(in oklab, var(--brand-warm), transparent 85%) inset;
}

/* Dialog / Backdrop */
dialog { border: none; background: transparent; }
dialog::backdrop {
  background: rgba(0,0,0,.55);
  backdrop-filter: blur(2px);
}
html[data-theme="light"] dialog::backdrop {
  background: rgba(0,0,0,.35);
}

/* Pill สถานะ — ผูกกับตัวแปรให้ดูเด้งใน Light */
.pill.success   { background: var(--pill-success-bg); color: var(--success); }
.pill.processing{ background: var(--pill-warn-bg);    color: var(--warn); }
.pill.failed,
.pill.timeout,
.pill.refunded  { background: var(--pill-info-bg);    color: #09daff; }

/* Countdown สีเตือนใน Light ให้ชัดขึ้น */
.countdown       { color: var(--text-muted); }
.countdown.warn  { color: color-mix(in oklab, var(--warn), black 10%); }
.countdown.danger{ color: color-mix(in oklab, var(--danger), black 5%); }

/* ธง (table/mobile) โปร่งใส + คมใน Light */
.orders-wrap .flag,
.m-orders .flag {
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
}
.orders-wrap .flag img,
.m-orders .flag img { border-radius: 6px; }

/* โฟกัส/โฮเวอร์การ์ดแอปให้ชัดเจนใน Light */
.card.app {
  transition: transform .08s ease, box-shadow .12s ease, border-color .12s ease;
}
.card.app:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 26px rgba(30,107,224,.18);
  border-color: color-mix(in oklab, var(--accent), transparent 60%);
}

/* ตารางประวัติ: ชื่อ/ป้าย + ธง จูน baseline ให้เนียน */
.orders-wrap td .badge.app { vertical-align: middle; }
.orders-wrap td .flag {
  display: inline-block;
  vertical-align: middle;
  margin-left: 8px;
  width: 24px; height: 18px;
  line-height: 0;
  transform: translateY(1px);
}

/* ===== Tabs: แบบเส้นใต้ยาวทั้งแถว ===== */
.tabs{
  display:flex;
  justify-content:space-between;
  align-items:flex-end;
  gap:0;
  margin:0 0 12px;
  border-bottom:1px solid #2b2b2f;  /* เส้นเทาเข้มยาวทั้งแถว */
  position:relative;
}

.tab{
  flex:1 1 0;
  background:transparent;
  border:0;
  border-radius:0;
  padding:8px 0 10px;
  text-align:center;
  cursor:pointer;

  font-size:13px;
  font-weight:500;
  letter-spacing:.3px;
  color:#e3b863;                 /* สีทองกลาง ๆ เหมือนเมนู */
  position:relative;
  transition:color .15s ease;
}

/* เส้นทองใต้แท็บที่ active */
.tab::after{
  content:"";
  position:absolute;
  left:0;
  right:0;
  bottom:-1px;
  height:2px;
  background:transparent;
  transition:background-color .18s ease, transform .18s ease;
  transform-origin:left;
  transform:scaleX(0);
}

/* hover แค่เน้นตัวหนังสือ */
.tab:hover{
  color:#ffd47a;
}

/* แท็บที่เลือกอยู่ */
.tab.active{
  color:#ffd47a;
}

.tab.active::after{
  background:#e3b863;
  transform:scaleX(1);          /* เส้นทองเต็มความกว้าง */
}

/* ซ่อน/โชว์เนื้อหาแท็บ */
.tabpane{ display:none; }
.tabpane.show{ display:block; animation: tabFadeIn .22s ease; }
@keyframes tabFadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }


.otp24 .tabpane{
  transform-origin: 50% 0;
  will-change: opacity, transform, filter;
}
.otp24.tab-switching .tabpane.show{
  animation: otp24SmoothIn .32s cubic-bezier(.2,.8,.2,1) both;
}
@media (prefers-reduced-motion: reduce){
  .otp24.tab-switching .tabpane.show,
  .tabpane.show{ animation:none !important; }
  .otp24-route-loader__ring{ animation:none !important; }
}

/* ============================================
   TERMS MODAL (Dark/Light Theme Aware)
   ============================================ */
.bt-terms-modal.hidden { display: none; }

.bt-terms-modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: inherit;
}

/* Backdrop */
.bt-terms-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,.55);
  backdrop-filter: blur(3px);
}

/* Dialog box */
.bt-terms-dialog {
  position: relative;
  z-index: 2;
  width: 92%;
  max-width: 520px;

  /* ใช้โทเคนธีมเดียวกับระบบ */
  background: var(--elevated-bg);
  color: var(--text-primary);
  border: 1px solid var(--elevated-border);
  box-shadow: var(--elevated-shadow);

  padding: 26px 28px 22px;
  border-radius: 16px;

  animation: fadeZoom .18s ease;
}

/* Light mode — ปรับให้ contrast ดีขึ้น */
html[data-theme="light"] .bt-terms-dialog {
  background: var(--elevated-bg-2);
  border-color: var(--elevated-border);
  box-shadow: 0 12px 26px rgba(15,32,75,.10);
}

/* Anim */
@keyframes fadeZoom {
  from { opacity:0; transform:scale(.92); }
  to   { opacity:1; transform:scale(1); }
}

/* Title */
.bt-terms-title {
  font-size: 20px;
  font-weight: 800;
  margin-bottom: 14px;
  text-align: center;
}

/* Scrollable text */
.bt-terms-body {
  max-height: 340px;
  overflow-y: auto;
  padding-right: 6px;
  font-size: 15px;
  line-height: 1.55;
  color: var(--text-primary);
}

.bt-terms-body strong {
  color: var(--accent);
  font-weight: 700;
}

/* Checkbox row */
.accept-row {
  display: flex;
  gap: 10px;
  align-items: center;
  margin-top: 14px;
  font-size: 14px;
  color: var(--text-primary);
}

.accept-row input[type="checkbox"] {
  width: 18px;
  height: 18px;
  accent-color: var(--accent);
}

/* Buttons */
.bt-terms-actions {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  margin-top: 20px;
}

/* Confirm */
.bt-terms-actions .btn-primary {
  flex: 1;
  background: linear-gradient(180deg, #2a84ff 0%, #1e6be0 100%);
  color: #fff;
  border: 1px solid rgba(30,107,224,.3);
  padding: 10px 0;
  border-radius: 10px;
  font-weight: 500;
  box-shadow: 0 6px 16px rgba(42,132,255,.35);
  cursor: pointer;
  text-align: center;
}

.bt-terms-actions .btn-primary:disabled {
  opacity: .55;
  cursor: not-allowed;
  filter: grayscale(.4);
}

/* Cancel */
.bt-terms-actions .btn-secondary {
  flex: 1;
  background: #e11d48;
  color: #fff;
  padding: 10px 0;
  border-radius: 10px;
  text-align: center;
  font-weight: 500;
  cursor: pointer;
  border: none;
}

.bt-terms-actions .btn-secondary:hover {
  filter: brightness(1.06);
}

/* Mobile */
@media (max-width: 640px){
  .bt-terms-dialog {
    max-width: 92vw;
    padding: 20px 22px 18px;
  }
  .bt-terms-title { font-size: 18px; }
  .bt-terms-body { max-height: 300px; }
}


/* =========================================================
   OTP24 PRO SAAS UI OVERRIDE — production lightweight layer
   ใช้ตัวแปรสีจาก layout.ejs / theme เดิม ไม่เพิ่มภาระ server
   ========================================================= */
:root{
  --otp-accent: var(--accent, #f6c65b);
  --otp-page: var(--page, #07090d);
  --otp-card: color-mix(in srgb, var(--card, #12161d) 86%, transparent);
  --otp-card2: color-mix(in srgb, var(--card, #161b23) 74%, var(--page, #07090d));
  --otp-text: var(--text, #f7f8fb);
  --otp-muted: var(--muted, #99a3b3);
  --otp-border: color-mix(in srgb, var(--border, rgba(255,255,255,.12)) 75%, transparent);
  --otp-border-strong: color-mix(in srgb, var(--otp-accent) 35%, var(--otp-border));
  --otp-glow: color-mix(in srgb, var(--otp-accent) 28%, transparent);
  --otp-blue: #2f9bff;
  --otp-green: #00e676;
  --otp-red: #ff4d61;
  --otp-radius: 22px;
}

.page.otp24{
  min-height: calc(100vh - 74px);
  padding: clamp(12px, 1.6vw, 28px);
  color: var(--otp-text);
  background:
    radial-gradient(900px 420px at 12% -10%, color-mix(in srgb, var(--otp-accent) 18%, transparent), transparent 62%),
    radial-gradient(900px 420px at 92% 2%, rgba(47,155,255,.13), transparent 60%),
    linear-gradient(180deg, color-mix(in srgb, var(--otp-page) 92%, #111827), var(--otp-page));
  isolation: isolate;
}
.page.otp24::before{
  content:"";
  position: fixed;
  inset: 0;
  pointer-events: none;
  opacity: .28;
  z-index: -1;
  background-image:
    linear-gradient(color-mix(in srgb, var(--otp-border) 40%, transparent) 1px, transparent 1px),
    linear-gradient(90deg, color-mix(in srgb, var(--otp-border) 40%, transparent) 1px, transparent 1px);
  background-size: 48px 48px;
  mask-image: linear-gradient(to bottom, black, transparent 76%);
}

/* Header / top statement */
.page.otp24 > .topbar,
.page.otp24 > .hero,
.otp24-hero{
  border: 1px solid var(--otp-border);
  border-radius: calc(var(--otp-radius) + 4px);
  background:
    linear-gradient(135deg, color-mix(in srgb, var(--otp-card) 96%, transparent), color-mix(in srgb, var(--otp-card2) 88%, transparent)),
    radial-gradient(420px 180px at 18% 0%, var(--otp-glow), transparent 72%);
  box-shadow: 0 24px 80px rgba(0,0,0,.28);
  backdrop-filter: blur(14px);
}

.tabs{
  position: sticky;
  top: 0;
  z-index: 20;
  display: grid;
  grid-template-columns: repeat(2, minmax(0,1fr));
  gap: 10px;
  padding: 8px;
  margin: 0 0 14px;
  border: 1px solid var(--otp-border);
  border-radius: 18px;
  background: color-mix(in srgb, var(--otp-card) 82%, transparent);
  box-shadow: 0 14px 42px rgba(0,0,0,.22);
  backdrop-filter: blur(18px);
}
.tab{
  position: relative;
  border: 0;
  border-radius: 14px;
  min-height: 48px;
  cursor: pointer;
  color: var(--otp-muted);
  font-weight: 900;
  letter-spacing: .02em;
  background: transparent;
  transition: transform .18s ease, color .18s ease, background .18s ease, box-shadow .18s ease;
  overflow: hidden;
}
.tab::after{
  content:"";
  position:absolute;
  inset:auto 12px 7px;
  height:2px;
  border-radius:999px;
  background: linear-gradient(90deg, transparent, var(--otp-accent), transparent);
  transform: scaleX(0);
  transition: transform .22s ease;
}
.tab:hover{ transform: translateY(-1px); color: var(--otp-text); background: color-mix(in srgb, var(--otp-accent) 8%, transparent); }
.tab.active{
  color: color-mix(in srgb, var(--otp-accent) 88%, #fff);
  background: linear-gradient(180deg, color-mix(in srgb, var(--otp-accent) 16%, transparent), color-mix(in srgb, var(--otp-accent) 5%, transparent));
  box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--otp-accent) 34%, transparent), 0 12px 32px color-mix(in srgb, var(--otp-accent) 10%, transparent);
}
.tab.active::after{ transform: scaleX(1); }
.tab:active{ transform: scale(.985); }

.tabpane{
  min-height: 62vh;
}
.tabpane.show,
.tabpane.active{
  /* display:block handled above; animation via tabFadeIn */
}

.input,
input[type="search"],
input[type="text"],
select{
  border: 1px solid var(--otp-border) !important;
  border-radius: 16px !important;
  color: var(--otp-text) !important;
