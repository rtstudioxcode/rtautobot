<script>
(function(){
  const KEY = 'otp_notice_suppress_until_v1'; // localStorage key
  const modal = document.getElementById('otpNoticeModal');
  const chk = document.getElementById('otpNoticeDontShow');
  const btnClose = document.getElementById('otpNoticeClose');

  function shouldShow(){
    try {
      const v = localStorage.getItem(KEY);
      if (!v) return true;
      const ts = Number(v);
      if (!Number.isFinite(ts)) return true;
      return Date.now() > ts; // show if now past expiry
    } catch(e){
      return true;
    }
  }

  function setSuppressFor1Day(){
    const until = Date.now() + 7 * 24 * 60 * 60 * 1000;
    try { localStorage.setItem(KEY, String(until)); } catch(e){ /* ignore */ }
  }

  // show modal on DOM ready if needed
  document.addEventListener('DOMContentLoaded', ()=>{
    try {
      if (shouldShow()) {
        // wait a tick so dialog styles/backdrop applied nicely
        setTimeout(()=> {
          if (!modal.open) modal.showModal();
        }, 120);
      }
    } catch(e){}
  });

  function closeWithAnimation(){
    if (!modal) return;
    try {
      if (!modal.open) return;
      modal.classList.add('is-closing');
      window.setTimeout(() => {
        try { modal.close(); } catch(e){}
        modal.classList.remove('is-closing');
      }, 220);
    } catch(e){
      try { modal.close(); } catch(_){}
    }
  }

  btnClose?.addEventListener('click', ()=>{
    if (chk && chk.checked) setSuppressFor1Day();
    closeWithAnimation();
  });

  // allow Escape/cancel to close as well but don't set suppression
  modal?.addEventListener('cancel', (ev)=> {
    ev.preventDefault();
    closeWithAnimation();
  });
})();
</script>

<script>
// helper: notify
function notify(title, text, variant='error'){
  if (window.showMsg) {
    window.showMsg({ variant, title, text });
  } else {
    alert(`${title}\n${text}`);
  }
}

/* ----- OTP ----- */
function normalizeOtp(v){
  const s = String(v ?? '').trim();
  if (!s || /^0+$/.test(s)) return null;  // ว่าง / ศูนย์ล้วน = ไม่มี
  return s;
}

/* ----- Tabs: Smooth switch + กัน FOUC ----- */
function setOtpTab(target, opts = {}){
  const next = String(target || 'shop').toLowerCase() === 'orders' ? 'orders' : 'shop';
  const tabs = document.querySelectorAll('.tab');
  const panes = document.querySelectorAll('.tabpane');
  const nextPane = document.getElementById('section-' + next);
  if (!nextPane) return;

  const currentPane = document.querySelector('.tabpane.show');
  const already = currentPane === nextPane;

  document.documentElement.classList.toggle('otp24-start-orders', next === 'orders');
  tabs.forEach(x => x.classList.toggle('active', x.dataset.target === next));

  const apply = () => {
    panes.forEach(x => x.classList.remove('show'));
    nextPane.classList.add('show');
    const root = document.querySelector('.otp24');
    if (root && !already) {
      root.classList.remove('tab-switching');
      void root.offsetWidth;
      root.classList.add('tab-switching');
      setTimeout(() => root.classList.remove('tab-switching'), 360);
    }
    if (typeof applyPagination === 'function') requestAnimationFrame(applyPagination);
  };

  apply();

  if (opts.push) {
    const u = new URL(location.href);
    if (next === 'orders') u.searchParams.set('tab', 'orders');
    else u.searchParams.delete('tab');
    history.replaceState(null, '', u.pathname + u.search + u.hash);
  }
}

document.querySelectorAll('.tab').forEach(t=>{
  t.addEventListener('click', () => setOtpTab(t.dataset.target, { push:true }));
});

requestAnimationFrame(() => {
  const u = new URL(location.href);
  if (u.searchParams.get('tab') === 'orders' || location.hash.replace('#','') === 'orders') setOtpTab('orders');
  else setOtpTab('<%= OTP_INITIAL_TAB %>');
});

/* ----- Buy flow ----- */
let chosen = { productId:null, countryId:null, name:'', price:0 };
function openBuyModal(id, name, price){
  chosen = { productId:id, countryId:null, name, price };
  document.getElementById('selApp').textContent   = `รายการ : ${name}`;
  document.getElementById('selPrice').textContent = `ราคา : ${price.toFixed(2)} บาท`;
  document.querySelectorAll('#buyModal .flag').forEach(b=>b.classList.remove('active'));
  document.getElementById('btnConfirm').disabled = true;
  document.getElementById('buyModal').showModal();
}
document.querySelectorAll('#buyModal .flag-btn').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    document.querySelectorAll('#buyModal .flag-btn').forEach(b=>b.classList.remove('active','selected'));
    btn.classList.add('active','selected');       // ← ใช้คู่กับ CSS ด้านบน
    chosen.countryId = Number(btn.dataset.ct);
    document.getElementById('btnConfirm').disabled = false;
  });
});
// สลับแท็บไป "ประวัติ"
function goOrdersTab(){
  setOtpTab('orders', { push:true });
}

function goOtpOrdersPage(url){
  const target = url || '/otp24?tab=orders';
  try { document.body.classList.add('otp24-navigating'); } catch(_) {}
  // ไปหน้าเป้าหมายโดยตรง ไม่ reload หน้าปัจจุบันก่อน จึงไม่เกิดช่วง style แตก 1 วิ
  window.location.replace(target);
}

// โพลลิ่งเช็คสถานะออเดอร์ทุก 1 วิ จนจบ
const POLL_DONE = new Set(['success', 'refunded', 'timeout', 'failed', 'canceled']);
const pollers = new Map();
const OTP24_SINGLE_POLL_MS = 6000;
const OTP24_LIST_POLL_MS = 15000;
const OTP24_LIST_POLL_HIDDEN_MS = 60000;

function startOrderPolling(orderId){
  if (!orderId || pollers.has(orderId)) return;

  // ป้องกันกระพริบ DOM เมื่อได้ OTP แล้ว
  let lastOtp = null;
  let lastStatus = null;

  const updateOtpCell = (tr, patch) => {
    const cell = tr.children[3];
    const nowText = new Date().toISOString().replace('T',' ').slice(0,19);
    const otpVal = normalizeOtp(patch.otp);

    if (otpVal && otpVal !== lastOtp) {
      lastOtp = otpVal;
      cell.innerHTML = `
        <div class="otp">OTP : <b>${otpVal}</b>
          <button class="copy" data-copy="${otpVal}" aria-label="คัดลอก OTP">
            <img src="/static/assets/otp24/copy.png" alt="" />
          </button>
        </div>
        <div class="ts">${nowText}</div>`;
      cell.classList.remove('flash'); void cell.offsetWidth; cell.classList.add('flash');
    } else if (!otpVal && lastOtp == null) {
      cell.innerHTML = `
        <div class="otp none">OTP : <span class="muted">ไม่พบข้อความ</span></div>
        <div class="ts">${nowText}</div>`;
    }
  };

  const updateStatusPill = (tr, patch) => {
    const pill = tr.querySelector('.pill');
    if (!pill) return;
    const st = String(patch.status || '').toLowerCase();
    if (st === lastStatus) return;
    lastStatus = st;

    pill.className = `pill ${st}`;
    pill.textContent =
      st==='success'    ? 'สำเร็จ' :
      st==='processing' ? 'กำลังรอ OTP' :
      st==='timeout'    ? 'คืนเครดิต' :
      st==='failed'     ? 'คืนเครดิต' :
      st==='refunded'   ? 'คืนเครดิต' : 'คืนเครดิต';
  };

  const updatePhoneCells = (tr, patch) => {
    if (!patch.phone) return;

    const ct = Number(tr.dataset.ct || 0);
    const formatted = patch.displayPhone || displayPhoneByCountry(patch.phone, ct);

    // desktop cell
    const cell = tr.children[2];
    const mono = cell.querySelector('.mono .v') || cell.querySelector('.mono');
    if (mono) mono.textContent = formatted;

    let btn = cell.querySelector('.copy');
    if (!btn){
      btn = document.createElement('button');
      btn.className = 'copy';
      btn.setAttribute('aria-label','คัดลอกเบอร์');
      btn.innerHTML = `<img src="/static/assets/otp24/copy.png" alt="">`;
      (cell.querySelector('.mono') || cell).appendChild(btn);
    }
    btn.dataset.copy = formatted;

    // mobile card
    const mCard = document.querySelector(`.m-orders .m-item[data-orderid="${orderId}"]`);
    if (mCard){
      const el = mCard.querySelector('.row2 .phone .v');
      if (el) el.textContent = formatted;
      let mBtn = mCard.querySelector('.row2 .phone .copy');
      if (!mBtn){
        mBtn = document.createElement('button');
        mBtn.className = 'copy';
        mBtn.setAttribute('aria-label','คัดลอกเบอร์');
        mBtn.innerHTML = `<img src="/static/assets/otp24/copy.png" alt="">`;
        el?.after(mBtn);
      }
      mBtn.dataset.copy = formatted;
    }
  };

  const stopThisPolling = () => {
    clearInterval(pollers.get(orderId));
    pollers.delete(orderId);
    const tr = document.querySelector(`tr[data-orderid="${CSS.escape(orderId)}"]`);
    tr?.querySelector('.countdown')?.remove();
    const mCard = document.querySelector(`.m-orders .m-item[data-orderid="${orderId}"]`);
    mCard?.querySelector('.countdown')?.remove();
    if (!hasProcessingRows()) stopOrdersAutoRefresh();
  };

  const tick = async () => {
    try{
      if (document.hidden) return;
      const r = await fetch(`/otp24/orders/${encodeURIComponent(orderId)}/refresh`, { method:'POST' });
      const j = await r.json();
      if (!j?.ok) return;

      const { patch } = j;
      const tr = document.querySelector(`tr[data-orderid="${CSS.escape(orderId)}"]`);
      if (!tr || !patch) return;

      // 1) อัปเดต OTP ทันทีที่มี
      updateOtpCell(tr, patch);

      // 2) อัปเดตสถานะ
      updateStatusPill(tr, patch);

      // 3) อัปเดตเบอร์ถ้ายังไม่เคยโชว์
      updatePhoneCells(tr, patch);

      // 4) หยุดเมื่อ success (ตามสเปคใหม่)
      const st = String(patch.status||'').toLowerCase();
      if (POLL_DONE.has(st)) stopThisPolling();

    }catch{
      // เงียบ ๆ ไป ไม่ให้ user สะดุด
    }
  };

  // เริ่มยิงทันที แล้วค่อยทุก 1 วินาที
  tick();
  const id = setInterval(tick, OTP24_SINGLE_POLL_MS);
  pollers.set(orderId, id);
}

document.getElementById('btnConfirm').addEventListener('click', async (e)=>{
  e.preventDefault();
  if (!chosen.productId || !chosen.countryId) return;
  try{
    const res = await fetch('/otp24/buy', {
      method:'POST',
      headers:{ 'content-type':'application/json', 'accept':'application/json' },
      body: JSON.stringify({ productId: chosen.productId, countryId: chosen.countryId })
    });
    const j = await res.json();
    if (!res.ok || !j?.ok) throw new Error(j?.error || 'สั่งซื้อไม่สำเร็จ');

    goOtpOrdersPage(j.redirect || '/otp24?tab=orders');
  }catch(err){ alert(err.message || err); }
});

/* ----- Utilities ----- */
function setCopyIcon(btn, success) {
  const img = btn.querySelector('img');
  if (!img) return;
  img.src = success
    ? '/static/assets/otp24/copy-success.png'
    : '/static/assets/otp24/copy.png';
}
document.addEventListener('click', (e) => {
  const btn = e.target.closest('.copy');
  if (!btn) return;

  navigator.clipboard.writeText(btn.dataset.copy || '').then(() => {
    setCopyIcon(btn, true);
    // กลับเป็นไอคอนปกติใน 900ms
    setTimeout(() => setCopyIcon(btn, false), 900);
  }).catch(() => {
    // ถ้า copy ไม่ได้ อย่าค้างไอคอน success
    setCopyIcon(btn, false);
  });
});

(() => {
