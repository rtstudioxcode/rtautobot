(() => {
  // เคลียร์ flag เก่าจากเวอร์ชันก่อนหน้า เพื่อไม่ให้เกิด reload/redirect ซ้อน
  if (sessionStorage.getItem('OTP24_AFTER_BUY')) sessionStorage.removeItem('OTP24_AFTER_BUY');
})();

function mmss(ms){
  if (!Number.isFinite(ms) || ms < 0) ms = 0;
  const s = Math.floor(ms/1000);
  const m = String(Math.floor(s/60)).padStart(2,'0');
  const ss = String(s%60).padStart(2,'0');
  return `${m}:${ss}`;
}
function tickCountdowns(){
  const now = Date.now();
  const upd = (el) => {
    const exp = Date.parse(el.dataset.expires || el.getAttribute('data-expires') || '');
    if (!Number.isFinite(exp)) return;
    const left = exp - now;
    el.textContent = left>0 ? `เหลือเวลาอีก ${mmss(left)} นาที` : 'ระบบกำลังคืนเครดิต';
    el.classList.toggle('warn', left>0 && left<=3*60*1000);
    el.classList.toggle('danger', left>0 && left<=60*1000);
  };
  document.querySelectorAll('#ordersBody .countdown').forEach(upd);
  document.querySelectorAll('#mOrders .countdown').forEach(upd);
  // ปรับหมายเลขในตาราง Desktop ให้ถูกต้องตามประเทศ
  document.querySelectorAll('#ordersBody tr').forEach(tr => {
    const ct = Number(tr.dataset.ct || 0);
    const box = tr.children?.[2];
    const mono = box?.querySelector('.mono .v') || box?.querySelector('.mono');
    if (mono){
      const formatted = displayPhoneByCountry(mono.textContent.trim(), ct);
      mono.textContent = formatted;
      const btn = box.querySelector('.copy');
      if (btn) btn.dataset.copy = formatted;
    }
  });

  // ปรับหมายเลขในลิสต์มือถือให้ถูกต้องเหมือนกัน
  document.querySelectorAll('#mOrders .m-item').forEach(card => {
    const ct = Number(card.dataset.ct || 0);
    const el = card.querySelector('.row2 .phone .v');
    if (el){
      const formatted = displayPhoneByCountry(el.textContent.trim(), ct);
      el.textContent = formatted;
      const btn = card.querySelector('.row2 .phone .copy');
      if (btn) btn.dataset.copy = formatted;
    }
  });
}

// ผูกกับลูปรีเฟรชหลัก (ทุก 1 วิอยู่แล้ว)
function startOrdersAutoRefresh(){
  stopOrdersAutoRefresh();
  ORD_AUTO_TIMER = setInterval(async () => {
    if (document.hidden) { tickCountdowns(); return; }
    await refreshProcessingOrdersOnce();
    tickCountdowns();
  }, OTP24_LIST_POLL_MS);
}

function displayPhoneByCountry(rawPhone, countryId){
  if (!rawPhone) return '-';

  // เก็บเฉพาะตัวเลขกับ "+" ไว้พอประมาณ (กันเคสมี space/dash)
  let s = String(rawPhone).trim();

  // ── ไทย: countryId = 52
  if (Number(countryId) === 52) {
    // รูปแบบ +66XXXXXXXX หรือ 66XXXXXXXX → แปลงเป็น 0XXXXXXXX
    if (/^\+?66\d{8,9}$/.test(s)) return s.replace(/^\+?66/, '0');
    // ถ้าเป็น 0XXXXXXXX อยู่แล้ว → ใช้เดิม
    if (/^0\d{8,9}$/.test(s)) return s;
    // รูปแบบอื่นของไทย ไม่รู้ชัดเจน → คืนค่าเดิม
    return s;
  }

  // ── ประเทศอื่น: บังคับให้ขึ้นต้นด้วย "+"
  // ถ้ามี "+" อยู่แล้ว → ใช้เดิม
  if (s.startsWith('+')) return s;
  // ถ้าเป็นรูปแบบ 00XXXXXXXX → แปลงเป็น +XXXXXXXX
  if (s.startsWith('00')) return '+' + s.slice(2);
  // ฟอลแบ็ก: ลบ non-digits แล้วเติม "+"
  return '+' + s.replace(/[^\d]/g, '');
}
</script>

<script>
/* ===== Auto-refresh loop for orders ===== */
let ORD_AUTO_TIMER = null;

function hasProcessingRows(){
  return !!document.querySelector('#ordersBody .pill.processing');
}

// ===============================
// 🔔 REFUND NOTIFY (OTP24)
// ===============================
const OTP24_REFUND_NOTIFY_KEY = 'otp24_refund_notified_v1';
const OTP24_REFUND_NOTIFY_MEMORY = new Set();

function getRefundNotifyStore() {
  try {
    const raw = localStorage.getItem(OTP24_REFUND_NOTIFY_KEY);
    const arr = JSON.parse(raw || '[]');
    return new Set(Array.isArray(arr) ? arr : []);
  } catch {
    return new Set();
  }
}

function saveRefundNotifyStore(set) {
  try {
    // กันโตเกินไป เก็บล่าสุดประมาณ 300 ออเดอร์พอ
    const arr = Array.from(set).slice(-300);
    localStorage.setItem(OTP24_REFUND_NOTIFY_KEY, JSON.stringify(arr));
  } catch {}
}

function fmtRefundBaht(v) {
  const n = Number(v || 0);
  return n.toLocaleString('th-TH', {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2
  });
}

function notifyOtp24RefundOnce(p) {
  if (!p) return;

  const status = String(p.status || '').toLowerCase();
  const isRefundedStatus = ['refunded', 'timeout', 'failed', 'cancelled', 'canceled'].includes(status);

  // ต้องเป็นเคสคืนเงินจริงเท่านั้น
  if (!isRefundedStatus) return;
  if (p.refundApplied !== true && p.refundApplied !== 'true') return;

  const orderId = String(p.orderId || p._id || '').trim();
  if (!orderId) return;

  const notifyId = `otp24:${orderId}`;

  // กันยิงซ้ำใน memory
  if (OTP24_REFUND_NOTIFY_MEMORY.has(notifyId)) return;

  // กันยิงซ้ำหลัง refresh หน้า
  const store = getRefundNotifyStore();
  if (store.has(notifyId)) {
    OTP24_REFUND_NOTIFY_MEMORY.add(notifyId);
    return;
  }

  const amount = Number(p.refundAmount ?? p.salePrice ?? p.price ?? p.amount ?? 0);
  if (!Number.isFinite(amount) || amount <= 0) return;

  const text = `ออเดอร์ ${orderId} ได้รับเครดิตคืนเป็นจำนวน ${fmtRefundBaht(amount)} บาท`;

  if (typeof window.showMsg === 'function') {
    window.showMsg({
      variant: 'success',
      title: 'คืนเครดิตสำเร็จ',
      text,
      timeout: 5000
    });
  } else if (window.notify?.success) {
    window.notify.success('คืนเครดิตสำเร็จ', text);
  } else {
    console.log(text);
  }

  OTP24_REFUND_NOTIFY_MEMORY.add(notifyId);
  store.add(notifyId);
  saveRefundNotifyStore(store);
}

function applyOrderPatch(p){
  // p: { orderId, status, otp, phone, message }
  if (p && String(p.status || '').toLowerCase() === 'success' && !normalizeOtp(p.otp)) {
    p = { ...p, status: 'processing', message: p.message || 'ระบบกำลังรอ OTP…' };
  }

  const tr = document.querySelector(`tr[data-orderid="${p.orderId}"]`);
  if (!tr) return;

  if (p.expiresAt){
    tr.dataset.expires = p.expiresAt;
    const cd = tr.querySelector('.countdown');
    if (cd) cd.dataset.expires = p.expiresAt;
  }

  // อัปเดตเบอร์ (ถ้ามี)
  if (Object.prototype.hasOwnProperty.call(p,'phone')) {
    const cell = tr.children[2];
    const ct = Number(tr.dataset.ct || 0);
    const formatted = displayPhoneByCountry(p.phone || '-', ct);

    // desktop
    const mono = cell.querySelector('.mono .v') || cell.querySelector('.mono');
    if (mono) mono.textContent = formatted;
    let btn = cell.querySelector('.copy');
    if (!btn && p.phone){
      btn = document.createElement('button');
      btn.className = 'copy';
      btn.setAttribute('aria-label','คัดลอกเบอร์');
      btn.innerHTML = `<img src="/static/assets/otp24/copy.png" alt="">`;
      (cell.querySelector('.mono') || cell).appendChild(btn);
    }
    if (btn) btn.dataset.copy = formatted;

    // mobile
    const m = document.querySelector(`.m-orders .m-item[data-orderid="${p.orderId}"]`);
    if (m){
      const v = m.querySelector('.row2 .phone .v');
      if (v) v.textContent = formatted;
      let mBtn = m.querySelector('.row2 .phone .copy');
      if (!mBtn && p.phone){
        mBtn = document.createElement('button');
        mBtn.className = 'copy';
        mBtn.setAttribute('aria-label','คัดลอกเบอร์');
        mBtn.innerHTML = `<img src="/static/assets/otp24/copy.png" alt="">`;
        v?.after(mBtn);
      }
      if (mBtn) mBtn.dataset.copy = formatted;
    }
  }

  // อัปเดต OTP block
  const cell = tr.children[3];
  const otpVal = normalizeOtp(p.otp);
  let otpDiv = cell.querySelector('.otp');
  if (!otpDiv){
    otpDiv = document.createElement('div');
    otpDiv.className = 'otp';
    cell.prepend(otpDiv);
  }
  if (otpVal){
    otpDiv.classList.remove('none');
    otpDiv.innerHTML = `OTP : <b>${otpVal}</b>
      <button class="copy" data-copy="${otpVal}" aria-label="คัดลอก OTP">
        <img src="/static/assets/otp24/copy.png" alt="">
      </button>`;
  } else {
    otpDiv.classList.add('none');
    otpDiv.innerHTML = `OTP : <span class="muted">ไม่พบข้อความ</span>`;
  }

  // อัปเดต Pill สถานะ + ข้อความ
  const mCardForPatch = document.querySelector(`.m-orders .m-item[data-orderid="${p.orderId}"]`);
  if (p.status){
    const status = String(p.status).toLowerCase();
    const label =
      status==='success'   ? 'สำเร็จ' :
      status==='refunded'  ? 'คืนเครดิต' :
      status==='timeout'   ? 'คืนเครดิต' :
      status==='failed'    ? 'คืนเครดิต' :
      status==='canceled'  ? 'ยกเลิก' :
                            'กำลังรอ OTP';

    const pill = tr.querySelector('.pill');
    if (pill) {
      pill.className = `pill ${status}`;
      pill.textContent = label;
    }

    const mPill = mCardForPatch?.querySelector('.pill');
    if (mPill) {
      mPill.className = `pill ${status}`;
      mPill.textContent = label;
    }

    // 🔔 แจ้งเตือนคืนเครดิต 1 ครั้งต่อออเดอร์
    notifyOtp24RefundOnce(p);
  }

  // อัปเดต OTP block ฝั่งมือถือด้วย
  if (mCardForPatch) {
    let mOtp = mCardForPatch.querySelector('.otp');
    if (mOtp) {
      if (otpVal) {
        mOtp.classList.remove('none');
        mOtp.innerHTML = `OTP : <b>${otpVal}</b>
          <button class="copy" data-copy="${otpVal}" aria-label="คัดลอก OTP">
            <img src="/static/assets/otp24/copy.png" alt="">
          </button>`;
      } else {
        mOtp.classList.add('none');
        mOtp.innerHTML = `OTP : <span class="muted">ไม่พบข้อความ</span>`;
      }
    }

    if (p.expiresAt) {
      mCardForPatch.dataset.expires = p.expiresAt;
      const mCd = mCardForPatch.querySelector('.countdown');
      if (mCd) mCd.dataset.expires = p.expiresAt;
    }
  }

  // จัดการ countdown ใต้ pill
  const status = String(p.status||'').toLowerCase();
  let cd = tr.querySelector('.countdown');

  if (status === 'processing') {
    if (!cd) {
      cd = document.createElement('div');
      cd.className = 'countdown';
      // ถ้าเซิร์ฟเวอร์ส่ง expiresAt มาใน patch ก็ใส่ด้วย (ถ้ายังไม่มี ให้ใช้ data-expires เดิม)
      // นี่คือ display only; ถ้าไม่มี ก็ไม่เป็นไร tick จะข้าม
      cd.dataset.expires = tr.getAttribute('data-expires') || '';
      tr.children[5].appendChild(cd); // คอลัมน์สถานะ
    }
  } else {
    cd?.remove();
  }

  // ถ้าออเดอร์นี้ success → ตัด countdown ทิ้ง และถ้าไม่เหลือ processing เลย ให้หยุด auto-refresh ทันที
  if (['success', 'refunded', 'timeout', 'failed', 'canceled'].includes(status)) {
    // ตัด countdown ของแถวนี้ทิ้ง
    tr.querySelector('.countdown')?.remove();
    tr.removeAttribute('data-expires');

    // มือถือด้วย
    const mCard = document.querySelector(`.m-orders .m-item[data-orderid="${p.orderId}"]`);
    mCard?.querySelector('.countdown')?.remove();
    mCard?.removeAttribute('data-expires');

    // ถ้าไม่เหลืองานสถานะ processing แล้ว → หยุดลูปทันที (ไม่ต้องรอรอบถัดไป)
    if (!hasProcessingRows()) stopOrdersAutoRefresh();
  }
}

// ดึง orderId ที่ยังอยู่สถานะ processing (รองรับทั้งจาก state และจาก DOM)
function getProcessingOrderIds() {
  const ids = new Set();

  // Desktop table rows
  document.querySelectorAll('#ordersBody tr[data-orderid]').forEach(tr => {
    const pill = tr.querySelector('.pill');
    const st = (pill?.className || '').toLowerCase();
    if (st.includes('processing')) {
      ids.add(tr.getAttribute('data-orderid'));
    }
  });

  // Mobile cards
  document.querySelectorAll('#mOrders .m-item[data-orderid]').forEach(card => {
    const pill = card.querySelector('.pill');
    const st = (pill?.className || '').toLowerCase();
    if (st.includes('processing')) {
      ids.add(card.getAttribute('data-orderid'));
    }
  });

  return Array.from(ids).filter(Boolean);
}

// เรียกรีเฟรชเฉพาะรายการที่ยัง processing ทีละรอบ
async function refreshProcessingOrdersOnce() {
  try {
    const ids = getProcessingOrderIds();
    if (!ids.length) {
      stopOrdersAutoRefresh?.();
      return;
    }

    const results = await Promise.allSettled(
      ids.map(async (orderId) => {
        const res = await fetch(`/otp24/orders/${encodeURIComponent(orderId)}/refresh`, { method: 'POST' });
        const j = await res.json().catch(() => ({}));
        if (res.ok && j?.ok && j?.patch) applyOrderPatch?.(j.patch);
        return j;
      })
    );

    // หลังอัปเดตทุกรายการแล้ว — ถ้าไม่เหลือ processing เลยให้หยุด
    if (!hasProcessingRows?.()) stopOrdersAutoRefresh?.();
  } catch {
    // เงียบไว้ตามสไตล์เดิม
  }
}

function startOrdersAutoRefresh(){
  stopOrdersAutoRefresh();
  ORD_AUTO_TIMER = setInterval(async () => {
    if (document.hidden) { tickCountdowns(); return; }
    await refreshProcessingOrdersOnce();
    tickCountdowns();
  }, OTP24_LIST_POLL_MS);
}

function stopOrdersAutoRefresh(){
  if (ORD_AUTO_TIMER){ clearInterval(ORD_AUTO_TIMER); ORD_AUTO_TIMER = null; }
}

// ให้ tick ทำงานแม้ยังไม่เริ่มลูปรีเฟรช (เผื่อหน้าเปิดอยู่เฉยๆ)
tickCountdowns();
setInterval(tickCountdowns, 1000);

/* เริ่มออโต้เมื่อเปิดแท็บ "ประวัติ" */
document.querySelector('.tab[data-target="orders"]')
  ?.addEventListener('click', () => {
    startOrdersAutoRefresh();
  });

/* เริ่มออโต้ทันทีถ้าหน้าเปิดมามี processing อยู่แล้ว */
if (hasProcessingRows()) startOrdersAutoRefresh();

/* หยุด/เริ่มตาม visibility (ประหยัดโหลด) */
document.addEventListener('visibilitychange', () => {
  if (document.hidden) stopOrdersAutoRefresh();
  else if (document.querySelector('#section-orders').classList.contains('show')) {
    startOrdersAutoRefresh();
  }
});

// แตะตรงไหนก็พับ/กาง (ใช้ event delegation)
document.getElementById('mOrders')?.addEventListener('click', (e) => {
  const item = e.target.closest('.m-item');
  if (!item) return;
  // กันปุ่ม copy
  if (e.target.closest('.copy')) return;
  item.classList.toggle('collapsed');
  const btn = item.querySelector('.toggle');
  if (btn) btn.textContent = item.classList.contains('collapsed') ? '+' : '−';
});

// helper: เปลี่ยนภาพไอคอน copy
function setCopyIcon(btn, success) {
  const img = btn.querySelector('img');
  if (!img) return;
  img.src = success
    ? '/static/assets/otp24/copy-success.png'
    : '/static/assets/otp24/copy.png';
}

document.addEventListener('click', (e) => {
  const btn = e.target.closest('.copy');
  if (!btn) return;

  navigator.clipboard.writeText(btn.dataset.copy || '').then(() => {
    setCopyIcon(btn, true);
    // กลับเป็นไอคอนปกติใน 900ms
    setTimeout(() => setCopyIcon(btn, false), 900);
  }).catch(() => {
    // ถ้า copy ไม่ได้ อย่าค้างไอคอน success
    setCopyIcon(btn, false);
  });
});
</script>

<script>
/* ========= Pagination (Client-side) ========= */
let ORDERS_PER_PAGE = Number(localStorage.getItem('OTP24_PER_PAGE')) || 20;
let currentPage = 1;

const $rows   = () => Array.from(document.querySelectorAll('#ordersBody tr'));
const $cards  = () => Array.from(document.querySelectorAll('#mOrders .m-item'));
const $info   = document.getElementById('pageInfo');
const $infoM  = document.getElementById('pageInfoMobile');
const $sel    = document.getElementById('perPageSelect');
const $selM   = document.getElementById('perPageSelectMobile');
const $ctrlD  = document.getElementById('ordersControlsDesktop');
const $ctrlM  = document.getElementById('ordersControlsMobile');

function totalItems(){ return (window.matchMedia('(max-width: 640px)').matches ? $cards().length : $rows().length); }
function totalPages(){ return Math.max(1, Math.ceil(totalItems() / ORDERS_PER_PAGE)); }
function clampPage(n){ return Math.min(Math.max(1, n), totalPages()); }

function applyPagination(){
  const isMobile = window.matchMedia('(max-width: 640px)').matches;
  const items = isMobile ? $cards() : $rows();

  const total = items.length;
  const pages = totalPages();
  currentPage = clampPage(currentPage);

  const start = (currentPage-1) * ORDERS_PER_PAGE;
  const end   = start + ORDERS_PER_PAGE;

  items.forEach((el, i) => {
    el.style.display = (i >= start && i < end) ? '' : 'none';
  });

  // อัปเดตตัวเลขหน้า
  if (!isMobile && $info)  $info.textContent  = `หน้า ${currentPage}/${pages}`;
  if (isMobile && $infoM)  $infoM.textContent = `หน้า ${currentPage}/${pages}`;

  // ปุ่ม disabled
  const setBtns = (root) => {
    if (!root) return;
    root.querySelector('[data-act="first"]')?.toggleAttribute('disabled', currentPage<=1);
    root.querySelector('[data-act="prev"]') ?.toggleAttribute('disabled', currentPage<=1);
    root.querySelector('[data-act="next"]') ?.toggleAttribute('disabled', currentPage>=pages);
    root.querySelector('[data-act="last"]') ?.toggleAttribute('disabled', currentPage>=pages);
  };
  setBtns($ctrlD);
  setBtns($ctrlM);
}

// เปลี่ยน per-page (เดสก์ท็อป & มือถือ)
function bindPerPage(selectEl){
  if (!selectEl) return;
  // set ค่าเริ่มต้น
  for (const opt of selectEl.options){
    opt.selected = Number(opt.value) === ORDERS_PER_PAGE;
  }
  selectEl.addEventListener('change', () => {
    ORDERS_PER_PAGE = Number(selectEl.value) || 20;
    localStorage.setItem('OTP24_PER_PAGE', ORDERS_PER_PAGE);
    currentPage = 1;
    applyPagination();
  });
}
bindPerPage($sel);
bindPerPage($selM);

// ปุ่มนำทาง (เดสก์ท็อป & มือถือ)
function bindPager(ctrlRoot){
  if (!ctrlRoot) return;
  ctrlRoot.addEventListener('click', (e) => {
    const btn = e.target.closest('.pg-btn');
    if (!btn) return;
    const act = btn.dataset.act;
    if (act === 'first') currentPage = 1;
    else if (act === 'prev') currentPage = clampPage(currentPage - 1);
    else if (act === 'next') currentPage = clampPage(currentPage + 1);
    else if (act === 'last') currentPage = totalPages();
    applyPagination();
  });
}
bindPager($ctrlD);
bindPager($ctrlM);

// เรียกครั้งแรกเมื่อโหลดหน้า
applyPagination();

// เมื่อรีเฟรชสถานะ/จำนวนรายการเปลี่ยน ให้คงหน้าปัจจุบันไว้ถ้าเป็นไปได้
const _origRefreshAll = refreshProcessingOrdersOnce;
refreshProcessingOrdersOnce = async function () {
  const out = await _origRefreshAll(); // ดึงแพตช์สถานะจากเซิร์ฟเวอร์
  applyPagination();                   // จัดหน้าใหม่ตามจำนวนรายการล่าสุด
  tickCountdowns();                    // อัปเดตตัวเลขนับถอยหลังให้ตรง DOM ล่าสุด

  // ถ้าไม่เหลือแถวสถานะ processing แล้ว ให้หยุดลูป auto-refresh ตอนนี้เลย
  if (!hasProcessingRows()) stopOrdersAutoRefresh();

  return out; // เผื่อที่อื่นยังใช้งานผลลัพธ์เดิม
};



/* ====== ซื้อเบอร์เดิม (buyotpagain) ====== */
window.CT2CODE = window.CT2CODE || {
  52:'th',187:'us',16:'gb',6:'id',10:'vn',5:'mm',1:'ua',19:'ng',62:'tr',3:'cn',4:'ph',24:'kh',25:'la',7:'my',21:'eg'
};


async function asJson(r){ const j = await r.json().catch(()=>({})); return { ok:r.ok, status:r.status, data:j }; }

window.FLAGIMG_BY_ID = function(id){
  const code = (window.CT2CODE || {})[Number(id)];
  return code ? '/static/assets/otp24/' + code + '.png' : null;
};

let REUSE_CTX = {};

// ─────────────────────────────────────────────
// คลิกปุ่ม “ใช้เบอร์เดิม”
// ─────────────────────────────────────────────
document.addEventListener('click', async (e) => {
  const btn = e.target.closest('.btn-reuse');
  if (!btn) return;

  // ทำ ctx จาก data-* ของปุ่ม ไว้เป็น fallback
  const ctx = {
    orderId: btn.dataset.orderid,
    app:     btn.dataset.app || '',
    number:  btn.dataset.number || '',
    price:   Number(btn.dataset.price || 0),
    ct:      Number(btn.dataset.ct || 0),
  };

  // 1) ลองเรียก PREVIEW (GET)
  let r = await fetch(`/otp24/buy-again/preview?orderId=${encodeURIComponent(ctx.orderId)}`, {
    headers:{ accept:'application/json' }
  }).catch(()=>null);
  let res = r ? await asJson(r) : { ok:false, status:0, data:{} };

  // 2) ถ้าไม่มี endpoint preview ให้ลอง POST preview:true
  if (!res.ok && (res.status === 404 || res.status === 405)) {
    r = await fetch('/otp24/buy-again', {
      method:'POST',
      headers:{ 'content-type':'application/json', accept:'application/json' },
      body: JSON.stringify({ orderId: ctx.orderId, preview:true })
    }).catch(()=>null);
    res = r ? await asJson(r) : { ok:false, status:0, data:{} };
  }

  // 3) ตีความผลลัพธ์ผิดพลาด → แจ้งเหตุผลที่ถูกต้อง
  if (!res.ok){
    const code = res.data?.code || res.data?.reason;
    if (res.status===409 || res.status===423 || code==='ACTIVE_ORDER' || code==='STILL_PROCESSING' || res.data?.active===true){
      return (window.showMsg||alert)({ variant:'error', title:'สั่งซื้อไม่สำเร็จ', text:'เบอร์ของคุณยังอยู่ในสถานะกำลังทำงานอยู่' });
    }
    if (res.status===410 || code==='REMOVED' || code==='NOT_REUSABLE'){
      return (window.showMsg||alert)({ variant:'error', title:'สั่งซื้อไม่สำเร็จ', text:'เบอร์นี้ถูกนำออกจากระบบไปแล้ว' });
    }
    return (window.showMsg||alert)({ variant:'error', title:'สั่งซื้อไม่สำเร็จ', text: res.data?.error || 'ระบบผู้ให้บริการขัดข้อง กรุณาลองใหม่' });
  }

  // 4) ผ่านเงื่อนไข → เปิดโมดัลยืนยัน
  const info = res.data?.preview || res.data || {};
  REUSE_CTX = {
    orderId: ctx.orderId,
    app:     info.appName   || ctx.app,
    number:  info.phone     || ctx.number,
    price:   Number(info.price ?? ctx.price),
    ct:      Number(info.countryId ?? ctx.ct),
  };

  document.getElementById('reuseApp').textContent    = REUSE_CTX.app || '—';
  document.getElementById('reuseNumber').textContent = displayPhoneByCountry(REUSE_CTX.number, REUSE_CTX.ct);

  const flagEl = document.getElementById('reuseFlag');
  const fcode  = (window.CT2CODE && window.CT2CODE[REUSE_CTX.ct]) || null;
  if (fcode){ flagEl.src = `/static/assets/otp24/${fcode}.png`; flagEl.style.display='inline-block'; }
  else { flagEl.removeAttribute('src'); flagEl.style.display='none'; }

  document.getElementById('reusePrice').textContent = REUSE_CTX.price.toFixed(2);
  document.getElementById('reuseModal').showModal();
});

// ─────────────────────────────────────────────
// ปุ่มยืนยันซื้อซ้ำ
// ─────────────────────────────────────────────
document.getElementById('btnReuseConfirm')?.addEventListener('click', async (e) => {
  e.preventDefault();
  if (!REUSE_CTX?.orderId) return;

  try{
    const r = await fetch('/otp24/buy-again', {
      method:'POST',
      headers:{ 'content-type':'application/json', accept:'application/json' },
      body: JSON.stringify({ orderId: REUSE_CTX.orderId })
    });
    const j = await r.json().catch(()=> ({}));
    if (!r.ok || !j?.ok){
      const code = j?.code || j?.reason || '';
      (window.showMsg || alert)({
        variant:'error',
        title:'สั่งซื้อไม่สำเร็จ',
        text: (code==='ACTIVE_ORDER' || code==='STILL_PROCESSING')
              ? 'เบอร์ของคุณยังอยู่ในสถานะกำลังทำงานอยู่'
              : (j?.error || 'เบอร์นี้ถูกนำออกจากระบบไปแล้ว')
      });
      return;
    }
    goOtpOrdersPage(j.redirect || '/otp24?tab=orders');
  } catch {
    (window.showMsg || alert)({ variant:'error', title:'สั่งซื้อไม่สำเร็จ', text:'เครือข่ายมีปัญหา' });
  } finally {
    document.getElementById('reuseModal')?.close();
  }
});

document.addEventListener('DOMContentLoaded', () => {
  const input = document.querySelector('#otpSearch');
  const apps = document.querySelectorAll('#appsGrid .card.app');

  input.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();

    apps.forEach(card => {
      const name = (card.dataset.name || '').toLowerCase();
      const show = name.includes(q);
      card.style.display = show ? '' : 'none';
    });
  });
});

document.addEventListener("DOMContentLoaded", () => {
  const grid = document.getElementById("appsGrid");  // ใช้ event delegation
  const termsModal = document.getElementById("termsModal");
  const termsBackdrop = termsModal.querySelector(".bt-terms-backdrop");
  const termsAccept = document.getElementById("termsAccept");
  const termsConfirm = document.getElementById("termsConfirm");
  const termsCancel = document.getElementById("termsCancel");

  const buyModal = document.getElementById("buyModal");
  const selApp = document.getElementById("selApp");
  const selPrice = document.getElementById("selPrice");

  let pendingId = null;
  let pendingApp = null;
  let pendingPrice = 0;

  /* ============================================================
     เมื่อคลิกที่การ์ดแอพ  (Event Delegation)
     ============================================================ */
  grid.addEventListener("click", (e) => {
    const card = e.target.closest("section.card.app");
    if (!card) return;

    pendingId = card.dataset.id;
    pendingApp = card.dataset.name;
    pendingPrice = Number(card.dataset.price || 0);

    // reset terms
    termsAccept.checked = false;
    termsConfirm.disabled = true;

    // show Terms modal
    termsModal.classList.remove("hidden");
  });

  /* ============================================================
     Checkbox ✔ ยอมรับเงื่อนไข
     ============================================================ */
  termsAccept.addEventListener("change", () => {
    termsConfirm.disabled = !termsAccept.checked;
  });

  /* ============================================================
     ปุ่มยืนยันเงื่อนไข
     ============================================================ */
  termsConfirm.addEventListener("click", () => {
    termsModal.classList.add("hidden");

    // ตั้งค่า into chosen (ใช้โดยระบบสั่งซื้อเดิม)
    chosen = {
      productId: pendingId,
      countryId: null,
      name: pendingApp,
      price: pendingPrice,
    };

    selApp.textContent = "รายการ : " + pendingApp;
    selPrice.textContent = "ราคา : " + pendingPrice.toFixed(2) + " บาท";

    buyModal.showModal();
  });

  /* ============================================================
     ปิด Terms (ปุ่ม Cancel)
     ============================================================ */
  termsCancel.addEventListener("click", () => {
    termsModal.classList.add("hidden");
  });

  /* ============================================================
     คลิก Backdrop เพื่อปิด Terms
     ============================================================ */
  termsBackdrop.addEventListener("click", () => {
    termsModal.classList.add("hidden");
  });
});

// เมื่อสลับมือถือ/เดสก์ท็อป (resize) ให้ปรับหน้าให้เหมาะสม
let _resizeTimer = null;
window.addEventListener('resize', () => {
  clearTimeout(_resizeTimer);
  _resizeTimer = setTimeout(applyPagination, 150);
});
</script>

