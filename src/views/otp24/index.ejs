#buyModal .flag{
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
}

/* รูปธงในโมดัลให้เต็มกรอบเหมือนเดิม แต่กรอบโปร่งใส */
#buyModal .flag img{
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: var(--flag-radius, 10px);
}

/* ธงที่แสดงในตารางประวัติ */
.orders-wrap .flag{
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
}

/* รูปธงในตาราง */
.orders-wrap .flag img{
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: 6px;
}

/* ธงในลิสต์มือถือ */
.m-orders .flag{
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
}
.m-orders .flag img{
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: 6px;
}

/* สถานะ “เลือก” ให้เห็นชัดด้วยเส้นขอบบาง ๆ (ไม่ใส่พื้น) */
