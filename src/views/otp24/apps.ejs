  --app-border: color-mix(in srgb, var(--border, rgba(255,255,255,.14)) 82%, transparent);
  --app-accent: var(--accent, #f4c95d);
  --app-gold: #f7d774;
  --app-gold-2: #c48b24;
  --app-gold-3: #8b5c13;
