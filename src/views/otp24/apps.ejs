<script>
(() => {
  const MODE = <%- safeJson(__mode) %>;
  let PRODUCTS = <%- safeJson(__products) %>;
  let ORDERS = [];
  let appsHistoryCache = { ts:0, data:null, pending:null };
  const APPS_HISTORY_CACHE_MS = 20 * 1000;
  let selected = null;
  let qty = 1;

  const baht = n => '฿' + Number(n || 0).toLocaleString('th-TH', { minimumFractionDigits:2, maximumFractionDigits:2 });
  const $ = s => document.querySelector(s);
  const $$ = s => Array.from(document.querySelectorAll(s));
  const imgFallback = '/static/logo/icon-logo.png';
  const imgPlaceholder = 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==';
  const LOCAL_IMAGE_CACHE_NAME = 'rtsmm-otp24-app-images-v3';
  const toast = (msg, type='info') => { if(window.notify){ const fn=window.notify[type]||window.notify.info; return fn(type==='error'?'เกิดข้อผิดพลาด':type==='success'?'สำเร็จ':'แจ้งเตือน', msg); } const el=$('#appsToast'); if(!el) return; el.textContent=msg; el.classList.add('show'); setTimeout(()=>el.classList.remove('show'),2600); };
  const imageDelay = 90;
  let imageQueue = Promise.resolve();
  const objectImageUrls = new Set();
  const pendingLazyImages = new Set();
  const imageObserver = ('IntersectionObserver' in window)
    ? new IntersectionObserver((entries)=>{
        entries.forEach(entry=>{
          if(!entry.isIntersecting) return;
          const img = entry.target;
          imageObserver.unobserve(img);
          fetchOtpImageElement(img);
        });
      }, { rootMargin:'260px 0px', threshold:0.01 })
    : null;

  function isLocalCacheImageUrl(src=''){
    const s = String(src || '').trim();
    return /^\/apps\/(?:img|icon)\//i.test(s) || new URL(s, location.origin).origin === location.origin && /\/apps\/(?:img|icon)\//i.test(new URL(s, location.origin).pathname);
  }

  function setImageShellBg(img, url){
    const shell = img.closest('.app-img-shell,.product-img-shell,.detail-image-shell');
    if(shell) shell.style.setProperty('--otp-img-bg', `url("${url}")`);
  }

  function setImageFromBlob(img, blob){
    const old = img.dataset.objectUrl;
    if(old && old.startsWith('blob:')) { try { URL.revokeObjectURL(old); } catch {} }
    const objUrl = URL.createObjectURL(blob);
    objectImageUrls.add(objUrl);
    img.dataset.objectUrl = objUrl;
    img.src = objUrl;
    setImageShellBg(img, objUrl);
    img.classList.remove('otp-img-loading');
  }

  async function readImageFromLocalCache(src){
    if(!('caches' in window) || !isLocalCacheImageUrl(src)) return null;
    const cache = await caches.open(LOCAL_IMAGE_CACHE_NAME);
    const req = new Request(src, { credentials:'same-origin' });
    const hit = await cache.match(req, { ignoreVary:true });
    if(!hit || !hit.ok) return null;
    const type = String(hit.headers.get('content-type') || '');
    if(type && !/^image\//i.test(type)) return null;
    const blob = await hit.blob();
    return blob && blob.size ? blob : null;
  }

  async function fetchImageToLocalCache(src){
    if(!src || src === imgFallback) return null;

    // External OTP24 images must NOT be fetched as Blob here. Browser fetch() needs CORS,
    // while normal <img src=...> loading does not. Using direct src keeps the UI intact
    // and also keeps image traffic away from MongoDB.
    if(!isLocalCacheImageUrl(src)) return { direct:true, src };

    if(!('caches' in window)) {
      return await fetch(src, { credentials:'same-origin', cache:'force-cache' }).then(r => r.ok ? r.blob() : null);
    }
    const cache = await caches.open(LOCAL_IMAGE_CACHE_NAME);
    const req = new Request(src, { credentials:'same-origin' });
    const res = await fetch(req, { cache:'force-cache' });
    if(!res.ok) throw new Error('image fetch failed');
    const type = String(res.headers.get('content-type') || '');
    if(type && !/^image\//i.test(type)) throw new Error('invalid image response');
    await cache.put(req, res.clone());
    const blob = await res.blob();
    return blob && blob.size ? blob : null;
  }

  function fetchOtpImageElement(img){
    if(!img || img.dataset.loaded === 'done' || pendingLazyImages.has(img)) return;
    pendingLazyImages.add(img);
    img.dataset.loaded = 'queue';
    img.classList.add('otp-img-loading');
    imageQueue = imageQueue.then(async()=>{
      const src = img.dataset.src;
      if(!src || src === imgFallback){ img.classList.remove('otp-img-loading'); img.dataset.loaded='done'; return; }

      try{
        const localBlob = await readImageFromLocalCache(src);
        if(localBlob){ setImageFromBlob(img, localBlob); img.dataset.loaded='done'; return; }
      }catch{}

      await new Promise(r=>setTimeout(r, imageDelay));
      try{
        const blob = await fetchImageToLocalCache(src);
        if(blob?.direct){
          img.src = blob.src;
          setImageShellBg(img, blob.src);
          img.classList.remove('otp-img-loading');
          img.dataset.loaded='done';
          return;
        }
        if(blob){ setImageFromBlob(img, blob); img.dataset.loaded='done'; return; }
        throw new Error('empty image blob');
      }catch{
        img.classList.remove('otp-img-loading');
        img.src = imgFallback;
        setImageShellBg(img, imgFallback);
        img.dataset.loaded='done';
      }finally{
        pendingLazyImages.delete(img);
      }
    }).catch(()=>{ pendingLazyImages.delete(img); });
  }

  function loadOtpImagesSlow(scope=document){
    const imgs = Array.from(scope.querySelectorAll('img.otp-img-lazy[data-src]:not([data-loaded])'));
    imgs.forEach(img=>{
      if(imageObserver){
        img.dataset.loaded = 'observe';
        imageObserver.observe(img);
      }else{
        fetchOtpImageElement(img);
      }
    });
  }

  window.addEventListener('pagehide', () => {
    objectImageUrls.forEach(url => { try { URL.revokeObjectURL(url); } catch {} });
    objectImageUrls.clear();
  });


  function switchTab(name){
    $$('.apps-tab').forEach(b=>b.classList.toggle('active', b.dataset.tab===name));
    $('#appsShop')?.classList.toggle('show', name==='shop');
    $('#appsHistory')?.classList.toggle('show', name==='history');
    const u = new URL(location.href); u.searchParams.set('tab', name); history.replaceState(null,'',u.toString());
    if(name==='history') loadHistory();
  }
  $$('.apps-tab').forEach(b=>b.addEventListener('click',()=>switchTab(b.dataset.tab)));

  function renderProducts(){
    if(MODE !== 'products') return;
    const grid = $('#productsGrid'); if(!grid) return;
    grid.innerHTML = '';
    $('#productsEmpty').style.display = PRODUCTS.length ? 'none' : 'block';
    PRODUCTS.forEach((p,i)=>{
      const card=document.createElement('article');
      const isOut = Number(p.amount || 0) <= 0 || p.isOutOfStock;
      card.className='product-card' + (selected && selected._id===p._id ? ' active' : '') + (isOut ? ' is-out' : '');
      card.dataset.id=p._id;
      card.innerHTML=`
        <div class="product-kind">ACCOUNT</div>
        <div class="product-img-shell" style="--otp-img-bg:url('${escapeAttr(p.img||imgFallback)}')">
          <img class="product-img otp-img-lazy" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==" data-src="${escapeAttr(p.img||imgFallback)}" loading="lazy" decoding="async" onerror="this.src='${imgFallback}'" alt="">
        </div>
        <div class="product-name">${escapeHtml(cleanInlineText(p.name||'-'))}</div>
        <div class="gold-line"></div>
        <div class="product-price">${baht(p.salePrice)}</div>
        <div class="product-meta"><span class="sold">${Number(p.sold||0).toLocaleString('th-TH')} ขายแล้ว</span><span class="stock">${Number(p.amount||0).toLocaleString('th-TH')} คงเหลือ</span></div>`;
      if(!isOut) card.addEventListener('click',()=>selectProduct(p._id));
      else card.setAttribute('aria-disabled','true');
      grid.appendChild(card);
      loadOtpImagesSlow(card);
      if(!selected && !isOut) setTimeout(()=>selectProduct(p._id),0);
    });
  }

  const ICON_DETAIL_CHAT = `<svg class="ui-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H9l-5 4v-4H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z"/><path d="M7 9h10M7 13h7"/></svg>`;
  const ICON_DETAIL_BOX = `<svg class="ui-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 8v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8"/><path d="M1 3h22v5H1Z"/><path d="M10 12h4"/></svg>`;

  function splitReadableThai(text){
    const raw = htmlToPlainText(text || '')
      .replace(/\s*\|\s*/g, '\n')
      .replace(/(ข้อมูลที่ได้รับ|สิ่งที่จะได้รับ|ได้รับอะไร|รายการที่ได้รับ)/gi, '\n$1\n')
      .replace(/(ไอดี\s*[:：]|รหัส\s*[:：]|2FA\s*[:：]|รอ\s*ADMIN|เปิดเมล|ยืนยันตัวตน|รับประกัน|หมายเหตุ)/gi, '\n$1')
      .replace(/\n{3,}/g, '\n\n')
      .trim();
    return raw.split(/\n+/).map(x => x.trim()).filter(Boolean);
  }

  function renderProductDescription(text){
    const lines = splitReadableThai(text);
    if(!lines.length) return '<div class="detail-pretty"><div class="detail-pretty-section"><div class="detail-pretty-text">ไม่มีรายละเอียดสินค้า</div></div></div>';

    const receiveIdx = lines.findIndex(x => /^(ข้อมูลที่ได้รับ|สิ่งที่จะได้รับ|ได้รับอะไร|รายการที่ได้รับ)$/i.test(x.replace(/[:：]/g,'').trim()));
    const descLines = receiveIdx >= 0 ? lines.slice(0, receiveIdx) : lines;
    const receiveLines = receiveIdx >= 0 ? lines.slice(receiveIdx + 1) : [];

    const descHtml = descLines.length
      ? `<div class="detail-pretty-section"><div class="detail-pretty-title"></div><div class="detail-pretty-text">${descLines.map(line => `<p>${escapeHtml(line)}</p>`).join('')}</div></div>`
      : '';

    const receiveHtml = receiveLines.length
      ? `<div class="detail-pretty-section"><div class="detail-pretty-title">${ICON_DETAIL_BOX}<span>ข้อมูลที่ได้รับ</span></div><ul class="detail-pretty-list">${receiveLines.map(line => `<li>${escapeHtml(line.replace(/^[-•]\s*/, ''))}</li>`).join('')}</ul></div>`
      : '';

    return `<div class="detail-pretty">${descHtml}${receiveHtml}</div>`;
  }

  function selectProduct(id){
    selected = PRODUCTS.find(p=>p._id===id) || null;
    $$('.product-card').forEach(c=>c.classList.toggle('active', selected && c.dataset.id===selected._id));
    if(!selected) return;
    $('#detailTitle').textContent = cleanInlineText(selected.name || selected.app || 'สินค้า');
    const detailImg = $('#detailImg');
    detailImg.removeAttribute('data-loaded');
    const nextImg = selected.img || imgFallback;
    detailImg.dataset.src = nextImg;
    detailImg.src = imgPlaceholder;
    const detailShell = $('#detailImgShell');
    if(detailShell) detailShell.style.setProperty('--otp-img-bg', `url("${imgFallback}")`);
    loadOtpImagesSlow(detailImg.parentElement || document);
    $('#detailMsg').innerHTML = renderProductDescription(selected.msgText || selected.msg || 'ไม่มีรายละเอียดสินค้า');
    $('#detailStock').textContent = Number(selected.amount||0).toLocaleString('th-TH') + ' รายการ';
    $('#detailExp').textContent = selected.exp || '-';
    $('#detailPrice').textContent = baht(selected.salePrice);
    $('#buyBtn').disabled = Number(selected.amount || 0) <= 0;
    if (Number(selected.amount || 0) <= 0) toast('สินค้านี้หมดแล้ว', 'warn');
    updateTotal();
  }

  function updateTotal(){
    if(MODE !== 'products') return;
    qty = Math.max(1, Math.floor(Number($('#qtyInput')?.value || 1)));
    $('#qtyInput').value = qty;
    $('#buyTotal').textContent = baht((selected?.salePrice || 0) * qty);
  }
  $('#qtyMinus')?.addEventListener('click',()=>{ $('#qtyInput').value=Math.max(1,qty-1); updateTotal(); });
  $('#qtyPlus')?.addEventListener('click',()=>{ $('#qtyInput').value=qty+1; updateTotal(); });
  $('#qtyInput')?.addEventListener('input', updateTotal);

  $('#buyBtn')?.addEventListener('click', async ()=>{
    if(!selected) return toast('กรุณาเลือกสินค้า', 'warn');
    if(Number(selected.amount || 0) <= 0 || selected.isOutOfStock) return toast('สินค้าหมดแล้ว กรุณาเลือกสินค้าอื่น', 'warn');
    const confirmFn = window.uiConfirm || window.UIConfirm;
    const ok = confirmFn ? await confirmFn({
      title:'ยืนยันสั่งซื้อแอคเคาท์',
      message:`${cleanInlineText(selected.name)} จำนวน ${qty} รายการ\nยอดชำระ ${baht(selected.salePrice * qty)}`,
      confirmText:'สั่งซื้อ',
      cancelText:'ยกเลิก',
      tone:'success'
    }) : confirm(`ยืนยันสั่งซื้อ ${cleanInlineText(selected.name)} จำนวน ${qty} รายการ\nยอดชำระ ${baht(selected.salePrice * qty)}`);
    if(!ok) return;
    const btn=$('#buyBtn'); btn.disabled=true; btn.textContent='กำลังสั่งซื้อ...';
    try{
      const r=await fetch('/apps/buy',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({productId:selected._id,quantity:qty})});
      const data=await r.json().catch(()=>({ok:false,error:'Invalid response'}));
      if(!r.ok || !data.ok) throw new Error(data.error||'สั่งซื้อไม่สำเร็จ');
      toast('สั่งซื้อสำเร็จ', 'success');
      if(data.productPatch){
        PRODUCTS = PRODUCTS.map(p => String(p._id)===String(data.productPatch.productId) ? {...p, ...data.productPatch} : p);
        if(selected && String(selected._id)===String(data.productPatch.productId)) selected = {...selected, ...data.productPatch};
        renderProducts();
        updateTotal();
      }
      if(data.order) openModal(data.order);
      appsHistoryCache = { ts:0, data:null, pending:null };
      await loadHistory({ force:true });
      switchTab('history');
    }catch(e){ toast(e.message||'เกิดข้อผิดพลาด', 'error'); }
    finally{ btn.disabled=false; btn.textContent='สั่งซื้อ'; }
  });

  async function loadHistory({ force=false } = {}){
    const body=$('#historyBody'); if(!body) return;
    const fresh = appsHistoryCache.data && Date.now() - appsHistoryCache.ts < APPS_HISTORY_CACHE_MS;
    if(!force && fresh){
      ORDERS = appsHistoryCache.data.orders || [];
      renderHistory();
      return;
    }
    if(appsHistoryCache.pending && !force) return appsHistoryCache.pending;
    body.innerHTML='<tr><td colspan="5">กำลังโหลดประวัติสินค้า...</td></tr>';
    appsHistoryCache.pending = (async()=>{
      try{
        const historyUrl = force ? `/apps/api/history?_=${Date.now()}` : '/apps/api/history';
        const r=await fetch(historyUrl, {
          cache:'no-store',
          headers:{ 'accept':'application/json', 'cache-control':'no-cache' }
        });
        const data=await r.json();
        appsHistoryCache = { ts:Date.now(), data, pending:null };
        ORDERS=data.orders||[];
        renderHistory();
      }catch(e){ body.innerHTML='<tr><td colspan="5">โหลดประวัติไม่สำเร็จ</td></tr>'; appsHistoryCache.pending=null; }
    })();
    return appsHistoryCache.pending;
  }
  function isRefundedOrder(o){
    return String(o?.status || '').toLowerCase() === 'refunded' || o?.refundApplied === true;
  }
  function orderStatusPill(o){
    if(isRefundedOrder(o)) return '<span class="status-pill refunded">↩ คืนเงินแล้ว</span>';
    return '<span class="status-pill">✓ สำเร็จ</span>';
  }
  function orderDisplayPrice(o){
    return isRefundedOrder(o) ? (Number(o?.refundAmount || 0) || Number(o?.salePrice || 0)) : Number(o?.salePrice || 0);
  }

  function renderHistory(){
    const body=$('#historyBody'); if(!body) return;
    const q=($('#histSearch')?.value||'').toLowerCase();
    const from=$('#histFrom')?.value ? new Date($('#histFrom').value+'T00:00:00') : null;
    const to=$('#histTo')?.value ? new Date($('#histTo').value+'T23:59:59') : null;
    const list=ORDERS.filter(o=>{
      const d=new Date(o.createdAt||Date.now());
      const blob=[o.orderId, cleanInlineText(o.appName), htmlToPlainText(o.accountText), htmlToPlainText(o.message)].join(' ').toLowerCase();
      return (!q||blob.includes(q)) && (!from||d>=from) && (!to||d<=to);
    });
    if(!list.length){ body.innerHTML='<tr><td colspan="5">ยังไม่มีประวัติ</td></tr>'; return; }
    body.innerHTML=list.map(o=>{
      const cleanName = cleanInlineText(o.appName || o.productName || '-');
      return `
      <tr>
        <td>${escapeHtml(o.orderId||'-')}</td>
        <td>
          <b>${escapeHtml(cleanName)}</b>
          <small class="hist-date">${formatDate(o.createdAt)}</small>
        </td>
        <td><strong>${baht(orderDisplayPrice(o))}</strong></td>
        <td><button class="detail-btn" data-order="${escapeAttr(o.orderId)}">ข้อมูลสินค้า</button></td>
        <td>${orderStatusPill(o)}</td>
      </tr>`;
    }).join('');
    body.querySelectorAll('[data-order]').forEach(btn=>btn.addEventListener('click',()=>{
      const o=ORDERS.find(x=>String(x.orderId)===String(btn.dataset.order));
      if(o) openModal(o);
    }));
  }
  ['#histSearch','#histFrom','#histTo'].forEach(sel=>$(sel)?.addEventListener('input',renderHistory));

  function htmlToPlainText(s){
    return String(s || '')
      .replace(/&lt;\s*br\s*\/?\s*&gt;/gi, '\n')
      .replace(/&lt;\s*hr[^&]*&gt;/gi, '\n')
      .replace(/&lt;[^&]*&gt;/g, '')
      .replace(/<\s*br\s*\/?\s*>/gi, '\n')
      .replace(/<\s*hr[^>]*>/gi, '\n')
      .replace(/<\s*\/\s*(p|div|li|tr)\s*>/gi, '\n')
      .replace(/<\s*li[^>]*>/gi, '• ')
      .replace(/<[^>]*>/g, '')
      .replace(/&nbsp;/gi, ' ')
      .replace(/&amp;/gi, '&')
      .replace(/&quot;/gi, '"')
      .replace(/&#39;|&apos;/gi, "'")
      .replace(/&lt;/gi, '<')
      .replace(/&gt;/gi, '>')
      .replace(/\r\n/g, '\n')
      .replace(/[ \t]+\n/g, '\n')
      .replace(/\n[ \t]+/g, '\n')
      .replace(/\n{3,}/g, '\n\n')
      .trim();
  }


  function cleanInlineText(s){
    return htmlToPlainText(s)
      .replace(/[\r\n]+/g, ' ')
      .replace(/\s{2,}/g, ' ')
      .trim();
  }

  function extractMail(text){
    const s=String(text||'');
    const m1=s.match(/(?:เมล|mail|email)\s*[:：]\s*([A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,})/i);
    if(m1) return m1[1];
    const m2=s.match(/\/mailz\/([^\s<>'"]+)/i);
    return m2 ? decodeURIComponent(m2[1]) : '';
  }
  function extractTwoFa(text){
    const s=String(text||'');
    const m1=s.match(/2FA\s*[:：]\s*([A-Z2-7a-z0-9\s]{12,})/i);
    if(m1) return m1[1].replace(/\s+/g,'');
    const m2=s.match(/\/2fa\/([^\s<>'"]+)/i);
    return m2 ? decodeURIComponent(m2[1]).replace(/\s+/g,'') : '';
  }

  const ICON_MAIL = `<svg class="ui-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Z"/><path d="m22 8-10 6L2 8"/></svg>`;
  const ICON_LOCK = `<svg class="ui-icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/><path d="M12 15v2"/></svg>`;
  function renderToolActions(o, detail){
    const wrap=$('#modalToolActions'); if(!wrap) return;
    const mail=(o.toolHints&&o.toolHints.mail)||extractMail(detail);
    const twoFa=(o.toolHints&&o.toolHints.twoFa)||extractTwoFa(detail);
    const parts=[];
    if(mail) parts.push(`<a class="tool-btn" href="/mailz/${encodeURIComponent(mail)}" target="_blank" rel="noopener">${ICON_MAIL}<span>เปิดเมล</span></a>`);
    if(twoFa) parts.push(`<a class="tool-btn" href="/2fa/${encodeURIComponent(twoFa)}" target="_blank" rel="noopener">${ICON_LOCK}<span>เปิด 2FA</span></a>`);
    wrap.innerHTML=parts.join('');
  }

  const APPS_WAITING_DETAIL_LINE_RX = /(?:เจ้าหน้าที่[\s\S]{0,120}กำลัง[\s\S]{0,120}ดำเนินการ[\s\S]{0,120}ส่ง[\s\S]{0,80}ข้อม(?:ู|ู|ลู|ูล)?สินค้า|กรุณาเช็ค[\s\S]{0,120}ประวัติสินค้า[\s\S]{0,80}(?:15\s*นาที|ข้อมูลล่าสุด)|ภายใน\s*24\s*(?:ชม\.?|ชั่วโมง))/i;
  function isWaitingDetailLine(line){
    return APPS_WAITING_DETAIL_LINE_RX.test(String(line || ''));
  }

  function cleanDetailLines(text, opts = {}){
    const raw = htmlToPlainText(text || 'ไม่มีข้อมูลสินค้า');
    const seen = new Set();
    return raw
      .replace(/\s*\|\s*/g, '\n')
      .split(/\n+/)
      .map(x => x.trim())
      .filter(line => {
        if(!line) return false;
        if(/^(?:[-—–_=*\s]{8,}|[─━═]+)$/.test(line)) return false;
        if(/^\.?\/?logstext\//i.test(line)) return false;
        if(/\/logstext\/[^\s]+\.txt/i.test(line)) return false;
        if(/^<\s*hr\b/i.test(line) || /^&lt;\s*hr\b/i.test(line)) return false;
        if(/เพื่อความรวดเร็ว/i.test(line) && /ติดต่อสอบถาม/i.test(line)) return false;
        if(/ติดต่อสอบถาม/i.test(line) && /facebook|เฟซบุ๊ก|เฟสบุ๊ค|fb\b/i.test(line)) return false;
        if(opts.removeWaiting && isWaitingDetailLine(line)) return false;
        const key = line
          .replace(/\s+/g, ' ')
          .replace(/(?:คืน\s*(?:เครดิต|เงิน)\s*[:：]\s*)(?:฿\s*)?[0-9][0-9,]*(?:\.\d+)?\s*(?:เครดิต|บาท|THB)?/i, 'คืนเครดิต:AMOUNT')
          .toLowerCase();
        if(seen.has(key)) return false;
        seen.add(key);
        return true;
      });
  }

  function detailToRows(text){
    const normalized = cleanDetailLines(text);
    if(!normalized.length){
      return '<div class="secret-plain">ไม่มีข้อมูลสินค้า</div>';
    }
    return normalized.map(line => {
      const m = line.match(/^([^:：]{1,34})\s*[:：]\s*(.+)$/);
      if(m){
        return `<div class="secret-row"><span class="secret-key">${escapeHtml(m[1].trim())}</span><span class="secret-value">${escapeHtml(m[2].trim())}</span></div>`;
      }
      return `<div class="secret-plain">${escapeHtml(line)}</div>`;
    }).join('');
  }

  function openModal(o){
    const title = cleanInlineText(o.appName || o.productName || 'ข้อมูลสินค้า');
    const detailRaw = o.accountText || o.linkText || o.message || 'ไม่มีข้อมูลสินค้า';
    const detail = cleanDetailLines(detailRaw, { removeWaiting:isRefundedOrder(o) }).join('\n') || 'ไม่มีข้อมูลสินค้า';
    $('#modalTitle').textContent = 'ข้อมูลสินค้า';
    $('#modalOrderNo').textContent = `#${o.orderId || '-'}`;
    $('#modalProductName').textContent = title;
    $('#modalDate').textContent = `วันที่สั่งซื้อ : ${formatDate(o.createdAt)}`;
    $('#modalPrice').textContent = baht(orderDisplayPrice(o));
    $('#modalSecret').innerHTML = detailToRows(detail);
    $('#modalSecret').dataset.copyText = detail || 'ไม่มีข้อมูลสินค้า';
    renderToolActions(o, detail);
    $('#detailModal').classList.add('show');
    $('#detailModal').setAttribute('aria-hidden','false');
  }
  function closeModal(){ $('#detailModal').classList.remove('show'); $('#detailModal').setAttribute('aria-hidden','true'); }
  $$('[data-close]').forEach(b=>b.addEventListener('click',closeModal));
  $('#detailModal')?.addEventListener('click',e=>{ if(e.target.id==='detailModal') closeModal(); });
  $('#copySecret')?.addEventListener('click',async()=>{ const box=$('#modalSecret'); await navigator.clipboard.writeText(box?.dataset?.copyText || box?.textContent || ''); toast('คัดลอกแล้ว'); });

  function escapeHtml(s){ return String(s??'').replace(/[&<>'"]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[m])); }
  function escapeAttr(s){ return escapeHtml(s).replace(/`/g,'&#96;'); }
  function formatDate(v){ try{return new Date(v).toLocaleString('th-TH',{dateStyle:'medium',timeStyle:'short'});}catch{return '-';} }

  loadOtpImagesSlow(document);
  renderProducts();
  if(<%- safeJson(__tab) %> === 'history') loadHistory();
})();
</script>

