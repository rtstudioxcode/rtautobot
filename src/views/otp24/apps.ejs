/* ==========================================================
   Enterprise Order Detail Modal — Premium Black/Gold Receipt
   เพิ่มเลเยอร์ดีไซน์ใหม่เฉพาะ Modal รายละเอียดสินค้า
========================================================== */
.apps-modal{
  background:
    radial-gradient(760px 420px at 50% 16%, color-mix(in srgb, var(--app-accent) 12%, transparent), transparent 64%),
    rgba(0,0,0,.74);
  backdrop-filter: blur(18px) saturate(132%);
}
.modal-box.order-detail-modal{
  width:min(980px,96vw);
  max-height:min(88vh,860px);
  overflow:hidden;
  border-radius:32px;
  border:1px solid color-mix(in srgb, var(--app-accent) 42%, var(--app-border));
  background:
    radial-gradient(820px 360px at 12% -10%, color-mix(in srgb, var(--app-accent) 18%, transparent), transparent 65%),
    radial-gradient(660px 280px at 102% 20%, color-mix(in srgb, var(--app-gold-2) 16%, transparent), transparent 64%),
    linear-gradient(145deg, color-mix(in srgb, var(--app-card-strong) 98%, #050505), color-mix(in srgb, #120d06 76%, var(--app-card)));
  box-shadow:
    0 44px 130px rgba(0,0,0,.72),
    0 0 0 1px color-mix(in srgb, var(--app-accent) 10%, transparent),
    0 0 70px color-mix(in srgb, var(--app-accent) 18%, transparent),
    inset 0 1px 0 rgba(255,255,255,.08);
}
.modal-box.order-detail-modal::before{
  content:"";
  display:block;
  height:5px;
  background:linear-gradient(90deg, transparent, var(--app-gold-2), var(--app-gold), var(--app-gold-2), transparent);
  box-shadow:0 0 24px color-mix(in srgb, var(--app-accent) 42%, transparent);
}
.modal-head.order-detail-head{
  position:relative;
  padding:24px 28px 12px;
  border-bottom:0;
  background:linear-gradient(180deg, rgba(255,255,255,.035), transparent);
}
.modal-head.order-detail-head h3{
  display:flex;
  align-items:center;
  gap:12px;
  font-size:27px;
  color:var(--app-text);
  text-shadow:0 0 22px rgba(247,215,116,.14);
}
.modal-head.order-detail-head h3::before{
  content:"";
  width:40px;
  height:40px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  border-radius:14px;
  color:#1b1204;
  background:linear-gradient(135deg,var(--app-gold),var(--app-gold-2));
  box-shadow:0 12px 32px color-mix(in srgb, var(--app-accent) 24%, transparent);
  font-size:18px;
}
.modal-close{
  width:44px;
  height:44px;
  border-radius:16px;
  border:1px solid color-mix(in srgb, var(--app-accent) 26%, var(--app-border));
  background:color-mix(in srgb, #050505 56%, transparent);
  box-shadow:inset 0 1px 0 rgba(255,255,255,.07);
}
.modal-body.order-detail-body{
  padding:0 28px 28px;
  overflow:auto;
  max-height:calc(min(88vh,860px) - 86px);
}
.order-detail-line{
  height:1px;
  margin:8px 0 22px;
  background:linear-gradient(90deg, var(--app-gold-2), color-mix(in srgb, var(--app-gold) 80%, transparent), transparent);
  box-shadow:0 0 24px color-mix(in srgb, var(--app-accent) 24%, transparent);
}
.order-detail-title{
  position:relative;
  grid-template-columns:auto minmax(0,1fr) auto;
  gap:14px;
  border-radius:22px;
  border:1px solid color-mix(in srgb, var(--app-accent) 28%, var(--app-border));
  background:
    linear-gradient(90deg, color-mix(in srgb, var(--app-accent) 12%, transparent), color-mix(in srgb, var(--app-card) 76%, transparent)),
    radial-gradient(460px 90px at 100% 0%, color-mix(in srgb, var(--app-accent) 14%, transparent), transparent 64%);
  padding:15px;
  box-shadow:0 18px 50px rgba(0,0,0,.22), inset 0 1px 0 rgba(255,255,255,.06);
}
.order-no{
  min-height:42px;
  border-radius:15px;
  color:#1b1204;
  background:linear-gradient(135deg,var(--app-gold),var(--app-gold-2));
  border:0;
  box-shadow:0 10px 26px color-mix(in srgb, var(--app-accent) 22%, transparent);
}
.order-product-name{
  font-size:16px;
  letter-spacing:.01em;
}
.order-date{
  padding:8px 10px;
  border-radius:999px;
  background:color-mix(in srgb, var(--app-page) 38%, transparent);
  border:1px solid color-mix(in srgb, var(--app-border) 70%, transparent);
}
.order-detail-label{
  margin:20px 0 14px;
  padding:0 2px;
}
.order-detail-label span{
  display:inline-flex;
  align-items:center;
  gap:8px;
  color:color-mix(in srgb, var(--app-text) 94%, var(--app-gold));
  font-size:16px;
}
.order-detail-label span::before{content:none;}
.order-detail-price{
  min-width:132px;
  text-align:right;
  padding:12px 16px;
  border-radius:18px;
  background:
    radial-gradient(120px 56px at 50% 50%, color-mix(in srgb, var(--app-accent) 22%, transparent), transparent 72%),
    color-mix(in srgb, var(--app-page) 35%, transparent);
  border:1px solid color-mix(in srgb, var(--app-accent) 24%, var(--app-border));
  color:var(--app-gold);
  font-size:22px;
  box-shadow:0 0 38px color-mix(in srgb, var(--app-accent) 13%, transparent);
}
.secret-box.clean-secret{
  display:grid;
  gap:10px;
  min-height:unset;
  max-height:320px;
  overflow:auto;
  padding:16px;
  border-radius:24px;
  background:
    linear-gradient(180deg, color-mix(in srgb, #050505 66%, transparent), color-mix(in srgb, var(--app-card) 70%, transparent));
  border:1px solid color-mix(in srgb, var(--app-accent) 20%, var(--app-border));
  box-shadow:inset 0 1px 0 rgba(255,255,255,.055), 0 22px 54px rgba(0,0,0,.22);
  font-family:inherit;
  white-space:normal;
}
.secret-row{
  display:grid;
  grid-template-columns:150px minmax(0,1fr);
  gap:12px;
  align-items:start;
  padding:13px 14px;
  border-radius:17px;
  background:linear-gradient(90deg, color-mix(in srgb, var(--app-accent) 8%, transparent), color-mix(in srgb, var(--app-page) 18%, transparent));
  border:1px solid color-mix(in srgb, var(--app-border) 72%, transparent);
}
.secret-key{
  color:var(--app-gold);
  font-weight:900;
  font-size:13px;
  letter-spacing:.02em;
}
.secret-value{
  color:color-mix(in srgb, var(--app-text) 94%, #fff);
  font-weight:760;
  line-height:1.65;
  word-break:break-word;
}
.secret-plain{
  padding:14px;
  border-radius:17px;
  color:color-mix(in srgb, var(--app-text) 92%, var(--app-muted));
  line-height:1.75;
  background:color-mix(in srgb, var(--app-page) 22%, transparent);
  border:1px solid color-mix(in srgb, var(--app-border) 70%, transparent);
  white-space:pre-wrap;
  word-break:break-word;
}
.copy-row.order-actions{
  margin-top:18px;
  padding-top:18px;
  border-top:1px solid color-mix(in srgb, var(--app-accent) 18%, var(--app-border));
}
.tool-btn,.copy-main-actions .ghost-btn{
  min-height:46px;
  border-radius:16px;
  font-weight:900;
}
.tool-btn{
  color:#1b1204;
  background:linear-gradient(135deg,var(--app-gold),var(--app-gold-2));
  border:0;
  box-shadow:0 12px 28px color-mix(in srgb, var(--app-accent) 16%, transparent);
}
.copy-main-actions .ghost-btn{
  padding:0 18px;
  border-color:color-mix(in srgb, var(--app-accent) 38%, var(--app-border));
  background:color-mix(in srgb, var(--app-page) 42%, transparent);
}
html[data-theme="light"] .modal-box.order-detail-modal{
  background:
    radial-gradient(760px 320px at 10% -10%, color-mix(in srgb, var(--app-accent) 18%, transparent), transparent 62%),
    linear-gradient(145deg, color-mix(in srgb, #fff 92%, var(--app-card)), color-mix(in srgb, #f7edd8 82%, var(--app-card)));
  box-shadow:0 34px 100px rgba(88,62,24,.22), 0 0 54px color-mix(in srgb, var(--app-accent) 15%, transparent);
}
html[data-theme="light"] .secret-box.clean-secret{
  background:linear-gradient(180deg,#fffaf0,color-mix(in srgb, var(--app-card) 88%, #fff));
}
@media (max-width:760px){
  .apps-modal{padding:12px;place-items:end center;}
  .modal-box.order-detail-modal{width:100%;border-radius:26px 26px 0 0;max-height:92vh;}
  .modal-head.order-detail-head{padding:20px 18px 10px;}
  .modal-head.order-detail-head h3{font-size:22px;}
  .modal-body.order-detail-body{padding:0 18px 18px;}
  .order-detail-title{grid-template-columns:1fr;}
  .order-date{justify-self:start;white-space:normal;}
  .order-detail-label{align-items:flex-start;}
  .order-detail-price{min-width:auto;font-size:20px;}
  .secret-row{grid-template-columns:1fr;gap:5px;}
  .copy-row.order-actions{flex-direction:column;align-items:stretch;}
  .tool-actions,.copy-main-actions{width:100%;margin:0;}
  .tool-btn,.copy-main-actions .ghost-btn{flex:1;}
}


