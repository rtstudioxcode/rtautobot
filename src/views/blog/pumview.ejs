<%
  const pageTitle = `${article.title} | คู่มือปั๊มวิว YouTube/TikTok แบบยั่งยืน | RTAUTOBOT`;
  const pageDesc  = article.excerpt
    || 'สอนปั๊มวิวให้โตอย่างยั่งยืนบน YouTube และ TikTok ด้วยการเข้าใจอัลกอริทึม Retention, CTR, Thumbnail, Title และตารางโพสต์ที่ช่วยให้คอนเทนต์ขึ้นจริงในหน้าแนะนำ.';
  const canonicalPath = `/blog/${article.slug || article._id || ''}`;

  title       = pageTitle;
  description = pageDesc;
  ogTitle     = pageTitle;
  ogDesc      = pageDesc;
  ogImage     = article.image;
%>

<script type="application/ld+json">
<%- safeJson({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.title,
  "description": pageDesc,
  "image": article.image,
  "author": {
    "@type": "Person",
    "name": article.author
  },
  "datePublished": article.dateISO || article.date,
  "dateModified": article.updatedAt || article.dateISO || article.date,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://rtautobot.com" + canonicalPath
  },
  "publisher": {
    "@type": "Organization",
    "name": "RTSSM-TH.COM",
    "logo": {
      "@type": "ImageObject",
      "url": "https://rtautobot.com/static/logo/logo-rtautobot.png"
    }
  }
}, null, 2) %>
</script>

<style>
  .pumview-enterprise{
    --pv-page:var(--page,#070910);
    --pv-card:var(--card,#10131d);
    --pv-text:var(--text,#eef6ff);
    --pv-muted:var(--muted,#a7adbb);
    --pv-border:var(--border,rgba(255,255,255,.10));
    --pv-accent:var(--accent,#08b84f);
    --pv-accent-2:#08b84f;
    --pv-soft:color-mix(in srgb,var(--pv-card) 78%,transparent);
    --pv-shadow:rgba(0,0,0,.30);
    --pv-green:#35d38b;
    --pv-blue:#60a5fa;
    --pv-red:#fb7185;
    --pv-radius:28px;
    color:var(--pv-text);
    width:100%;
    min-height:100vh;
    position:relative;
    overflow:hidden;
    padding:28px 18px 0;
    background:
      radial-gradient(circle at 12% 8%, color-mix(in srgb,var(--pv-accent) 18%,transparent), transparent 34%),
      radial-gradient(circle at 86% 18%, rgba(96,165,250,.13), transparent 32%),
      linear-gradient(180deg, color-mix(in srgb,var(--pv-page) 94%,#141821), var(--pv-page));
  }
  html[data-theme="light"] .pumview-enterprise,
  html.light .pumview-enterprise,
  body.light .pumview-enterprise{
    --pv-page:var(--page,#f7f8fb);
    --pv-card:var(--card,#ffffff);
    --pv-text:var(--text,#141414);
    --pv-muted:var(--muted,#667085);
    --pv-border:var(--border,rgba(20,20,20,.12));
    --pv-shadow:rgba(16,24,40,.12);
    --pv-soft:rgba(255,255,255,.72);
  }
  .pumview-enterprise *{box-sizing:border-box;}
  .pumview-enterprise a{color:inherit;}
  .pv-shell{max-width:1180px;margin:0 auto;position:relative;z-index:1;}
  .pv-orb{position:absolute;border-radius:999px;filter:blur(8px);pointer-events:none;opacity:.55;animation:pvFloat 10s ease-in-out infinite;}
  .pv-orb.one{width:180px;height:180px;right:7%;top:96px;background:radial-gradient(circle,var(--pv-accent),transparent 62%);}
  .pv-orb.two{width:140px;height:140px;left:4%;top:420px;background:radial-gradient(circle,rgba(96,165,250,.45),transparent 62%);animation-delay:-4s;}
  @keyframes pvFloat{0%,100%{transform:translate3d(0,0,0) scale(1)}50%{transform:translate3d(0,-20px,0) scale(1.06)}}

  .pv-hero{
    position:relative;
    display:grid;
    grid-template-columns:minmax(0,1.08fr) minmax(320px,.92fr);
    gap:24px;
    align-items:stretch;
    margin-bottom:24px;
  }
  .pv-hero-card,.pv-cover-card,.pv-card,.pv-cta,.site-footer{
    border:1px solid var(--pv-border);
    background:
      linear-gradient(180deg,rgba(255,255,255,.055),rgba(255,255,255,.018)),
      color-mix(in srgb,var(--pv-card) 92%,transparent);
    box-shadow:0 22px 60px var(--pv-shadow), inset 0 1px 0 rgba(255,255,255,.06);
    backdrop-filter:blur(16px);
    -webkit-backdrop-filter:blur(16px);
  }
  .pv-hero-card{border-radius:34px;padding:32px;overflow:hidden;position:relative;animation:pvRise .58s ease both;}
  .pv-hero-card::before{content:"";position:absolute;inset:-1px;background:linear-gradient(135deg,color-mix(in srgb,var(--pv-accent) 32%,transparent),transparent 42%,rgba(96,165,250,.14));pointer-events:none;mask:linear-gradient(#000,transparent 62%);}
  .pv-kicker{display:inline-flex;align-items:center;gap:9px;padding:8px 12px;border-radius:999px;border:1px solid color-mix(in srgb,var(--pv-accent) 34%,var(--pv-border));background:color-mix(in srgb,var(--pv-accent) 12%,transparent);color:var(--pv-accent-2);font-size:12px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;margin-bottom:16px;}
  .pv-title{position:relative;margin:0;font-size:clamp(30px,4.8vw,58px);line-height:1.03;letter-spacing:-.05em;font-weight:950;max-width:820px;}
  .pv-desc{position:relative;margin:16px 0 0;color:var(--pv-muted);font-size:clamp(15px,1.45vw,18px);line-height:1.8;max-width:720px;}
  .pv-meta{display:flex;flex-wrap:wrap;gap:10px;margin-top:22px;}
  .pv-meta span{display:inline-flex;align-items:center;gap:8px;padding:9px 12px;border-radius:999px;background:var(--pv-soft);border:1px solid var(--pv-border);color:var(--pv-muted);font-size:13px;font-weight:800;}
  .pv-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:24px;}
  .pv-btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;border:0;text-decoration:none;border-radius:18px;padding:13px 18px;font-weight:650;transition:transform .2s ease,box-shadow .2s ease,background .2s ease;}
  .pv-btn.primary{color:#17130a;background:linear-gradient(135deg,#08b84f,#08b84f 56%,#05b84f);box-shadow:0 16px 32px color-mix(in srgb,var(--pv-accent) 28%,transparent);}
  .pv-btn.ghost{color:var(--pv-text);background:var(--pv-soft);border:1px solid var(--pv-border);}
  .pv-btn:hover{transform:translateY(-2px);}
  .pv-cover-card{border-radius:34px;padding:12px;overflow:hidden;position:relative;animation:pvRise .64s .08s ease both;}
  .pv-cover-card img{width:100%;height:100%;min-height:360px;max-height:520px;object-fit:cover;border-radius:24px;display:block;filter:saturate(1.06) contrast(1.04);}
  .pv-cover-card::after{content:"";position:absolute;inset:12px;border-radius:24px;background:linear-gradient(180deg,transparent 45%,rgba(0,0,0,.52));pointer-events:none;}
  .pv-cover-badge{position:absolute;left:26px;right:26px;bottom:26px;z-index:2;display:flex;justify-content:space-between;gap:12px;align-items:center;padding:12px 14px;border-radius:20px;background:rgba(12,14,20,.72);border:1px solid rgba(255,255,255,.14);backdrop-filter:blur(12px);color:#fff;}
  .pv-cover-badge strong{font-size:20px;display:block;}
  .pv-cover-badge small{color:rgba(255,255,255,.68);font-weight:800;}

  .pv-stats{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin:0 0 24px;}
  .pv-stat{border:1px solid var(--pv-border);border-radius:24px;padding:16px;background:var(--pv-soft);box-shadow:0 14px 38px color-mix(in srgb,var(--pv-shadow) 78%,transparent);animation:pvRise .55s ease both;}
  .pv-stat:nth-child(2){animation-delay:.06s}.pv-stat:nth-child(3){animation-delay:.12s}.pv-stat:nth-child(4){animation-delay:.18s}
  .pv-stat .ico{width:42px;height:42px;border-radius:16px;display:grid;place-items:center;background:color-mix(in srgb,var(--pv-accent) 16%,transparent);border:1px solid color-mix(in srgb,var(--pv-accent) 28%,var(--pv-border));margin-bottom:10px;}
  .pv-stat strong{display:block;font-size:22px;line-height:1.1;}
  .pv-stat span{display:block;margin-top:4px;color:var(--pv-muted);font-size:12px;font-weight:800;}

  .pv-layout{display:grid;grid-template-columns:minmax(0,1fr) 320px;gap:24px;align-items:start;}
  .pv-article{min-width:0;}
  .pv-card{border-radius:30px;padding:26px;margin-bottom:18px;position:relative;overflow:hidden;animation:pvReveal both;animation-timeline:view();animation-range:entry 5% cover 22%;}
  .pv-card h2{margin:0 0 14px;font-size:clamp(23px,2.4vw,32px);line-height:1.15;letter-spacing:-.03em;}
  .pv-card h3{margin:18px 0 8px;font-size:18px;}
  .pv-card p,.pv-card li{color:var(--pv-muted);line-height:1.85;font-size:15.5px;}
  .pv-card strong{color:var(--pv-text);}
  .pv-card ul,.pv-card ol{padding-left:22px;margin:12px 0 0;}
  .pv-card li+li{margin-top:8px;}
  .pv-card a:not(.pv-btn){color:var(--pv-accent-2);font-weight:900;text-decoration:none;border-bottom:1px dashed color-mix(in srgb,var(--pv-accent) 50%,transparent);}
  .pv-keypoints{border-color:color-mix(in srgb,var(--pv-accent) 30%,var(--pv-border));background:linear-gradient(135deg,color-mix(in srgb,var(--pv-accent) 11%,transparent),color-mix(in srgb,var(--pv-card) 92%,transparent));}
  .pv-tip{padding:14px 16px;border-radius:20px;border:1px solid color-mix(in srgb,var(--pv-blue) 28%,var(--pv-border));background:color-mix(in srgb,var(--pv-blue) 9%,transparent);}
  .pv-grid-2{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px;}
  .pv-mini{border:1px solid var(--pv-border);border-radius:22px;padding:18px;background:color-mix(in srgb,var(--pv-soft) 80%,transparent);}
  .pv-table-wrap{overflow:auto;border-radius:22px;border:1px solid var(--pv-border);margin-top:16px;}
  .pv-table{width:100%;border-collapse:separate;border-spacing:0;min-width:680px;}
  .pv-table th,.pv-table td{padding:14px 16px;text-align:left;border-bottom:1px solid var(--pv-border);vertical-align:top;}
  .pv-table th{background:color-mix(in srgb,var(--pv-accent) 13%,var(--pv-card));color:var(--pv-text);font-size:13px;font-weight:950;}
  .pv-table tr:last-child td{border-bottom:0;}
  .pv-table td{color:var(--pv-muted);}
  .pv-steps{counter-reset:pvstep;display:grid;gap:12px;margin-top:16px;}
  .pv-step{counter-increment:pvstep;display:grid;grid-template-columns:44px 1fr;gap:14px;align-items:start;padding:14px;border-radius:20px;border:1px solid var(--pv-border);background:var(--pv-soft);}
  .pv-step::before{content:counter(pvstep);width:44px;height:44px;border-radius:16px;display:grid;place-items:center;background:linear-gradient(135deg,#08b84f,#08b84f);color:#17130a;font-weight:950;box-shadow:0 12px 22px color-mix(in srgb,var(--pv-accent) 25%,transparent);}
  .pv-step strong{display:block;margin-bottom:3px;}
  .pv-faq details{border:1px solid var(--pv-border);border-radius:20px;padding:16px;background:var(--pv-soft);}
  .pv-faq details+details{margin-top:10px;}
  .pv-faq summary{cursor:pointer;font-weight:950;color:var(--pv-text);}
  .pv-faq summary::marker{color:var(--pv-accent);}

  .pv-sidebar{position:sticky;top:86px;display:grid;gap:14px;}
  .pv-side-card{border:1px solid var(--pv-border);border-radius:28px;padding:18px;background:color-mix(in srgb,var(--pv-card) 86%,transparent);box-shadow:0 18px 44px var(--pv-shadow);backdrop-filter:blur(14px);}
  .pv-side-card h3{margin:0 0 12px;font-size:16px;}
  .pv-toc{display:grid;gap:7px;}
  .pv-toc a{display:flex;align-items:center;gap:9px;text-decoration:none;color:var(--pv-muted);font-weight:850;font-size:13px;padding:9px 10px;border-radius:14px;transition:background .2s ease,color .2s ease,transform .2s ease;}
  .pv-toc a::before{content:"";width:7px;height:7px;border-radius:999px;background:color-mix(in srgb,var(--pv-accent) 52%,transparent);box-shadow:0 0 16px color-mix(in srgb,var(--pv-accent) 35%,transparent);}
  .pv-toc a:hover,.pv-toc a.active{color:var(--pv-text);background:var(--pv-soft);transform:translateX(2px);}
  .pv-service-list{display:grid;gap:8px;}
  .pv-service-list span{display:flex;justify-content:space-between;gap:10px;padding:10px 12px;border-radius:16px;background:var(--pv-soft);color:var(--pv-muted);font-size:13px;font-weight:850;}
  .pv-service-list b{color:var(--pv-accent-2);}

  .pv-cta{border-radius:34px;padding:28px;margin:22px 0 26px;display:grid;grid-template-columns:1fr auto;gap:18px;align-items:center;background:linear-gradient(135deg,color-mix(in srgb,var(--pv-accent) 18%,var(--pv-card)),color-mix(in srgb,var(--pv-card) 92%,transparent));}
  .pv-cta h2{margin:0;font-size:clamp(24px,3vw,36px);line-height:1.12;}
  .pv-cta p{margin:8px 0 0;color:var(--pv-muted);line-height:1.75;}

  .site-footer{border-radius:34px 34px 0 0;margin-top:30px;overflow:hidden;}
  .site-footer__topline{height:3px;background:linear-gradient(90deg,transparent,var(--pv-accent),transparent);}
  .site-footer__container{display:grid;grid-template-columns:1.4fr repeat(3,1fr);gap:22px;padding:28px;}
  .brand-logo{max-width:170px;height:auto;object-fit:contain;}
  .brand-text{margin:14px 0 0;color:var(--pv-muted);line-height:1.75;font-size:14px;}
  .footer-title{margin:0 0 12px;font-size:14px;color:var(--pv-text);font-weight:950;}
  .footer-list{list-style:none;padding:0;margin:0;display:grid;gap:9px;}
  .footer-list a{text-decoration:none;color:var(--pv-muted);font-size:14px;font-weight:800;transition:color .2s ease,transform .2s ease;display:inline-block;}
  .footer-list a:hover{color:var(--pv-accent-2);transform:translateX(2px);}

  @keyframes pvRise{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
  @keyframes pvReveal{from{opacity:.2;transform:translateY(22px) scale(.99)}to{opacity:1;transform:translateY(0) scale(1)}}
  @media (max-width:1020px){
    .pv-hero,.pv-layout,.pv-cta{grid-template-columns:1fr;}
    .pv-sidebar{position:relative;top:auto;order:-1;}
    .pv-stats{grid-template-columns:repeat(2,minmax(0,1fr));}
    .pv-cover-card img{min-height:280px;}
  }
  @media (max-width:720px){
    .pumview-enterprise{padding:18px 12px 0;}
    .pv-hero-card{padding:22px;border-radius:28px;}
    .pv-cover-card{border-radius:28px;}
    .pv-cover-card img{min-height:230px;border-radius:20px;}
    .pv-cover-badge{left:20px;right:20px;bottom:20px;align-items:flex-start;flex-direction:column;}
    .pv-stats{grid-template-columns:1fr 1fr;gap:10px;}
    .pv-card{padding:20px;border-radius:24px;}
    .pv-grid-2{grid-template-columns:1fr;}
    .pv-cta{padding:22px;border-radius:28px;}
    .pv-cta .pv-btn{width:100%;}
    .site-footer__container{grid-template-columns:1fr;text-align:center;padding:24px 18px;}
    .footer-list a:hover{transform:none;}
  }
  @media (max-width:430px){
    .pv-stats{grid-template-columns:1fr;}
    .pv-actions{display:grid;}
    .pv-btn{width:100%;}
  }
  @media (prefers-reduced-motion:reduce){
    .pumview-enterprise *, .pumview-enterprise *::before, .pumview-enterprise *::after{animation:none!important;transition:none!important;scroll-behavior:auto!important;}
  }
</style>

<section class="pumview-enterprise">
  <span class="pv-orb one" aria-hidden="true"></span>
  <span class="pv-orb two" aria-hidden="true"></span>

  <div class="pv-shell">
    <header class="pv-hero">
      <div class="pv-hero-card">
        <div class="pv-kicker"><span>✦</span> Growth Playbook</div>
        <h1 class="pv-title"><%= article.title || 'ปั๊มวิวให้โตแบบยั่งยืน' %></h1>
        <p class="pv-desc"><%= pageDesc %></p>
        <div class="pv-meta" aria-label="ข้อมูลบทความ">
          <span>🕒 <%= article.date || '7 พฤศจิกายน 2026' %></span>
          <span>👤 <%= article.author || 'RTAUTOBOT' %></span>
          <span>⚡ อ่านประมาณ 6 นาที</span>
        </div>
        <div class="pv-actions">
          <a class="pv-btn primary" href="/orders/new">เริ่มเพิ่มยอดวิวตอนนี้</a>
          <a class="pv-btn ghost" href="#algo">อ่านคู่มือก่อนสั่ง</a>
        </div>
      </div>

      <figure class="pv-cover-card">
        <img src="/static/assets/thumbnails/blog5.gif" alt="บทความการตลาดวิดีโอ YouTube/TikTok: <%= article.title %>" loading="lazy">
        <figcaption class="pv-cover-badge">
          <div><small>Retention + CTR</small><strong>โตแบบยั่งยืน</strong></div>
          <div><small>Platform</small><strong>YouTube / TikTok</strong></div>
        </figcaption>
      </figure>
    </header>

    <section class="pv-stats" aria-label="ไฮไลต์บทความ">
      <div class="pv-stat"><span class="ico">🎯</span><strong>CTR</strong><span>ปกและหัวข้อที่คนอยากกด</span></div>
      <div class="pv-stat"><span class="ico">⏱️</span><strong>Retention</strong><span>ทำให้คนดูจบมากขึ้น</span></div>
      <div class="pv-stat"><span class="ico">💬</span><strong>Engagement</strong><span>เพิ่มไลก์ คอมเมนต์ แชร์</span></div>
      <div class="pv-stat"><span class="ico">🚀</span><strong>Boost</strong><span>เสริมแรงช่วงเริ่มต้น</span></div>
    </section>

    <div class="pv-layout">
      <main class="pv-article">
        <article>
          <section class="pv-card pv-keypoints">
            <h2>สรุปเร็ว ก่อนเริ่มปั๊มวิว</h2>
            <ul>
              <li>ชนะอัลกอริทึมด้วย “การดูจบ” และ “การมีส่วนร่วม”</li>
              <li>Thumbnail + Title คือด่านแรกที่ต้องชนะ CTR</li>
              <li>คีย์เวิร์ดและแท็กต้องตรงกับเนื้อหา อย่ายิงสุ่ม</li>
              <li>โพสต์สม่ำเสมอ พร้อมโครงสร้างคลิปชัดเจน = โตยาวกว่า</li>
              <li>ต้องการแรงส่งช่วงเริ่มต้น ใช้ <a href="/orders/new" target="_blank" rel="noopener">บริการเพิ่มยอดแบบมืออาชีพ</a> เสริมได้</li>
            </ul>
          </section>

          <section id="algo" class="pv-card">
            <h2>1) เข้าใจอัลกอริทึมแบบภาคปฏิบัติ</h2>
            <p>แพลตฟอร์มจะแนะนำคลิปที่ทำให้ผู้ชมอยู่ในระบบนานขึ้นและมีปฏิสัมพันธ์มากขึ้น ดังนั้นการปั๊มวิวที่ดีไม่ใช่แค่เพิ่มตัวเลข แต่ต้องช่วยให้คอนเทนต์ดูน่าเชื่อถือและต่อยอดกับพฤติกรรมผู้ชมจริง</p>
            <ul>
              <li><strong>CTR</strong> อัตราคลิกเข้า มาจากปกและหัวข้อที่ดึงดูด</li>
              <li><strong>Retention</strong> เปอร์เซ็นต์ดูจบหรือเวลารับชมเฉลี่ย โครงสร้างเนื้อหาต้องแน่น</li>
              <li><strong>Engagement</strong> ไลก์ คอมเมนต์ แชร์ และบันทึก ช่วยส่งสัญญาณว่าคลิปน่าสนใจ</li>
            </ul>
            <p class="pv-tip"><strong>ทริค:</strong> ใช้ 5–15 วินาทีแรกขายคุณค่าหลักให้ชัด เช่น ผลลัพธ์ที่จะได้ ช่วงไฮไลต์ หรือปัญหาที่คนดูอยากรู้คำตอบ</p>
          </section>

          <section id="content-plan" class="pv-card">
            <h2>2) แผนคอนเทนต์ที่ดูจบจริง</h2>
            <div class="pv-steps">
              <div class="pv-step"><div><strong>Hook</strong><p>เปิดด้วยปัญหา ผลลัพธ์ หรือตัวเลขน่าสนใจในช่วง 0:00–0:15</p></div></div>
              <div class="pv-step"><div><strong>Value Blocks</strong><p>แบ่งเนื้อหาเป็น 3–5 บล็อก เปลี่ยนภาพ มุมกล้อง หรือกราฟิกทุก 4–8 วินาที</p></div></div>
