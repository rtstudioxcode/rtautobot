<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Kanit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>

    :root{
      --rt-page: var(--page, #07080b);
      --rt-card: var(--card, #17181d);
      --rt-card-2: color-mix(in srgb, var(--card, #17181d) 72%, #0a0b10);
      --rt-soft: color-mix(in srgb, var(--card, #17181d) 84%, #ffffff 4%);
      --rt-text: var(--text, #fff4df);
      --rt-muted: var(--muted, #d9c895);
      --rt-border: var(--border, rgba(255,255,255,.12));
      --rt-accent: var(--accent, #f8d66b);
      --rt-accent-2: #d59a25;
      --rt-green: #33e889;
      --rt-blue: #4eb7ff;
      --rt-red: #ff6b7e;
      --rt-shadow: rgba(0,0,0,.48);
      --rt-radius-xl: 34px;
      --rt-radius-lg: 26px;
      --rt-radius-md: 18px;
      color-scheme: dark;
    }

    html[data-theme="light"], html.light, body.light, [data-theme="light"]{
      --rt-page: var(--page, #f6f7fb);
      --rt-card: var(--card, #ffffff);
      --rt-card-2: #f8fafc;
      --rt-soft: #f1f5f9;
      --rt-text: var(--text, #10131a);
      --rt-muted: var(--muted, #607089);
      --rt-border: var(--border, rgba(15,23,42,.12));
      --rt-shadow: rgba(15,23,42,.12);
      color-scheme: light;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:"Kanit",system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
      background:
        radial-gradient(circle at 13% 9%, color-mix(in srgb,var(--rt-accent) 20%, transparent), transparent 28%),
        radial-gradient(circle at 82% 18%, rgba(74,118,255,.18), transparent 30%),
        radial-gradient(circle at 50% 86%, rgba(128,74,255,.12), transparent 32%),
        var(--rt-page);
      color:var(--rt-text);
      overflow-x:hidden;
    }

    body::before{
      content:"";
      position:fixed;inset:0;pointer-events:none;z-index:-1;
      background-image:
        linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px);
      background-size:58px 58px;
      mask-image:linear-gradient(to bottom, rgba(0,0,0,.75), transparent 82%);
    }

    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    .rt-wrap{width:min(1480px,calc(100% - 32px));margin:0 auto}

    .rt-landing-nav{
      position:relative;
      z-index:50;
      width:100vw;
      margin:0;
      margin-left:calc(50% - 50vw);
      margin-right:calc(50% - 50vw);
      backdrop-filter:blur(18px);
      -webkit-backdrop-filter:blur(18px);
      background:color-mix(in srgb,var(--rt-page) 80%, transparent);
      border-top:1px solid color-mix(in srgb,var(--rt-border) 54%, transparent);
      border-bottom:1px solid var(--rt-border);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.035);
    }
    .rt-landing-nav .rt-wrap{
      width:100%;
      max-width:none;
      margin:0;
      padding-inline:clamp(12px,1.55vw,28px);
    }
    .rt-nav-inner{height:78px;display:flex;align-items:center;justify-content:space-between;gap:18px}
    .rt-brand{display:flex;align-items:center;gap:12px;font-weight:900;letter-spacing:.02em}
    .rt-brand-mark{width:36px;height:36px;border-radius:16px;display:grid;place-items:center;background:linear-gradient(135deg,#ffe689,#c58b22);color:#17130a;box-shadow:0 18px 44px color-mix(in srgb,var(--rt-accent) 26%, transparent)}
    .rt-brand small{display:block;color:var(--rt-muted);font-size:12px;font-weight:700;margin-top:2px}
    .rt-nav-links{display:flex;align-items:center;gap:8px;color:var(--rt-muted);font-weight:800;font-size:14px}
    .rt-nav-links a{padding:10px 13px;border-radius:999px;transition:.2s ease}
    .rt-nav-links a:hover{background:var(--rt-soft);color:var(--rt-text);transform:translateY(-1px)}

    .rt-btn{border:0;border-radius:18px;padding:14px 20px;font-weight:500;display:inline-flex;align-items:center;justify-content:center;gap:10px;cursor:pointer;transition:transform .2s ease,box-shadow .2s ease,filter .2s ease}
    .rt-btn:hover{transform:translateY(-2px);filter:saturate(1.05)}
    .rt-btn-primary{background:linear-gradient(135deg,#fff0a4,#f4c84e 55%,#c88d25);color:#17130a;box-shadow:0 18px 44px color-mix(in srgb,var(--rt-accent) 26%, transparent)}
    .rt-btn-ghost{background:color-mix(in srgb,var(--rt-card) 70%, transparent);border:1px solid var(--rt-border);color:var(--rt-text)}

    .rt-hero{position:relative;padding:46px 0 34px}
    .rt-hero-grid{display:grid;grid-template-columns:minmax(0,1.05fr) minmax(420px,.95fr);gap:22px;align-items:stretch}
    .rt-panel{
      position:relative;overflow:hidden;border:1px solid var(--rt-border);border-radius:var(--rt-radius-xl);
      background:linear-gradient(145deg,color-mix(in srgb,var(--rt-card) 92%,transparent),color-mix(in srgb,var(--rt-card-2) 90%,transparent));
      box-shadow:0 28px 80px var(--rt-shadow), inset 0 1px 0 rgba(255,255,255,.06);
    }
    .rt-panel::before{content:"";position:absolute;inset:-2px;background:radial-gradient(circle at 18% 10%,color-mix(in srgb,var(--rt-accent) 22%,transparent),transparent 34%),radial-gradient(circle at 86% 18%,rgba(80,120,255,.12),transparent 32%);pointer-events:none}
    .rt-panel > *{position:relative;z-index:1}
    .rt-hero-main{padding:56px 52px;min-height:560px;display:flex;flex-direction:column;justify-content:space-between}
    .rt-kicker{display:inline-flex;align-items:center;gap:8px;width:max-content;padding:9px 14px;border-radius:999px;border:1px solid color-mix(in srgb,var(--rt-accent) 46%,var(--rt-border));background:color-mix(in srgb,var(--rt-accent) 10%,transparent);color:var(--rt-accent);font-size:13px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}
    .rt-hero h1{font-size:clamp(42px,5.6vw,96px);line-height:.96;margin:24px 0 18px;letter-spacing:-.06em}
    .rt-hero h1 span{background:linear-gradient(135deg,#fff7df,#ffe28a 45%,#c58d2b);-webkit-background-clip:text;background-clip:text;color:transparent}
    .rt-lead{max-width:760px;margin:0;color:var(--rt-muted);font-size:clamp(17px,1.35vw,23px);line-height:1.75;font-weight:700}
    .rt-hero-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:34px}
    .rt-trust{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:34px}
    .rt-mini{padding:18px;border:1px solid var(--rt-border);border-radius:22px;background:color-mix(in srgb,var(--rt-soft) 66%,transparent)}
    .rt-mini strong{display:block;font-size:26px;color:var(--rt-accent);line-height:1}
    .rt-mini span{display:block;color:var(--rt-muted);font-weight:800;margin-top:8px;font-size:13px}

    .rt-hero-side{display:grid;gap:14px;padding:16px}
    .rt-command{padding:22px;border-radius:26px;background:color-mix(in srgb,var(--rt-soft) 70%,transparent);border:1px solid var(--rt-border)}
    .rt-command-head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:18px}
    .rt-command h3{margin:0;font-size:22px}
    .rt-live{font-weight:900;color:var(--rt-green);font-size:13px;display:flex;align-items:center;gap:7px}
    .rt-live i{width:9px;height:9px;border-radius:50%;background:var(--rt-green);box-shadow:0 0 0 8px rgba(51,232,137,.12)}
    .rt-dash{display:grid;gap:10px}
    .rt-dash-row{display:grid;grid-template-columns:42px 1fr auto;align-items:center;gap:12px;padding:14px;border:1px solid var(--rt-border);border-radius:20px;background:color-mix(in srgb,var(--rt-card) 84%,transparent);animation:floatIn .65s ease both}
    .rt-dash-row:nth-child(2){animation-delay:.08s}.rt-dash-row:nth-child(3){animation-delay:.16s}.rt-dash-row:nth-child(4){animation-delay:.24s}
    .rt-dash-ico{width:42px;height:42px;border-radius:16px;display:grid;place-items:center;background:linear-gradient(135deg,color-mix(in srgb,var(--rt-accent) 30%,transparent),color-mix(in srgb,var(--rt-blue) 14%,transparent));color:var(--rt-accent)}
    .rt-dash-row strong{display:block;font-size:15px}.rt-dash-row span{display:block;color:var(--rt-muted);font-size:12px;font-weight:700;margin-top:2px}.rt-pill{padding:8px 11px;border-radius:999px;background:color-mix(in srgb,var(--rt-green) 15%,transparent);color:var(--rt-green);font-weight:600;font-size:12px}
    .rt-chart{height:190px;border:1px solid var(--rt-border);border-radius:24px;background:linear-gradient(180deg,rgba(255,255,255,.03),transparent);padding:18px;position:relative;overflow:hidden}
    .rt-chart svg{position:absolute;inset:auto 14px 18px 14px;width:calc(100% - 28px);height:120px;overflow:visible}.rt-chart path.line{stroke:var(--rt-accent);stroke-width:6;fill:none;filter:drop-shadow(0 10px 18px color-mix(in srgb,var(--rt-accent) 32%,transparent));stroke-dasharray:720;stroke-dashoffset:720;animation:draw 1.4s ease .35s forwards}.rt-chart path.area{fill:url(#rtGrad);opacity:.62}.rt-chart h4{margin:0;font-size:15px;color:var(--rt-muted)}.rt-chart strong{font-size:36px;color:var(--rt-accent)}

    .rt-platforms{padding:18px 0 34px}
    .rt-section-head{display:flex;align-items:end;justify-content:space-between;gap:18px;margin:0 0 18px}.rt-section-head h2{font-size:clamp(28px,3vw,48px);margin:0;letter-spacing:-.04em}.rt-section-head p{margin:8px 0 0;color:var(--rt-muted);font-weight:500;max-width:760px;line-height:1.7}.rt-link{color:var(--rt-accent);font-weight:600;display:inline-flex;align-items:center;gap:8px}
    .rt-platform-grid{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:12px}
    .rt-platform{min-height:106px;padding:16px;border-radius:24px;border:1px solid var(--rt-border);background:linear-gradient(180deg,color-mix(in srgb,var(--rt-card) 90%,transparent),color-mix(in srgb,var(--rt-soft) 62%,transparent));box-shadow:0 18px 46px color-mix(in srgb,var(--rt-shadow) 42%,transparent);display:flex;flex-direction:column;justify-content:space-between;transition:.22s ease;opacity:0;transform:translateY(16px)}
    .rt-platform.show{opacity:1;transform:translateY(0)}.rt-platform:hover{transform:translateY(-5px);border-color:color-mix(in srgb,var(--rt-accent) 44%,var(--rt-border));box-shadow:0 24px 60px color-mix(in srgb,var(--rt-accent) 12%,var(--rt-shadow))}.rt-platform i{font-size:24px;color:var(--rt-accent)}.rt-platform strong{font-size:15px}.rt-platform span{font-size:12px;color:var(--rt-muted);font-weight:800}


    /* ======================================================
       OTP24 SERVICE + TELEGRAM PREMIUM SALES SECTIONS
    ====================================================== */
    .rt-service-showcase{padding:18px 0 42px;position:relative}
    .rt-service-showcase .rt-section-head{margin-bottom:20px}
    .rt-service-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px;align-items:stretch}
    .rt-service-grid.single{grid-template-columns:1fr}
    .rt-service-card.full{min-height:auto}
    .rt-service-card{position:relative;overflow:hidden;border:1px solid color-mix(in srgb,var(--rt-accent) 22%,var(--rt-border));border-radius:34px;background:linear-gradient(145deg,color-mix(in srgb,var(--rt-card) 94%,transparent),color-mix(in srgb,var(--rt-card-2) 92%,transparent));box-shadow:0 24px 72px color-mix(in srgb,var(--rt-shadow) 86%,transparent), inset 0 1px 0 rgba(255,255,255,.06);padding:30px;min-height:640px;display:flex;flex-direction:column;justify-content:space-between;isolation:isolate}
    .rt-service-card::before{content:"";position:absolute;inset:-2px;background:radial-gradient(circle at 14% 10%,color-mix(in srgb,var(--svc-glow,var(--rt-accent)) 24%,transparent),transparent 35%),radial-gradient(circle at 92% 2%,rgba(255,255,255,.08),transparent 28%),linear-gradient(135deg,transparent 10%,rgba(255,255,255,.035),transparent 54%);pointer-events:none;z-index:-1}
    .rt-service-card::after{content:"";position:absolute;inset:0;border-radius:inherit;padding:1px;background:linear-gradient(135deg,color-mix(in srgb,var(--svc-glow,var(--rt-accent)) 72%,transparent),transparent 34%,color-mix(in srgb,var(--rt-accent) 42%,transparent));-webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);-webkit-mask-composite:xor;mask-composite:exclude;pointer-events:none;opacity:.52}
    .rt-service-card.otp{--svc-glow:#f8d66b}.rt-service-card.telegram{--svc-glow:#4eb7ff}
    .rt-service-top{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:22px}
    .rt-service-badge{width:64px;height:64px;border-radius:22px;display:grid;place-items:center;font-size:30px;background:linear-gradient(135deg,#fff0a4,#f4c84e 55%,#c88d25);color:#17130a;box-shadow:0 18px 44px color-mix(in srgb,var(--svc-glow,var(--rt-accent)) 28%,transparent)}
    .rt-service-card.telegram .rt-service-badge{background:linear-gradient(135deg,#9bd7ff,#4eb7ff 58%,#2563eb);color:#07111f}
    .rt-service-status{display:inline-flex;align-items:center;gap:8px;padding:9px 12px;border-radius:999px;border:1px solid color-mix(in srgb,var(--svc-glow,var(--rt-accent)) 40%,var(--rt-border));background:color-mix(in srgb,var(--svc-glow,var(--rt-accent)) 11%,transparent);color:color-mix(in srgb,var(--svc-glow,var(--rt-accent)) 86%,#fff);font-size:12px;font-weight:900;letter-spacing:.04em;text-transform:uppercase;white-space:nowrap}.rt-service-status i{width:8px;height:8px;border-radius:999px;background:var(--rt-green);box-shadow:0 0 0 7px rgba(51,232,137,.12)}
    .rt-service-card h3{font-size:clamp(30px,3vw,46px);line-height:1.04;letter-spacing:-.045em;margin:0 0 12px}.rt-service-card h3 span{background:linear-gradient(135deg,#fff7df,#ffe28a 52%,#c58d2b);-webkit-background-clip:text;background-clip:text;color:transparent}.rt-service-card.telegram h3 span{background:linear-gradient(135deg,#eaf7ff,#9bd7ff 50%,#4eb7ff);-webkit-background-clip:text;background-clip:text;color:transparent}.rt-service-lead{margin:0;color:var(--rt-muted);font-weight:700;line-height:1.8;font-size:16px}
    .rt-service-points{display:grid;gap:10px;margin:24px 0}.rt-service-point{display:grid;grid-template-columns:42px 1fr;gap:12px;align-items:start;padding:14px;border:1px solid var(--rt-border);border-radius:20px;background:color-mix(in srgb,var(--rt-soft) 64%,transparent);transition:.22s ease}.rt-service-point:hover{transform:translateY(-2px);border-color:color-mix(in srgb,var(--svc-glow,var(--rt-accent)) 48%,var(--rt-border));background:color-mix(in srgb,var(--rt-soft) 82%,transparent)}.rt-service-point .n{width:42px;height:42px;border-radius:16px;display:grid;place-items:center;font-weight:900;color:#17130a;background:linear-gradient(135deg,#fff0a4,#f4c84e 55%,#c88d25)}.rt-service-card.telegram .rt-service-point .n{background:linear-gradient(135deg,#bfe7ff,#4eb7ff);color:#07111f}.rt-service-point b{display:block;font-size:15px;color:var(--rt-text);margin-bottom:3px}.rt-service-point small{display:block;color:var(--rt-muted);font-weight:700;line-height:1.65}
    .rt-service-metrics{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin:22px 0}.rt-service-metrics div{border:1px solid var(--rt-border);border-radius:18px;background:color-mix(in srgb,var(--rt-card) 74%,transparent);padding:14px}.rt-service-metrics strong{display:block;color:color-mix(in srgb,var(--svc-glow,var(--rt-accent)) 86%,#fff);font-size:21px;line-height:1}.rt-service-metrics span{display:block;color:var(--rt-muted);font-size:12px;font-weight:800;margin-top:7px;line-height:1.35}
    .rt-service-actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:18px}.rt-service-actions .rt-btn{flex:1 1 190px}.rt-btn-blue{background:linear-gradient(135deg,#bfe7ff,#4eb7ff 55%,#2563eb);color:#07111f;box-shadow:0 18px 44px rgba(78,183,255,.2)}
    .rt-service-note{margin-top:14px;padding:13px 14px;border-radius:18px;border:1px dashed color-mix(in srgb,var(--svc-glow,var(--rt-accent)) 36%,var(--rt-border));color:var(--rt-muted);font-size:13px;font-weight:700;line-height:1.65;background:color-mix(in srgb,var(--svc-glow,var(--rt-accent)) 7%,transparent)}
    .rt-trust-strip{margin-top:18px;display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}.rt-trust-strip div{padding:18px;border:1px solid var(--rt-border);border-radius:22px;background:linear-gradient(180deg,color-mix(in srgb,var(--rt-card) 88%,transparent),color-mix(in srgb,var(--rt-soft) 54%,transparent));box-shadow:0 16px 44px color-mix(in srgb,var(--rt-shadow) 40%,transparent)}.rt-trust-strip b{display:block;color:var(--rt-accent);font-size:18px;margin-bottom:5px}.rt-trust-strip span{display:block;color:var(--rt-muted);font-size:13px;font-weight:700;line-height:1.55}


    .rt-feature-wrap{padding:18px 0 34px}.rt-feature-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px}.rt-feature{padding:26px;border:1px solid var(--rt-border);border-radius:30px;background:linear-gradient(145deg,color-mix(in srgb,var(--rt-card) 88%,transparent),color-mix(in srgb,var(--rt-soft) 62%,transparent));box-shadow:0 20px 60px var(--rt-shadow);position:relative;overflow:hidden}.rt-feature::after{content:"";position:absolute;width:180px;height:180px;border-radius:50%;right:-90px;top:-90px;background:color-mix(in srgb,var(--rt-accent) 14%,transparent);filter:blur(4px)}.rt-feature .ico{width:54px;height:54px;border-radius:18px;display:grid;place-items:center;background:linear-gradient(135deg,#ffe28a,#c88d25);color:#17130a;font-size:24px;box-shadow:0 16px 34px color-mix(in srgb,var(--rt-accent) 24%,transparent)}.rt-feature h3{font-size:24px;margin:18px 0 8px}.rt-feature p{margin:0;color:var(--rt-muted);font-weight:700;line-height:1.75}

    .rt-cta{padding:18px 0 58px}.rt-cta-box{padding:42px;border-radius:34px;border:1px solid color-mix(in srgb,var(--rt-accent) 32%,var(--rt-border));background:linear-gradient(135deg,color-mix(in srgb,var(--rt-accent) 18%,var(--rt-card)),color-mix(in srgb,var(--rt-card) 90%,transparent));display:flex;align-items:center;justify-content:space-between;gap:22px;box-shadow:0 26px 80px var(--rt-shadow)}.rt-cta h2{font-size:clamp(28px,3vw,48px);margin:0 0 8px}.rt-cta p{margin:0;color:var(--rt-muted);font-weight:700;line-height:1.7;max-width:820px}

    .rt-footer{border-top:1px solid var(--rt-border);padding:20px 0;color:var(--rt-muted);text-align: center;font-size:14px;font-weight:400}.rt-footer .rt-wrap{display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap}

    .reveal{opacity:0;transform:translateY(18px);transition:opacity .65s ease, transform .65s ease}.reveal.show{opacity:1;transform:translateY(0)}
    @keyframes draw{to{stroke-dashoffset:0}}@keyframes floatIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}



    /* ======================================================
       HOME + LAYOUT.EJS FIX
       layout.ejs ใช้ <nav class="nav rt-nav"> ใน topbar ขวา
       หน้า Home จึงต้องใช้ .rt-landing-nav แยก และคืนค่า .rt-nav ของ layout ให้โปร่งใส
    ====================================================== */
    body:has(.rt-hero) .topbar.rt-topbar nav.nav.rt-nav,
    body:has(.rt-hero) header.topbar.rt-topbar nav.nav.rt-nav{
      position:relative !important;
      top:auto !important;
      z-index:2 !important;
      height:auto !important;
      min-height:0 !important;
      width:auto !important;
      padding:0 !important;
      margin:0 !important;
      display:flex !important;
      align-items:center !important;
      justify-content:flex-end !important;
      gap:10px !important;
      overflow:visible !important;
      isolation:auto !important;
      background:transparent !important;
      background-color:transparent !important;
      background-image:none !important;
      border:0 !important;
      border-bottom:0 !important;
      border-radius:0 !important;
      box-shadow:none !important;
      outline:0 !important;
      backdrop-filter:none !important;
      -webkit-backdrop-filter:none !important;
    }

    body:has(.rt-hero) .topbar.rt-topbar nav.nav.rt-nav::before,
    body:has(.rt-hero) .topbar.rt-topbar nav.nav.rt-nav::after{
      content:none !important;
      display:none !important;
      opacity:0 !important;
      background:transparent !important;
      border:0 !important;
      box-shadow:none !important;
    }

    body:has(.rt-hero) .topbar.rt-topbar nav.nav.rt-nav .rt-action-pill,
    body:has(.rt-hero) .topbar.rt-topbar nav.nav.rt-nav .rt-theme-switch{
      position:relative !important;
      z-index:3 !important;
      flex:0 0 auto !important;
    }

    /* Landing nav ของ index.ejs ให้เต็มขอบจอ ไม่เหลือรางดำด้านซ้าย/ขวา */
    body:has(.rt-hero){
      overflow-x:hidden;
    }



    /* ======================================================
       LANDING NAV ALIGNMENT FIX — ชิด topbar + content center
       - layout.ejs ครอบหน้านี้ด้วย main.container จึงต้องล้าง padding/margin เฉพาะหน้า home
