    /* =====================================================
       MOBILE LUX NAV + 3D ART POLISH (RTAUTOBOT)
       - Responsive Navbar แบบ Mockup
       - Floating / rotate animation สำหรับ icon ในทุก section
       - เพิ่มมิติให้มือถือใน art cards ด้วย CSS 3D lighting
    ====================================================== */
    .rt-mobile-actions{display:none;align-items:center;gap:12px;}
    .rt-mobile-icon-btn{
      width:56px;height:56px;border-radius:999px;display:grid;place-items:center;
      color:#ffedb7;border:1px solid rgba(248,214,107,.24);
      background:linear-gradient(145deg,rgba(255,255,255,.055),rgba(255,255,255,.018));
      box-shadow:inset 0 1px 0 rgba(255,255,255,.08),0 16px 42px rgba(0,0,0,.28);
      backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
      transition:transform .22s ease, border-color .22s ease, box-shadow .22s ease;
    }
    .rt-mobile-icon-btn:hover{transform:translateY(-2px);border-color:rgba(248,214,107,.48);box-shadow:0 20px 54px rgba(248,214,107,.10),inset 0 1px 0 rgba(255,255,255,.12)}
    .rt-mobile-icon-btn i{font-size:23px;filter:drop-shadow(0 0 12px rgba(248,214,107,.2));}

    .rt-float-icon{
      animation:rtFloatLuxury 5.8s ease-in-out infinite, rtIconGlow 3.4s ease-in-out infinite alternate !important;
      transform-style:preserve-3d;will-change:transform,filter;
    }
    .rt-float-icon:nth-of-type(2n){animation-duration:6.6s,3.9s !important;animation-delay:.35s,.1s !important;}
    .rt-float-icon:nth-of-type(3n){animation-duration:7.2s,4.4s !important;animation-delay:.75s,.2s !important;}
    .rt-float-icon.small{animation-name:rtFloatLuxuryTiny,rtIconGlow !important;}
    @keyframes rtFloatLuxury{
      0%,100%{transform:translate3d(0,0,18px) rotate(-4deg) scale(1)}
      35%{transform:translate3d(8px,-13px,28px) rotate(6deg) scale(1.035)}
      70%{transform:translate3d(-7px,8px,22px) rotate(-2deg) scale(.985)}
    }
    @keyframes rtFloatLuxuryTiny{
      0%,100%{transform:translate3d(0,0,12px) rotate(2deg) scale(1)}
      45%{transform:translate3d(-5px,-9px,20px) rotate(-7deg) scale(1.045)}
      72%{transform:translate3d(6px,5px,15px) rotate(5deg) scale(.99)}
    }
    @keyframes rtIconGlow{
      from{filter:drop-shadow(0 10px 20px rgba(0,0,0,.34)) drop-shadow(0 0 10px rgba(248,214,107,.10));}
      to{filter:drop-shadow(0 16px 32px rgba(0,0,0,.42)) drop-shadow(0 0 22px rgba(248,214,107,.25));}
    }
    .rt-art-orbit{animation:rtOrbitSpin 18s linear infinite;transform-origin:center;}
    .rt-art-orbit.two{animation-duration:24s;animation-direction:reverse;}
    .rt-art-orbit.three{animation-duration:30s;}
    @keyframes rtOrbitSpin{to{rotate:360deg}}

    .rt-art-phone{
      position:relative;isolation:isolate;
      transform-style:preserve-3d;
      animation:rtPhoneHover 7.2s ease-in-out infinite;
      box-shadow:
        0 44px 90px rgba(0,0,0,.66),
        0 0 0 1px rgba(248,214,107,.20),
        inset 0 1px 0 rgba(255,255,255,.13) !important;
    }
    .rt-art-phone::before{
      content:"";position:absolute;inset:-18px;border-radius:inherit;z-index:-1;
      background:radial-gradient(circle at 62% 30%,rgba(248,214,107,.32),transparent 34%),radial-gradient(circle at 32% 84%,rgba(80,160,255,.12),transparent 28%);
      filter:blur(18px);opacity:.82;transform:translateZ(-26px);
      pointer-events:none;
    }
    .rt-art-phone::after{
      content:"";position:absolute;inset:10px 10px 10px 10px;border-radius:28px;pointer-events:none;z-index:4;
      background:linear-gradient(118deg,rgba(255,255,255,.18) 0%,rgba(255,255,255,.035) 22%,transparent 38%,rgba(248,214,107,.10) 72%,transparent 100%);
      mix-blend-mode:screen;opacity:.7;
    }
    .rt-phone-screen{position:relative;overflow:hidden;box-shadow:inset 0 0 0 1px rgba(248,214,107,.10), inset 0 28px 80px rgba(248,214,107,.045)}
    .rt-phone-screen::before{
      content:"";position:absolute;left:50%;top:10px;transform:translateX(-50%);width:58px;height:9px;border-radius:999px;
      background:linear-gradient(90deg,rgba(0,0,0,.75),rgba(255,255,255,.08),rgba(0,0,0,.75));opacity:.85;
    }
    .rt-phone-screen::after{
      content:"";position:absolute;inset:auto 18px 16px;border-radius:999px;height:4px;background:rgba(248,214,107,.22);filter:blur(.2px);
    }
    @keyframes rtPhoneHover{
      0%,100%{transform:rotate(10deg) translate3d(0,0,0)}
      50%{transform:rotate(7deg) translate3d(0,-10px,18px)}
    }
    .rt-service-art .rt-art-phone{animation-duration:7.8s;}
    .rt-service-art.telegram .rt-art-phone{animation-delay:.35s;}

