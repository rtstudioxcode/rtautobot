<script>
  (() => {
    document.body && document.body.classList.add('rt-home-clean-layout');
    const html = document.documentElement;
    const applyTheme = () => {
      const t = html.getAttribute('data-theme') || localStorage.getItem('theme') || localStorage.getItem('app-theme');
      if (t) html.setAttribute('data-bs-theme', t === 'light' ? 'light' : 'dark');
    };
    applyTheme();
    window.addEventListener('themechange', applyTheme);
    new MutationObserver(applyTheme).observe(html, { attributes:true, attributeFilter:['data-theme','class'] });

    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('show');
        io.unobserve(entry.target);
      });
    }, { threshold:.14 });

    document.querySelectorAll('.reveal,.rt-platform').forEach((el, i) => {
      el.style.transitionDelay = Math.min(i * 45, 360) + 'ms';
      io.observe(el);
    });

    const resetLandingNavScroll = () => {
      const chips = document.querySelector('.rt-landing-nav .rt-nav-links');
      if (chips) chips.scrollLeft = 0;
    };
    window.addEventListener('load', resetLandingNavScroll, { once: true });
    window.addEventListener('resize', resetLandingNavScroll);
    requestAnimationFrame(resetLandingNavScroll);
  })();
</script>
