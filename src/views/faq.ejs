            ['order','ทำไมยอดวิวหรือผู้ติดตามไม่ขึ้นทันทีทั้งที่งานเสร็จแล้ว?','บางแพลตฟอร์มมีดีเลย์ในการอัปเดตตัวเลข เช่น YouTube, TikTok หรือ Instagram อาจใช้เวลาหลายชั่วโมงถึง 48 ชั่วโมงก่อนตัวเลขแสดงตรงกัน'],
            ['order','สั่งหลายบริการพร้อมกันในลิงก์เดียวกันได้ไหม?','ไม่แนะนำ เพราะ Start Count ของแต่ละงานอาจเพี้ยน ส่งผลต่อการคำนวณยอดจริง การรับประกัน และการขอเติมคืนภายหลัง'],
            ['money','เติมเงินแล้วแต่ยอดไม่เข้า ต้องทำอย่างไร?','ตรวจสอบยอดโอนและข้อมูลสลิปให้ตรงกับรายการที่ระบบสร้าง หากยอดยังไม่เข้าให้ติดต่อทีมงานพร้อมหลักฐานการโอนเพื่อให้ตรวจสอบได้เร็วขึ้น'],
            ['money','ยอดเงินถูกตัดแล้ว แต่คำสั่งซื้อไม่สำเร็จ จะได้เงินคืนไหม?','หากคำสั่งซื้อสร้างไม่สำเร็จหรือระบบได้รับสถานะคืนบางส่วน/ยกเลิกตามเงื่อนไข ระบบจะคืนยอดกลับเข้ากระเป๋าให้ตามจำนวนที่เกี่ยวข้อง'],
            ['money','ยอดคืนเงินเข้าที่ไหน?','ยอดคืนเงินจะกลับเข้ายอดคงเหลือในบัญชี RTSMM-TH ของคุณ สามารถนำไปใช้สั่งซื้อบริการอื่นต่อได้ทันที'],
            ['refill','ระบบเติมคืน (Refill) ทำงานอย่างไร?','บริการที่มีการรับประกันจะสามารถขอเติมคืนได้เมื่อยอดลดลงตามเงื่อนไข ระบบจะเติมยอดกลับให้ ไม่ใช่การเริ่มงานใหม่ทั้งหมด'],
            ['refill','ยอดลดลง ขอเติมคืนได้ทุกบริการไหม?','ขอเติมคืนได้เฉพาะบริการที่ระบุว่ามีประกัน และต้องอยู่ในช่วงเวลารับประกันตามรายละเอียดบริการนั้น ๆ'],
            ['refill','กดขอเติมคืนแล้วต้องรอนานแค่ไหน?','โดยทั่วไปใช้เวลาประมาณ 1–72 ชั่วโมง ขึ้นอยู่กับคิวงานและผู้ให้บริการ หากเกินเวลาควรติดต่อทีมงานเพื่อช่วยตรวจสอบ'],
            ['order','กดขอยกเลิกคำสั่งซื้อแล้วต้องรอนานแค่ไหน?','คำขอยกเลิกอาจใช้ตั้งแต่ไม่กี่นาทีจนถึง 24–72 ชั่วโมง ขึ้นกับสถานะงานและเงื่อนไขของบริการ หากงานเริ่มทำแล้วบางรายการอาจยกเลิกไม่ได้'],
            ['account','สมัครสมาชิกต้องใช้อะไรบ้าง?','ใช้ข้อมูลบัญชีตามที่ระบบกำหนด เช่น ชื่อผู้ใช้ อีเมล และรหัสผ่าน จากนั้นเข้าสู่ระบบเพื่อเติมเงินและเริ่มสั่งซื้อได้'],
            ['account','ลืมรหัสผ่านต้องทำอย่างไร?','ไปที่หน้าเข้าสู่ระบบแล้วเลือกเมนูลืมรหัสผ่าน ทำตามขั้นตอนยืนยันตัวตน หรือแจ้งทีมงานหากไม่สามารถดำเนินการเองได้'],
            ['account','ควรอ่านรายละเอียดบริการก่อนสั่งซื้อไหม?','ควรอ่านทุกครั้ง เพราะแต่ละบริการมีเงื่อนไขต่างกัน เช่น รูปแบบลิงก์ จำนวนขั้นต่ำ ความเร็ว การรับประกัน และข้อจำกัดเฉพาะแพลตฟอร์ม']
          ]; %>
          <% faqs.forEach((faq, idx) => { %>
            <article class="faq-item" data-cat="<%= faq[0] %>" data-text="<%= (faq[1] + ' ' + faq[2]).toLowerCase() %>">
              <button class="faq-q" type="button" aria-expanded="false">
                <span class="num"><%= String(idx + 1).padStart(2, '0') %></span>
                <span><%= faq[1] %></span>
                <span class="plus">+</span>
              </button>
              <div class="faq-a"><div class="faq-a-inner"><%= faq[2] %></div></div>
            </article>
          <% }) %>
          <div class="faq-empty" id="faqEmpty">ไม่พบคำถามที่ตรงกับคำค้น ลองใช้คำสั้นลง เช่น “เติมเงิน” หรือ “ยกเลิก”</div>
        </div>
      </div>

