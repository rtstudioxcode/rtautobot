    .faq-visual{position:relative;border:1px solid var(--faq-border);border-radius:30px;min-height:300px;overflow:hidden;background:linear-gradient(180deg,color-mix(in srgb,#151923 80%,transparent),#07080b);box-shadow:0 20px 60px rgba(0,0,0,.28)}
    .faq-visual img{width:100%;height:100%;min-height:300px;object-fit:cover;opacity:.82;filter:saturate(1.05) contrast(1.05)}
    .faq-visual::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 24%,rgba(0,0,0,.78))}
    .faq-visual-badge{position:absolute;left:22px;bottom:22px;right:22px;z-index:2;border:1px solid rgba(255,255,255,.16);background:rgba(9,10,14,.74);backdrop-filter:blur(16px);border-radius:22px;padding:18px}
    .faq-visual-badge strong{display:block;font-size:22px;color:#fff8e8;margin-bottom:4px}.faq-visual-badge span{color:#d9c998;font-weight:800}

    .faq-stats{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:16px;margin:22px 0}
    .faq-stat{border:1px solid var(--faq-border);border-radius:24px;padding:20px;background:linear-gradient(135deg,color-mix(in srgb,var(--faq-card) 95%,transparent),color-mix(in srgb,var(--faq-card2) 88%,transparent));box-shadow:0 14px 44px rgba(0,0,0,.16);position:relative;overflow:hidden;animation:faqUp .55s ease both}
    .faq-stat:nth-child(2){animation-delay:.06s}.faq-stat:nth-child(3){animation-delay:.12s}.faq-stat:nth-child(4){animation-delay:.18s}
    .faq-stat::after{content:"";position:absolute;right:-30px;bottom:-58px;width:170px;height:88px;background:linear-gradient(135deg,transparent,color-mix(in srgb,var(--faq-accent) 22%,transparent));transform:rotate(-10deg)}
    .faq-stat .ico{width:46px;height:46px;display:grid;place-items:center;border-radius:16px;background:color-mix(in srgb,var(--faq-accent) 22%,transparent);margin-bottom:16px}
    .faq-stat strong{display:block;font-size:32px;color:var(--faq-text);letter-spacing:-.04em}.faq-stat span{display:block;color:var(--faq-muted);font-weight:800;margin-top:4px}

    .faq-control{position:sticky;top:14px;z-index:20;border:1px solid var(--faq-border);border-radius:28px;padding:16px;background:color-mix(in srgb,var(--faq-card) 88%,transparent);backdrop-filter:blur(22px);box-shadow:0 18px 50px rgba(0,0,0,.22);display:grid;grid-template-columns:1fr auto;gap:14px;align-items:center;margin:22px 0}
    .faq-search{display:flex;align-items:center;gap:12px;background:color-mix(in srgb,var(--faq-page) 62%,transparent);border:1px solid var(--faq-border);border-radius:20px;padding:0 16px;min-height:56px}
    .faq-search input{width:100%;border:0;outline:0;background:transparent;color:var(--faq-text);font:inherit;font-weight:800}.faq-search input::placeholder{color:color-mix(in srgb,var(--faq-muted) 70%,transparent)}
    .faq-chips{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end}
    .faq-chip{border:1px solid var(--faq-border);background:color-mix(in srgb,var(--faq-card2) 72%,transparent);color:var(--faq-muted);border-radius:999px;padding:11px 14px;font-weight:900;cursor:pointer;transition:.2s ease;white-space:nowrap}
    .faq-chip.active,.faq-chip:hover{background:linear-gradient(135deg,#ffe48a,var(--faq-accent2));color:#171001;border-color:transparent;transform:translateY(-1px)}

    .faq-content{display:grid;grid-template-columns:minmax(0,1fr) 360px;gap:22px;margin-bottom:34px}
    .faq-panel{border:1px solid var(--faq-border);border-radius:30px;background:linear-gradient(180deg,color-mix(in srgb,var(--faq-card) 94%,transparent),color-mix(in srgb,var(--faq-card2) 78%,transparent));box-shadow:var(--faq-shadow);overflow:hidden}
    .faq-panel-head{display:flex;justify-content:space-between;gap:18px;align-items:center;padding:24px;border-bottom:1px solid var(--faq-border)}
    .faq-panel-head h2{margin:0;font-size:26px;letter-spacing:-.03em}.faq-panel-head p{margin:6px 0 0;color:var(--faq-muted);font-weight:800}.faq-count{padding:10px 14px;border-radius:999px;background:color-mix(in srgb,var(--faq-accent) 15%,transparent);color:var(--faq-accent);font-weight:900;white-space:nowrap}
    .faq-list{padding:12px}
    .faq-item{border:1px solid var(--faq-border);border-radius:22px;margin:10px 0;background:color-mix(in srgb,var(--faq-page) 34%,transparent);overflow:hidden;transition:.22s ease;animation:faqUp .45s ease both}
    .faq-item[hidden]{display:none!important}
    .faq-q{width:100%;display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:14px;border:0;background:transparent;color:var(--faq-text);padding:20px;text-align:left;font:inherit;cursor:pointer;font-weight:950}
    .faq-q .num{width:38px;height:38px;border-radius:14px;display:grid;place-items:center;background:color-mix(in srgb,var(--faq-accent) 18%,transparent);color:var(--faq-accent);font-size:.85rem}.faq-q .plus{width:38px;height:38px;border-radius:14px;display:grid;place-items:center;border:1px solid var(--faq-border);transition:.2s ease}.faq-a{display:grid;grid-template-rows:0fr;transition:grid-template-rows .28s ease}.faq-a-inner{overflow:hidden;color:var(--faq-muted);line-height:1.8;font-weight:750;padding:0 20px}.faq-item.active{border-color:color-mix(in srgb,var(--faq-accent) 42%,var(--faq-border));box-shadow:0 16px 42px color-mix(in srgb,var(--faq-accent) 10%,transparent)}.faq-item.active .faq-a{grid-template-rows:1fr}.faq-item.active .faq-a-inner{padding:0 20px 20px}.faq-item.active .plus{transform:rotate(45deg);background:color-mix(in srgb,var(--faq-accent) 18%,transparent);color:var(--faq-accent)}

    .faq-side{display:grid;gap:16px;align-content:start;position:sticky;top:110px}
    .faq-side-card{border:1px solid var(--faq-border);border-radius:28px;background:linear-gradient(150deg,color-mix(in srgb,var(--faq-card) 94%,transparent),color-mix(in srgb,var(--faq-card2) 76%,transparent));box-shadow:0 18px 54px rgba(0,0,0,.18);padding:22px;overflow:hidden;position:relative}
    .faq-side-card::after{content:"";position:absolute;right:-34px;bottom:-42px;width:160px;height:90px;background:linear-gradient(135deg,transparent,color-mix(in srgb,var(--faq-accent) 18%,transparent));transform:rotate(-14deg)}
    .faq-side-card h3{margin:0 0 10px;font-size:22px}.faq-side-card p{margin:0 0 18px;color:var(--faq-muted);line-height:1.7;font-weight:750}.faq-side-list{display:grid;gap:10px}.faq-side-row{display:flex;align-items:center;gap:12px;border:1px solid var(--faq-border);border-radius:18px;padding:12px;background:color-mix(in srgb,var(--faq-page) 34%,transparent);font-weight:900}.faq-side-row span{width:36px;height:36px;border-radius:14px;display:grid;place-items:center;background:color-mix(in srgb,var(--faq-accent) 15%,transparent)}

    .faq-cta{margin:26px 0 0;border-radius:34px;border:1px solid var(--faq-border);padding:34px;background:linear-gradient(135deg,color-mix(in srgb,var(--faq-accent) 18%,var(--faq-card)),color-mix(in srgb,var(--faq-blue) 13%,var(--faq-card)));box-shadow:var(--faq-shadow);display:grid;grid-template-columns:1fr auto;gap:20px;align-items:center}.faq-cta h2{margin:0;font-size:clamp(26px,3vw,44px);letter-spacing:-.04em}.faq-cta p{margin:8px 0 0;color:var(--faq-muted);font-weight:800;line-height:1.7}.faq-cta .faq-actions{margin:0;justify-content:flex-end}

    .faq-footer{margin-top:34px;border-top:1px solid var(--faq-border);padding:34px 0 42px;color:var(--faq-muted)}.faq-footer-grid{display:grid;grid-template-columns:1.4fr repeat(3,1fr);gap:24px}.faq-footer img{max-width:190px;height:auto}.faq-footer h4{color:var(--faq-text);margin:0 0 12px}.faq-footer a{display:block;margin:8px 0;color:var(--faq-muted);font-weight:800}.faq-footer a:hover{color:var(--faq-accent)}

    .faq-empty{display:none;padding:36px;text-align:center;color:var(--faq-muted);font-weight:900}.faq-empty.show{display:block}

    @keyframes faqShine{0%,40%{transform:translateX(-62%)}70%,100%{transform:translateX(82%)}}@keyframes faqFloatIn{from{opacity:0;transform:translateY(18px) scale(.985)}to{opacity:1;transform:none}}@keyframes faqUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}

    @media (max-width:1100px){.faq-hero-grid,.faq-content,.faq-cta{grid-template-columns:1fr}.faq-side{position:static}.faq-stats{grid-template-columns:repeat(2,1fr)}.faq-control{grid-template-columns:1fr}.faq-chips{justify-content:flex-start}}
    @media (max-width:640px){.faq-page{width:min(100% - 22px, 100%);padding-top:16px}.faq-hero{padding:24px;border-radius:26px}.faq-title{font-size:44px}.faq-stats{grid-template-columns:1fr}.faq-control{position:relative;top:auto;border-radius:22px}.faq-panel-head{display:block}.faq-count{display:inline-flex;margin-top:12px}.faq-q{grid-template-columns:auto 1fr;gap:10px;padding:16px}.faq-q .plus{grid-column:2;justify-self:start}.faq-footer-grid{grid-template-columns:1fr}.faq-cta{padding:24px}.faq-cta .faq-actions{justify-content:flex-start}.faq-visual{min-height:220px}.faq-visual img{min-height:220px}}
  </style>
