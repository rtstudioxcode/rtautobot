  <script>
    (() => {
      const list = document.getElementById('faqList');
      const search = document.getElementById('faqSearch');
      const chips = [...document.querySelectorAll('.faq-chip')];
      const items = [...document.querySelectorAll('.faq-item')];
      const empty = document.getElementById('faqEmpty');
      const count = document.getElementById('faqCount');
      let active = 'all';

      const update = () => {
        const q = (search?.value || '').trim().toLowerCase();
        let shown = 0;
        items.forEach(item => {
          const okCat = active === 'all' || item.dataset.cat === active;
          const okText = !q || (item.dataset.text || '').includes(q);
          const show = okCat && okText;
          item.hidden = !show;
          if (show) shown++;
        });
        if (count) count.textContent = `${shown.toLocaleString('th-TH')} รายการ`;
        empty?.classList.toggle('show', shown === 0);
      };

      list?.addEventListener('click', (e) => {
        const btn = e.target.closest('.faq-q');
        if (!btn) return;
        const item = btn.closest('.faq-item');
        const open = item.classList.toggle('active');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });

      chips.forEach(chip => chip.addEventListener('click', () => {
        chips.forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        active = chip.dataset.filter || 'all';
        update();
      }));

      search?.addEventListener('input', update);
      update();
    })();
  </script>
