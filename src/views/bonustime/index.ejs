  border-radius: 999px;
  padding: 8px 18px;
  font-size: 14px;
  border: 1px solid var(--border);
  background: var(--page);
  color: var(--text);
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition:
    background 0.2s ease-out,
    box-shadow 0.2s ease-out,
    transform 0.15s ease-out;
}
/* กดแล้วยุบลงนิดหน่อย */
.bt-btn:active {
  transform: translateY(1px) scale(0.99);
}

/* ===== PRIMARY (เหลือง) ===== */
.bt-btn.primary {
  background: linear-gradient(135deg, #05b84f, #05b84f);
  color: #111827 !important;          /* ตัวหนังสือเข้มอ่านง่าย */
  text-shadow: 0 0 2px rgba(255,255,255,0.4);
  font-weight: 400;
}
.bt-btn.primary:hover {
  background: linear-gradient(135deg, #05b84f, #08b84f);
  box-shadow: 0 0 18px rgba(6, 199, 85, 0.45);
}

/* ===== UPDATEDATA (ปุ่มกลางดำ) ===== */
.bt-btn.updatedata {
  background: radial-gradient(circle at top left, #1f2937 0%, #020617 65%);
  border: 1px solid #0a2347;
  color: #f9fafb !important;          /* ขาวสว่างตัดกับพื้นดำ */
  text-shadow: 0 0 3px rgba(0,0,0,0.8);
}
.bt-btn.updatedata:hover {
  background: radial-gradient(circle at top left, #111827 0%, #020617 70%);
  box-shadow: 0 0 14px rgba(248, 250, 252, 0.22);
}

/* ===== WARN (ส้มเตือน) ===== */
.bt-btn.warn {
  background: linear-gradient(135deg, #05b84f, #05b84f);
  color: #111827 !important;          /* ใช้ตัวหนังสือเข้มเหมือนปุ่มเหลือง */
  text-shadow: 0 0 2px rgba(255,255,255,0.4);
  font-weight: 400;
}
.bt-btn.warn:hover {
  background: linear-gradient(135deg, #08b84f, #08b84f);
  box-shadow: 0 0 18px rgba(6, 199, 85, 0.5);
}

.bt-btn.ghost {
  background: transparent;
}

@media (max-width: 768px) {
  .bt-grid {
    grid-template-columns: minmax(0, 120px) minmax(0, 1fr);
  }
}

