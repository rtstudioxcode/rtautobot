<script>
(function(){
  const KEY = 'bt_notice_suppress_until_v1'; // localStorage key
  const modal = document.getElementById('btNoticeModal');
  const chk = document.getElementById('btNoticeDontShow');
  const btnClose = document.getElementById('btNoticeClose');
  const btnCloseX = document.getElementById('btNoticeCloseX');
  const helpBtn = document.getElementById('btNoticeHelpBtn');

  function shouldShow(){
    try {
      const v = localStorage.getItem(KEY);
      if (!v) return true;
      const ts = Number(v);
      if (!Number.isFinite(ts)) return true;
      return Date.now() > ts; // show if now past expiry
    } catch(e){
      return true;
    }
  }

  function setSuppressFor1Day(){
    const until = Date.now() + 1 * 24 * 60 * 60 * 1000;
    try { localStorage.setItem(KEY, String(until)); } catch(e){ /* ignore */ }
  }

  // show modal on DOM ready if needed
  document.addEventListener('DOMContentLoaded', ()=>{
    try {
      if (shouldShow()) {
        // wait a tick so dialog styles/backdrop applied nicely
        setTimeout(()=> {
          if (!modal.open) modal.showModal();
        }, 120);
      }
    } catch(e){}
  });

  function closeBtNotice(applySuppress){
    if (applySuppress && chk && chk.checked) setSuppressFor1Day();
    try { if (modal.open) modal.close(); } catch(e){}
  }

  btnClose?.addEventListener('click', ()=> closeBtNotice(true));
  btnCloseX?.addEventListener('click', ()=> closeBtNotice(false));

  // allow Escape/cancel to close as well but don't set suppression
  modal?.addEventListener('cancel', (ev)=> {
    ev.preventDefault();
    try { modal.close(); } catch(e){}
  });

  // 👇 เพิ่มบล็อกนี้
  const helpLink = document.getElementById("btNoticeHelpLink");
  function openBtHelpFromNotice() {
    // ถ้าเช็ก "ไม่แสดงอีกในวันนี้" ก็ให้จำไว้เหมือนกดปุ่มปิด
    if (chk && chk.checked) setSuppressFor1Day();

    // ปิด modal ทันที
    try {
      if (modal.open) modal.close();
    } catch (e) {}

    // สลับไปแท็บ "ช่วยเหลือ"
    const helpTabBtn = document.querySelector('.bt-tab[data-tab="helpers"]');
    if (helpTabBtn) {
      helpTabBtn.click();
    }
  }

  helpLink?.addEventListener("click", openBtHelpFromNotice);
  helpBtn?.addEventListener("click", openBtHelpFromNotice);

  const editDialog = document.getElementById('btEditModal');
  if (editDialog && !editDialog.dataset.viewportClickBound) {
    editDialog.dataset.viewportClickBound = '1';
    editDialog.addEventListener('click', (ev) => {
      const modal = editDialog.querySelector('.bt-edit-modal-enterprise');
      if (editDialog.open && modal && !modal.contains(ev.target)) editDialog.close('cancel');
    });
    editDialog.addEventListener('cancel', (ev) => {
      ev.preventDefault();
      editDialog.close('cancel');
    });
  }

})();
</script>

<script>
// ================== GLOBAL NOTIFY HELPER ==================
function btNotify(variant, title, text) {
  // 1) ถ้ามีฟังก์ชัน notify ที่คุณประกาศใน layout
  if (typeof window.notify === 'function') {
    return window.notify({ variant, title, text });
  }
  // 2) ถ้ามีตัว wrapper แบบที่คุณแปะให้ดู (notify ใน scope ปัจจุบัน)
  if (typeof notify === 'function') {
    return notify({ variant, title, text });
  }
  // 3) ถ้ามี showMsg (dialog) ก็ใช้ได้
  if (typeof window.showMsg === 'function') {
    return window.showMsg({ variant, title, text });
  }
  // 4) fallback สุดท้าย — alert ธรรมดา
  alert((title ? title + '\n' : '') + (text || ''));
}

let PENDING_EXTEND_TENANT = null;

let logInterval = null;

if (logInterval) {
    clearInterval(logInterval);
    logInterval = null;
}
// ================== CONFIRM HELPER (ใช้ uiConfirm ถ้ามี) ==================
async function btConfirm(message) {
  // ถ้ามี uiConfirm (การ์ดสวย ๆ) ให้ใช้
  if (window.uiConfirm) {
    return await window.uiConfirm({
      variant: "success",
      title: "ยืนยันอัปเกรดแพ็กเกจ",
      sub: message,
      okText: "อัปเกรดเลย",
      cancelText: "ยกเลิก",
      focus: "cancel",
    });
  }

  // ถ้าไม่มี uiConfirm (เช่น หน้าโหลดไม่ครบ) ใช้ confirm เดิม
  if (window.originalConfirm) {
    return window.originalConfirm(message);
  }
  return window.confirm(message);
}

// ================== CACHE + PLAN CONFIG ==================
const BONUSTIME_CACHE = {};

const PLANS_NORMAL = [ // สล็อต+บาคาร่า
    { days: 30,  price: 1500,  label: "1 เดือน",   discount: "0%" },
    { days: 90,  price: 4050,  label: "3 เดือน",  discount: "-10%" },
    { days: 180, price: 7200,  label: "6 เดือน",  discount: "-20%" },
    { days: 365, price: 12600, label: "12 เดือน", discount: "-30%" },
    { days: 730, price: 21600, label: "24 เดือน", discount: "-40%" },
];

const PLANS_LOTTO = [ // สล็อต+บาคาร่า+หวย
    { days: 30,  price: 2000,  label: "1 เดือน",   discount: "0%" },
    { days: 90,  price: 5400,  label: "3 เดือน",  discount: "-10%" },
    { days: 180, price: 9600,  label: "6 เดือน",  discount: "-20%" },
    { days: 365, price: 16800, label: "12 เดือน", discount: "-30%" },
    { days: 730, price: 28800, label: "24 เดือน", discount: "-40%" },
];

const UPGRADE_LOTTO_PRICE = 1000;

// ================== TABS ==================
function setActiveTab(name) {
  const tabButtons = document.querySelectorAll(".bt-tab");

  tabButtons.forEach((btn) => {
    btn.classList.toggle("active", btn.dataset.tab === name);
  });

  Object.values(panes).forEach((pane) => {
    if (pane) pane.classList.remove("show");
  });

  if (panes[name]) panes[name].classList.add("show");
}

const tabButtons = document.querySelectorAll(".bt-tab");
const panes = {
  order:   document.getElementById("tab-order"),
  history: document.getElementById("tab-history"),
  helpers: document.getElementById("helpers"),
};

let LOCK_TAB = null;

if (tabButtons.length) {
  tabButtons.forEach((btn) => {
    btn.addEventListener("click", () => {

      if (LOCK_TAB && btn.dataset.tab !== LOCK_TAB) return;

      tabButtons.forEach((x) => x.classList.remove("active"));
      btn.classList.add("active");

      Object.values(panes).forEach((pane) => {
        if (pane) pane.classList.remove("show");
      });

      const name = btn.dataset.tab;
      if (panes[name]) panes[name].classList.add("show");
    });
  });
}

// ================== HELPERS: วันหมดอายุ ==================
function calcExpiredDate(start, days) {
    if (!start || !days) return null;
    const [d, m, y] = start.split("/").map((v) => parseInt(v));
    if (!d || !m || !y) return null;
    const startDate = new Date(y - 543, m - 1, d);
    return new Date(startDate.getTime() + days * 24 * 60 * 60 * 1000);
}

function calcRemainDays(expiry) {
    if (!expiry) return 0;
    const now = new Date();
    const diff = expiry - now;
    return Math.max(0, Math.ceil(diff / (1000 * 60 * 60 * 24)));
}

// ================== CountDown นับถอยหลัง ==================
let BT_COUNTDOWN_TIMER = null;

function formatRemainFull(msDiff) {
  if (msDiff <= 0) return null;

  const totalSec = Math.floor(msDiff / 1000);
  const days = Math.floor(totalSec / 86400);
  const hours = Math.floor((totalSec % 86400) / 3600);
  const mins = Math.floor((totalSec % 3600) / 60);

  if (days > 0) {
    return `อีก ${days} วัน ${hours} ชม. ${mins} นาที`;
  }
  if (hours > 0) {
    return `อีก ${hours} ชม. ${mins} นาที`;
  }
  return `อีก ${mins} นาที`;
}

function applyCountdownColor(el, daysLeft) {
  el.classList.remove(
    "bt-countdown-pill--safe",
    "bt-countdown-pill--warn15",
    "bt-countdown-pill--warn7",
    "bt-countdown-pill--warn3"
  );

  if (daysLeft < 3) {
    el.classList.add("bt-countdown-pill--warn3");
  } else if (daysLeft < 7) {
    el.classList.add("bt-countdown-pill--warn7");
  } else if (daysLeft < 15) {
    el.classList.add("bt-countdown-pill--warn15");
  } else {
    el.classList.add("bt-countdown-pill--safe");
  }
}

function initBonustimeCountdowns() {
  const nodes = document.querySelectorAll(".bt-countdown-pill[data-expiry]");
  if (!nodes.length) {
    if (BT_COUNTDOWN_TIMER) {
      clearInterval(BT_COUNTDOWN_TIMER);
      BT_COUNTDOWN_TIMER = null;
    }
    return;
  }

  function tick() {
    const now = Date.now();
    nodes.forEach((el) => {
      const iso = el.dataset.expiry;
      if (!iso) return;
      const exp = new Date(iso).getTime();
      const diff = exp - now;

      if (diff <= 0) {
        // หมดอายุแล้ว ไม่ต้องแสดง countdown
        el.remove();
        return;
      }

      const label = formatRemainFull(diff);
      if (!label) return;

      el.textContent = label;

      // แปลงเป็นวันเพื่อเลือกสี
      const daysLeft = Math.ceil(diff / (1000 * 60 * 60 * 24));
      applyCountdownColor(el, daysLeft);
    });
  }

  // อัปเดตทันที 1 รอบ
  tick();

  if (BT_COUNTDOWN_TIMER) clearInterval(BT_COUNTDOWN_TIMER);
  BT_COUNTDOWN_TIMER = setInterval(tick, 30000);
}

