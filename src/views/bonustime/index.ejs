<script id="bt-enterprise-polish">
(() => {
  const root = document.querySelector('.page.bonustime');
  if (!root) return;

  const cards = root.querySelectorAll('.bt-package, .bt-metric-card');
  cards.forEach((card) => {
    card.addEventListener('pointermove', (ev) => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const r = card.getBoundingClientRect();
      const x = ((ev.clientX - r.left) / r.width - .5) * 6;
      const y = ((ev.clientY - r.top) / r.height - .5) * -6;
      card.style.setProperty('--rx', `${y}deg`);
      card.style.setProperty('--ry', `${x}deg`);
    }, { passive:true });
    card.addEventListener('pointerleave', () => {
      card.style.removeProperty('--rx');
      card.style.removeProperty('--ry');
    });
  });

  const editDialog = document.getElementById('btEditModal');
  if (editDialog && !editDialog.dataset.viewportClickBound) {
    editDialog.dataset.viewportClickBound = '1';
    editDialog.addEventListener('click', (ev) => {
      const modal = editDialog.querySelector('.bt-edit-modal-enterprise');
      if (editDialog.open && modal && !modal.contains(ev.target)) editDialog.close('cancel');
    });
    editDialog.addEventListener('cancel', (ev) => {
      ev.preventDefault();
      editDialog.close('cancel');
    });
  }

})();
</script>
