/* ====== Card สั่งซื้อแพ็กเกจ ====== */
.bonustime-order h2 {
  font-size: 20px;
}

.bt-package-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 16px;
}

.bt-package {
  background: var(--card, #111316);
  border: 1px solid var(--border, #25272c);
  border-radius: 16px;
  padding: 16px 18px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  transition: background .2s, border-color .2s, transform .1s, opacity .2s;
}

.bt-package.disabled {
  opacity: .45;
}

.bt-package.disabled .pkg-actions button {
  cursor: not-allowed;
}

.pkg-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8px;
  font-size: 14px;
}

.pkg-title {
  font-weight: 400;
}

.pkg-remaining {
  font-size: 13px;
  padding: 4px 10px;
  border-radius: 999px;
  background: var(--elevated-bg, #181920);
  color: var(--accent, #63cff0);
}

.pkg-body {
  font-size: 14px;
}

.pkg-meta .badge {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 999px;
  border: 1px solid var(--accent, #63cff0);
  font-size: 12px;
}

.pkg-desc {
  margin: 8px 0;
  line-height: 1.5;
  font-weight: 400;
}

.pkg-price {
  font-size: 16px;
  font-weight: 400;
  color: var(--accent, #63cff0);
}

.pkg-actions {
  margin-top: 4px;
  display: flex;
  justify-content: flex-end;
}

/* กล่องรูปแพ็กเกจ */
.pkg-thumb {
  width: 100%;
  border-radius: 14px;
  overflow: hidden;
  margin-bottom: 10px;
  background: var(--page, #050608);
  aspect-ratio: 16 / 9;
}

.pkg-thumb img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

@media (max-width: 640px) {
  .pkg-thumb {
    aspect-ratio: 4 / 3;
  }
}

/* ====== Dialog base (ใช้ร่วมกันทั้งหมด) ====== */
.bt-dialog {
  border: none;
  padding: 0;
  background: transparent;
}

.bt-dialog::backdrop {
  background: rgba(0, 0, 0, 0.65);
}

/* กล่อง modal หลัก */
.bt-modal {
  min-width: min(520px, 100vw - 32px);
  max-width: 520px;
  max-height: min(740px, 100vh - 48px);
  margin: 0;
  border-radius: 18px;
  background: var(--card, #101114);
  border: 1px solid var(--border, #262932);
  padding: 18px 20px 16px;
  color: var(--text, #f9fafb);
  font-size: 14px;
  box-shadow:
    0 18px 45px rgba(0, 0, 0, 0.65),
    0 0 0 1px rgba(0, 0, 0, 0.6);
  display: flex;
  flex-direction: column;
}

.bt-modal h2 {
  font-size: 18px;
  margin: 0 0 4px;
}

/* เนื้อหาเลื่อนในตัว ไม่ใช่ลากทั้ง dialog */
.bt-modal .bt-modal-body {
  margin-top: 10px;
  padding-right: 4px;
  overflow-y: auto;
  flex: 1;
}

/* ฟิลด์ฟอร์ม */
.bt-field {
  display: flex;
  flex-direction: column;
  gap: 5px;
  margin-top: 10px;
}

.bt-field span {
  font-size: 13px;
  color: var(--muted);
}

.bt-field input,
.bt-field textarea {
  background: var(--page);
  border-radius: 10px;
  border: 1px solid var(--border);
  padding: 8px 10px;
  font-size: 14px;
  color: var(--text);
}

.bt-field textarea {
  resize: vertical;
}

/* ปุ่มท้าย modal */
.bt-modal footer.row-end {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  margin-top: 14px;
}

/* ====== แผงเลือกแพ็กเกจต่ออายุ ====== */
.bt-plan-scroll {
  margin-top: 8px;
  border-radius: 14px;
  border: 1px solid var(--border);
  background: var(--page);
  max-height: 260px;
  overflow-y: auto;
}

.bt-plan-list {
  display: grid;
  gap: 6px;
  padding: 6px;
}

.bt-plan {
  border-radius: 10px;
  padding: 8px 10px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  transition: background .15s, border-color .15s;
}

.bt-plan input {
  margin-right: 8px;
}

.bt-plan-main {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.bt-plan-label {
  font-size: 14px;
}

.bt-plan-discount {
  font-size: 12px;
  color: var(--muted);
}

.bt-plan-price {
  font-size: 14px;
  font-weight: 400;
}

/* hover / checked */
.bt-plan:hover {
  background: rgba(6, 199, 85, 0.05);
}

.bt-summary {
  margin-top: 14px;
  padding: 8px 10px;
  border-radius: 12px;
  border: 1px dashed var(--border);
  background: var(--page);
}

.bt-summary-main {
  font-size: 15px;
  margin-top: 4px;
}

.bt-summary-note {
  margin-top: 2px;
}

/* ===== ปรับสัดส่วนบนมือถือสำหรับหน้า Bonustime ===== */
@media (max-width: 768px) {
  /* หน้า Bonustime กว้างเต็ม ไม่ติด padding ของ .container */
  .page.bonustime.container {
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding: 0;
  }

  /* แถบแท็บให้ยาวเต็มหน้าจอ (ใน content ดำ) */
  .page.bonustime .bt-tabbar {
    width: 100%;
    margin: 10px 0 18px;
    padding: 0 16px;
    box-sizing: border-box;
  }

  .page.bonustime .bt-tab {
    flex: 1;
  }

  /* wrapper ของแต่ละแท็บให้เต็มกว้าง */
  .page.bonustime #tab-order,
  .page.bonustime #tab-history {
    width: 100%;
  }

  /* เนื้อหาในแท็บ: สั่งซื้อ / ประวัติ = กว้าง ~95% อยู่กลางจอ */
  .page.bonustime #tab-order > .bonustime-order {
    width: 95%;
    max-width: 95%;
    margin: 0 auto;
  }

  .page.bonustime #tab-history > .history-list {
    width: 95%;
    max-width: 95%;
    margin: 0 auto;
  }

  /* ด้านใน history list ให้กินเต็มส่วน 95% */
  .page.bonustime #bonustimeHistory {
    width: 100%;
    max-width: 100%;
    margin: 0;
  }

  .page.bonustime #bonustimeHistory .bonustime-card {
    width: 100%;
    max-width: 100%;
  }

  /* การ์ดแพ็กเกจให้แสดงทีละใบเต็ม section (95% ของจอ) */
  .page.bonustime .bt-package-grid {
    grid-template-columns: 1fr;
  }

  .page.bonustime .bt-package {
    width: 100%;
  }
}

/* แถวลิงก์ + ปุ่มคัดลอก ให้อยู่ติดกัน */
.bt-value.link-row {
  display: inline-flex;
  align-items: center;
  gap: 8px;              /* ระยะห่างระหว่างลิงก์กับปุ่ม */
  flex-wrap: wrap;
}

/* ปุ่มคัดลอกลิงก์ */
.copy-link-btn {
  border-radius: 999px;
  border: 1px solid var(--border);
  background: var(--page);
  color: var(--text);
  font-size: 12px;
  padding: 4px 10px;
  cursor: pointer;
  white-space: nowrap;
}

.copy-link-btn:hover {
  border-color: var(--accent, #05b84f);
}

/* ================================
   DESKTOP LAYOUT — ปรับให้บาลานซ์
================================== */

/* ลดความกว้างการ์ดลง */
@media (min-width: 1024px) {
  .bt-package-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 28px;
    padding-inline: 20px;
  }

  .bt-package {
    max-width: 850px;     /* จำกัดความกว้าง */
    margin-inline: auto;  /* จัดกลาง */
    padding: 20px 22px 26px;
  }

  /* ย้ายรูปให้ลอยขึ้นกลางมากขึ้น */
  .pkg-thumb {
    aspect-ratio: 16/7 !important; /* จากเดิม 16/9 → 16/7 เพื่อให้สูงน้อยลง */
    margin-bottom: 16px;
    transform: translateY(-12px);  /* ดึงขึ้นนิดนึง */
  }

  .pkg-thumb img {
    object-position: center -370px; /* ดันภาพขึ้นไปให้ Mockup อยู่กึ่งกลาง */
  }

  /* ข้อความด้านล่างดึงขึ้นเล็กน้อย */
  .pkg-desc {
    margin-top: 6px;
  }

  /* ปุ่มให้อยู่ใกล้เนื้อหามากขึ้น */
  .pkg-actions {
    margin-top: 10px;
  }
}

/* ----- Bonustime Helpers / FAQ ----- */
.bt-help {
  margin-top: 8px;
}

.bt-help-title {
  font-size: 18px;
  font-weight: 400;
  margin-bottom: 4px;
}

/* กล่องเทาที่ครอบ FAQ ทั้งหมด */
#helpers .faq-card {
  background: var(--card);
  border: 1px dashed var(--border);
  border-radius: 18px;
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);

  /* ❗ ไม่ต้องมี padding ซ้ายขวา ให้กล่องเขียวเต็มพอดี */
  padding: 12px 0 14px;
}

/* ทำให้ accordion ด้านในกว้างเต็มกล่องเทา */
#helpers .accordion-clean {
  width: 99%;       /* เต็มความกว้าง faq-card */
  max-width: 100%;
  margin: 0;
  justify-self: center;
}

/* กัน ul ไปสร้างระยะเพิ่มเอง */
#helpers .accordion-clean > ul {
  margin: 0;
  padding: 0;
}

/* แต่ละข้อ FAQ ให้กินเต็มความกว้าง accordion */
#helpers .accordion-clean .accordion-item {
  border: 1px dashed var(--border);
  border-radius: 12px;
  overflow: hidden;
  background: var(--page);
  margin-bottom: 10px;
  width: 100%;
}

/* หัวข้อ FAQ */
#helpers .accordion-clean .accordion-title {
  display: flex;
  align-items: center;
  gap: .6rem;
  padding: 14px 16px;
  cursor: pointer;
  font-weight: 400;
  font-size: 15px;
  color: var(--text);
  background: rgba(34, 197, 94, 0.08);
}

#helpers .accordion-clean .accordion-title i {
  color: #4ade80;
}

#helpers .accordion-clean .accordion-content {
  display: none;
  padding: 14px 16px 18px;
  font-size: 14px;
  color: var(--text);
  border-top: 1px dashed var(--border);
  background: var(--page);
}

#helpers .accordion-clean .accordion-item.active .accordion-content {
  display: block;
}

#helpers .accordion-clean .accordion-item.active .accordion-title {
  background: rgba(34, 197, 94, 0.16);
}
/* ===== Video ===== */
.bt-help-video {
  margin: 16px 0 24px;
  border-radius: 14px;
  overflow: hidden;
  background: #000;
}

.bt-help-video-frame {
  position: relative;
  width: 100%;
  padding-top: 56.25%; /* 16:9 */
  background: #000;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid #222; /* ปรับตามโทนเว็บได้ */
}

.bt-help-video-frame iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: 0;
}

/* ===== Steps List ===== */
.help-steps {
  margin: 0;
  padding-left: 1.2rem;
}

.help-steps li {
  margin-bottom: 4px;
}

/* ===== PDF Frame ===== */
.bt-help-pdf {
  margin-top: 8px;
}

.bt-help-pdf .pdf-frame {
  margin-bottom: 10px;
  border-radius: 14px;
  overflow: hidden;
  background: #000;
  height: min(540px, 70vh);
  border: 1px solid var(--border);
}

.bt-help-pdf iframe {
  width: 100%;
  height: 100%;
  border: 0;
}

/* ===== Image Blocks ===== */
.bt-help-img {
  margin-top: 8px;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid var(--border);
  background: #000;
  max-width: 640px;
}

.bt-help-img img {
  display: block;
  width: 100%;
  height: auto;
}

/* มือถือ: FAQ เต็มกล่อง + PDF เห็นทีละหน้าแล้วเลื่อนเอา */
@media (max-width: 768px) {
  #helpers .faq-card {
    padding: 16px 12px;      /* ขยับให้พอดีขอบจอมือถือ */
  }

  #helpers .accordion-clean {
    width: 100%;
    max-width: 100%;
  }

  .bt-help-pdf .pdf-frame {
    height: 150px;           /* เน้นเห็นทีละหน้า แล้ว scroll ใน iframe */
  }
}

.tenant-block {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.tenant-hint {
  font-size: 11px;
  opacity: 0.75;
}

/* พับรายละเอียดแพ็กเกจไว้ก่อน */
.pkg-details {
  display: none;
  margin-top: 8px;
}

/* เมื่อการ์ดถูกเปิดให้แสดงรายละเอียด */
.bt-package.open .pkg-details {
  display: block;
}

/* hint ข้อความกดดูรายละเอียด */
.pkg-hint {
  margin-top: 6px;
  font-size: 12px;
  color: var(--muted, #9ca3af);
}

/* ตอนเปิดอยู่ อาจทำให้ hint จางลงนิดนึง */
.bt-package.open .pkg-hint {
  opacity: 0.6;
}

/* grid การ์ดแพ็กเกจ */
.bt-package-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 16px;

  /* เพิ่มบรรทัดนี้ */
  align-items: flex-start;   /* <== ทำให้แต่ละการ์ดสูงตามเนื้อหาของตัวเอง */
}

.bt-inline-link {
  color: var(--accent, #05b84f);
  cursor: pointer;
  text-decoration: none;
  font-weight: 400;
}

.bt-inline-link:hover {
  opacity: 0.9;
}


/* Modal BG */
.img-modal {
  display: none;
  position: fixed;
  z-index: 9999;
  inset: 0;
  backdrop-filter: blur(12px);
  background: rgba(0, 0, 0, 0.35);
  align-items: center;
  justify-content: center;
  cursor: zoom-out;
}

/* รูปที่ขยาย */
.img-modal-content {
  max-width: 90vw;
  max-height: 90vh;
  border-radius: 8px;
  cursor: zoom-out;
  box-shadow: 0 0 25px rgba(0,0,0,0.5);
  animation: fadeIn 0.15s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: scale(0.93); }
  to   { opacity: 1; transform: scale(1); }
}

/* ให้ cursor เป็น zoom-in ตอนยังไม่ได้ขยาย */
.previewable {
  cursor: zoom-in;
}

.bonustime-card .bt-status-wrap {
  display: flex;
  align-items: center;
  gap: 6px;
}

.bonustime-card .bt-status-wrap {
  display: flex;
  align-items: center;
  gap: 6px;
}

/* base */
.bt-countdown-pill {
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 999px;
  white-space: nowrap;
  font-weight: 400;
}

/* > 15 วัน → เขียว */
.bt-countdown-pill--safe {
  border: 1px solid #22c55e;
  background: rgba(34, 197, 94, 0.22);
  color: #bbf7d0;
}

/* < 15 วัน → เหลือง */
.bt-countdown-pill--warn15 {
  border: 1px solid #05b84f;
  background: rgba(6, 199, 85, 0.20);
  color: #21b95c;
}

/* < 7 วัน → ส้ม */
.bt-countdown-pill--warn7 {
  border: 1px solid #05b84f;
  background: rgba(6, 199, 85, 0.24);
  color: #eef6ff;
}

/* < 3 วัน → แดง */
.bt-countdown-pill--warn3 {
  border: 1px solid #ef4444;
  background: rgba(239, 68, 68, 0.26);
  color: #fee2e2;
}

/* =============== BONUSTIME MOBILE FIX =============== */

/* ป้องกันข้อความยาวล้นกล่อง */
.bonustime-card .bt-value,
.bonustime-card .bt-value span,
.bonustime-card .bt-value a {
  word-break: break-all;
  overflow-wrap: break-word;
}

/* Layout เดิมสำหรับ desktop = 2 columns */
.bonustime-card .bt-grid {
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 3px 25px;
}

/* ---------- MOBILE MODE ---------- */
@media (max-width: 768px) {

  /* 1 คอลัมน์: label บน / value ล่าง */
  .bonustime-card .bt-grid {
    grid-template-columns: 1fr;
  }

  .bonustime-card .bt-label {
    font-weight: 400;
    margin-top: 12px;
  }

  .bonustime-card .bt-value {
    margin-bottom: 4px;
  }

  /* ช่องลิงก์ ปุ่มคัดลอก ให้อยู่บรรทัดเดียวกันแบบ flex */
  .bonustime-card .link-row {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
  }

  .bonustime-card .copy-link-btn {
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* countdown + status pill */
  .bonustime-card .bt-status-wrap {
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
  }
}

#railwayMonitorModal::backdrop {
  background: rgba(0,0,0,0.35);
