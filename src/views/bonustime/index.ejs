        <label class="bt-field bt-flow-field">
          <span>ลิงก์เข้าสู่ระบบ</span>
          <input id="btOrderLogin" type="text" required placeholder="https://.../login">
        </label>

        <label class="bt-field bt-flow-field">
          <span>ลิงก์สมัครสมาชิก</span>
          <input id="btOrderSignup" type="text" required placeholder="https://.../register">
        </label>

        <label class="bt-field bt-flow-field">
          <span>ลิงก์ไลน์ติดต่อ</span>
          <input id="btOrderLineAdmin" type="text" required placeholder="https://lin.ee/...">
        </label>
      </section>
    </div>

    <footer class="bt-flow-footer">
      <button type="button" class="bt-btn ghost bt-flow-cancel" onclick="document.getElementById('btOrderModal').close()">ยกเลิก</button>
      <button type="button" class="bt-btn primary bt-flow-save" onclick="submitBonustimeOrder()">ยืนยันสั่งซื้อ ↗</button>
    </footer>
  </form>
</dialog>

