async function loadBonustimeHistory() {
    const box = document.getElementById("bonustimeHistory");
    if (!box) return;

    box.innerHTML = `<p class="muted">กำลังโหลดข้อมูล…</p>`;

    try {
      const res = await fetch("/bonustime/history");
      const data = await res.json();

      if (!data.ok || !Array.isArray(data.records) || !data.records.length) {
          box.innerHTML = `<p class="muted">ไม่มีประวัติการสั่งซื้อ</p>`;
          return;
      }

      box.innerHTML = "";

      data.records.forEach((rec) => {
          BONUSTIME_CACHE[rec._id] = rec;

          let statusText = "";
          let expiryDate = null;
          let remainDays = null;
          
          if (rec.LICENSE_DISABLED === true) {
            statusText = "ไม่มีวันหมดอายุ";
          } else {
            expiryDate = calcExpiredDate(
              rec.LICENSE_START_DATE,
              rec.LICENSE_DURATION_DAYS
            );
            if (expiryDate) {
              const now = new Date();
              const diff = expiryDate - now;
              remainDays = Math.ceil(diff / (1000 * 60 * 60 * 24));
            }

            if (!expiryDate || (remainDays !== null && remainDays <= 0)) {
              statusText = "หมดอายุแล้ว";
            } else {
              statusText = `เหลืออีก ${remainDays} วัน`;
            }
          }

          const lottoText = rec.LOTTO_ENABLED ? "เปิด" : "ปิด";
          // ถ้ายังไม่ได้เปิดหวย ให้เตรียมปุ่มอัปเกรดเพิ่ม
          const upgradeBtnHtml = !rec.LOTTO_ENABLED
            ? `<button class="bt-btn warn" onclick="upgradeLotto('${rec._id}')">
                อัปเกรดเพิ่มหวย +฿1,000
              </button>`
            : "";

          // ถ้า LICENSE_DISABLED เป็น true หรือไม่มีวันหมดอายุ -> ไม่แสดงปุ่มต่ออายุ
          const canExtend = rec.LICENSE_DISABLED !== true;
          const extendBtnHtml = canExtend
            ? `<button class="bt-btn primary" onclick="openExtend('${rec._id}')">
                ต่ออายุการใช้งาน
              </button>`
            : "";
          
          const updatedataAllowed = true;
          const updatedataBtnHtml = updatedataAllowed
              ? `
                <button class="bt-btn updatedata" onclick="openEdit('${rec._id}')">
                  แก้ไขข้อมูล
                </button>
              `
              : "";

          // ถ้ายังไม่หมดอายุและมี expiryDate ให้สร้าง countdown pill
          const countdownHtml =
            expiryDate && remainDays > 0
              ? `<div class="bt-countdown-pill" data-expiry="${expiryDate.toISOString()}"></div>`
              : "";

          const el = document.createElement("section");
          el.className = "bonustime-card open";

          el.innerHTML = `
          <div class="collapse-head">
              <div class="tenant-block">
                <div class="tenant">${rec.NAME || "-"}</div>
                <div class="tenant-hint muted small">กดเพื่อขยายหรือพับรายละเอียด Services</div>
              </div>
              <div class="bt-status-wrap">
                <div class="status-pill">${statusText}</div>
                ${countdownHtml}
              </div>
          </div>

          <div class="collapse-body">
              <div class="bt-grid">
              <div class="bt-label">Service</div>
              <div class="bt-value ellipsis" title="${rec.tenantId || ""}">
                  ${rec.serviceKey || rec.tenantId || "-"}
              </div>

              <div class="bt-label">Serial Key</div>
              <div class="bt-value ellipsis" title="${rec.serial_key || ""}">
                  ${rec.serial_key || "-"}
              </div>

              <div class="bt-label">CHANNEL_ACCESS_TOKEN</div>
              <div class="bt-value ellipsis" title="${rec.CHANNEL_ACCESS_TOKEN || ""}">
                  ${rec.CHANNEL_ACCESS_TOKEN || "-"}
              </div>

              <div class="bt-label">CHANNEL_SECRET</div>
              <div class="bt-value ellipsis" title="${rec.CHANNEL_SECRET || ""}">
                  ${rec.CHANNEL_SECRET || "-"}
              </div>

              <div class="bt-label">โลโก้เว็บ</div>
              <div class="bt-value ellipsis" title="${rec.LOGO || ""}">
                  ${rec.LOGO || "-"}
              </div>

              <div class="bt-label">ลิงก์เข้าสู่ระบบ</div>
              <div class="bt-value ellipsis" title="${rec.LOGIN_URL || ""}">
                  ${rec.LOGIN_URL || "-"}
              </div>

              <div class="bt-label">ลิงก์สมัครสมาชิก</div>
              <div class="bt-value ellipsis" title="${rec.SIGNUP_URL || ""}">
                  ${rec.SIGNUP_URL || "-"}
              </div>

              <div class="bt-label">ลิงก์ไลน์ติดต่อ</div>
              <div class="bt-value ellipsis" title="${rec.LINE_ADMIN || ""}">
                  ${rec.LINE_ADMIN || "-"}
              </div>

              <div class="bt-label">เปิดใช้งานหวย</div>
              <div class="bt-value">${lottoText}</div>

              <div class="bt-label">เริ่มใช้งาน</div>
              <div class="bt-value">${rec.LICENSE_START_DATE || "-"}</div>

              <div class="bt-label">จำนวนวัน</div>
              <div class="bt-value">${rec.LICENSE_DURATION_DAYS ?? "-"}</div>

              <div class="bt-label">ลิงก์เชื่อมต่อ</div>
              <div class="bt-value link-row">
              <span class="link-text" title="${rec.LINK || ""}">
                  ${rec.LINK || "-"}
              </span>
              ${
                  rec.LINK
                  ? `<button
                      type="button"
                      class="copy-link-btn"
                      data-link="${rec.LINK}"
                      onclick="copyLink(this)">
                      คัดลอก
                      </button>`
                  : ""
