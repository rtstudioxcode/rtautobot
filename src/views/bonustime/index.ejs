    const item = data.item; // { _id, tenantId }
    const dlg = document.getElementById("btOrderModal");

    // เก็บ _id ของ server ที่จะขายให้จริง ๆ
    document.getElementById("btOrderId").value = item._id;
    document.getElementById("btOrderType").value = type;

    // โชว์ tenantId ที่ backend เลือกจริง ๆ
    document.getElementById("btOrderTenantLabel").textContent =
      `Service: ${item.tenantId || "-"}`;

    // เคลียร์ค่าเก่าของฟอร์มทุกครั้งก่อนแสดง
    document.getElementById("btOrderName").value = "";
    document.getElementById("btOrderAccessToken").value = "";
    document.getElementById("btOrderSecret").value = "";
    document.getElementById("btOrderLogo").value = "";
    document.getElementById("btOrderLogin").value = "";
    document.getElementById("btOrderSignup").value = "";
    document.getElementById("btOrderLineAdmin").value = "";

    dlg.showModal();
  } catch (err) {
    // console.error(err);
    btNotify('error', 'ไม่สามารถเปิดฟอร์มสั่งซื้อได้', 'กรุณาลองใหม่อีกครั้ง');
  }
}

