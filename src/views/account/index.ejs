    // ===== Avatar upload =====
    const btnAvatar = pick('btnChangeAvatar');
    const input = pick('avatarInput');
    const img = pick('avatarPreview');

    const MAX_MB = 10;
    const ACCEPT = /image\/(png|jpe?g|webp|gif)/i;

    let tmpUrl = null;
    let abortController = null;

    const setImg = (url) => {
      if (!url) return;
      img.src = url;
    };

    const revokeTmp = () => {
      if (tmpUrl) {
        try { URL.revokeObjectURL(tmpUrl); } catch { }
        tmpUrl = null;
      }
    };

    btnAvatar?.addEventListener('click', () => input?.click());

    input?.addEventListener('change', async (e) => {
      const f = e.currentTarget.files?.[0];
      if (!f) return;

      // ===== validate =====
      if (!ACCEPT.test(f.type)) {
        warn('ไฟล์ไม่รองรับ', 'อนุญาตเฉพาะ PNG, JPG, WEBP และ GIF');
        input.value = '';
        return;
      }

      if (f.size > MAX_MB * 1024 * 1024) {
        warn('ไฟล์ใหญ่เกินไป', `ขนาดสูงสุด ${MAX_MB}MB`);
        input.value = '';
        return;
      }

      // ===== cancel request เก่า =====
      if (abortController) abortController.abort();
      abortController = new AbortController();

      // ===== preview =====
      revokeTmp();
      tmpUrl = URL.createObjectURL(f);
      setImg(tmpUrl);

      const prevSrc = img.dataset.prev || img.src;

      btnAvatar.disabled = true;
      btnAvatar.classList.add('loading');

      const fd = new FormData();
      fd.append('avatar', f);

      try {
        const r = await fetch('/account/profile', {
          method: 'POST',
          body: fd,
          credentials: 'same-origin', // 🔥 สำคัญมาก
          signal: abortController.signal,
          headers: {
            'X-Requested-With': 'XMLHttpRequest'
          }
        });

        let j = {};
        try { j = await r.json(); } catch { }

        if (!r.ok || !j?.ok) {
          throw new Error(j?.error || `HTTP ${r.status}`);
        }

        // ===== update image (กัน cache 100%) =====
        if (j.user?.avatarUrl) {
          revokeTmp();
          setImg(j.user.avatarUrl);
          img.dataset.prev = j.user.avatarUrl;
        }

        // ===== OTP UI =====
        if (j.user?.email && !j.user?.emailVerified) {
          document.getElementById('otpArea')?.removeAttribute('hidden');
        }

        // ===== success effect =====
        img.classList.add('avatar-success');
        setTimeout(() => img.classList.remove('avatar-success'), 500);

        ok('อัปโหลดรูปโปรไฟล์แล้ว');

      } catch (err) {

        if (err.name === 'AbortError') return;

        // ===== rollback =====
        revokeTmp();
        setImg(prevSrc);

        img.classList.add('avatar-error');
        setTimeout(() => img.classList.remove('avatar-error'), 600);

        fail('อัปโหลดไม่สำเร็จ', err.message || 'เครือข่ายมีปัญหา');

      } finally {
        btnAvatar.disabled = false;
        btnAvatar.classList.remove('loading');
        input.value = '';
      }
    });

    // ===== เก็บรูปล่าสุดไว้ fallback =====
    img?.addEventListener('load', () => {
