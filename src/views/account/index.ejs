<!-- 1) BRIDGE: map showMsg → notify และยึด alert ทั้งหน้าให้เป็น notify -->
<script>
  (() => {
    // ถ้ามี layout.notify ให้แมป showMsg → notify
    if (window.notify) {
      window.showMsg = (opts) => window.notify(opts);
    }

    // เปลี่ยน alert ทั้งหน้า → notify
    const __origAlert = window.alert.bind(window);
    window.alert = (message) => {
      if (window.notify) {
        window.notify({ variant: 'info', title: 'แจ้งเตือน', text: String(message ?? '') });
      } else {
        __origAlert(message);
      }
    };

    // ยูทิลสั้น
    window._n = (variant, title, text = '', extras = {}) =>
      (window.notify ? window.notify({ variant, title, text, ...extras }) : __origAlert(`${title}\n${text || ''}`));

    // Helper มาตรฐาน (ไม่มี fallback เป็น alert อีก)
    window.ok = (detail = 'ดำเนินการเรียบร้อย', extras = {}) => window.showMsg?.({ variant: 'success', title: 'สำเร็จ', text: detail, ...extras });
    window.warn = (title, text = '', extras = {}) => window.showMsg?.({ variant: 'warn', title, text, ...extras });
    window.fail = (title, text = '', extras = {}) => window.showMsg?.({ variant: 'error', title, text, ...extras });
    window.info = (title, text = '', extras = {}) => window.showMsg?.({ variant: 'info', title, text, ...extras });
  })();
</script>

<!-- 2) Password eye + validate (เดิม แต่ไม่แตะระบบแจ้งเตือน) -->
<script>
  (() => {
    const ICON_EYE = `
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path fill="currentColor" d="M12 5c-5.5 0-9.5 4.5-10.7 6 1.2 1.5 5.2 6 10.7 6s9.5-4.5 10.7-6C21.5 9.5 17.5 5 12 5zm0 10a4 4 0 1 1 0-8 4 4 0 0 1 0 8z"/>
    </svg>`;
    const ICON_EYE_OFF = `
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path fill="currentColor" d="M2.8 1.4 1.4 2.8l3.1 3.1C2.8 7.3 1.5 8.9 1.3 9.2l-.3.4.3.4C2.5 11.5 6.5 16 12 16c1.7 0 3.2-.4 4.6-1.1l3.6 3.6 1.4-1.4L2.8 1.4zM12 14c-3.9 0-7.2-3-8.8-4.8C4.2 7.8 7.2 5 12 5c2 0 3.8.6 5.4 1.7l-2 2A4 4 0 0 0 10.7 8l-2 2A4 4 0 0 0 12 14z"/>
    </svg>`;

    document.querySelectorAll('.pw-toggle').forEach(btn => { btn.innerHTML = ICON_EYE; });
    document.addEventListener('click', (e) => {
      const btn = e.target.closest('.pw-toggle'); if (!btn) return;
      const input = btn.previousElementSibling; if (!input) return;
      const show = input.type === 'password';
      input.type = show ? 'text' : 'password';
      btn.setAttribute('aria-pressed', show ? 'true' : 'false');
      btn.innerHTML = show ? ICON_EYE_OFF : ICON_EYE;
    });

    const form = document.getElementById('formPassword');
    const btnSubmit = form?.querySelector('button[type="submit"]');
    const cur = form?.querySelector('input[name="currentPassword"]');
    const pw1 = form?.querySelector('input[name="newPassword"]');
    const pw2 = form?.querySelector('input[name="newPassword2"]');
    const msg = document.getElementById('pwMismatchMsg');
    const MIN = 6;

    function validate() {
      const v0 = (cur?.value || '').trim();
      const v1 = (pw1?.value || '').trim();
      const v2 = (pw2?.value || '').trim();
      const tooShort = v1.length > 0 && v1.length < MIN;
      const mismatch = v2.length > 0 && v1 !== v2;
      msg.style.display = mismatch ? '' : 'none';
      const okBtn = v0.length >= 1 && v1.length >= MIN && v2.length >= MIN && !mismatch && !tooShort;
      if (btnSubmit) btnSubmit.disabled = !okBtn;
    }
    ['input', 'blur'].forEach(ev => {
      cur?.addEventListener(ev, validate);
      pw1?.addEventListener(ev, validate);
      pw2?.addEventListener(ev, validate);
    });
    form?.addEventListener('submit', (e) => { validate(); if (btnSubmit?.disabled) e.preventDefault(); });
    validate();
  })();
</script>

