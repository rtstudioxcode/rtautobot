<section class="account-container">
  <h1 class="page-title" id="acctPageTitle">ตั้งค่าข้อมูลส่วนตัว</h1>

  <div class="acc-wrap">
    <!-- = LEFT: Summary = -->
    <aside class="acc-side">
      <div class="prof-card">
        <div class="prof-avatar">
          <img id="avatarPreview"
            src="<%= userDoc.avatarSrc || (typeof buildAvatarSrc === 'function' ? buildAvatarSrc(userDoc.avatarUrl, userDoc.avatarVer) : (userDoc.avatarUrl || '/static/logo/icon-logo.png')) %>"
            loading="lazy" decoding="async" onerror="this.onerror=null;this.src='/static/logo/icon-logo.png';"
            alt="avatar">
        </div>

        <div style="display:flex;justify-content:center;gap:8px;">
          <button type="button" id="btnChangeAvatar" class="btn-line">เปลี่ยนรูปโปรไฟล์</button>
          <input id="avatarInput" name="avatar" type="file" hidden accept="image/png,image/jpeg,image/webp,image/gif">
        </div>

        <div class="prof-name">
          <%= userDoc.name || (me?.username || '' ) %>
        </div>
        <div class="prof-mail">
          <%= userDoc.email || '-' %>
            <% if (userDoc.email) { %>
              <% if (userDoc.emailVerified) { %>
                <span class="badge ok">ยืนยันแล้ว</span>
                <% } else { %>
                  <span class="badge warn">ยังไม่ยืนยัน</span>
                  <% } %>
                    <% } %>
        </div>

        <div class="kv">
          <div>ระดับบัญชี</div>
          <div><span class="badge warn">
              <%= userDoc.levelName || `เลเวล ${userDoc.level || '1' }` %>
            </span></div>
        </div>
        <% if (userDoc.serial_key) { %>
          <div class="kv">
            <div>Serial Key</div>
            <div>
              <span class="badge ok">
                <%= userDoc.serial_key %>
              </span>
            </div>
          </div>
          <% } %>
            <div class="kv">
              <div>ยอดคงเหลือ</div>
              <div><span class="badge balance">
                  <%= balanceText %>
                </span></div>
            </div>

            <!-- ✅ อัปเดตข้อความรองรับไฟล์ -->
            <div class="muted sm" style="margin-top:8px">ไฟล์ที่รองรับ: png, jpg, jpeg, webp, gif (สูงสุด 10MB)</div>
      </div>

      <div class="prof-card" style="margin-top:14px">
        <div class="kv">
          <div>ยืนยันตัวตน KYC</div>
          <div><a class="badge danger">ยังไม่เปิดใช้งาน</a></div>
        </div>
        <div class="kv">
          <div>ช่วยเหลือ</div>
          <div><a class="badge ok" href="https://line.me/R/ti/p/@507vkplq" target="_blank" rel="noopener">Line
              Official</a></div>
        </div>
      </div>
    </aside>

    <!-- = RIGHT: Tabs = -->
    <div class="acc-main">
      <div class="tabs">
        <button class="tab active" data-tab="tab-general">การตั้งค่าทั่วไป</button>
        <button class="tab" data-tab="tab-points">ข้อมูลระดับบัญชี</button>
        <button class="tab" data-tab="tab-affiliate">แนะนำเพื่อน</button>
      </div>

      <!-- GENERAL -->
      <div class="tabpane show" id="tab-general">
        <form id="formProfile" class="card" enctype="multipart/form-data">
          <div class="card-header">
            <div class="title">ข้อมูลส่วนตัว</div>
          </div>
          <div class="form-grid">
            <label>ชื่อ - นามสกุล
              <input name="name" type="text" value="<%= userDoc.name || '' %>" <%=userDoc.name ? 'disabled' : '' %>
              placeholder="ระบุชื่อ-นามสกุล">
              <% if (userDoc.name) { %><small class="muted sm">ตั้งแล้ว หากต้องการเปลี่ยนให้ติดต่อผู้ดูแล</small>
                <% } %>
            </label>

            <label>Username
              <div class="static-input" aria-readonly="true">
                <%= userDoc.username || '-' %>
              </div>
            </label>

            <label>Email Address
              <div class="email-row">
                <input name="email" type="email" value="<%= userDoc.email || '' %>" <%=userDoc.email ? 'disabled' : ''
                  %>
                placeholder="name@example.com">
                <% if (userDoc.email) { %>
                  <% if (userDoc.emailVerified) { %>
                    <button type="button" class="badge2 ok" disabled>ยืนยันแล้ว</button>
                    <% } else { %>
                      <button id="btnSendOtp" type="button" class="btn" data-email="<%= userDoc.email %>">
                        ส่งรหัสยืนยัน
                      </button>
                      <% } %>
                        <% } %>
              </div>
            </label>

            <% if (userDoc.email && !userDoc.emailVerified) { %>
              <!-- ซ่อนจนกว่าจะกด "ส่งรหัสยืนยัน" สำเร็จ -->
              <div id="otpArea" class="otp-row" hidden>
                <input id="otpCode" type="text" inputmode="numeric" maxlength="6" placeholder="กรอกรหัส 6 หลัก">
                <button id="btnVerifyOtp" type="button" class="btn-lux">ยืนยัน</button>
              </div>
              <% } %>

                <label>Timezone
                  <div class="static-input" aria-readonly="true">(GMT+7:00) Asia/Bangkok (Thailand Time)</div>
                </label>

                <label>สกุลเงิน
                  <div class="static-input" aria-readonly="true">
                    <%= userDoc.currency || 'THB' %>
                  </div>
                </label>
          </div>

          <div class="card-actions">
            <button class="btn-lux" type="submit">บันทึกข้อมูล</button>
          </div>
        </form>

        <form id="formPassword" class="card">
          <div class="card-header">
            <div class="title">เปลี่ยนรหัสผ่าน</div>
          </div>
          <div class="form-grid">
            <label>รหัสผ่านเดิม
              <div class="pw-field">
                <input name="currentPassword" type="password" required>
                <button type="button" class="pw-toggle" aria-label="แสดง/ซ่อนรหัสผ่าน" aria-pressed="false"
                  title="แสดง/ซ่อน"></button>
              </div>
            </label>

            <label>รหัสผ่านใหม่
              <div class="pw-field">
                <input name="newPassword" type="password" minlength="6" required>
                <button type="button" class="pw-toggle" aria-label="แสดง/ซ่อนรหัสผ่าน" aria-pressed="false"
                  title="แสดง/ซ่อน"></button>
              </div>
            </label>

            <label>ยืนยันรหัสผ่านใหม่
              <div class="pw-field">
                <input name="newPassword2" type="password" minlength="6" required>
                <button type="button" class="pw-toggle" aria-label="แสดง/ซ่อนรหัสผ่าน" aria-pressed="false"
                  title="แสดง/ซ่อน"></button>
              </div>
              <small id="pwMismatchMsg" class="muted sm" style="color: var(--danger); display:none;">
                รหัสผ่านใหม่ไม่ตรงกัน
              </small>
            </label>
          </div>
          <div class="card-actions">
            <button class="btn-lux" type="submit">เปลี่ยนรหัสผ่าน</button>
          </div>
        </form>
      </div>

      <!-- =========== Tab: Points และ Level(แทนที่บล็อกเดิมทั้งหมด) =========== -->
      <div class="tabpane" id="tab-points">
        <div class="card" style="margin-bottom:14px">
          <div class="card-header">
            <div class="title">คะแนนสะสม (Points)</div>
            <span class="pill lvl">
              <%= userDoc.levelName ? userDoc.levelName : ('เลเวล ' + (userDoc.level || ' 1')) %>
            </span>
          </div>

          <div class="form-grid">
            <div class="score-wrap">
              <div>
                <div class="bignum" data-id="points-num">
                  <% var __points=(agg && typeof agg.points==='number' ) ? agg.points : 0; %>
                    <%= __points.toLocaleString(undefined,{maximumFractionDigits:2}) %> คะแนน
                </div>
                <div class="muted" style="color: #31d810;">ใช้จ่ายครบ ฿50 | ได้รับ 0.5 Point</div>
              </div>

              <div>
                <div class="kv" style="margin-bottom:8px">
                  <div>เรทแลกเป็นเงิน</div>
                  <% var __rate=(agg && typeof agg.pointRateTHB==='number' ) ? agg.pointRateTHB : 0; %>
                    <div><span class="badge balance" data-id="point-rate">฿<%= __rate.toLocaleString() %> / 1
                          แต้ม</span></div>
                </div>
                <div class="kv">
                  <div>มูลค่าแลกได้ (หากแลกทั้งหมด)</div>
                  <% var __val=(agg && typeof agg.pointValueTHB==='number' ) ? agg.pointValueTHB : 0; %>
                    <div><span class="badge balance" data-id="point-value">≈ ฿<%=
                          __val.toLocaleString(undefined,{maximumFractionDigits:2}) %></span></div>
                </div>

                <div class="kv" style="color: #dbad16;">
                  <div>⚠️ คำเตือน: เมื่อแลกแต้มเป็นเงินระดับบัญชีของคุณจะลดลงตามไปด้วย</div>
                </div>

                <div class="card-actions" style="text-align:right;padding:12px 0 0">
                  <% var __canRedeem=(__points>= 100);
                    var __needLeft = Math.max(0, 100 - __points);
                    %>
                    <button id="btnRedeemPoints" class="btn <%= __canRedeem ? 'primary' : '' %>" <% if (!__canRedeem) {
                      %>
                      disabled aria-disabled="true"
                      title="ต้องมีอย่างน้อย 100 แต้ม (ขาดอีก <%= __needLeft.toLocaleString() %> แต้ม)"
                        <% } %>
                          >
                          แลกแต้มเป็นเงิน (ขั้นต่ำ 100 แต้ม)
                    </button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <div class="title">ยอดใช้จ่ายสะสม</div>
            <span class="pill lvl">
              <%= userDoc.levelName || `เลเวล ${userDoc.level || '1' }` %>
            </span>
          </div>

          <%
            // ✅ ประกาศก่อนใช้งานเสมอ
            const __spent = (typeof agg !== 'undefined' && agg && typeof agg.totalSpent === 'number')
              ? agg.totalSpent
              : 0;
            const __level = Number(userDoc.level || 1);
            const __need = [0, ...((levels || []).map(l => Number(l.need || 0)))];
            const __nextMax = __need[__level + 1] || __need.at(-1) || 1;
            const __pctRaw = (__spent / __nextMax) * 100;
            const __pct = Math.max(0, Math.min(100, +__pctRaw.toFixed(2)));

            // ✅ ถ้าจะโชว์ breakdown ให้ประกาศตัวแปรของมัน “หลังจาก” __spent แล้ว
            const __raw = (agg && typeof agg.totalSpentRaw === 'number')
              ? agg.totalSpentRaw
              : (typeof userDoc.totalSpentRaw === 'number' ? userDoc.totalSpentRaw : 0);
            const __redeemed = (agg && typeof agg.redeemedSpent === 'number')
              ? agg.redeemedSpent
              : (typeof userDoc.redeemedSpent === 'number' ? userDoc.redeemedSpent : 0);
            %>

            <div class="form-grid">
              <div class="score-wrap">
                <div>
                  <div class="bignum">฿<%= __spent.toFixed(2) %>
                  </div>
                  <div class="subcap">ใช้จ่ายไปแล้ว</div>
                  <!-- (ออปชัน) breakdown -->
                  <div class="muted">ยอดทั้งหมด: ฿<%= __raw.toLocaleString(undefined,{maximumFractionDigits:2}) %>
                  </div>
                  <div class="muted">· แลกเครดิตไปแล้ว: ฿<%=
                      __redeemed.toLocaleString(undefined,{maximumFractionDigits:2}) %>
                  </div>
                  <div class="muted">· ใช้แต้มไปแล้ว: <%=
                      Number(agg?.pointsRedeemed||0).toLocaleString(undefined,{minimumFractionDigits:2}) %> Point</div>
                  <!-- <div class="muted">· ใช้คำนวณเลเวล: ฿<%= __spent.toLocaleString(undefined,{maximumFractionDigits:2}) %></div> -->
                  <!-- <div class="subcap" style="margin-top:6px">
                    ยอดดิบทั้งหมด: ฿<%= __raw.toLocaleString(undefined,{maximumFractionDigits:2}) %>
                    · แลกไปแล้ว: ฿<%= __redeemed.toLocaleString(undefined,{maximumFractionDigits:2}) %>
                    · ใช้คำนวณเลเวล: ฿<%= __spent.toLocaleString(undefined,{maximumFractionDigits:2}) %>
                  </div> -->
                </div>
                <div>
                  <div class="prog">
                    <div class="fill" style="width:<%= __pct %>%"></div>
                  </div>
                  <div class="subcap" style="margin-top:6px">
                    เป้าหมายเลเวลถัดไป: ฿<%= (__nextMax || 0).toLocaleString() %> (<%= __pct %>%)
                  </div>
                </div>
              </div>
            </div>
        </div>

        <!-- ระดับบัญชี (แสดงทีละ 2 การ์ด) -->
        <div class="card">
          <div class="card-header">
            <div class="title">ข้อมูลระดับบัญชี</div>
          </div>

          <div id="levelsTrack"><!-- เติมด้วย JS เดิม --></div>

          <div class="level-nav">
            <button class="btn" id="lvPrev" aria-label="ก่อนหน้า">‹</button>
            <button class="btn primary" id="lvNext" aria-label="ถัดไป">›</button>
          </div>
        </div>
      </div>

      <!-- =========== Tab: AFFILIATE(แนะนำเพื่อน) =========== -->
      <!-- AFFILIATE -->
      <div class="tabpane" id="tab-affiliate">
        <!-- Section: รายละเอียด -->
        <div class="card">
          <div class="card-header">
            <div class="title">ระบบแนะนำเพื่อน (Affiliate <span id="aff-rate-title">—</span>%)</div>
          </div>
          <div class="form-grid">
            <div class="muted">
              <ul style="margin:0 0 0 18px;padding:0">
                <li>คุณจะได้รับ <strong><span id="aff-rate-inline"></span>%</strong>
                  ของยอดออเดอร์ทุกคำสั่งซื้อของเพื่อนที่สมัครผ่านลิงก์ของคุณ</li>
                <li>ระบบคิดให้อัตโนมัติทุกครั้งที่คำสั่งซื้อของเพื่อนอยู่ในสถานะนับยอด
                  (paid/completed/success/done/processing)</li>
                <li>ลิงก์แนะนำจะถูกสร้างเมื่อคุณกดปุ่ม “สร้างลิงก์แนะนำ” เท่านั้น และเป็นคีย์เฉพาะตัว
                  ไม่ผูกกับชื่อผู้ใช้</li>
                <li>ตัวอย่างรูปแบบลิงก์: <code>https://rtautobot.com/aff?=รหัสแนะนำเพื่อนของคุณ</code></li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Section: สรุปรายได้ -->
        <div class="card" style="margin-top:14px">
          <div class="card-header aff-header">
            <div class="title">
              สรุปรายได้จากการแนะนำ
            </div>

            <!-- หลอดความคืบหน้าระดับ -->
            <div class="aff-progress" aria-label="Affiliate tier progress">
              <div class="bar">
                <div class="fill" id="aff-tier-fill" style="width:0%"></div>
              </div>
              <div class="note muted" id="aff-tier-note"></div>
            </div>

            <span class="pill clickable" id="aff-tier-pill">
              <span id="aff-refcount">
                <%= (affiliateSummary?.referredCount ?? 0).toLocaleString() %>
              </span> คนที่คุณแนะนำ
            </span>
          </div>

          <div class="card-stack" id="aff-kpis">
            <div class="summary-kpi">
              <div class="rt-title">จำนวนออเดอร์ทั้งหมด</div>
              <div class="bignum" id="aff-orders">
                <%= (affiliateSummary?.orders ?? 0).toLocaleString() %>
              </div>
            </div>
            <div class="summary-kpi">
              <div class="rt-title">ยอดใช้จ่ายรวมของเพื่อน</div>
              <div class="bignum">฿<span id="aff-spent">
                  <%= Number(affiliateSummary?.spentTHB ?? 0).toLocaleString(undefined,{minimumFractionDigits:2}) %>
                </span></div>
            </div>

            <div class="summary-kpi">
              <div class="rt-title">
                รายได้การแนะนำเพื่อนของคุณ (<span id="aff-rate-inline-2">
                  <%= (typeof affRatePct==='number' ? affRatePct : (affiliateSummary?.ratePct ?? 5)) %>
                </span>%)
              </div>

              <div class="bignum" style="color:#31d810">
                <span id="aff-withdrawable">
                  <%= Number(affiliateSummary?.withdrawableTHB ?? 0).toLocaleString(undefined,{minimumFractionDigits:2})
                    %>
                </span>
              </div>

              <div class="kpi-actions">
                <div class="muted small">ยอดที่ถอนได้ตอนนี้: ฿
                  <span id="aff-withdrawable">
                    <%= Number(affiliateSummary?.withdrawableTHB ??
                      0).toLocaleString(undefined,{minimumFractionDigits:2}) %>
                  </span>
                </div>
                <button class="btn success" id="btnAffWithdraw" <%= Number(affiliateSummary?.withdrawableTHB ?? 0) > 0 ? '' : 'disabled' %>>
                  ถอนรายได้
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Section: สร้าง/แสดงลิงก์ -->
        <div class="card" style="margin-top:14px">
          <div class="card-header">
            <div class="title">ลิงก์แนะนำเพื่อน</div>
          </div>
          <div class="form-grid">
            <div id="aff-create-area">
              <button id="btnCreateAff" class="btn-lux">+ สร้างลิงก์แนะนำ</button>
              <small class="muted">ลิงก์จะถูกสร้างเพียงครั้งเดียว และใช้งานได้ตลอด</small>
            </div>
            <div id="aff-link-area" hidden>
              <label>ลิงก์ของคุณ
                <div class="static-input" id="aff-link" style="word-break:break-all"></div>
              </label>
              <div class="card-actions" style="text-align:right;padding:0">
                <button class="btn" id="btnCopyAff">คัดลอกลิงก์</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Section: รายการการถอนรายได้แนะนำเพื่อน -->
        <div class="card" style="margin-top:14px">
          <div class="card-header">
            <div class="title">รายการการถอนรายได้แนะนำเพื่อน</div>
          </div>
          <div class="form-grid">
            <!-- Desktop table -->
            <div class="table-wrap only-desktop">
              <table class="tbl" id="aff-withdraw-table">
                <thead>
                  <tr>
                    <th style="text-align:left">วันที่</th>
                    <th>ยอดเงิน</th>
                    <th>ประเภท</th>
                    <th>สถานะ</th>
                  </tr>
                </thead>
                <tbody id="aff-list"></tbody>
              </table>
            </div>

            <!-- Mobile list -->
            <div class="only-mobile" id="aff-list-mobile"></div>

            <!-- Page control -->
            <div class="page-control" id="aff-pager">
              <!-- Per-page: custom dropdown + select เดิม (ซ่อนไว้) -->
              <div class="perpage perpage-dd">
                <label>ต่อหน้า</label>

                <!-- ปุ่มสวยๆ -->
                <button id="perpageBtn" class="dd-btn" type="button" aria-haspopup="listbox" aria-expanded="false">
                  <span id="perpageLabel">10</span>
                  <svg class="chev" width="12" height="12" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill="currentColor" d="M7 10l5 5 5-5z" />
                  </svg>
                </button>

                <!-- เมนูลอย (จะถูกวางแบบ fixed) -->
                <ul id="perpageMenu" class="dd-menu" role="listbox">
                  <li role="option" data-val="20" aria-selected="true">20</li>
                  <li role="option" data-val="50">50</li>
                  <li role="option" data-val="100">100</li>
                </ul>

                <!-- select เดิม: ซ่อนไว้และใช้ sync กับ backend -->
                <select id="aff-perpage" class="fsel" hidden>
                  <option value="20" selected>20</option>
                  <option value="50">50</option>
                  <option value="100">100</option>
                </select>
              </div>

              <!-- กลุ่มปุ่มเปลี่ยนหน้า -->
              <div class="pager">
                <button class="btn" id="aff-prev" aria-label="หน้าก่อน">‹</button>
                <span class="muted sm" id="aff-pageinfo">หน้า 1/1</span>
                <button class="btn" id="aff-next" aria-label="หน้าถัดไป">›</button>
              </div>
            </div>

            <div class="muted" id="aff-empty" style="display:none">ยังไม่มีข้อมูล</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Modal: เลือกประเภทการถอนรายได้แนะนำ -->
<dialog id="affWithdrawModal">
  <form method="dialog" class="modal affw-modal">
    <h3 class="affw-title">เลือกวิธีการถอนรายได้</h3>
    <p class="muted">โปรดเลือกวิธี</p>

    <!-- hidden field สำหรับส่งค่า -->
    <input type="hidden" id="affWKind" value="balance">

    <div class="affw-grid">
      <button type="button" class="affw-option is-active" data-kind="balance" aria-pressed="true">
        <div class="affw-opt-title">เครดิต</div>
        <div class="affw-opt-sub muted">สามารถถอนได้เลย</div>
