      if (dataEmail) return dataEmail;
      const field = $('input[name="email"]');
      return (field?.value || '').trim().toLowerCase();
    }

    function startCooldown(seconds) {
      if (!btnSendOtp || !Number.isFinite(seconds) || seconds <= 0) return;
      const original = btnSendOtp.textContent;
      btnSendOtp.disabled = true;
      let left = Math.ceil(seconds);
      btnSendOtp.textContent = `ส่งใหม่ได้ใน ${left}s`;
      const t = setInterval(() => {
        left -= 1;
        if (left <= 0) {
          clearInterval(t);
          btnSendOtp.disabled = false;
          btnSendOtp.textContent = original || 'ส่งรหัสยืนยัน';
          return;
        }
        btnSendOtp.textContent = `ส่งใหม่ได้ใน ${left}s`;
      }, 1000);
    }

    btnSendOtp?.addEventListener('click', async () => {
