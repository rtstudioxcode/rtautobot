      verifyBtn.disabled = true;
      try {
        const r = await fetch('/account/email/verify', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ code })
        });
        const j = await r.json();
        if (!j.ok) { verifyBtn.disabled = false; return fail('ยืนยันไม่สำเร็จ', j.error || ''); }
        ok('ยืนยันอีเมลเรียบร้อย');
        window.location.reload();
      } catch {
        verifyBtn.disabled = false;
        fail('ยืนยันไม่สำเร็จ', 'เครือข่ายมีปัญหา');
      }
    });

    // ===== Redeem Points =====
    const btnRedeem = document.getElementById('btnRedeemPoints');
    if (btnRedeem) {
      btnRedeem.addEventListener('click', async () => {
        if (btnRedeem.disabled) return;
        btnRedeem.disabled = true;
        const oldLabel = btnRedeem.textContent;
        btnRedeem.textContent = 'กำลังแลก…';

        try {
          const r = await fetch('/account/points/redeem', { method: 'POST' });
          const j = await r.json();

          if (!r.ok || !j?.ok) { fail('แลกแต้มไม่สำเร็จ', j?.error || 'โปรดลองใหม่'); return; }

          const pointsNum = Number(j.remainPoints || 0);
          const pointsEl = document.querySelector('[data-id="points-num"]');
          if (pointsEl) pointsEl.innerHTML = `${pointsNum.toLocaleString(undefined, { maximumFractionDigits: 2 })} คะแนน`;
          const rateEl = document.querySelector('[data-id="point-rate"]');
          if (rateEl) rateEl.textContent = `฿${(j.rate || 0).toLocaleString()} / 1 แต้ม`;
          const valEl = document.querySelector('[data-id="point-value"]');
          if (valEl) valEl.textContent = `≈ ฿${(j.pointValueTHB || 0).toLocaleString(undefined, { maximumFractionDigits: 2 })}`;

          const prEl = document.querySelector('[data-id="points-redeemed"]');
          if (prEl && typeof j.pointsRedeemed === 'number') {
            prEl.textContent = `฿${j.pointsRedeemed.toLocaleString(undefined, { minimumFractionDigits: 2 })}`;
          }

          if (pointsNum < 100) {
            btnRedeem.classList.remove('primary');
            btnRedeem.setAttribute('disabled', 'disabled');
          }

          const added = Number(j.addedBalance || 0);
          ok(`แลก ${j.redeemed} แต้ม เป็น ฿${added.toLocaleString(undefined, { maximumFractionDigits: 2 })} แล้ว`, {
            onClose: () => window.location.replace('/account')
          });
          setTimeout(() => { try { window.location.replace('/account'); } catch { } }, 300);
        } catch {
          fail('แลกแต้มไม่สำเร็จ', 'เครือข่ายมีปัญหา');
        } finally {
          btnRedeem.textContent = oldLabel;
          if (!btnRedeem.hasAttribute('disabled')) btnRedeem.disabled = false;
        }
      });
    }

    // ===== Levels renderer (2 cols) =====
    const track = document.getElementById('levelsTrack');
    const pages = [];
    const _levels = window.__LEVELS__ || [];
    for (let i = 0; i < _levels.length; i += 2) pages.push(_levels.slice(i, i + 2));
    let page = 0;

    function render() {
      track.innerHTML = '';
      const pickPercent = s => {
        const m = (s || '').match(/-?\d+(?:\.\d+)?%/);
        return m ? m[0] : (s || '—');
      };
      (pages[page] || []).forEach(lv => {
        const perks = lv.perks || [];
        const bonusTxt = perks.find(p => p.includes('โบนัสเติมเงิน')) || '';
        const discountTxt = perks.find(p => p.includes('ส่วนลดทุกคำสั่งซื้อ')) || '';
        const bonusVal = pickPercent(bonusTxt);
        const discountVal = pickPercent(discountTxt);

        track.insertAdjacentHTML('beforeend', `
        <div class="prof-card" style="padding:14px">
          <div class="kv" style="margin-bottom:8px">
            <div><strong>${lv.name}</strong></div>
            <div><span class="badge balance">ใช้จ่าย &gt; ฿${(lv.need || 0).toLocaleString()}</span></div>
          </div>
          <div class="kv"><div>อัตราการแลกเปลี่ยน ↔ (Point × Rate)</div><div><span class="badge balance">${lv.rate}</span></div></div>
          <div class="kv"><div>โบนัสเติมเงิน</div><div><span class="badge warn">${bonusVal}</span></div></div>
          <div class="kv"><div>ส่วนลดทุกคำสั่งซื้อ</div><div><span class="badge warn">${discountVal}</span></div></div>
          ${perks.filter(p => !p.includes('โบนัสเติมเงิน') && !p.includes('ส่วนลดทุกคำสั่งซื้อ'))
            .map(p => `<div class="muted" style="margin:6px 0">• ${p}</div>`).join('')}
        </div>
      `);
      });
    }
    render();
    document.getElementById('lvPrev')?.addEventListener('click', () => { page = (page - 1 + pages.length) % pages.length; render(); });
    document.getElementById('lvNext')?.addEventListener('click', () => { page = (page + 1) % pages.length; render(); });
  })();
</script>

<script>
  (() => {
    const $ = s => document.querySelector(s);
    const fmt = n => Number(n || 0).toLocaleString(undefined, { maximumFractionDigits: 2 });
    // fallback สำหรับ ok/fail ถ้าไม่มีตัวช่วย
    const ok = window.ok || (msg => alert(msg));
    const fail = window.fail || (msg => alert(msg));
    const btn = document.getElementById('btnCreateAff');
    if (!btn) return;

    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      if (btn.disabled) return;
      const old = btn.textContent;
      btn.disabled = true; btn.textContent = 'กำลังสร้าง…';

      try {
        const r = await fetch('/account/affiliate/create-link', { method: 'POST' });
        const j = await r.json();
        if (!r.ok || !j?.ok || !j?.link) {
          fail(j?.error || 'สร้างลิงก์ไม่สำเร็จ');
          return;
        }

        // สลับ UI มาโชว์ลิงก์ทันที
        const create = document.getElementById('aff-create-area');
        const area = document.getElementById('aff-link-area');
        const out = document.getElementById('aff-link');
        if (create && area && out) {
          create.hidden = true;
          area.hidden = false;
          out.textContent = j.link;
        }

        ok('สร้างลิงก์แนะนำเรียบร้อย');
      } catch {
        fail('เครือข่ายมีปัญหา โปรดลองใหม่');
      } finally {
        btn.disabled = false; btn.textContent = old;
      }
    });

    let lastStats = null;

    let __loadingStats = false;
    async function loadStats() {
      if (__loadingStats) return
      __loadingStats = true;
      try {
        const r = await fetch('/account/affiliate/stats');
        const j = await r.json();
        if (!r.ok || !j?.ok) throw new Error('fail');
        lastStats = j;

        // % เรต (ป้องกัน NaN และปัดเศษ)
        const rawRate = Number(j?.summary?.ratePct);
        const rate = Number.isFinite(rawRate) ? Math.min(40, Math.max(5, Math.round(rawRate))) : 5;
        $('#aff-rate-title') && ($('#aff-rate-title').textContent = rate);
        $('#aff-rate-inline') && ($('#aff-rate-inline').textContent = rate);
        $('#aff-rate-inline-2') && ($('#aff-rate-inline-2').textContent = rate);

        $('#aff-refcount') && ($('#aff-refcount').textContent = j.summary.referredCount || 0);
        $('#aff-orders') && ($('#aff-orders').textContent = j.summary.orders || 0);
        $('#aff-spent') && ($('#aff-spent').textContent = fmt(j.summary.spentTHB || 0));
        $('#aff-earn') && ($('#aff-earn').textContent = fmt(j.summary.earningsTHB || 0));

        // ยอดถอนได้ + ปุ่ม
        const wd = Number(j.summary.withdrawableTHB || 0);
        $('#aff-withdrawable') && ($('#aff-withdrawable').textContent = fmt(wd));
        // if (btn) btn.disabled = !(wd > 0.0001);

        // หลอดเลื่อนระดับ
        const t = j.tier || {};
        const cont = $('.aff-progress');
        const fill = $('#aff-tier-fill');
        const note = $('#aff-tier-note');

        const atMax = !!(t.atMax || rate >= 40);
        cont && cont.classList.toggle('max', atMax);

        if (atMax) {
          fill && (fill.style.width = '100%');
          note && (note.textContent = 'ระดับของคุณถึงระดับสูงสุดแล้ว');
        } else if (t) {
          const p = Math.max(0, Math.min(100, Number(t.progressPct || 0)));
          fill && (fill.style.width = p + '%');
          if (note && t.next) note.textContent = `ระดับถัดไป: ${t.next.rate}%`;
        }
      } finally {
        __loadingStats = false;
      }
    }

    function openTierModal(payload) {
      const next = payload?.tier?.next;
      const refs = payload?.summary?.referredCount || 0;
      const earn = payload?.summary?.earningsTHB || 0;

      let html;
      if (!next) {
        html = `<div class="modal"><div class="modal-body">
        <h3>ระดับสูงสุดแล้ว</h3>
        <p class="muted">คุณได้รับ 40% และไม่ต้องทำเงื่อนไขเพิ่มเติม</p>
        <div style="text-align:right;margin-top:12px"><button class="btn" id="tierClose">ปิด</button></div>
      </div></div>`;
      } else {
        const needRefs = Math.max(0, next.refs - refs);
        const needEarn = Math.max(0, next.earn - earn);
        html = `<div class="modal"><div class="modal-body">
        <h3>ระดับถัดไป ${next.rate}%</h3>
        <ul>
          <li>แนะนำเพิ่มอีก <b>${needRefs}</b> คน (เป้าหมาย ${next.refs})</li>
          <li>ยอดรายได้รวมถึง <b>฿${next.earn.toLocaleString()}</b>
              <small class="muted">(ขาดอีก ฿${needEarn.toLocaleString()})</small></li>
        </ul>
        <div style="text-align:right;margin-top:12px"><button class="btn" id="tierClose">ปิด</button></div>
      </div></div>`;
      }
      const wrap = document.createElement('div');
      wrap.className = 'modal-wrap';
      wrap.innerHTML = html;
      document.body.appendChild(wrap);
      wrap.addEventListener('click', e => {
        if (e.target.id === 'tierClose' || e.target === wrap) wrap.remove();
      });
    }

    // เปิดโมดัลจากข้อมูลล่าสุด ถ้าไม่มีค่อย fetch
    $('#aff-tier-pill')?.addEventListener('click', async () => {
      if (lastStats) return openTierModal(lastStats);
      try {
        const r = await fetch('/account/affiliate/stats');
        const j = await r.json();
        if (r.ok && j?.ok) openTierModal(j);
      } catch { }
    });

    window.loadAffStats = loadStats;

    loadStats();
  })();

  (() => {
    const titleEl = document.getElementById('acctPageTitle');
    const tabs = document.querySelectorAll('.tabs .tab');

    // อัปเดต H1 + document.title ตามแท็บที่ active
    function updateTitle() {
      const active = document.querySelector('.tabs .tab.active');
      const label = (active?.textContent || 'ตั้งค่าข้อมูลส่วนตัว').trim();
      if (titleEl) titleEl.textContent = label;
      // (ออปชัน) อัปเดต title ของแท็บเบราว์เซอร์ให้เข้ากัน
      document.title = `${label} — RTAUTOBOT`;
    }

    // ผูก event กับทุกแท็บ (ถ้าโค้ดเปลี่ยนแท็บของคุณมีอยู่แล้ว แทรกแค่ updateTitle() หลังจากสลับคลาส)
    tabs.forEach(btn => {
      btn.addEventListener('click', () => {
        // ถ้ามีโค้ดสลับแท็บเดิมอยู่แล้ว ไม่ต้องทำส่วน remove/add นี้ซ้ำ
        document.querySelectorAll('.tabs .tab').forEach(b => {
          b.classList.toggle('active', b === btn);
          b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
          b.setAttribute('tabindex', b === btn ? '0' : '-1');
        });
        updateTitle();
      });
    });

    // รองรับเปิดด้วยแฮช เช่น /account#tab-affiliate
    window.addEventListener('hashchange', updateTitle);

    // ตั้งค่าครั้งแรกเมื่อโหลดหน้า
    updateTitle();
  })();

  // สลับโชว์ลิงก์ถ้ามีคีย์อยู่แล้ว + ใช้ https:
  (() => {
    const key = <%- JSON.stringify(userDoc.affiliateKey || null).replace(/</g, '\\u003c') %>;
    if (key) {
      const link = `https://rtautobot.com/aff?=${key}`;
      const create = document.getElementById('aff-create-area');
      const area = document.getElementById('aff-link-area');
      const out = document.getElementById('aff-link');
      if (create && area && out) {
        create.hidden = true; area.hidden = false; out.textContent = link;
      }
    }
  })();
</script>

<script>
  (() => {
    // ดึงค่าลิงก์จาก #aff-link (รองรับ data-href หรือ textContent)
    function getAffLink() {
      const el = document.getElementById('aff-link');
      if (!el) return '';
      return (el.dataset.href || el.textContent || '').trim();
    }

    // คัดลอกด้วย Clipboard API พร้อม fallback execCommand
    async function copyToClipboard(text) {
      if (!text) return false;
      try {
        await navigator.clipboard.writeText(text);
        return true;
      } catch {
        try {
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.setAttribute('readonly', '');
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.focus();
          ta.select();
          const ok = document.execCommand('copy');
          ta.remove();
          return ok;
        } catch {
          return false;
        }
      }
    }

    // แสดงผลลัพธ์ + feedback ปุ่ม
    function showFeedback(ok, btn) {
      if (window.showMsg) {
        window.showMsg({
          variant: ok ? 'success' : 'error',
          title: ok ? 'คัดลอกแล้ว' : 'คัดลอกไม่สำเร็จ',
          text: ok ? 'ลิงก์ถูกคัดลอกไปยังคลิปบอร์ดเรียบร้อย' : 'โปรดลองอีกครั้ง'
        });
      } else {
        alert(ok ? 'คัดลอกแล้ว' : 'คัดลอกไม่สำเร็จ');
      }

      if (btn) {
        const old = btn.textContent;
        btn.textContent = ok ? 'คัดลอกแล้ว ✓' : 'คัดลอกลิงก์';
        btn.disabled = true;
        setTimeout(() => { btn.textContent = old; btn.disabled = false; }, 1200);
      }
    }

    // จัดการคลิกคัดลอกจากปุ่ม
    async function handleCopyClick(e) {
      e.preventDefault();
      const link = getAffLink();
      const ok = await copyToClipboard(link);
      showFeedback(ok, e.currentTarget);
    }

    // ติดตั้ง event ให้ปุ่มและช่องลิงก์ (รองรับกรณี UI เพิ่งถูกสลับมาแสดง)
    function bindCopyHandlers() {
      const btn = document.getElementById('btnCopyAff');
      if (btn && !btn.__copyBound) {
        btn.addEventListener('click', handleCopyClick);
        btn.__copyBound = true;
      }
      const field = document.getElementById('aff-link');
      if (field && !field.__copyBound) {
        field.addEventListener('click', async () => {
          const ok = await copyToClipboard(getAffLink());
          showFeedback(ok);
        });
        field.title = field.title || 'คลิกเพื่อคัดลอก';
        field.style.cursor = field.style.cursor || 'pointer';
        field.__copyBound = true;
      }
    }

    // ผูกครั้งแรก
    bindCopyHandlers();

    // เฝ้าดู #aff-link-area เผื่อส่วนลิงก์ถูกเปลี่ยน DOM ภายหลัง (เช่น หลัง "สร้างลิงก์")
    const area = document.getElementById('aff-link-area');
    if (area) {
      const mo = new MutationObserver(bindCopyHandlers);
      mo.observe(area, { childList: true, subtree: true });
    }
  })();
</script>

<script>
  // ===== ถอนรายได้ (เปิด Modal เลือกประเภท) =====
  (() => {
    const $ = s => document.querySelector(s);
    const fmt = n => Number(n || 0).toLocaleString(undefined, { maximumFractionDigits: 2 });
    const modal = $('#affWithdrawModal');
    const btnOpen = $('#btnAffWithdraw');
    const btnConfirm = $('#affWConfirm');
    const kindField = $('#affWKind');

    function setActive(kind) {
      kind = (kind === 'cash') ? 'cash' : 'balance';
      kindField.value = kind;
      document.querySelectorAll('#affWithdrawModal .affw-option').forEach(el => {
        const on = el.dataset.kind === kind;
        el.classList.toggle('is-active', on);
        el.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
    }

    // bind click ให้การ์ดตัวเลือก
    document.addEventListener('click', (e) => {
      const el = e.target.closest('#affWithdrawModal .affw-option');
      if (!el) return;
      setActive(el.dataset.kind);
    });

    async function doWithdraw(kind) {
      try {
        const r = await fetch('/account/affiliate/withdraw', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: kind })
        });
        const j = await r.json();

        if (!r.ok || !j?.ok) { fail(j?.error || 'ถอนรายได้ไม่สำเร็จ'); return; }

        if (kind === 'balance') ok(`เพิ่มยอดกระเป๋าแล้ว ฿${fmt(j.addedBalance || 0)}`);
        else ok('บันทึกการถอนแบบเงินสดแล้ว');

        await (window.loadAffStats?.());
        await (window.affWSetPage?.(1));
        await (window.renderAffWithdraws?.());
      } catch { fail('เครือข่ายมีปัญหา โปรดลองใหม่'); }
    }

    btnOpen?.addEventListener('click', e => {
      e.preventDefault();
      if (btnOpen.disabled) return;
      btnOpen.disabled = true;                 /* ป้องกันดับเบิลคลิก */
      try {
        setActive(kindField?.value || 'balance');
        if (typeof modal?.showModal === 'function') modal.showModal();
        else {
          const kind = confirm('ถอนเป็นเครดิต (OK) ? ยกเลิก = เงินสด') ? 'balance' : 'cash';
          doWithdraw(kind);
        }
      } finally {
        // เปิดโมดัลแล้วค่อยคืนค่า เพื่อกันคลิกซ้ำก่อน modal โผล่
        setTimeout(() => { btnOpen.disabled = false; }, 250);
      }
    });

    btnConfirm?.addEventListener('click', async (e) => {
      e.preventDefault();
      const kind = (kindField?.value === 'cash') ? 'cash' : 'balance';
      modal?.close();
      await doWithdraw(kind);
    });
  })();
</script>

<script>
  (() => {
    const $ = s => document.querySelector(s);
    const listTbody = $('#aff-list');
    const listMobile = $('#aff-list-mobile');
    const emptyEl = $('#aff-empty');
    const pageInfo = $('#aff-pageinfo');
    const btnPrev = $('#aff-prev');
    const btnNext = $('#aff-next');
    const selPerPage = $('#aff-perpage');        // select เดิม (ซ่อนไว้)
    // องค์ประกอบของดรอปดาวน์ใหม่
    const ddBtn = document.getElementById('perpageBtn');
    const ddMenu = document.getElementById('perpageMenu');
    const ddLabel = document.getElementById('perpageLabel');

    // ---------- state ----------
    let currentPage = 1;
    let totalPages = 1;

    const tFmt = new Intl.DateTimeFormat('th-TH', {
      dateStyle: 'medium',
      timeStyle: 'short',
      timeZone: 'Asia/Bangkok'
    });

    const fmtTH = n => Number(n || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const kindBadge = k => k === 'balance' ? 'เครดิต' : 'เงินสด';
    const statusBadge = s => s === 'success'
      ? '<span class="badge st-success">สำเร็จ</span>'
      : '<span class="badge st-fail">ล้มเหลว</span>';

    async function fetchWithdraws(page = 1, perPage = 10) {
      const r = await fetch(`/account/affiliate/withdraws?page=${page}&perPage=${perPage}`);
      const j = await r.json();
      if (!r.ok || !j?.ok) throw new Error('fetch failed');
      return j;
    }

    function renderDesktop(items) {
      if (!listTbody) return;
      listTbody.innerHTML = items.map(it => `
      <tr>
        <td>${tFmt.format(new Date(it.createdAt))}</td>
        <td style="text-align:right">฿${fmtTH(it.amount)}</td>
        <td style="text-align:center"><span class="badge kind">${kindBadge(it.kind)}</span></td>
        <td style="text-align:center">${statusBadge(it.status)}</td>
      </tr>
    `).join('');
    }

    function renderMobile(items) {
      if (!listMobile) return;
      listMobile.innerHTML = items.map(it => `
      <div class="affw-item">
        <div class="affw-hd" onclick="this.parentElement.classList.toggle('open')">
          <div class="affw-ttl">${tFmt.format(new Date(it.createdAt))}</div>
          <div><span class="badge kind">${kindBadge(it.kind)}</span></div>
        </div>
        <div class="affw-body">
          <div class="kv"><div>ยอดเงิน</div><div>฿${fmtTH(it.amount)}</div></div>
          <div class="kv"><div>สถานะ</div><div>${statusBadge(it.status)}</div></div>
        </div>
      </div>
    `).join('');
    }

    async function renderWithdraws() {
      const per = Number(selPerPage?.value || 10);
      try {
        const j = await fetchWithdraws(currentPage, per);
        const items = Array.isArray(j.items) ? j.items : [];
        totalPages = Math.max(1, Math.ceil((j.total || 0) / (j.perPage || per)));

        // toggle empty
        const isEmpty = items.length === 0;
        if (emptyEl) emptyEl.style.display = isEmpty ? '' : 'none';

        renderDesktop(items);
        renderMobile(items);

        if (pageInfo) pageInfo.textContent = `หน้า ${currentPage}/${totalPages}`;
        if (btnPrev) btnPrev.disabled = currentPage <= 1;
        if (btnNext) btnNext.disabled = currentPage >= totalPages;
      } catch {
        if (emptyEl) emptyEl.style.display = '';
        if (listTbody) listTbody.innerHTML = '';
        if (listMobile) listMobile.innerHTML = '';
        if (pageInfo) pageInfo.textContent = `หน้า 1/1`;
        if (btnPrev) btnPrev.disabled = true;
        if (btnNext) btnNext.disabled = true;
      }
    }

    // ---------- page events ----------
    btnPrev?.addEventListener('click', async () => {
      if (currentPage > 1) {
        currentPage -= 1;
        await renderWithdraws();
      }
    });
    btnNext?.addEventListener('click', async () => {
      if (currentPage < totalPages) {
        currentPage += 1;
        await renderWithdraws();
      }
    });
    selPerPage?.addEventListener('change', async () => {
      currentPage = 1;
      // sync ป้ายบนปุ่มด้วย (กันกรณีมีการเปลี่ยนจากภายนอก)
      if (ddLabel) ddLabel.textContent = selPerPage.value;
      // sync aria-selected ของเมนู
      if (ddMenu) {
        [...ddMenu.children].forEach(li =>
          li.setAttribute('aria-selected', li.dataset.val === selPerPage.value ? 'true' : 'false')
        );
      }
      await renderWithdraws();
    });

    // ---------- Custom dropdown binding ----------
    function openMenu() {
      const rect = ddBtn.getBoundingClientRect();
      ddMenu.style.minWidth = rect.width + 'px';
      ddMenu.style.left = rect.left + 'px';
      ddMenu.style.top = rect.bottom + 'px';
      ddMenu.classList.add('show');
      ddBtn.setAttribute('aria-expanded', 'true');
    }
    function closeMenu() {
      ddMenu.classList.remove('show');
      ddBtn.setAttribute('aria-expanded', 'false');
    }

    if (ddBtn && ddMenu && ddLabel && selPerPage) {
      // init
      const initVal = selPerPage.value || '10';
      ddLabel.textContent = initVal;
      [...ddMenu.children].forEach(li =>
        li.setAttribute('aria-selected', li.dataset.val === initVal ? 'true' : 'false')
      );

      ddBtn.addEventListener('click', (e) => {
        e.preventDefault();
        ddMenu.classList.contains('show') ? closeMenu() : openMenu();
      });

      ddMenu.addEventListener('click', (e) => {
        const li = e.target.closest('li[role="option"]');
        if (!li) return;
        const v = li.dataset.val;
        ddLabel.textContent = v;
        [...ddMenu.children].forEach(x => x.setAttribute('aria-selected', 'false'));
        li.setAttribute('aria-selected', 'true');
        closeMenu();
        // sync -> select เดิม + trigger change
        if (selPerPage.value !== v) {
          selPerPage.value = v;
          selPerPage.dispatchEvent(new Event('change', { bubbles: true }));
        }
      });

      // ปิดเมื่อคลิกนอก/กด ESC/เลื่อน/รีไซส์
      document.addEventListener('click', (e) => { if (!e.target.closest('.perpage-dd')) closeMenu(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
      window.addEventListener('scroll', () => ddMenu.classList.contains('show') && closeMenu(), true);
      window.addEventListener('resize', () => ddMenu.classList.contains('show') && closeMenu());
    }

    // ---------- expose & first render ----------
    window.renderAffWithdraws = renderWithdraws;
    window.affWSetPage = (p = 1) => {
      currentPage = Math.max(1, Number(p) || 1);
      renderWithdraws();
    };

    renderWithdraws();
  })();
