    chipBar.addEventListener('click', (e) => {
      window.RTSMM_ORDER_PAGE?.onChip?.(e);
    });
  }

  // ถ้าไม่มีอะไรเลยก็ไม่ต้องทำ
  if (!filtersBar && !searchWrap && !searchInput) return;

  function resetChipToAll() {
    if (window.RTSMM_ORDER_PAGE?.resetChipToAll) {
      window.RTSMM_ORDER_PAGE.resetChipToAll();
    }
  }

  // คลิกที่โซน search (ไม่รวมชิป) -> reset เป็น "ทั้งหมด"
  if (filtersBar) {
    filtersBar.addEventListener('click', (e) => {
      const inSearchArea =
        e.target.closest('.search-all-wrap') ||
        e.target.id === 'searchAll';

      if (!inSearchArea) return;
      resetChipToAll();
    });
  }

  // โฟกัสที่ input ค้นหา -> ก็ reset ด้วย (กันคลิกจาก icon ฯลฯ)
  if (searchInput) {
    searchInput.addEventListener('focus', resetChipToAll);
  }
});
</script>

<script>
document.addEventListener('click', (e) => {
  const btn = e.target.closest('.tab');
  if (!btn) return;

  const tab = btn.dataset.tab;

  // ===== กรณี TAB 2 → Redirect ไป /my/orders =====
  if (tab === 'history') {
    window.location.href = '/my/orders';
    return;
  }

  // ===== เปลี่ยนแท็บปกติ (TAB 1) =====
  document.querySelectorAll('.tab').forEach(t =>
    t.classList.remove('active')
  );
  btn.classList.add('active');

  document.querySelectorAll('.tabpane').forEach(p =>
    p.classList.remove('show')
  );
  document.getElementById('tab-' + tab).classList.add('show');
});
</script>

