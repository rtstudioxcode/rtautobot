<script>
// ✅ local wrapper: ใช้ชื่อ notify ในไฟล์นี้โดยไม่พึ่ง window.notify
const notify = (opts = {}) => {
  const { variant='info', title='ข้อความ', text='' } = opts || {};
  // ถ้ามี window.notify ที่เป็นฟังก์ชัน ให้เรียกอันนั้น
  if (typeof window.notify === 'function') {
    return window.notify({ variant, title, text });
  }
  // ถ้ามี showMsg (ของ dialog) ก็ใช้ได้
  if (typeof window.showMsg === 'function') {
    return window.showMsg({ variant, title, text });
  }
  // fallback สุดท้าย
  alert((title ? title + '\n' : '') + (text || ''));
};
</script>

<script>
// =========================
// ⚡ CONFIG + GLOBALS
// =========================
const CACHE_TTL = 24 * 60 * 60 * 1000; // 24 ชม.
const CACHE_REVALIDATE_AFTER = 30 * 60 * 1000; // อย่า SWR ทุก refresh ลด network origin
let CACHE_VERSION = window.__CACHE_VERSION__ || "v1";

const MEMORY_CACHE = new Map();
const PENDING_FETCH = new Map();
const MAX_MEMORY_ITEMS = 150;

// =========================
// 🔑 LOAD CACHE VERSION
// =========================
async function initCacheVersion() {
  try {
    const res = await fetch('/api/cache-version');
    const json = await res.json();
    if (json?.version) {
      CACHE_VERSION = String(json.version);
      // console.log("🔑 CACHE_VERSION:", CACHE_VERSION);
    }
  } catch (e) {
    // console.warn("cache version fallback");
  }
}

// =========================
// 🧠 KEY (07:03 + VERSION)
// =========================
function getServiceCacheKey(url) {
  const now = new Date();

  if (
    now.getHours() < 7 ||
    (now.getHours() === 7 && now.getMinutes() < 3)
  ) {
    now.setDate(now.getDate() - 1);
  }

  const dateKey = now.toISOString().slice(0, 10);

  // 🔥 สำคัญ: ใส่ version
  return `${url}:v=${CACHE_VERSION}:${dateKey}`;
}

// =========================
// ⚡ MEMORY CACHE (LRU)
// =========================
function setMemoryCache(key, value) {
  if (MEMORY_CACHE.size >= MAX_MEMORY_ITEMS) {
    const firstKey = MEMORY_CACHE.keys().next().value;
    MEMORY_CACHE.delete(firstKey);
  }
  MEMORY_CACHE.set(key, value);
}

// =========================
// 📦 IndexedDB (L2)
// =========================
const DB_NAME = "rt_cache_db";
const STORE = "api_cache";

function openDB() {
  return new Promise((resolve, reject) => {
    const req = indexedDB.open(DB_NAME, 1);
    req.onupgradeneeded = () => {
      req.result.createObjectStore(STORE);
    };
    req.onsuccess = () => resolve(req.result);
    req.onerror = () => reject(req.error);
  });
}

async function idbGet(key) {
  const db = await openDB();
  return new Promise((resolve) => {
    const tx = db.transaction(STORE, "readonly");
    const store = tx.objectStore(STORE);
    const req = store.get(key);
    req.onsuccess = () => resolve(req.result || null);
    req.onerror = () => resolve(null);
  });
}

async function idbSet(key, value) {
  const db = await openDB();
  return new Promise((resolve) => {
    const tx = db.transaction(STORE, "readwrite");
    const store = tx.objectStore(STORE);
    store.put(value, key);
    tx.oncomplete = () => resolve(true);
    tx.onerror = () => resolve(false);
  });
}

// =========================
// ♻️ SWR REVALIDATE
// =========================
function revalidate(url, key) {
  if (PENDING_FETCH.has(key)) return;

  setTimeout(async () => {
    try {
      const res = await fetch(url);
      if (!res.ok) return;

      const data = await res.json();

      setMemoryCache(key, data);

      const payload = { data, ts: Date.now() };
      const str = JSON.stringify(payload);

      if (str.length > 400_000) {
        await idbSet(key, payload);
      } else {
        localStorage.setItem(key, str);
      }

      // console.log("♻️ revalidated:", key);
    } catch {}
  }, 1000);
}

// =========================
// 🧹 CLEANUP
// =========================
function cleanupLocalStorage() {
  try {
    const keys = Object.keys(localStorage).filter(k => k.includes(':v='));
    const removeCount = Math.floor(keys.length / 2);

    for (let i = 0; i < removeCount; i++) {
      localStorage.removeItem(keys[i]);
    }

    // console.warn("🧹 cleaned localStorage:", removeCount);
  } catch {}
}

// =========================
// 🚀 FETCH CACHED (FULL SWR)
// =========================
async function fetchCached(url) {
  const key = getServiceCacheKey(url);

  // ⚡ MEMORY
  if (MEMORY_CACHE.has(key)) {
    return MEMORY_CACHE.get(key);
  }

  // 🟣 IDB
  try {
    const idbVal = await idbGet(key);
    if (idbVal && idbVal.data && Date.now() - idbVal.ts < CACHE_TTL) {
      setMemoryCache(key, idbVal.data);
      if (Date.now() - idbVal.ts > CACHE_REVALIDATE_AFTER) revalidate(url, key);
      return idbVal.data;
    }
  } catch {}

  // 🟢 localStorage
  const raw = localStorage.getItem(key);
  if (raw) {
    try {
      const parsed = JSON.parse(raw);
      if (parsed?.data && Date.now() - parsed.ts < CACHE_TTL) {
        setMemoryCache(key, parsed.data);
        if (Date.now() - parsed.ts > CACHE_REVALIDATE_AFTER) revalidate(url, key);
        return parsed.data;
      } else {
        localStorage.removeItem(key);
      }
    } catch {
      localStorage.removeItem(key);
    }
  }

  // 🚫 dedupe
  if (PENDING_FETCH.has(key)) {
    return PENDING_FETCH.get(key);
  }

  // 🔴 FETCH
  const fetchPromise = (async () => {
    try {
      const res = await fetch(url);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const data = await res.json();

      setMemoryCache(key, data);

      const payload = { data, ts: Date.now() };
      const str = JSON.stringify(payload);

      try {
        if (str.length > 400_000) {
          await idbSet(key, payload);
        } else {
          localStorage.setItem(key, str);
        }
      } catch {
        cleanupLocalStorage();
        try { await idbSet(key, payload); } catch {}
      }

      return data;
    } finally {
      PENDING_FETCH.delete(key);
    }
  })();

  PENDING_FETCH.set(key, fetchPromise);
  return fetchPromise;
}

// =========================
// 🚀 INIT (สำคัญมาก)
// =========================
(async () => {
  await initCacheVersion(); // 🔥 โหลด version ก่อนใช้ cache
})();
</script>

<script>
// === หน่วยคำนวณตาม DB (เลิกยึด 1/1000 ตายตัว) ===
let currentUnitStep = 1000; // หน่วยที่ใช้คำนวณ ณ ตอนนี้

function isPerPiece(obj = {}) {
  const type = String(obj.type || '').toLowerCase();
  const step = Number(obj.step ?? NaN);
  const min  = Number(obj.min  ?? NaN);
  const max  = Number(obj.max  ?? NaN);
  // “แบบชิ้นเดียว” หรือแพ็กเกจ -> ต่อ 1 ชิ้น
  return (type === 'package') || (step === 1) || (min === 1 && max === 1);
}
function pickUnitStepFromSvc(svc = {}) {
  if (isPerPiece(svc)) return 1;
  if (Number.isFinite(+svc.step) && +svc.step > 0) return +svc.step;
  return 1000; // fallback เดิม
}

function unitLabel(u){ return (u <= 1 ? '1' : u.toLocaleString()); }
</script>

<script>
