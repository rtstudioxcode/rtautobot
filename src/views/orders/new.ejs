  /* ---------- รายการบริการย่อย ---------- */
  function computeUnitForService(c) {
    return Number(c.rateUnit || 1000);
  }

  function renderChildList(){
    const q = ($('#childSearch').value || '').toLowerCase().trim();
    const globalQ = ($('#searchAll').value || '').toLowerCase().trim();

    const list = children.filter(c=>{
      const s = `${c.id} ${c.name}`.toLowerCase();
      return (!q || s.includes(q)) && (!globalQ || s.includes(globalQ));
    });

    const gid = $('#groupId').value;

    // ใส่ base rate ไว้ก่อน
    $('#childList').innerHTML = list.length ? list.map(c => {
      const u = Number(c.rateUnit || 1000);
      const unitStr = (u <= 1 ? '1' : u.toLocaleString());
      return `
        <div class="opt" data-id="${c.id}">
          <div class="row">
            <div>
              <span class="id">ID: ${c.id}</span>
              <span class="name"> — ${c.name || ''}</span>
            </div>
            <div class="rate" data-rate-for="${c.id}">
              ${fmt(c.rate)} ${c.currency || 'THB'} / ${u.toLocaleString()}
            </div>
          </div>
        </div>`;
    }).join('') : `<div class="empty muted">ไม่พบบริการที่ตรงกับคำค้น</div>`;

    // แล้วค่อยอัปเดตเป็น effective rate ทีละตัว — ใช้ cache ก่อน ยิง API เฉพาะตัวที่ยังไม่มี
    (async () => {
      const gid = $('#groupId').value;
      const miss = [];
      list.forEach(c => {
        const cached = getCachedEffectiveRate(gid, c.id);
        const el = document.querySelector(`.rate[data-rate-for="${CSS.escape(String(c.id))}"]`);
        if (cached != null) {
          if (el) {
            const u = Number(c.rateUnit || 1000);
            const unitStr = (u <= 1 ? '1' : u.toLocaleString());
            el.textContent = `${fmt(cached)} ${c.currency || 'THB'} / ${unitStr}`;
          }
        } else {
          miss.push(c);
        }
      });
      if (!miss.length) return;

      const requestKey = `${gid}:${miss.map(c => c.id).join(',')}`;
      if (effectiveRatePending.has(requestKey)) return effectiveRatePending.get(requestKey);

      const job = (async () => {
        const items = miss.map(c => ({ serviceId: gid, childId: String(c.id), qty: 0 }));
        try {
          const res = await fetch('/api/pricing/effective-rate/batch', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items })
          });
          const json = await res.json().catch(() => ({}));
          if (!json.ok) return;
          const rates = json.rates || {};
          miss.forEach(c => {
            const erObj = rates[`${gid}:${c.id}:0`];
            if (!erObj || erObj.rate == null) return;
            const rateValue = Number(erObj.rate);
            setCachedEffectiveRate(gid, c.id, rateValue);
            const el = document.querySelector(`.rate[data-rate-for="${CSS.escape(String(c.id))}"]`);
            if (el) {
              const u = Number(c.rateUnit || 1000);
              const unitStr = (u <= 1 ? '1' : u.toLocaleString());
              el.textContent = `${fmt(rateValue)} ${c.currency || 'THB'} / ${unitStr}`;
            }
          });
        } catch {}
        finally { effectiveRatePending.delete(requestKey); }
      })();
      effectiveRatePending.set(requestKey, job);
      return job;
    })();

    $('#childList').onclick = e=>{
      const el=e.target.closest('.opt'); if(!el) return;
      $('#childSel').classList.remove('open');
      $('#childBtn').setAttribute('aria-expanded','false');
      const svc = children.find(v=>String(v.id)===el.dataset.id);
      chooseChild(svc);
    };
  }

  // ✅ โหลด service-groups ของทุกแพลตฟอร์มเข้า groupsByPlatform ให้ครบก่อนค้นหา
  async function ensureAllGroupsLoaded() {
    if (allGroupsLoaded) return;
    if (!Array.isArray(platforms) || !platforms.length) return;

    const jobs = platforms.map(async (p) => {
      const key = String(p._id);
      if (groupsByPlatform.has(key)) return; // โหลดแล้วข้าม

      try {
        const res = await fetchCached(`/api/service-groups?cat=${key}`);
        const data = await res.json();
        if (Array.isArray(data)) {
          groupsByPlatform.set(key, data);
        } else {
          groupsByPlatform.set(key, []);
        }
      } catch (e) {
        // console.error('load groups for', key, 'error', e);
        groupsByPlatform.set(key, []);
      }
    });

    await Promise.all(jobs);
    allGroupsLoaded = true;
  }

  function renderSearchChunk(reset = false) {
    const box = document.getElementById('searchSuggest');
    if (!box) return;
    if (reset) {
      box.innerHTML = '';
      searchRendered = 0;
    }

    // ถ้าแสดงครบแล้วก็ไม่ต้องทำอะไร
    if (searchRendered >= searchResults.length) return;

    const slice = searchResults.slice(
      searchRendered,
      searchRendered + SEARCH_CHUNK_SIZE
    );

    const html = slice.map(r => {
      let kindClass = 'sg-kind-s';
      let kindLabel = 'บริการ';
      let iconHtml = '';

      if (r.kind === 'platform') {
        kindClass = 'sg-kind-p';
        kindLabel = 'แพลตฟอร์ม';
      } else if (r.kind === 'group') {
        kindClass = 'sg-kind-g';
        kindLabel = 'หมวดหมู่';

        // icon กลุ่ม (เหมือนเดิม)
        const grpArr = groupsByPlatform.get(r.platformId) || [];
        const gObj = grpArr.find(g => String(g._id) === String(r.groupId));
        const iconUrl = gObj ? pickGroupIcon(gObj) : null;
        if (iconUrl) {
          iconHtml = `<img class="sg-icon" src="${iconUrl}" alt="">`;
        }
      }

      const labelSafe = r.label.replace(/"/g, '&quot;');

      return `
        <button type="button"
                class="sg-opt"
                data-kind="${r.kind}"
                data-platform="${r.platformId || ''}"
                data-group="${r.groupId || ''}"
                data-service="${r.serviceId || ''}">
          ${iconHtml}
          <span class="sg-kind ${kindClass}">${kindLabel}</span>
          <span class="sg-main" title="${labelSafe}">${r.label}</span>
          ${r.sub ? `<span class="sg-sub">${r.sub}</span>` : ''}
        </button>
      `;
    }).join('');

    box.insertAdjacentHTML('beforeend', html);
    searchRendered += slice.length;
  }

  async function runGlobalSearchDropdown(query) {
    const box = document.getElementById('searchSuggest');
    if (!box) return;

    const q = String(query || '').trim().toLowerCase();
    if (q.length < 2) {
      box.hidden = true;
      box.innerHTML = '';
      searchResults = [];
      searchRendered = 0;
      return;
    }

    const results = [];

    // 1) แพลตฟอร์ม
    for (const p of platforms) {
      if ((p.name || '').toLowerCase().includes(q)) {
        results.push({
          kind: 'platform',
          platformId: String(p._id),
          label: p.name || '',
        });
      }
    }

    // 2) หมวดหมู่/บริการทุกแพลตฟอร์ม (ไม่จำกัดแค่ current)
    groupsByPlatform.forEach((grpArr, platId) => {
      const platName = getPlatformNameById(platId);

      grpArr.forEach(g => {
        const gName = g?.name || '';
        const gNameLower = gName.toLowerCase();

        if (gNameLower.includes(q)) {
          results.push({
            kind: 'group',
            platformId: String(platId),
            groupId: String(g._id),
            label: gName,
            sub: platName || ''
          });
        }

        const svcList = Array.isArray(g?.details?.services) ? g.details.services : [];
        svcList.forEach(svc => {
          const text = `${svc.id} ${svc.name || ''}`.toLowerCase();
          if (text.includes(q)) {
            results.push({
              kind: 'service',
              platformId: String(platId),
              groupId: String(g._id),
              serviceId: String(svc.id),
              label: `ID: ${svc.id} — ${svc.name || ''}`,
              sub: gName || platName || ''
            });
          }
        });
      });
    });

    if (!results.length) {
      box.innerHTML = `<div class="sg-empty muted">ไม่พบผลลัพธ์ที่ตรงกับคำค้น</div>`;
      box.hidden = false;
      searchResults = [];
      searchRendered = 0;
      return;
    }

    // ✅ เก็บผลไว้ global แล้วให้ render ทีละก้อน
    searchResults = results;
    box.hidden = false;
    renderSearchChunk(true);
  }

  function filterChildrenFromGlobal(){ renderChildList(); }
  let effectiveRateCache = new Map();
  const EFFECTIVE_RATE_CACHE_TTL = 6 * 60 * 60 * 1000;
  const EFFECTIVE_RATE_LS_PREFIX = 'rtsmm:effective-rate:';
  const effectiveRatePending = new Map();

  function rateCacheKey(groupId, childId){
    return `${groupId}:${childId}`;
  }
  function getCachedEffectiveRate(groupId, childId){
    const key = rateCacheKey(groupId, childId);
    if (effectiveRateCache.has(key)) return effectiveRateCache.get(key);
    try {
      const raw = localStorage.getItem(EFFECTIVE_RATE_LS_PREFIX + key);
      if (!raw) return null;
      const row = JSON.parse(raw);
      if (!row || Date.now() - Number(row.ts || 0) > EFFECTIVE_RATE_CACHE_TTL) {
        localStorage.removeItem(EFFECTIVE_RATE_LS_PREFIX + key);
        return null;
      }
      const val = Number(row.rate);
      if (!Number.isFinite(val)) return null;
      effectiveRateCache.set(key, val);
      return val;
    } catch { return null; }
  }
  function setCachedEffectiveRate(groupId, childId, rate){
    const val = Number(rate);
    if (!Number.isFinite(val)) return;
    const key = rateCacheKey(groupId, childId);
    effectiveRateCache.set(key, val);
    try { localStorage.setItem(EFFECTIVE_RATE_LS_PREFIX + key, JSON.stringify({ rate: val, ts: Date.now() })); } catch {}
  }


  document.addEventListener('click', async (e) => {
    const box = document.getElementById('searchSuggest');
    if (!box) return;

    const btn = e.target.closest('.sg-opt');
    if (btn && box.contains(btn)) {
      const kind = btn.dataset.kind;
      const platformId = btn.dataset.platform;
      const groupId = btn.dataset.group;
      const serviceId = btn.dataset.service;

      // ซ่อน dropdown ก่อน
      box.hidden = true;

      if (kind === 'platform') {
        await ensurePlatformSelected(platformId);
        return;
      }

      if (kind === 'group') {
        await ensurePlatformSelected(platformId);
        const grpArr = groupsByPlatform.get(String(platformId)) || groups;
        const gObj = grpArr.find(g => String(g._id) === String(groupId));
        if (gObj) chooseGroup(gObj);
        return;
      }

      if (kind === 'service') {
        // ใช้ตัวช่วยเดิมที่มี already: autoPickByServiceId
        if (serviceId) {
          // จะวิ่งหา service ทุกแพลตฟอร์มให้เอง
          await autoPickByServiceId(serviceId);
        }
        return;
      }
    } else {
      // คลิกรอบนอก -> ปิด
      if (!box.contains(e.target) && e.target.id !== 'searchAll') {
        box.hidden = true;
      }
    }
  });

  /* ---------- ดึง effective rate (ถ้า endpoint มี) ---------- */
  async function fetchEffectiveRateIfAvailable(groupId, childId, baseRate) {
    const cached = getCachedEffectiveRate(groupId, childId);
    if (cached != null) return cached;

    try {
      const url = `/api/pricing/effective-rate?serviceId=${encodeURIComponent(groupId)}&childId=${encodeURIComponent(childId)}`;
      const data = await fetchCached(url);
      if (!data || data.rate == null) return null;
      setCachedEffectiveRate(groupId, childId, data.rate);
      return Number(data.rate);
    } catch (e) {
      return null;
    }
  }

  /* ---------- รายละเอียด/ฟอร์ม ---------- */
  async function chooseChild(svc){
    currentChild = svc;
    currentUnitStep = Number(svc.rateUnit || 1000);

    // ===============================
    // 🔒 ตรวจว่าเป็น service ราคา/ชิ้น
    // ===============================
    isPerPieceService =
      currentUnitStep === 1 &&
      Number(svc.min) === 1 &&
      Number(svc.max) === 1;

    $('#childText').textContent = svc?.name || '—';
    $('#providerServiceId').value = svc?.id || '';

    // base rate
    rate     = Number(svc?.rate || 0);
    currency = svc?.currency || 'THB';
    effectiveRate = null;
    rateSource = 'base';
    $('#rateNote').style.display = 'none';

    const gid = $('#groupId').value;
    const cid = String(svc?.id || '');
    const er = await fetchEffectiveRateIfAvailable(gid, cid, Number(svc.rate || 0));
    if (er !== null) {
      effectiveRate = er;
      rateSource = 'effective';
      $('#rateNote').style.display = '';
      $('#rateNote').textContent =
        `อัตรานี้เป็นราคาหลังปรับตามกฎของบัญชีคุณ (ต่อ ${currentUnitStep.toLocaleString()} หน่วย)`;
    }

    const displayRate = rateSource==='effective' ? effectiveRate : rate;

    const bits = [];
    const unit = Number(svc.rateUnit || currentUnitStep || 1000);
    bits.push(`อัตรา: ${fmt(displayRate)} ${currency} / ${unit.toLocaleString()}`);
    bits.push(`ช่วง: ${svc.min||0}-${svc.max||0}${svc.step? ' | ขั้นละ '+svc.step: ''}`);
    if (svc.average_delivery) bits.push(`เฉลี่ย: ${svc.average_delivery}`);
    if (svc.dripfeed) bits.push('Dripfeed');
    if (svc.refill)   bits.push('Refill');
    if (svc.cancel)   bits.push('ยกเลิกได้');

    $('#hdr').textContent  = svc?.name || '';
    $('#meta').textContent = bits.join(' | ');
    const rawDesc = svc?.description || currentGroup?.description || '';
    $('#desc').innerHTML = sanitizeDesc(renderDescText(rawDesc));

    const q    = $('#qty');
    const min  = Math.max(1, Number(svc.min || 1));
    const max  = Math.max(min, Number(svc.max || min));
    const step = Number(svc.step || 1);

    const qtyWrap = q.closest('.with-hint');

    currentMin = min;
    currentMax = max;

    // ===== ราคา/ชิ้น → ล็อก qty =====
    if (isPerPieceService) {
      q.value = '1';
      q.readOnly = true;
      q.style.display = 'none';
      if (qtyWrap) qtyWrap.style.display = 'none';
    } else {
      q.readOnly = false;
      q.style.display = '';
      if (qtyWrap) qtyWrap.style.display = '';
      q.value = '';
    }
    // q.placeholder = `เช่น ${min.toLocaleString()} – ${max.toLocaleString()}`;

    const minVal = $('#minVal'), maxVal = $('#maxVal');
    if (minVal) minVal.textContent = min.toLocaleString();
    if (maxVal) maxVal.textContent = max.toLocaleString();

    const debouncedEstimate = debounce(() => {
      // ราคา effective rate ถูก cache แยกแล้ว ปริมาณเปลี่ยนให้คำนวณยอดรวมบนหน้าเว็บเท่านั้น
      updateEstimate();
    }, 300);

    q.removeEventListener('input', updateEstimate);
    q.addEventListener('input', debouncedEstimate);

    $('#drip').disabled = !svc.dripfeed;
    $('#drip').checked  = !!svc.dripfeed;

    // 👇 ตรวจชื่อ service เพื่อตัดสินว่าเป็น comments/SEO ไหม
    const svcName = (svc?.name || "").toLowerCase();

    isCommentService =
      svcName.includes("custom comment") ||
      svcName.includes("custom comments") ||
      svcName.includes("comment package") ||
      svcName.includes("comment reply") ||
      (svc?.type && String(svc.type).toLowerCase().includes("comment"));

    isSeoService =
      svcName.includes("seo") ||
      svcName.includes("keyword") ||
      (svc?.type && String(svc.type).toLowerCase().includes("seo"));

    const commentBoxEl = document.getElementById("commentBox");
    const keywordBoxEl = document.getElementById("keywordBox");
    const qtyLabelWrap = q.closest('.with-hint');

    if (commentBoxEl) commentBoxEl.style.display = isCommentService ? "" : "none";
    if (keywordBoxEl) keywordBoxEl.style.display = isSeoService ? "" : "none";

    // 🔒 ถ้าเป็น service ที่ต้องกรอกข้อความ → lock ช่องปริมาณ + ให้ระบบคำนวณเอง
    if (isCommentService || isSeoService) {
      q.readOnly = true;
      q.classList.add('auto-qty');
      if (qtyLabelWrap) qtyLabelWrap.classList.add('auto-qty');
      syncAutoQtyFromFields();       // ดึงจาก textarea ครั้งแรกเลย
    } else {
      q.readOnly = false;
      q.classList.remove('auto-qty');
      if (qtyLabelWrap) qtyLabelWrap.classList.remove('auto-qty');
    }

    updateEstimate();
    $('#detailBox').style.display = '';
    requestAnimationFrame(() => syncRightRailHeights?.());
    setTimeout(() => syncRightRailHeights?.(), 80);

    const note = document.getElementById('perPieceNote');
    if (note) note.style.display = isPerPieceService ? '' : 'none';
  }
  function resetDetail(){ $('#childText').textContent='—'; $('#detailBox').style.display='none'; }
  function clearAll(){
    $('#groupText').textContent = '—';
    $('#childText').textContent = '—';
    $('#groupList').innerHTML = '';
    $('#childList').innerHTML = '';
    resetDetail();
  }
  function calcUnitRate(){
    return rateSource==='effective' && Number.isFinite(effectiveRate) ? effectiveRate : rate;
  }
  function updateEstimate(){
    const n = isPerPieceService ? 1 : Number($('#qty').value || 0);
    const rateUsed = calcUnitRate(); // base หรือ effective
    const unit = Number(currentChild?.rateUnit || 1000);

    const price = Math.max(0, (n / unit) * rateUsed);

    $('#est').value = `${fmt(price)} ${currency}`;
  }

  /* ---------- ส่งคำสั่งซื้อ ---------- */
  async function submitOrder(ev){
    ev.preventDefault();

    // ก่อนส่ง ให้ sync จำนวนจาก textarea → qty อีกรอบ
    syncAutoQtyFromFields();

    const groupId = $('#groupId').value?.trim();
    const childId = $('#providerServiceId').value?.trim();
    const link    = $('#link').value?.trim();
    const qty = isPerPieceService ? 1 : Number($('#qty').value || 0);

    const commentsVal = document.getElementById('comments')?.value.trim() || '';
    const keywordsVal = document.getElementById('keywords')?.value.trim() || '';

    const errs = [];
    if (!groupId) errs.push('ไม่พบรหัสกลุ่มบริการ (groupId)');
    if (!childId) errs.push('ยังไม่ได้เลือก “บริการย่อย”');
    if (!link)    errs.push('กรุณากรอกลิงก์/เป้าหมาย');
    if (!(qty > 0)) errs.push('จำนวนต้องมากกว่า 0');

    // ✅ บังคับให้อยู่ในช่วงขั้นต่ำ-สูงสุดของบริการ
    if (!isPerPieceService && qty > 0 && (qty < currentMin || qty > currentMax)) {
      errs.push(`จำนวนต้องอยู่ในช่วงขั้นต่ำ ${currentMin.toLocaleString()} ถึงสูงสุด ${currentMax.toLocaleString()}`);
    }

    if (isCommentService && !commentsVal) {
      errs.push('บริการนี้ต้องกรอกคอมเมนต์ (1 บรรทัด = 1 คอมเมนต์)');
    }
    if (isSeoService && !keywordsVal) {
      errs.push('บริการ SEO ต้องใส่ Keyword');
    }

    if (errs.length){
      notify({
        variant: 'warn',
        title: 'ข้อมูลไม่ครบถ้วน',
        text: errs.join(' • ')
      });
      return false;
    }

    const payload = {
      groupId,
      providerServiceId: childId,
      link,
      quantity: qty,
      dripfeed: $('#drip').checked,
      follow_system: $('#sys').checked
    };

    if (isCommentService) payload.comments = commentsVal;
    if (isSeoService)    payload.keywords = keywordsVal;

    const submitBtn = $('#orderForm button[type="submit"]');
    submitBtn && (submitBtn.disabled = true);

    try {
      const res  = await fetch('/orders', {
        method: 'POST',
        headers: { 'Content-Type':'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(payload)
      });

      const ok = res.ok;
      let data = {};
      try { data = await res.json(); } catch {}

      if (!ok || !data?.ok) {
        const titleErr =
          (typeof data?.error === 'string' && data.error.trim()) ||
          `สั่งซื้อไม่สำเร็จ (${res.status})`;

        const reason =
          (typeof data?.detail === 'string' && data.detail) ||
          (typeof data?.detail?.error === 'string' && data.detail.error) ||
          (typeof data?.message === 'string' && data.message) ||
          explainHttpStatus(res.status, '');

        notify({
          variant: 'error',
          title: titleErr,
          text: `เหตุผล: ${reason}`
        });

        // console.warn('ORDER ERROR => status:', res.status, 'reason:', titleErr, 'payload:', data);
        return false;
      }

      notify({
        variant: 'success',
        title: 'สั่งซื้อสำเร็จ',
        text: `สร้างคำสั่งซื้อแล้ว • Provider Order: ${data.providerOrderId || '-'}`
      });

      $('#qty').value  = '';
      $('#link').value = '';
      if (isCommentService) $('#comments').value = '';
      if (isSeoService)     $('#keywords').value = '';
      updateEstimate();
      return false;

    } catch (err) {
      notify({
        variant: 'error',
        title: 'เครือข่ายมีปัญหา',
        text: `ไม่สามารถติดต่อเซิร์ฟเวอร์ได้ (${err?.message || 'unknown'})`
      });
      // console.error('network error:', err);
      return false;
    } finally {
      submitBtn && (submitBtn.disabled = false);
    }
  }
  // =====================================================
  // ✅ EXPORT ฟังก์ชัน/ค่าที่สคริปต์ด้านนอกต้องใช้
  // =====================================================
  window.RTSMM_ORDER_PAGE = window.RTSMM_ORDER_PAGE || {};

  window.RTSMM_ORDER_PAGE.GROUP_ICON_MAP = GROUP_ICON_MAP;
  window.RTSMM_ORDER_PAGE.syncAutoQtyFromFields = syncAutoQtyFromFields;
  window.RTSMM_ORDER_PAGE.renderGroupList = renderGroupList;
  window.RTSMM_ORDER_PAGE.onChip = onChip;
  window.RTSMM_ORDER_PAGE.init = init;
  window.RTSMM_ORDER_PAGE.submitOrder = submitOrder;

  window.RTSMM_ORDER_PAGE.resetChipToAll = function resetChipToAll() {
    currentChipId = "";

    const bar = document.getElementById("chipBar");
    if (!bar) return;

    const chips = bar.querySelectorAll(".chip");
    chips.forEach((chip, idx) => {
      const isAll =
        chip.dataset.chip === "" ||
        chip.dataset.sub === "" ||
        idx === 0;

      chip.classList.toggle("active", isAll);
    });

    renderGroupList(true);
  };

  // ✅ รองรับโค้ดเดิมที่เรียกผ่าน window.*
  window.onChip = onChip;
  window.submitOrder = submitOrder;
  window.init = init;
  window.syncAutoQtyFromFields = syncAutoQtyFromFields;
  window.renderGroupList = renderGroupList;
  window.resetChipToAll = window.RTSMM_ORDER_PAGE.resetChipToAll;
})();
</script>

<script>
// — เพิ่มตรงสคริปต์ของหน้าเดียวกับ loadLatestUpdates() —
const DIFF_TH = {
  new: 'เพิ่มใหม่',
  open: 'เปิดใช้งาน',
  close: 'ปิดการใช้งาน',
  removed: 'ลบออก',
  updated: 'อัปเดต',
  state: 'สถานะเริ่มต้น',
};
const STATUS_TH = {
  new: 'เพิ่มใหม่',
  open: 'เปิดใช้งาน',
  active: 'เปิดใช้งาน',
  close: 'ปิดการใช้งาน',
  closed: 'ปิดการใช้งาน',
  removed: 'ลบออก',
  delete: 'ลบออก',
  deleted: 'ลบออก',
};

function tDiff(s){ const k = String(s||'').toLowerCase(); return DIFF_TH[k] || s || '—'; }
function tStatus(s){ const k = String(s||'').toLowerCase(); return STATUS_TH[k] || s || '—'; }

// ===== ดึงอัปเดตของ "วันล่าสุด" ผ่าน API เดิมที่คุณมีอยู่แล้ว =====
async function loadLatestUpdates(){
  const el = document.getElementById('updatesList');
  if (!el) return;

  try {
    const j = await fetchCached('/api/changes?latest=1&target=service&limit=300');

    if (!j?.ok) {
      el.innerHTML = '<div class="muted">โหลดข้อมูลไม่สำเร็จ</div>';
      return;
    }

    const items = Array.isArray(j.items) ? j.items : [];

    if (!items.length) {
      el.innerHTML = '<div class="muted">วันนี้ยังไม่มีอัปเดต</div>';
      return;
    }

    el.innerHTML = '';

    items.forEach(x => {
      const d = new Date(x.ts);
      const hh = String(d.getHours()).padStart(2,'0');
      const mm = String(d.getMinutes()).padStart(2,'0');

      const icon = getGroupIconByName(x.serviceName);

      const row = document.createElement('div');
      row.className = 'update-item';

      row.innerHTML = `
        <div class="update-head">
          <span class="muted">${hh}:${mm}</span>
          <div class="update-badges">
            ${x.platform ? `<span class="badge">${escapeHtml(x.platform)}</span>` : ''}
            ${x.categoryName ? `<span class="badge">${escapeHtml(x.categoryName)}</span>` : ''}
            ${x.diff ? `<span class="badge">${escapeHtml(tDiff(x.diff))}</span>` : ''}
            ${(x.oldStatus || x.newStatus)
              ? `<span class="badge">${escapeHtml(tStatus(x.newStatus))}</span>`
              : ''
            }
          </div>
        </div>

        <div class="update-title">
          ${icon ? `<img class="up-icon" src="${icon}">` : ''}
          <b>${escapeHtml(x.serviceName || '—')}</b>
          <small class="muted">#${escapeHtml(x.providerServiceId||'')}</small>
        </div>
      `;

      el.appendChild(row);
    });

    requestAnimationFrame(() => syncRightRailHeights?.());
    setTimeout(() => syncRightRailHeights?.(), 80);

  } catch (e) {
    // console.error(e);
    el.innerHTML = '<div class="muted">เครือข่ายมีปัญหา</div>';
    requestAnimationFrame(() => syncRightRailHeights?.());
  }
}

function escapeHtml(s){
  return String(s).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
}

// ===== Right Rail Root Fix: ให้ 2 การ์ดฝั่งขวาติดกัน และรวมสูงเท่ากับฝั่งซ้าย =====
function syncRightRailHeights(){
  const left    = document.getElementById('detailBox');
  const rail    = document.querySelector('.right-rail');
  const stack   = document.querySelector('.right-rail-stack');
  const updates = document.querySelector('.updates-panel');
  const legend  = document.querySelector('.emoji-panel');
  const updatesList = document.querySelector('.updates-list');
  const legendList  = document.querySelector('.legend-list');

  if (!rail || !stack || !updates || !legend) return;

  const nodes = [rail, stack, updates, legend, updatesList, legendList].filter(Boolean);
  const clearRightRailInline = () => {
    nodes.forEach(el => {
      [
        '--rr-total','--rr-updates','--rr-emoji',
        'height','min-height','max-height','overflow','display','flex-direction','gap',
        'align-items','justify-content','flex','flex-basis','position','top','margin','padding'
      ].forEach(prop => el.style.removeProperty(prop));
    });
  };

  // Responsive: ไม่บังคับความสูงบนจอแคบ เพราะจะทำให้การ์ดซ้อน/โดนตัด
  if (window.matchMedia('(max-width: 1100px)').matches) {
    clearRightRailInline();
    return;
  }

  const leftVisible = left && getComputedStyle(left).display !== 'none';
  const leftHeight = leftVisible ? Math.ceil(left.getBoundingClientRect().height || left.offsetHeight || 0) : 0;
  const gap = 14;

  // บังคับโครงสร้างจริง: aside เป็น sticky shell, stack เป็น flex column ตัวเดียว
  rail.style.setProperty('display', 'block', 'important');
  rail.style.setProperty('position', 'sticky', 'important');
  rail.style.setProperty('top', '16px', 'important');
  rail.style.setProperty('margin', '0', 'important');
  rail.style.setProperty('padding', '0', 'important');
  rail.style.setProperty('overflow', 'visible', 'important');
  rail.style.setProperty('min-height', '0', 'important');

  stack.style.setProperty('display', 'flex', 'important');
  stack.style.setProperty('flex-direction', 'column', 'important');
  stack.style.setProperty('align-items', 'stretch', 'important');
  stack.style.setProperty('justify-content', 'flex-start', 'important');
  stack.style.setProperty('gap', `${gap}px`, 'important');
  stack.style.setProperty('margin', '0', 'important');
  stack.style.setProperty('padding', '0', 'important');
  stack.style.setProperty('overflow', 'visible', 'important');
  stack.style.setProperty('min-height', '0', 'important');

  // ก่อนเลือกบริการ: ให้ขวาเรียงติดกันตามเนื้อหาจริง ไม่ต้องยืดตามซ้าย
  if (!leftHeight) {
    rail.style.setProperty('height', 'auto', 'important');
    stack.style.setProperty('height', 'auto', 'important');

    [updates, legend].forEach(card => {
      card.style.setProperty('margin', '0', 'important');
      card.style.setProperty('height', 'auto', 'important');
      card.style.setProperty('min-height', '0', 'important');
      card.style.setProperty('max-height', 'none', 'important');
      card.style.setProperty('overflow', 'hidden', 'important');
      card.style.setProperty('display', 'flex', 'important');
      card.style.setProperty('flex-direction', 'column', 'important');
      card.style.setProperty('flex', '0 0 auto', 'important');
    });

    if (updatesList) {
      updatesList.style.setProperty('max-height', '220px', 'important');
      updatesList.style.setProperty('overflow', 'auto', 'important');
      updatesList.style.setProperty('min-height', '0', 'important');
    }
    if (legendList) {
      legendList.style.setProperty('max-height', '340px', 'important');
      legendList.style.setProperty('overflow', 'auto', 'important');
      legendList.style.setProperty('min-height', '0', 'important');
    }
    return;
  }

  // หลังเลือกบริการ: รวมความสูงขวา = ซ้าย, gap คงที่ 14px
  const total = Math.max(520, leftHeight);
  const usable = Math.max(0, total - gap);

  // อัปเดตวันนี้มีเนื้อหาเยอะ ให้พื้นที่เยอะกว่าครึ่งนิด ๆ แต่ไม่กินการ์ดล่างจนอ่านยาก
  const minUpdates = 245;
  const minLegend = 245;
  let updatesH = Math.round(usable * 0.50);
  updatesH = Math.max(minUpdates, Math.min(updatesH, usable - minLegend));
  let legendH = usable - updatesH;

  // fallback กรณีซ้ายเตี้ยผิดปกติ
  if (legendH < minLegend) {
    legendH = Math.max(180, minLegend);
    updatesH = Math.max(180, usable - legendH);
  }

  rail.style.setProperty('--rr-total', `${total}px`);
  rail.style.setProperty('--rr-updates', `${updatesH}px`);
  rail.style.setProperty('--rr-emoji', `${legendH}px`);
  rail.style.setProperty('height', `${total}px`, 'important');
  rail.style.setProperty('max-height', 'none', 'important');

  stack.style.setProperty('height', `${total}px`, 'important');
  stack.style.setProperty('max-height', 'none', 'important');

  updates.style.setProperty('margin', '0', 'important');
  updates.style.setProperty('height', `${updatesH}px`, 'important');
  updates.style.setProperty('min-height', '0', 'important');
  updates.style.setProperty('max-height', `${updatesH}px`, 'important');
  updates.style.setProperty('overflow', 'hidden', 'important');
  updates.style.setProperty('display', 'flex', 'important');
  updates.style.setProperty('flex-direction', 'column', 'important');
  updates.style.setProperty('flex', `0 0 ${updatesH}px`, 'important');

  legend.style.setProperty('margin', '0', 'important');
  legend.style.setProperty('height', `${legendH}px`, 'important');
  legend.style.setProperty('min-height', '0', 'important');
  legend.style.setProperty('max-height', `${legendH}px`, 'important');
  legend.style.setProperty('overflow', 'hidden', 'important');
  legend.style.setProperty('display', 'flex', 'important');
  legend.style.setProperty('flex-direction', 'column', 'important');
  legend.style.setProperty('flex', `0 0 ${legendH}px`, 'important');

  if (updatesList) {
    updatesList.style.setProperty('flex', '1 1 auto', 'important');
    updatesList.style.setProperty('min-height', '0', 'important');
    updatesList.style.setProperty('max-height', 'none', 'important');
    updatesList.style.setProperty('overflow', 'auto', 'important');
    updatesList.style.setProperty('overscroll-behavior', 'contain');
  }
  if (legendList) {
    legendList.style.setProperty('flex', '1 1 auto', 'important');
    legendList.style.setProperty('min-height', '0', 'important');
    legendList.style.setProperty('max-height', 'none', 'important');
    legendList.style.setProperty('overflow', 'auto', 'important');
    legendList.style.setProperty('overscroll-behavior', 'contain');
  }
}

function initHeightSync(){
  syncRightRailHeights();
  window.addEventListener('resize', syncRightRailHeights);

  if ('ResizeObserver' in window) {
    const ro = new ResizeObserver(() => syncRightRailHeights());
    ['detailBox', 'updatesList'].forEach(id => {
      const el = document.getElementById(id);
      if (el) ro.observe(el);
    });
    const rail = document.querySelector('.right-rail-stack');
    if (rail) ro.observe(rail);
  }

  // กันฟอนต์/รูปโหลดทีหลังทำให้ขนาดเปลี่ยน
  setTimeout(syncRightRailHeights, 80);
  setTimeout(syncRightRailHeights, 350);
}


// ===== เปิด/ปิด dropdown ของ .select =====
function bindSelectToggle(selId) {
  const sel = document.getElementById(selId);
  if (!sel) return;

  const btn = sel.querySelector('.select-btn');
  if (!btn) return;

  btn.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation(); // กันไม่ให้ event หลุดไปถึงตัวที่ปิดทั้งหมด

    const isOpen = sel.classList.toggle('open');
    btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });
}

document.addEventListener('DOMContentLoaded', () => {
  // กัน init ซ้ำแบบ production-safe
  if (!window.__RTSMM_ORDER_PAGE_INITED__) {
    window.__RTSMM_ORDER_PAGE_INITED__ = true;

    if (typeof window.init === "function") {
      window.init();
    }
  }

  // เปิด/ปิด dropdown หมวดหมู่ + บริการ
  bindSelectToggle('groupSel');
  bindSelectToggle('childSel');

  if (typeof loadLatestUpdates === "function") {
    loadLatestUpdates();
  }

  if (typeof initHeightSync === "function") {
    initHeightSync();
  }

  // ผูก auto-qty กับการพิมพ์คอมเมนต์/คีย์เวิร์ด
  const cmtEl = document.getElementById('comments');
  const kwEl  = document.getElementById('keywords');

  if (cmtEl) {
    cmtEl.addEventListener('input', () => {
      window.RTSMM_ORDER_PAGE?.syncAutoQtyFromFields?.();
    });
  }

  if (kwEl) {
    kwEl.addEventListener('input', () => {
      window.RTSMM_ORDER_PAGE?.syncAutoQtyFromFields?.();
    });
  }

  const box = document.getElementById('searchSuggest');
  if (box && typeof renderSearchChunk === "function") {
    box.addEventListener('scroll', () => {
      if (box.hidden) return;

      const nearBottom =
        box.scrollTop + box.clientHeight >= box.scrollHeight - 40;

      if (nearBottom) {
        renderSearchChunk(false);
      }
    });
  }
});

function getGroupIconByName(name){
  const n = String(name || "").toLowerCase();

  const map =
    window.RTSMM_ORDER_PAGE?.GROUP_ICON_MAP ||
    window.GROUP_ICON_MAP ||
    [];

  for (const g of map) {
    for (const kw of (g.match || [])) {
      if (n.includes(String(kw).toLowerCase())) {
        return g.icon;
      }
    }
  }

  return null;
}
</script>

<script>
(function(){
  const updateStats = () => {
    const p = document.querySelectorAll('#platformGrid > *').length;
    const g = document.querySelectorAll('#groupList > *').length;
    const pe = document.getElementById('oePlatformCount');
    const ge = document.getElementById('oeGroupCount');
    if (pe && p) pe.textContent = p.toLocaleString('th-TH');
    if (ge && g) ge.textContent = g.toLocaleString('th-TH');
  };
  document.addEventListener('DOMContentLoaded', () => {
    updateStats();
    const targets = ['platformGrid','groupList'];
    targets.forEach(id => {
      const el = document.getElementById(id);
      if (el) new MutationObserver(updateStats).observe(el, { childList:true, subtree:false });
    });
  });
})();
</script>
