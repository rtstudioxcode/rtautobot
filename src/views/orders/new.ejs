<script>
/* FINAL Dropdown Layer Controller: adds high-z classes while dropdown is open */
(() => {
  const root = document.querySelector('.order-new-enterprise');
  if (!root || root.dataset.layerFixReady === '1') return;
  root.dataset.layerFixReady = '1';

  function syncOrderDropdownLayers(){
    const opened = Array.from(root.querySelectorAll('.select.open'));

    root.querySelectorAll('.dropdown-card-open').forEach(el => el.classList.remove('dropdown-card-open'));
    root.querySelectorAll('.dropdown-sel-open').forEach(el => el.classList.remove('dropdown-sel-open'));

    opened.forEach(sel => {
      sel.closest('.card')?.classList.add('dropdown-card-open');
      sel.closest('.sel')?.classList.add('dropdown-sel-open');
    });

    root.classList.toggle('dropdown-any-open', opened.length > 0);
  }

  document.addEventListener('click', () => requestAnimationFrame(syncOrderDropdownLayers), true);
  document.addEventListener('keydown', () => requestAnimationFrame(syncOrderDropdownLayers), true);

  const observer = new MutationObserver(syncOrderDropdownLayers);
  root.querySelectorAll('.select').forEach(sel => observer.observe(sel, { attributes:true, attributeFilter:['class'] }));

  syncOrderDropdownLayers();
})();
</script>