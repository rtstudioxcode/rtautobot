              <div class="shmd-progress-track">
                <div id="shmd-bar-val" class="shmd-progress-fill"></div>
              </div>
              <div class="shmd-progress-footer">
                เหลือ <span id="shmd-left-val">0</span> จาก <span id="shmd-total-val">0</span>
              </div>
            </div>
          </div>
        </section>

        <section class="shmd-section" id="shmd-comments-sec" style="display:none;">
        <h3 class="shmd-sec-title">Comments <span style="color: #f7cb3b;" >(1 บรรทัดต่อ 1 Comment)</span></h3>
          <div class="shmd-comments-wall" id="shmd-comments-val"></div>
        </section>
