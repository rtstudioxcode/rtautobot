
<% const title = "ประวัติการใช้บริการ Social"; %>
<% bodyClass = 'orders-wide'; %>
<%
function decideDisplaySSR(o){
  const qty = Number(o.quantity)||0;
  const st  = String(o.status||'').toLowerCase();

  if (st === 'canceled')  return { label: 'ยกเลิก', donePct: 0, showPct: false, isDone: false };
  if (st === 'canceling') return { label: 'กำลังยกเลิก…', donePct: 0, showPct: false, isDone: false };
  if (st === 'partial')   return { label: 'คืนบางส่วน', donePct: 0, showPct: false, isDone: false };

  const hasProgress = (typeof o.progress === 'number' && isFinite(o.progress));
  const hasRemains  = (typeof o.remains  === 'number' && isFinite(o.remains));
  const hasCounts   = (typeof o.startCount === 'number' && isFinite(o.startCount) && typeof o.currentCount === 'number' && isFinite(o.currentCount));

  let donePct = 0;
  if (hasProgress) {
    donePct = Math.max(0, Math.min(100, o.progress));
  } else if (hasRemains && qty > 0) {
    donePct = Math.max(0, Math.min(100, (1 - Math.max(0, o.remains)/qty) * 100));
  } else if (hasCounts && qty > 0) {
    donePct = Math.max(0, Math.min(100, ((o.currentCount - o.startCount)/qty) * 100));
  }

  // completed ต้องเขียวเฉพาะตอนมีหลักฐานว่างานครบจริงเท่านั้น
  const realDone =
    (hasProgress && o.progress >= 99.995) ||
    (hasRemains && qty > 0 && Number(o.remains) <= 0) ||
    (hasCounts && qty > 0 && (Number(o.currentCount) - Number(o.startCount)) >= qty);

  if (st === 'completed' && realDone) {
    return { label: 'เสร็จสิ้น', donePct: 100, showPct: false, isDone: true };
  }

  // ถ้า Provider ส่ง completed มาเร็ว แต่ยังไม่มีหลักฐานว่างานครบ ให้ถือว่ารอดำเนินการ/ดำเนินการก่อน
  if (!hasProgress && !hasRemains && !hasCounts) {
    return { label: 'รอดำเนินการ', donePct: 0, showPct: false, isDone: false };
  }

  if (donePct <= 0) return { label: 'รอดำเนินการ', donePct: 0, showPct: false, isDone: false };

  return { label: `ดำเนินการ ~ ${donePct.toFixed(2)}%`, donePct, showPct: true, isDone: false };
}%>
<%
// helper แปลงวันเวลาไทย (พ.ศ.)
function fmtTH(d){
  try {
    return new Date(d).toLocaleString('th-TH', {
      timeZone: 'Asia/Bangkok',
      year: 'numeric',      // พ.ศ.
      month: 'long',        // เดือนภาษาไทย
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
      hour12: false
    });
  } catch { return '-'; }
}

// เฉพาะวันที่ (ไม่เอาเวลา)
function fmtTHDate(d){
  try {
    return new Date(d).toLocaleDateString('th-TH', {
      timeZone: 'Asia/Bangkok',
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    });
  } catch { return '-'; }
}
%>

<div class="orders-enterprise order-history-enterprise">
  <section class="oe-hero" aria-label="Order history hero">
    <div class="oe-hero-inner">
      <div>
        <div class="oe-eyebrow"><i></i> ORDER HISTORY</div>
        <h1>ประวัติคำสั่งซื้อ</h1>
        <p>ตรวจสอบทุกคำสั่งซื้อได้ในที่เดียว ติดตามสถานะแบบเรียลไทม์ และดูรายละเอียดงานได้อย่างชัดเจน</p>
      </div>
      <div class="oe-metrics" aria-label="History summary">
        <div class="oe-metric"><small>ทั้งหมด</small><b><%= Number(typeof total !== 'undefined' ? total : 0).toLocaleString('th-TH') %></b></div>
        <div class="oe-metric"><small>หน้านี้</small><b><%= (list || []).length.toLocaleString('th-TH') %></b></div>
        <div class="oe-metric"><small>หน้า</small><b><%= Number(typeof page !== 'undefined' ? page : 1).toLocaleString('th-TH') %>/<%= Math.max(1, Math.ceil((Number(typeof total !== 'undefined' ? total : 0)||0) / Math.max(1, Number(typeof perPage !== 'undefined' ? perPage : 20)||20))).toLocaleString('th-TH') %></b></div>
      </div>
    </div>
  </section>

<!-- ===== แท็บด้านบน ===== -->
<div class="tabs">
  <button type="button" class="tab" data-tab="order">
    สั่งซื้อบริการ
  </button>
  <button type="button" class="tab active" data-tab="history">
    ประวัติคำสั่งซื้อ
  </button>
</div>

<!-- ===== TAB 1: สั่งซื้อบริการ (ของเดิมทั้งหมด) ===== -->
<section id="tab-order" class="tabpane">
  <!-- ไปที่หน้า /orders/new แทน  -->
</section>

<!-- ===== TAB 2: ประวัติคำสั่งซื้อ ===== -->
<section id="tab-history" class="tabpane show">
  <!-- แท็บตัวกรองสถานะ -->
  <div class="orders-history tabs" id="statusTabs">
    <button class="tab active" data-st="all">ทั้งหมด</button>
    <button class="tab" data-st="processing">รอดำเนินการ</button>
    <button class="tab" data-st="inprogress">ดำเนินการ</button>
    <button class="tab" data-st="completed">เสร็จสิ้น</button>
    <button class="tab" data-st="partial">คืนบางส่วน</button>
    <button class="tab" data-st="canceled">ยกเลิก</button>
  </div>

  <!-- ───── Page Controls (ใต้รายการ) ───── -->
  <%
    const pageNum    = Number(typeof page    !== 'undefined' ? page    : 1)  || 1;
    const perPageNum = Number(typeof perPage !== 'undefined' ? perPage : 20) || 20;
    const totalCount = Number(typeof total   !== 'undefined' ? total   : 0)  || 0;

    const pages   = Math.max(1, Math.ceil(totalCount / Math.max(1, perPageNum)));
    const fromIdx = totalCount ? Math.min(totalCount, (pageNum - 1) * perPageNum + 1) : 0;
    const toIdx   = totalCount ? Math.min(totalCount, pageNum * perPageNum) : 0;

    const keep = {
      from: (typeof from   !== 'undefined' ? from   : ''),
      to:   (typeof to     !== 'undefined' ? to     : ''),
      q:    (typeof q      !== 'undefined' ? q      : ''),
      st:   (typeof status !== 'undefined' ? status : '')
    };

    function linkTo(p, pp) {
      const sp = new URLSearchParams();
      if (keep.from) sp.set('from', keep.from);
      if (keep.to)   sp.set('to',   keep.to);
      if (keep.q)    sp.set('q',    keep.q);
      if (keep.st)   sp.set('status', keep.st);
      sp.set('page', p);
      sp.set('perPage', pp);
      return '/my/orders?' + sp.toString();
    }

    const PERPAGE_OPTIONS = [10, 20, 50, 100, 250, 500, 1000];
  %>

  <div class="pager-wrap">
    <div class="pager-left">
      <label class="muted" style="margin-right:8px;">แสดง</label>
      <div class="perpage">
        <select id="ppSelect" class="pp-select">
          <% PERPAGE_OPTIONS.forEach(n => { %>
            <option value="<%= n %>" <%= perPageNum===n ? 'selected' : '' %>><%= n %></option>
          <% }) %>
          <option value="all" <%= (perPageNum>=totalCount && totalCount>0) ? 'selected' : '' %>>แสดงทั้งหมด</option>
        </select>
      </div>
      <span class="muted" style="margin-left:8px;">แถว</span>
    </div>

    <div class="pager-center muted">
      <% if (totalCount > 0) { %>
        แสดง <%= fromIdx %> ถึง <%= toIdx %> จาก <%= totalCount %> แถว
      <% } else { %>ไม่มีข้อมูล<% } %>
    </div>

    <nav class="pager-right" aria-label="pagination">
      <a class="page-btn <%= pageNum<=1 ? 'disabled' : '' %>" href="<%= pageNum<=1 ? '#' : linkTo(pageNum-1, perPageNum) %>">ก่อนหน้า</a>

      <%
        const span = 2;
        const start = Math.max(1, pageNum - span);
        const end   = Math.min(pages, pageNum + span);
        const showFirst = start > 1;
        const showLast  = end < pages;
      %>

      <% if (showFirst) { %>
        <a class="page-btn" href="<%= linkTo(1, perPageNum) %>">1</a>
        <% if (start > 2) { %><span class="page-ellipsis">…</span><% } %>
      <% } %>

      <% for (let p=start; p<=end; p++) { %>
        <a class="page-btn <%= p===pageNum ? 'active' : '' %>" href="<%= linkTo(p, perPageNum) %>"><%= p %></a>
      <% } %>

      <% if (showLast) { %>
        <% if (end < pages-1) { %><span class="page-ellipsis">…</span><% } %>
        <a class="page-btn" href="<%= linkTo(pages, perPageNum) %>"><%= pages %></a>
      <% } %>

      <a class="page-btn <%= pageNum>=pages ? 'disabled' : '' %>" href="<%= pageNum>=pages ? '#' : linkTo(pageNum+1, perPageNum) %>">ถัดไป</a>
    </nav>
  </div>

  <div id="page-bottom"></div>

  <!-- ตารางออเดอร์ (เดสก์ท็อป) -->
  <div class="orders-history table-wrap card order-desktop">
    <table class="table order-table" id="orderTable">
      <thead>
        <tr>
          <th style="width:62px">ID</th>
          <th style="width:170px">วันที่</th>
          <th>บริการ / ลิงก์</th>
          <th style="width:140px">ค่าใช้จ่าย</th>
          <th style="width:110px">ปริมาณ</th>
          <th style="width:160px">สถานะ</th>
        </tr>
      </thead>
      <tbody>
        <% (list || []).forEach(o => { %>
          <tr data-status="<%= (o.status||'').toLowerCase() %>" data-order-id="<%= o._id %>">
            <td>
              <a class="mono" href="/orders/<%= o._id %>" title="DB _id: <%= o._id %>">
                <%= o.providerOrderId || '-' %>
              </a>
            </td>
            <td class="mono"><%= fmtTH(o.createdAt) %></td>
            <td>
              <div class="svc">
                <div class="svc-name">
                  <span class="badge soft">#<%= o.service?.providerServiceId || o.providerServiceId || '-' %></span>
                  <b><%= 
                      o.providerResponse?.raw?.service?.name 
                      || o.serviceName 
                      || o.service?.name 
                      || '-' 
                    %>
                  </b>
                  <% if (o.meta?.country) { %><span class="badge flag"><%= o.meta.country %></span><% } %>
                  <% if (o.meta?.speed)   { %><span class="badge blue"><%= o.meta.speed %></span><% } %>
                </div>
                <div class="link ellipsis">
                  <span class="muted" aria-hidden="true">🔗</span>
                  <a href="<%= o.link %>" target="_blank" rel="noopener"><%= o.link %></a>
                </div>
              </div>
            </td>
            <td class="mono">
              <%
                const costNum = Number(
                  o.estCost ?? o.cost ?? (((o.quantity||0)/1000) * (o.service?.rate||0))
                );
                const costText = Number.isFinite(costNum)
                  ? costNum.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })
                  : '0.00';
                const cur = o.currency || o.service?.currency || 'THB';
              %>
              <%= costText %> <%= cur %>
            </td>
            <td class="mono"><%= o.quantity %></td>
            <td class="st-cell">
              <% const dd = decideDisplaySSR(o); %>
              <%
                const canCancel  = !!(o.uiFlags && o.uiFlags.canCancel);
                const isDone     = !!(o.uiFlags && o.uiFlags.isDone);
                const canRepeat  = isDone && !!(o.service && o.service._id);
                const stLower    = String(o.status||'').toLowerCase();
              %>

            <div class="st-block">
              <!-- pill สถานะยาว -->
              <div
                class="pill long <%= dd.isDone
                  ? 'ok'
                  : (stLower==='canceled' ? 'danger'
                    : (stLower==='canceling' ? 'warn'
                      : (stLower==='partial' ? 'warn' : ''))) %>"
                data-pct="<%= dd.donePct %>">

                <i class="bar" style="width:<%= (stLower==='canceling')
                  ? '0'
                  : (dd.isDone ? '100' : dd.donePct) %>%"></i>

                <span class="label">
                  <% const isPartialRefund =
                      (stLower==='canceled' && Number(o.refundAmount||0)>0 && o.refundType==='partial'); %>
                  <% if (isPartialRefund) { %>
                    <span class="badge warn" style="margin-right:8px">คืนบางส่วน</span>
                  <% } %>

                  <% if (stLower === 'canceling') { %>
                    <!-- ⬅️ กำลังสั่งยกเลิก -->
                    กำลังส่งยกเลิก…
                  <% } else if (dd.showPct) { %>
                    ดำเนินการ ~ <span class="pct"><%= dd.donePct.toFixed(2) %>%</span>
                  <% } else { %>
                    <%= dd.label %>
                  <% } %>
                </span>
              </div>

              <!-- ปุ่มใต้สถานะ -->
              <div class="st-actions under">
                <% if (o.uiFlags?.canCancel) { %>
                  <button
                    type="button"
                    class="xbtn xbtn-sync btn-cancel"
                    title="ยกเลิกออเดอร์นี้"
                    onclick="startCancel('<%= o._id %>')">
                    <img src="/static/assets/emoji/cancel.png" alt="" class="icon" />
                  </button>
                <% } %>

                <% if (!(dd.isDone || stLower === 'canceled' || stLower === 'partial' || stLower === 'canceling')) { %>
                  <button type="button" class="xbtn xbtn-sync btn-refresh" data-id="<%= o._id %>"
                          title="อัปเดตสถานะออเดอร์" aria-label="อัปเดตสถานะออเดอร์">
                    <img src="/static/assets/emoji/updatestatus.png" alt="" class="icon" />
                  </button>
                <% } %>

                <% const isPartialRefundCanceled = (stLower === 'canceled' && Number(o.refundAmount||0)>0 && o.refundType==='partial'); %>
                <% const canRepeatStrict =
                  (
                    stLower === 'completed' ||
                    stLower === 'partial' ||
                    isPartialRefundCanceled
                  ) && (
                    o?.service?._id || 
                    o?.providerServiceId
                  ); 
                %>
                <% if (canRepeatStrict) { %>
                  <button type="button" class="xbtn xbtn-primary btn-repeat" data-id="<%= o._id %>"
                          title="สั่งซ้ำรายการนี้" aria-label="สั่งซ้ำรายการนี้">
                    <img src="/static/assets/emoji/repeat.png" alt="" class="icon" />
                  </button>
                <% } %>

                <button type="button" class="xbtn xbtn-info open-order" data-id="<%= o._id %>"
                        title="รายละเอียด" aria-label="รายละเอียด">
                  <img src="/static/assets/emoji/detail.png" alt="" class="icon" />
                </button>
              </div>
            </div>
          </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    
    <% if (!(list||[]).length) { %>
      <div class="empty muted">ยังไม่มีออเดอร์ในช่วงนี้</div>
    <% } %>
  </div>

  <!-- การ์ดออเดอร์ (มือถือ) -->
  <div class="orders-history order-cards" id="orderCards">
    <% (list || []).forEach(o => { 
      const st = (o.status||'').toLowerCase();
    %>
      <article class="o-card" data-status="<%= st %>" data-order-id="<%= o._id %>">
        <header class="o-head">
          <div class="o-id mono">
            <a href="/orders/<%= o._id %>" title="DB _id: <%= o._id %>">
              <%= o.providerOrderId || '-' %>
            </a>
          </div>
          <div class="o-date mono"><%= fmtTH(o.createdAt) %></div>
          <button class="o-toggle" aria-label="toggle">＋</button>
        </header>

        <div class="o-body">
          <div class="o-row">
            <div class="o-label">บริการ / ลิงก์</div>
            <div class="o-val">
              <div class="svc-name">
                <span class="badge soft">#<%= 
                  o.providerServiceId 
                  || o.service?.providerServiceId 
                  || '-' 
                  %>
                </span>
                <b><%= o.service?.name || o.serviceName || '-' %></b>
                <% if (o.meta?.country) { %><span class="badge flag"><%= o.meta.country %></span><% } %>
                <% if (o.meta?.speed)   { %><span class="badge blue"><%= o.meta.speed %></span><% } %>
              </div>
              <div class="link">
                <span class="muted" aria-hidden="true">🔗</span>
                <a href="<%= o.link %>" target="_blank" rel="noopener"><%= o.link %></a>
              </div>
            </div>
          </div>

          <div class="o-row">
            <div class="o-label">ค่าใช้จ่าย</div>
            <div class="o-val mono">
              <%
                const mCostNum = Number(
                  o.estCost ?? o.cost ?? (((o.quantity||0)/1000) * (o.service?.rate||0))
                );
                const mCostText = Number.isFinite(mCostNum)
                  ? mCostNum.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })
                  : '0.00';
                const mCur = o.currency || o.service?.currency || 'THB';
              %>
              <%= mCostText %> <%= mCur %>
            </div>
          </div>

          <div class="o-row">
            <div class="o-label">ปริมาณ</div>
            <div class="o-val mono"><%= o.quantity %></div>
          </div>

          <div class="o-row">
            <div class="o-label">สถานะ</div>
            <div class="o-val">
              <% const mdd = decideDisplaySSR(o); %>
              <%
                const canCancel = !!(o.uiFlags && o.uiFlags.canCancel);
                const isDone    = !!(o.uiFlags && o.uiFlags.isDone);
                const canRepeat = isDone && !!(o.service && o.service._id);
              %>
              <% const stLower = String(o.status||'').toLowerCase(); %>

              <div class="st-stack">
                <span
                  class="pill progress <%= mdd.isDone
                    ? 'ok'
                    : (stLower==='canceled' ? 'danger'
                      : (stLower==='canceling' ? 'warn'
                        : (stLower==='partial' ? 'warn' : ''))) %>"
                  data-pct="<%= (stLower==='canceling') ? 0 : mdd.donePct %>">

                  <% const isPartialRefund = (
                      stLower === 'canceled' &&
                      Number(o.refundAmount || 0) > 0 &&
                      o.refundType === 'partial'
                    ); %>

                  <% if (isPartialRefund) { %>
                    <span class="badge warn" style="margin-right:8px">คืนบางส่วน</span>
                  <% } %>

                  <% if (stLower === 'canceling') { %>
                    กำลังส่งยกเลิก…
                  <% } else if (mdd.showPct) { %>
                    ดำเนินการ ~ <span class="pct" data-pct="<%= mdd.donePct %>"><%= mdd.donePct.toFixed(2) %>%</span>
                  <% } else { %>
                    <%= mdd.label %>
                  <% } %>
                </span>
                <div class="st-actions">
                  <!-- ยกเลิก: เฉพาะ "processing" -->
                  <% if (o.uiFlags?.canCancel) { %>
                    <button
                      type="button"
                      class="xbtn xbtn-sync btn-cancel"
                      style="width:100%;"
                      title="ยกเลิกออเดอร์นี้"
                      onclick="startCancel('<%= o._id %>')">
                      <img src="/static/assets/emoji/cancel.png" alt="" class="icon" />
                    </button>
                  <% } %>

                  <!-- รีเฟรช: ไม่แสดงเมื่อ completed หรือ canceled -->
                  <% if (!(mdd.isDone || stLower === 'canceled' || stLower === 'partial' || stLower === 'canceling')) { %>
                    <button
                      type="button"
                      class="xbtn xbtn-sync btn-refresh"
                      data-id="<%= o._id %>"
                      title="อัปเดตสถานะออเดอร์"
                      aria-label="อัปเดตสถานะออเดอร์">
                      <img src="/static/assets/emoji/updatestatus.png" alt="" class="icon" />
                    </button>
                  <% } %>

                  <!-- สั่งซื้อใหม่: เฉพาะ "completed" -->
                  <% const isPartialRefundCanceled = (stLower === 'canceled' && Number(o.refundAmount||0) > 0 && o.refundType === 'partial'); %>
                  <% const canRepeatStrict =
                    (
                      stLower === 'completed' ||
                      stLower === 'partial' ||
                      isPartialRefundCanceled
                    ) && (
                      o?.service?._id || 
                      o?.providerServiceId
                    ); 
                  %>
                  <% if (canRepeatStrict) { %>
                    <button
                      type="button"
                      class="xbtn xbtn-primary btn-repeat"
                      data-id="<%= o._id %>"
                      title="สั่งซ้ำรายการนี้"
                      aria-label="สั่งซ้ำรายการนี้">
                      <img src="/static/assets/emoji/repeat.png" alt="" class="icon" />
                    </button>
                  <% } %>

                  <button
                    type="button"
                    class="xbtn xbtn-info open-order"
                    data-id="<%= o._id %>"
                    title="รายละเอียด"
                    aria-label="รายละเอียด">
                    <img src="/static/assets/emoji/detail.png" alt="" class="icon" />
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </article>
    <% }) %>

    <% if (!(list||[]).length) { %>
      <div class="empty muted">ยังไม่มีออเดอร์ในช่วงนี้</div>
    <% } %>
  </div>

  <!-- ===== Modal: รายละเอียดคำสั่งซื้อ ===== -->
  <div id="shmdOrderModal" class="shmd-modal" role="dialog" aria-hidden="true">
    <div class="shmd-backdrop" data-close-shmd="1"></div>
    
    <div class="shmd-container">
      <header class="shmd-header">
        <div class="shmd-header-content">
          <span class="shmd-badge">รายละเอียดคำสั่งซื้อ</span>
          <h2 class="shmd-title">ID: <span id="shmd-id-val">#0000</span></h2>
        </div>
        <button class="shmd-close-btn" data-close-shmd="1">&times;</button>
      </header>

      <div class="shmd-body">
        <section class="shmd-card shmd-card-price">
          <div class="shmd-price-row">
            <span class="shmd-label">ยอดชำระสุทธิ</span>
            <span id="shmd-cost-val" class="shmd-value shmd-highlight-green">-</span>
          </div>
          <div id="shmd-refund-box" class="shmd-refund-alert" style="display:none;">
            <span class="shmd-label">ยอดคืนเงิน</span>
