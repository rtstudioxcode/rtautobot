<script>
/* FINAL PerPage Layer Controller: keeps custom dropdown clickable above table */
(() => {
  const root = document.querySelector('.order-history-enterprise');
  if (!root || root.dataset.ppLayerFixReady === '1') return;
  root.dataset.ppLayerFixReady = '1';

  function syncPerPageLayer(){
    const open = !!root.querySelector('.ppc-wrap.open');
    root.querySelectorAll('.pager-wrap').forEach(p => p.classList.toggle('pp-open', open));
  }

  document.addEventListener('click', () => requestAnimationFrame(syncPerPageLayer), true);
  document.addEventListener('keydown', () => requestAnimationFrame(syncPerPageLayer), true);

  const observer = new MutationObserver(syncPerPageLayer);
  root.querySelectorAll('.ppc-wrap').forEach(w => observer.observe(w, { attributes:true, attributeFilter:['class'] }));

  syncPerPageLayer();
})();
</script>

